PORT=3000
SESSION_SECRET=change-this-to-a-random-string-for-production
NODE_ENV=production

# ── SMTP Email Configuration ──────────────────────────────
# Option 1: Resend (recommended — free tier: 3,000 emails/month)
#   1. Sign up at https://resend.com
#   2. Add & verify your domain (tstc.com.au)
#   3. Create an API key
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_YOUR_API_KEY_HERE
SMTP_FROM_NAME=T&S Traffic Control
SMTP_FROM_EMAIL=noreply@tstc.com.au

# Option 2: Microsoft 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@tstc.com.au
# SMTP_PASS=your-app-password-here
# SMTP_FROM_NAME=T&S Traffic Control
# SMTP_FROM_EMAIL=noreply@tstc.com.au

# Base URL for email links (set to your Railway URL)
APP_BASE_URL=https://your-app.up.railway.app
