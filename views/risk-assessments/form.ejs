<% locals.currentPage = 'risk-assessments' %>
<%
  const formAction = isEdit ? '/risk-assessments/' + ra.id : '/risk-assessments';
  const selectedKind = isEdit ? ra.kind : (prefillKind || 'job');
  const selectedJobId = isEdit && ra.job_id ? String(ra.job_id) : (prefillJobId || '');
%>

<div class="max-w-3xl mx-auto space-y-5">
  <div class="flex items-center gap-2 text-sm text-gray-500">
    <a href="/risk-assessments" class="hover:text-brand-600">Risk Assessment Register</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-gray-900"><%= isEdit ? 'Edit' : 'New' %></span>
  </div>
  <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Risk Assessment' : (selectedKind === 'template' ? 'Import Risk Assessment template' : 'New Risk Assessment') %></h1>

  <form method="POST" action="<%= formAction %>" enctype="multipart/form-data" class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 space-y-5">
    <%- include('../partials/csrf') %>

    <!-- Kind toggle -->
    <div>
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Kind</label>
      <div class="flex gap-2">
        <label class="flex-1 cursor-pointer">
          <input type="radio" name="kind" value="job" <%= selectedKind === 'job' ? 'checked' : '' %> class="peer sr-only">
          <div class="border border-gray-300 rounded-lg p-3 text-center peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:ring-2 peer-checked:ring-brand-200">
            <div class="text-sm font-semibold text-gray-900">Job-linked Risk Assessment</div>
            <div class="text-xs text-gray-500 mt-0.5">Tied to a specific job. Can start as a draft.</div>
          </div>
        </label>
        <label class="flex-1 cursor-pointer">
          <input type="radio" name="kind" value="template" <%= selectedKind === 'template' ? 'checked' : '' %> class="peer sr-only">
          <div class="border border-gray-300 rounded-lg p-3 text-center peer-checked:border-brand-500 peer-checked:bg-brand-50 peer-checked:ring-2 peer-checked:ring-brand-200">
            <div class="text-sm font-semibold text-gray-900">Template</div>
            <div class="text-xs text-gray-500 mt-0.5">Reusable Risk Assessment that any job can pull from.</div>
          </div>
        </label>
      </div>
    </div>

    <div>
      <label for="title" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Title <span class="text-rose-500">*</span></label>
      <input type="text" id="title" name="title" required value="<%= isEdit ? (ra.title || '') : '' %>" placeholder="e.g. Working at heights — gantry install"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
    </div>

    <div>
      <label for="description" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Description</label>
      <textarea id="description" name="description" rows="2" placeholder="What activity does this Risk Assessment cover?"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"><%= isEdit ? (ra.description || '') : '' %></textarea>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div data-job-only>
        <label for="job_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Linked job</label>
        <select id="job_id" name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">— None —</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>" <%= String(selectedJobId) === String(j.id) ? 'selected' : '' %>><%= j.job_number %> — <%= [j.project_name, j.client].filter(Boolean).join(' · ') %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="owner_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Assignee / owner</label>
        <select id="owner_id" name="owner_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">— Unassigned —</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= isEdit && ra.owner_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</label>
        <select id="status" name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <% Object.entries(statusLabels).forEach(([v, l]) => { %>
            <option value="<%= v %>" <%= isEdit && ra.status === v ? 'selected' : '' %>><%= l %></option>
          <% }) %>
        </select>
        <p class="text-xs text-gray-400 mt-1">Auto-set to Active when a file is attached, Draft otherwise.</p>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Risk Assessment file <span class="text-gray-400 font-normal normal-case tracking-normal">(optional)</span></label>
        <input type="file" name="ra_file" accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png" class="block w-full text-sm text-gray-700 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
        <% if (isEdit && ra.file_path) { %>
          <p class="text-xs text-gray-500 mt-1">Current: <a href="/risk-assessments/<%= ra.id %>/file" class="text-brand-600 hover:underline"><%= ra.file_original_name || 'Download' %></a> — uploading replaces it.</p>
        <% } else { %>
          <p class="text-xs text-gray-400 mt-1">PDF, DOC/DOCX, XLS/XLSX or image. Max 25 MB.</p>
        <% } %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="expiry_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Expiry / next review</label>
        <input type="date" id="expiry_date" name="expiry_date"
          value="<%= isEdit && ra.expiry_date ? ra.expiry_date : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <p class="text-xs text-gray-400 mt-1" id="expiryHint">Leave blank to auto-set: <span id="expiryHintCycle">+6 months</span> from today.</p>
      </div>
      <div>
        <label for="notes" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Internal notes</label>
        <textarea id="notes" name="notes" rows="2" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"><%= isEdit ? (ra.notes || '') : '' %></textarea>
      </div>
    </div>

    <div class="flex items-center justify-end gap-2 pt-3 border-t border-gray-200">
      <a href="<%= isEdit ? '/risk-assessments/' + ra.id : '/risk-assessments' %>" class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg">Cancel</a>
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg"><%= isEdit ? 'Save changes' : 'Create Risk Assessment' %></button>
    </div>
  </form>
</div>

<script>
  // Hide the "Linked job" picker when "Template" is selected. Also update the
  // expiry hint to reflect the cycle for the chosen kind (3mo template vs 6mo job).
  (function () {
    const radios = document.querySelectorAll('input[name="kind"]');
    const jobBlock = document.querySelector('[data-job-only]');
    const cycleHint = document.getElementById('expiryHintCycle');
    function sync() {
      const kind = (document.querySelector('input[name="kind"]:checked') || {}).value;
      jobBlock.style.display = kind === 'template' ? 'none' : '';
      if (cycleHint) cycleHint.textContent = kind === 'template' ? '+3 months' : '+6 months';
    }
    radios.forEach(r => r.addEventListener('change', sync));
    sync();
  })();
</script>
