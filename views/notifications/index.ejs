<% locals.currentPage = 'notifications' %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Notifications</h1>
    <p class="text-gray-500 text-sm mt-1"><%= unreadCount %> unread</p>
  </div>
  <div class="flex items-center gap-2">
    <form method="POST" action="/notifications/mark-all-read" class="inline">
      <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Mark All Read</button>
    </form>
    <form method="POST" action="/notifications/clear-old" class="inline">
      <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear 30d+</button>
    </form>
  </div>
</div>

<% if (notifications.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
    </svg>
    <p class="text-gray-400">No notifications.</p>
  </div>
<% } else { %>
<div class="space-y-2">
  <% notifications.forEach(function(n) { %>
  <form method="POST" action="/notifications/<%= n.id %>/read" class="block">
    <button type="submit" class="w-full text-left bg-white border rounded-xl p-4 hover:bg-gray-50 transition-colors
      <%= n.is_read ? 'border-gray-200/50 opacity-60' : 'border-gray-300' %>">
      <div class="flex items-start gap-3">
        <!-- Icon by type -->
        <div class="flex-shrink-0 mt-0.5">
          <% if (n.type === 'overdue_task') { %>
            <span class="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </span>
          <% } else if (n.type === 'expiring_compliance') { %>
            <span class="w-8 h-8 rounded-full bg-amber-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </span>
          <% } else if (n.type === 'new_incident' || n.type === 'critical_defect') { %>
            <span class="w-8 h-8 rounded-full bg-red-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </span>
          <% } else if (n.type === 'missing_update') { %>
            <span class="w-8 h-8 rounded-full bg-yellow-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </span>
          <% } else if (n.type === 'equipment_overdue') { %>
            <span class="w-8 h-8 rounded-full bg-amber-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            </span>
          <% } else if (n.type === 'follow_up_due') { %>
            <span class="w-8 h-8 rounded-full bg-purple-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </span>
          <% } else if (n.type === 'corrective_action_due') { %>
            <span class="w-8 h-8 rounded-full bg-rose-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            </span>
          <% } else { %>
            <span class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center">
              <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            </span>
          <% } %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium <%= n.is_read ? 'text-gray-500' : 'text-gray-900' %>"><%= n.title %></p>
          <p class="text-xs text-gray-400 mt-0.5"><%= n.message %></p>
          <div class="flex items-center gap-3 mt-1">
            <% if (n.job_number) { %><span class="text-xs text-brand-600"><%= n.job_number %></span><% } %>
            <span class="text-xs text-gray-400"><%= new Date(n.created_at).toLocaleString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
        </div>
        <% if (!n.is_read) { %>
          <span class="w-2 h-2 rounded-full bg-brand-600 flex-shrink-0 mt-2"></span>
        <% } %>
      </div>
    </button>
  </form>
  <% }); %>
</div>
<% } %>
