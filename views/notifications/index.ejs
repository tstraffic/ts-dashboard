<% locals.currentPage = 'notifications' %>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Notifications</h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= unreadCount %> unread of <%= totalCount %> total</p>
  </div>
  <div class="flex items-center gap-2">
    <form method="POST" action="/notifications/mark-all-read" class="inline">
      <%- include('../partials/csrf') %>
      <button type="submit" class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors">Mark All Read</button>
    </form>
    <form method="POST" action="/notifications/clear-old" class="inline">
      <%- include('../partials/csrf') %>
      <button type="submit" class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors">Clear 30d+</button>
    </form>
  </div>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-3 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= totalCount %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Unread</p>
    <p class="text-xl font-bold <%= unreadCount > 0 ? 'text-brand-600' : 'text-gray-900' %> mt-0.5"><%= unreadCount %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Read</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= totalCount - unreadCount %></p>
  </div>
</div>

<!-- Filter Tabs -->
<div class="flex items-center gap-1 mb-5 border-b border-gray-200 pb-2">
  <a href="/notifications" class="px-3 py-1.5 text-sm font-medium rounded-lg <%= filter === 'all' ? 'bg-brand-50 text-brand-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50' %> transition-colors">
    All <span class="text-[10px] opacity-60"><%= totalCount %></span>
  </a>
  <a href="/notifications?filter=unread" class="px-3 py-1.5 text-sm font-medium rounded-lg <%= filter === 'unread' ? 'bg-brand-50 text-brand-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50' %> transition-colors">
    Unread <% if (unreadCount > 0) { %><span class="inline-flex items-center justify-center w-5 h-5 text-[10px] font-bold bg-brand-600 text-white rounded-full ml-1"><%= unreadCount %></span><% } %>
  </a>
  <a href="/notifications?filter=read" class="px-3 py-1.5 text-sm font-medium rounded-lg <%= filter === 'read' ? 'bg-brand-50 text-brand-700' : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50' %> transition-colors">
    Read
  </a>
</div>

<%
  const typeIcons = {
    overdue_task: { bg: 'bg-red-50', color: 'text-red-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
    task_assigned: { bg: 'bg-blue-50', color: 'text-blue-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>' },
    task_status_change: { bg: 'bg-blue-50', color: 'text-blue-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>' },
    expiring_compliance: { bg: 'bg-amber-50', color: 'text-amber-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>' },
    new_incident: { bg: 'bg-red-50', color: 'text-red-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>' },
    critical_defect: { bg: 'bg-red-50', color: 'text-red-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>' },
    missing_update: { bg: 'bg-yellow-50', color: 'text-yellow-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>' },
    equipment_overdue: { bg: 'bg-orange-50', color: 'text-orange-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>' },
    follow_up_due: { bg: 'bg-purple-50', color: 'text-purple-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>' },
    corrective_action_due: { bg: 'bg-rose-50', color: 'text-rose-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>' },
  };
  const defaultIcon = { bg: 'bg-blue-50', color: 'text-brand-600', icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>' };
%>

<% if (notifications.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
    </svg>
    <p class="text-gray-500 text-sm font-medium">No notifications</p>
    <p class="text-gray-400 text-xs mt-1"><%= filter === 'unread' ? 'All caught up!' : 'Nothing to show' %></p>
  </div>
<% } else { %>
<div class="space-y-2">
  <%
    let lastDate = '';
    notifications.forEach(function(n) {
      const nDate = new Date(n.created_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
      const showDateHeader = nDate !== lastDate;
      lastDate = nDate;
      const ti = typeIcons[n.type] || defaultIcon;
  %>
  <% if (showDateHeader) { %>
    <div class="pt-2 pb-1">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= nDate %></p>
    </div>
  <% } %>
  <form method="POST" action="/notifications/<%= n.id %>/read" class="block">
    <%- include('../partials/csrf') %>
    <button type="submit" class="w-full text-left bg-white border rounded-xl p-3 hover:bg-gray-50 transition-colors
      <%= n.is_read ? 'border-gray-100 opacity-50' : 'border-gray-200 shadow-sm' %>">
      <div class="flex items-start gap-3">
        <div class="flex-shrink-0 mt-0.5">
          <span class="w-8 h-8 rounded-full flex items-center justify-center <%= ti.bg %>">
            <svg class="w-4 h-4 <%= ti.color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><%- ti.icon %></svg>
          </span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium <%= n.is_read ? 'text-gray-500' : 'text-gray-900' %>"><%= n.title %></p>
          <p class="text-xs text-gray-400 mt-0.5 line-clamp-2"><%= n.message %></p>
          <div class="flex items-center gap-3 mt-1">
            <% if (n.job_number) { %><span class="text-xs text-brand-600 font-medium"><%= n.job_number %></span><% } %>
            <span class="text-[10px] text-gray-300"><%= new Date(n.created_at).toLocaleString('en-AU', { hour: '2-digit', minute: '2-digit' }) %></span>
            <% if (n.type) { %><span class="text-[10px] text-gray-300"><%= n.type.replace(/_/g, ' ') %></span><% } %>
          </div>
        </div>
        <% if (!n.is_read) { %>
          <span class="w-2.5 h-2.5 rounded-full bg-brand-600 flex-shrink-0 mt-2"></span>
        <% } %>
      </div>
    </button>
  </form>
  <% }) %>
</div>
<div class="mt-3 text-xs text-gray-400"><%= notifications.length %> notification<%= notifications.length !== 1 ? 's' : '' %></div>
<% } %>
