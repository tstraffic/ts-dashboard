<% locals.currentPage = 'documents' %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Documents</h1>
    <p class="text-slate-400 text-sm mt-1">Browse documents by job</p>
  </div>
</div>

<div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700">
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Job</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Client</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Documents</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Last Upload</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700">
      <% jobs.forEach(job => { %>
      <tr class="hover:bg-slate-700/50">
        <td class="px-4 py-3 font-medium text-blue-400"><%= job.job_number %></td>
        <td class="px-4 py-3 text-slate-300"><%= job.client %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (job.status === 'active') { %>bg-blue-900/60 text-blue-300
            <% } else if (job.status === 'on_hold') { %>bg-orange-900/60 text-brand-300
            <% } else if (job.status === 'won') { %>bg-emerald-900/60 text-emerald-300
            <% } else { %>bg-slate-700 text-slate-300<% } %>"><%= job.status ? job.status.replace('_', ' ') : '-' %></span>
        </td>
        <td class="px-4 py-3 text-white font-medium"><%= job.doc_count %></td>
        <td class="px-4 py-3 text-slate-400 text-xs"><%= job.last_upload || 'None' %></td>
        <td class="px-4 py-3">
          <a href="/documents/job/<%= job.id %>" class="text-brand-400 hover:text-brand-300 text-sm font-medium">View &rarr;</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
