<!-- Block Modal -->
<div id="blockModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('blockModal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Block from Allocation</h3>
    <form method="POST" action="/hr/employees/<%= employee.id %>/block" class="space-y-4">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="action" value="block">
      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Reason</label>
        <input type="text" name="block_reason" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Reason for blocking...">
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="px-5 py-2.5 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition">Block Employee</button>
        <button type="button" onclick="document.getElementById('blockModal').classList.add('hidden')" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</button>
      </div>
    </form>
  </div>
</div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TAB: Training                                -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="tab-training" class="emp-tab-content" style="display:none;">
    <% if (locals.training && training.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Module</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Score</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Result</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Completed</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% training.forEach(function(t) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-sm font-medium text-gray-900">
                <% if (t.module === 'employee_guide') { %>T&S Employee Guide<% } else { %><%= t.module %><% } %>
              </td>
              <td class="px-4 py-3 text-sm text-gray-700 tabular-nums"><%= t.score %> / <%= t.total %> (<%= Math.round((t.score / t.total) * 100) %>%)</td>
              <td class="px-4 py-3">
                <% if (t.passed) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Passed</span>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">Failed</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-xs text-gray-500 tabular-nums"><%= t.completed_at ? new Date(t.completed_at).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
        <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-1">No training records</h3>
        <p class="text-gray-500 text-sm">This employee hasn't completed any training modules yet.</p>
      </div>
    <% } %>
  </div>

<script>
// ── Tab switching (global so onclick works) ──
function switchEmpTab(target) {
  document.querySelectorAll('.emp-tab').forEach(function(t) {
    t.classList.remove('border-brand-600', 'text-brand-600');
    t.classList.add('border-transparent', 'text-gray-500');
  });
  document.querySelectorAll('.emp-tab-content').forEach(function(c) {
    c.style.display = 'none';
  });

  var activeTab = document.querySelector('[data-tab="' + target + '"]');
  var activeContent = document.getElementById('tab-' + target);
  if (activeTab) {
    activeTab.classList.add('border-brand-600', 'text-brand-600');
    activeTab.classList.remove('border-transparent', 'text-gray-500');
  }
  if (activeContent) {
    activeContent.style.display = '';
  }
  try { history.replaceState(null, '', '#' + target); } catch(e) {}
}

// ── Check hash on load ──
(function() {
  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById('tab-' + hash)) {
    switchEmpTab(hash);
  }
})();

// ── Upload modal helper ──
function openUploadModal(docType) {
  var modal = document.getElementById('uploadDocModal');
  var select = document.getElementById('uploadDocType');
  if (select && docType) select.value = docType;
  modal.classList.remove('hidden');
}

// ── Edit competency modal ──
function openEditComp(comp) {
  var modal = document.getElementById('editCompModal');
  var form = document.getElementById('editCompForm');
  form.action = '/hr/competencies/' + comp.id;
  document.getElementById('edit_comp_type').value = comp.competency_type || '';
  document.getElementById('edit_comp_name').value = comp.competency_name || '';
  document.getElementById('edit_comp_level').value = comp.competency_level || '';
  document.getElementById('edit_comp_issue').value = comp.issue_date || '';
  document.getElementById('edit_comp_expiry').value = comp.expiry_date || '';
  document.getElementById('edit_comp_status').value = comp.status || 'valid';
  document.getElementById('edit_comp_doc').value = comp.linked_document_id || '';
  document.getElementById('edit_comp_mandatory').checked = !!comp.mandatory_for_role;
  document.getElementById('edit_comp_notes').value = comp.notes || '';
  modal.classList.remove('hidden');
}
</script>
