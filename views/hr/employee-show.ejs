<% locals.currentPage = 'hr-employees' %>
<%
  function formatDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric' });
  }

  const statusBadge = {
    active:     'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    onboarding: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    on_leave:   'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    suspended:  'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    inactive:   'bg-gray-100 text-gray-500',
    offboarded: 'bg-gray-100 text-gray-500',
    reserved:   'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
    deactivated:'bg-gray-100 text-gray-500',
    terminated: 'bg-red-50 text-red-600 ring-1 ring-red-500/20',
  };

  const readinessBadge = {
    ready:                'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    ready_with_warnings:  'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    non_compliant:        'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    blocked:              'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    onboarding:           'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    on_leave:             'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    offboarded:           'bg-gray-100 text-gray-500',
  };

  const readinessLabel = {
    ready:                'Ready',
    ready_with_warnings:  'Warnings',
    non_compliant:        'Non-Compliant',
    blocked:              'Blocked',
    onboarding:           'Onboarding',
    on_leave:             'On Leave',
    offboarded:           'Offboarded',
  };

  const verificationBadge = {
    pending:  'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    verified: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    rejected: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    expired:  'bg-gray-100 text-gray-600',
  };

  const compStatusBadge = {
    valid:         'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    expiring_soon: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    expired:       'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    missing:       'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    suspended:     'bg-gray-100 text-gray-600',
  };

  // Key document types that map to induction uploads
  const keyDocTypes = [
    { type: 'white_card', label: 'White Card', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', mandatory: true },
    { type: 'tc_licence', label: 'TC Licence', icon: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2', mandatory: true },
    { type: 'drivers_licence_front', label: "Driver's Licence (Front)", icon: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2', mandatory: true },
    { type: 'drivers_licence_back', label: "Driver's Licence (Back)", icon: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2', mandatory: true },
  ];

  // Build lookup for key docs
  const keyDocMap = {};
  keyDocTypes.forEach(kd => { keyDocMap[kd.type] = null; });
  const otherDocs = [];
  (documents || []).forEach(doc => {
    if (keyDocMap.hasOwnProperty(doc.document_type) && !keyDocMap[doc.document_type]) {
      keyDocMap[doc.document_type] = doc;
    } else {
      otherDocs.push(doc);
    }
  });

  // Document types for upload modal
  const allDocTypes = [
    { val: 'white_card', label: 'White Card' },
    { val: 'tc_licence', label: 'TC Licence' },
    { val: 'drivers_licence_front', label: "Driver's Licence (Front)" },
    { val: 'drivers_licence_back', label: "Driver's Licence (Back)" },
    { val: 'contract', label: 'Contract' },
    { val: 'training_certificate', label: 'Training Certificate' },
    { val: 'VOC', label: 'VOC (Verification of Competency)' },
    { val: 'medical', label: 'Medical Certificate' },
    { val: 'ID', label: 'Photo ID' },
    { val: 'induction_record', label: 'Induction Record' },
    { val: 'policy_acknowledgement', label: 'Policy Acknowledgement' },
    { val: 'other', label: 'Other' },
  ];

  // Competency types
  const defaultCompTypes = [
    { val: 'traffic_controller_licence', label: 'Traffic Controller Licence' },
    { val: 'white_card', label: 'White Card' },
    { val: 'first_aid', label: 'First Aid' },
    { val: 'drivers_licence', label: "Driver's Licence" },
    { val: 'truck_licence', label: 'Truck Licence (HR/HC/MC)' },
    { val: 'working_at_heights', label: 'Working at Heights' },
    { val: 'confined_space', label: 'Confined Space' },
    { val: 'EWP', label: 'EWP (Elevated Work Platform)' },
    { val: 'forklift', label: 'Forklift Licence' },
    { val: 'rsa', label: 'RSA' },
    { val: 'other', label: 'Other' },
  ];
  const compTypes = defaultCompTypes;

  function formatType(type) {
    if (!type) return '-';
    if (typeof type !== 'string') return String(type);
    return type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }

  function isImageFile(filename) {
    if (!filename) return false;
    return /\.(jpg|jpeg|png|gif|webp|heic|heif|bmp|svg|avif)$/i.test(filename);
  }

  const todayStr = new Date().toISOString().split('T')[0];
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/hr/roster" class="hover:text-gray-900 transition">Roster</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= employee.full_name %></span>
</div>

<div class="space-y-5">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 bg-brand-100 rounded-full flex items-center justify-center text-brand-700 font-bold text-xl">
        <%= (employee.first_name || '?')[0] %><%= (employee.last_name || '?')[0] %>
      </div>
      <div>
        <h1 class="text-xl font-bold text-gray-900"><%= employee.full_name %></h1>
        <div class="flex flex-wrap items-center gap-2 mt-1">
          <% if (employee.employee_code) { %><span class="text-xs font-mono text-gray-400"><%= employee.employee_code %></span><% } %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusBadge[employee.employment_status] || statusBadge.inactive %>"><%= (employee.employment_status || 'unknown').replace(/_/g, ' ') %></span>
          <% if (employee.payment_type) { %><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-100 text-gray-600"><%= employee.payment_type.toUpperCase() %></span><% } %>
          <% if (readiness) { %><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= readinessBadge[readiness.status] || 'bg-gray-100 text-gray-500' %>"><%= readinessLabel[readiness.status] || readiness.status %></span><% } %>
        </div>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/hr/employees/<%= employee.id %>/edit" class="inline-flex items-center px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </a>
      <% if (employee.employment_status === 'inactive' || employee.employment_status === 'deactivated') { %>
        <form method="POST" action="/hr/employees/<%= employee.id %>/toggle-active" class="inline">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="reactivate">
          <button class="inline-flex items-center px-3 py-2 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium rounded-lg hover:bg-emerald-100 transition">
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Reactivate
          </button>
        </form>
      <% } else if (employee.employment_status === 'active') { %>
        <form method="POST" action="/hr/employees/<%= employee.id %>/toggle-active" class="inline">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="deactivate">
          <button class="inline-flex items-center px-3 py-2 bg-amber-50 border border-amber-200 text-amber-700 text-sm font-medium rounded-lg hover:bg-amber-100 transition">
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
            Deactivate
          </button>
        </form>
      <% } %>
      <% if (employee.blocked_from_allocation) { %>
        <form method="POST" action="/hr/employees/<%= employee.id %>/block" class="inline">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="unblock">
          <button class="inline-flex items-center px-3 py-2 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm font-medium rounded-lg hover:bg-emerald-100 transition">
            <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
            Unblock
          </button>
        </form>
      <% } else { %>
        <button onclick="document.getElementById('blockModal').classList.remove('hidden')" class="inline-flex items-center px-3 py-2 bg-red-50 border border-red-200 text-red-700 text-sm font-medium rounded-lg hover:bg-red-100 transition">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Block
        </button>
      <% } %>
    </div>
  </div>

  <!-- Block warning -->
  <% if (employee.blocked_from_allocation) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      <span><strong>Blocked from allocation.</strong> <% if (employee.block_reason) { %>Reason: <%= employee.block_reason %><% } %></span>
    </div>
  <% } %>

  <!-- Tabs -->
  <div class="border-b border-gray-200">
    <nav class="flex gap-6 -mb-px overflow-x-auto" id="empTabs">
      <button onclick="switchEmpTab('overview')" data-tab="overview" class="emp-tab whitespace-nowrap pb-3 px-1 border-b-2 border-brand-600 text-brand-600 text-sm font-medium transition cursor-pointer">Overview</button>
      <button onclick="switchEmpTab('documents')" data-tab="documents" class="emp-tab whitespace-nowrap pb-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 text-sm font-medium transition cursor-pointer">Documents <span class="ml-1 bg-gray-100 text-gray-600 text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= documents.length %></span></button>
      <button onclick="switchEmpTab('competencies')" data-tab="competencies" class="emp-tab whitespace-nowrap pb-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 text-sm font-medium transition cursor-pointer">Competencies <span class="ml-1 bg-gray-100 text-gray-600 text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= competencies.length %></span></button>
      <button onclick="switchEmpTab('workforce')" data-tab="workforce" class="emp-tab whitespace-nowrap pb-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 text-sm font-medium transition cursor-pointer">Linked Workforce <% if (crewMember) { %><span class="ml-1 w-2 h-2 bg-emerald-500 rounded-full inline-block"></span><% } %></button>
      <button onclick="switchEmpTab('training')" data-tab="training" class="emp-tab whitespace-nowrap pb-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 text-sm font-medium transition cursor-pointer">Training <% if (locals.training && training.length > 0) { %><span class="ml-1 bg-emerald-100 text-emerald-700 text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= training.length %></span><% } %></button>
    </nav>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TAB: Overview                               -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="tab-overview" class="emp-tab-content">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Left column: Details -->
      <div class="lg:col-span-2 space-y-5">

        <!-- Employment Info -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Employment</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-6">
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Role / Level</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.traffic_role_level || employee.role_title || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Employment Type</p><p class="text-sm text-gray-900 mt-0.5 capitalize"><%= employee.employment_type ? employee.employment_type.replace(/_/g, ' ') : '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Payment Type</p><p class="text-sm text-gray-900 mt-0.5 uppercase"><%= employee.payment_type || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Start Date</p><p class="text-sm text-gray-900 mt-0.5"><%= formatDate(employee.start_date) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">End Date</p><p class="text-sm text-gray-900 mt-0.5"><%= formatDate(employee.end_date) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Probation Ends</p><p class="text-sm text-gray-900 mt-0.5"><%= formatDate(employee.probation_end_date) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Manager</p><p class="text-sm text-gray-900 mt-0.5"><% if (manager) { %><a href="/hr/employees/<%= manager.id %>" class="text-brand-600 hover:text-brand-700"><%= manager.full_name %></a><% } else { %>-<% } %></p></div>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Contact</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-6">
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Phone</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.phone || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Email</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.email || '-' %></p></div>
            <% if (canViewSensitive) { %>
              <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Date of Birth</p><p class="text-sm text-gray-900 mt-0.5"><%= formatDate(employee.date_of_birth) %></p></div>
            <% } %>
            <div class="col-span-2 sm:col-span-3"><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Address</p><p class="text-sm text-gray-900 mt-0.5"><%= [employee.address, employee.suburb, employee.state, employee.postcode].filter(Boolean).join(', ') || '-' %></p></div>
          </div>
        </div>

        <!-- Licences & Cards -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Licences & Cards</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-6">
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">White Card Number</p><p class="text-sm text-gray-900 mt-0.5 font-mono"><%= employee.white_card_number || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">TC Licence Number</p><p class="text-sm text-gray-900 mt-0.5 font-mono"><%= employee.tc_licence_number || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">TC Licence State</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.tc_licence_state || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">TC Date of Issue</p><p class="text-sm text-gray-900 mt-0.5"><%= formatDate(employee.tc_licence_date_of_issue) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Driver's Licence Number</p><p class="text-sm text-gray-900 mt-0.5 font-mono"><%= employee.drivers_licence_number || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Ticket Classification</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.ticket_classification || '-' %></p></div>
          </div>
        </div>

        <!-- Operational -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Operational</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-4 gap-x-6">
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Primary Region</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.primary_work_region || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Base Location</p><p class="text-sm text-gray-900 mt-0.5"><%= employee.base_location || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Induction</p><p class="text-sm text-gray-900 mt-0.5"><%= formatType(employee.induction_status) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">PPE Status</p><p class="text-sm text-gray-900 mt-0.5"><%= formatType(employee.ppe_issued_status) %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Allocatable</p><p class="text-sm mt-0.5 <%= employee.allocatable ? 'text-emerald-600' : 'text-red-600' %>"><%= employee.allocatable ? 'Yes' : 'No' %></p></div>
          </div>
        </div>

        <!-- Pay Rates (Admin / Finance only) -->
        <% if (typeof showRates !== 'undefined' && showRates) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Pay Rates</h2>
          <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
            <% const rateLabels = {rate_day:'Day',rate_ot:'OT',rate_dt:'DT',rate_night:'Night',rate_night_ot:'Night OT',rate_night_dt:'Night DT',rate_travel:'Travel',rate_meal:'Meal',rate_weekend:'Weekend'}; %>
            <% Object.entries(rateLabels).forEach(([key, label]) => { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= label %></p>
              <p class="text-lg font-bold text-gray-900 mt-0.5">$<%= (employee[key] || 0).toFixed(2) %></p>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>

        <!-- Super & Bank Details (from induction submission) -->
        <% if (locals.induction) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Superannuation & Bank Details</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-3">
            <% if (induction.super_fund_name) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Super Fund</p>
              <p class="text-sm font-medium text-gray-900"><%= induction.super_fund_name %></p>
            </div>
            <% } %>
            <% if (induction.super_fund_abn) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Super ABN</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.super_fund_abn %></p>
            </div>
            <% } %>
            <% if (induction.super_usi) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">USI</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.super_usi %></p>
            </div>
            <% } %>
            <% if (induction.super_member_number) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Member Number</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.super_member_number %></p>
            </div>
            <% } %>
            <% if (induction.bank_name) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Bank</p>
              <p class="text-sm font-medium text-gray-900"><%= induction.bank_name %></p>
            </div>
            <% } %>
            <% if (induction.bank_account_name) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Account Name</p>
              <p class="text-sm text-gray-700"><%= induction.bank_account_name %></p>
            </div>
            <% } %>
            <% if (induction.bank_bsb) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">BSB</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.bank_bsb %></p>
            </div>
            <% } %>
            <% if (induction.bank_account_number) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Account Number</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.bank_account_number %></p>
            </div>
            <% } %>
            <% if (induction.tax_file_number) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">TFN</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.tax_file_number %></p>
            </div>
            <% } %>
            <% if (induction.abn_number) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">ABN</p>
              <p class="text-sm text-gray-700 font-mono"><%= induction.abn_number %></p>
            </div>
            <% } %>
          </div>
          <% if (!induction.super_fund_name && !induction.bank_bsb && !induction.tax_file_number && !induction.abn_number) { %>
            <p class="text-sm text-gray-400">No super or bank details submitted yet.</p>
          <% } %>
        </div>
        <% } %>

        <!-- Internal Notes -->
        <% if (employee.internal_notes) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Internal Notes</h2>
          <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= employee.internal_notes %></p>
        </div>
        <% } %>
      </div>

      <!-- Right column: Sidebar cards -->
      <div class="space-y-5">

        <!-- Quick Info -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Quick Info</h3>
          <dl class="space-y-2.5">
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Employee ID</dt><dd class="text-xs font-medium text-gray-900"><%= employee.employee_code || '-' %></dd></div>
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Status</dt><dd><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusBadge[employee.employment_status] || statusBadge.inactive %>"><%= (employee.employment_status || 'unknown').replace(/_/g, ' ') %></span></dd></div>
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Readiness</dt><dd><% if (readiness) { %><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= readinessBadge[readiness.status] || 'bg-gray-100 text-gray-500' %>"><%= readinessLabel[readiness.status] || readiness.status %></span><% } else { %>-<% } %></dd></div>
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Documents</dt><dd class="text-xs font-medium text-gray-900"><%= documents.length %></dd></div>
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Competencies</dt><dd class="text-xs font-medium text-gray-900"><%= competencies.length %></dd></div>
            <% if (crewMember) { %>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Crew Member</dt><dd><a href="/crew/<%= crewMember.id %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium"><%= crewMember.full_name %></a></dd></div>
            <% } %>
            <div class="flex justify-between"><dt class="text-xs text-gray-500">Created</dt><dd class="text-xs text-gray-500"><%= formatDate(employee.created_at) %></dd></div>
          </dl>
        </div>

        <!-- Emergency Contact -->
        <% if (canViewSensitive) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Emergency Contact</h3>
          <% if (employee.emergency_contact_name) { %>
            <dl class="space-y-2.5">
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Name</dt><dd class="text-xs font-medium text-gray-900"><%= employee.emergency_contact_name %></dd></div>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Phone</dt><dd class="text-xs font-medium text-gray-900"><%= employee.emergency_contact_phone || '-' %></dd></div>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Relationship</dt><dd class="text-xs font-medium text-gray-900"><%= employee.emergency_contact_relationship || '-' %></dd></div>
            </dl>
          <% } else { %>
            <p class="text-xs text-gray-400">No emergency contact on file.</p>
          <% } %>
        </div>
        <% } %>

        <!-- Induction (overall) -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Induction</h3>

          <% if (employee.inducted_at) { %>
            <div class="flex items-center gap-2 text-emerald-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-semibold">Inducted</span>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              <%= new Date(employee.inducted_at + (employee.inducted_at.includes('T') ? '' : 'Z')).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day:'numeric', month:'short', year:'numeric' }) %>
              <% if (employee.inducted_method) { %> · <%= employee.inducted_method.replace(/_/g,' ') %><% } %>
              <% if (inductionMarkedBy) { %> · marked by <%= inductionMarkedBy %><% } %>
            </p>
            <form method="POST" action="/hr/employees/<%= employee.id %>/mark-inducted" class="mt-3" onsubmit="return confirm('Clear induction status for <%= employee.full_name %>?')">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="completed" value="0">
              <button type="submit" class="text-xs text-gray-500 hover:text-red-600 font-medium">Clear induction status</button>
            </form>
          <% } else { %>
            <div class="flex items-center gap-2 text-amber-700 mb-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <span class="text-sm font-semibold">Not inducted</span>
            </div>
            <form method="POST" action="/hr/employees/<%= employee.id %>/mark-inducted">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="completed" value="on">
              <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold rounded-lg transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Mark in-person induction complete
              </button>
            </form>
          <% } %>

          <!-- Module status breakdown -->
          <div class="mt-3 pt-3 border-t border-gray-100">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Module status</p>
            <ul class="space-y-1.5">
              <% [['employee_guide','Employee Guide'],['tc_training_1','TC Training Module 1']].forEach(([key,label]) => { %>
                <li class="flex items-center justify-between text-xs">
                  <span class="text-gray-700"><%= label %></span>
                  <% if (trainingPasses && trainingPasses[key]) { %>
                    <span class="text-emerald-600 font-semibold flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                      <%= trainingPasses[key].score %>/<%= trainingPasses[key].total %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-400">—</span>
                  <% } %>
                </li>
              <% }) %>
              <li class="flex items-center justify-between text-xs">
                <span class="text-gray-700">SOP / SWMS Acknowledgement</span>
                <% if (typeof sopStatus !== 'undefined' && sopStatus.signed) { %>
                  <span class="text-emerald-600 font-semibold flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    Signed
                  </span>
                <% } else { %>
                  <span class="text-gray-400">—</span>
                <% } %>
              </li>
            </ul>
          </div>

          <!-- Online training permission -->
          <div class="mt-3 pt-3 border-t border-gray-100">
            <div class="flex items-center justify-between gap-2">
              <div>
                <p class="text-xs font-semibold text-gray-800">Online training access</p>
                <p class="text-[11px] text-gray-500">Lets them take training presentations on the worker portal.</p>
              </div>
              <form method="POST" action="/hr/employees/<%= employee.id %>/toggle-online-training">
                <%- include('../partials/csrf') %>
                <button type="submit" class="<%= employee.online_training_allowed ? 'bg-emerald-500' : 'bg-gray-300' %> relative inline-flex h-6 w-11 items-center rounded-full transition-colors flex-shrink-0" aria-label="Toggle online training">
                  <span class="<%= employee.online_training_allowed ? 'translate-x-6' : 'translate-x-1' %> inline-block h-4 w-4 transform rounded-full bg-white transition shadow"></span>
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- SOP Acknowledgement -->
        <% if (typeof sopStatus !== 'undefined' && employee.linked_crew_member_id) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <div class="flex items-center justify-between mb-3">
            <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest">SOP Sign-Off</h3>
            <code class="text-[10px] bg-gray-100 px-1.5 py-0.5 rounded text-gray-600"><%= sopStatus.version %></code>
          </div>

          <% if (sopStatus.signed) { %>
            <div class="flex items-center gap-2 text-emerald-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-sm font-semibold">Signed</span>
            </div>
            <p class="text-xs text-gray-500 mt-1">
              on <%= new Date(sopStatus.signedAt + (sopStatus.signedAt.includes('T') ? '' : 'Z')).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day:'numeric', month:'short', year:'numeric' }) %>
            </p>
          <% } else { %>
            <div class="flex items-center gap-2 text-amber-700 mb-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <span class="text-sm font-semibold">Not signed</span>
            </div>

            <% if (sopStatus.openLinkUrl) { %>
              <div class="bg-gray-50 border border-gray-200 rounded-lg p-2.5 mb-3">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Active link</p>
                <div class="flex items-center gap-2">
                  <input type="text" value="<%= sopStatus.openLinkUrl %>" readonly id="sop-link-input"
                         class="flex-1 min-w-0 bg-white border border-gray-200 rounded px-2 py-1 text-[11px] font-mono text-gray-700" />
                  <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('sop-link-input').value).then(()=>{this.textContent='✓';setTimeout(()=>{this.textContent='Copy'},1500)})"
                          class="text-xs px-2 py-1 bg-brand-600 hover:bg-brand-500 text-white rounded font-medium flex-shrink-0">Copy</button>
                </div>
              </div>
            <% } %>

            <div class="flex flex-col gap-2">
              <% if (employee.email) { %>
                <form method="POST" action="/hr/employees/<%= employee.id %>/sop-link">
                  <%- include('../partials/csrf') %>
                  <input type="hidden" name="action" value="email">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-xs font-semibold rounded-lg transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Email link to <%= employee.email %>
                  </button>
                </form>
              <% } else { %>
                <p class="text-[11px] text-gray-500 italic">No email on file — use Copy Link, or set their email first.</p>
              <% } %>
              <% if (!sopStatus.openLinkUrl) { %>
                <form method="POST" action="/hr/employees/<%= employee.id %>/sop-link">
                  <%- include('../partials/csrf') %>
                  <input type="hidden" name="action" value="copy">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-3 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-semibold rounded-lg transition">
                    Generate copy-paste link
                  </button>
                </form>
              <% } %>
            </div>
          <% } %>

          <% if (sopHistory && sopHistory.length > 0) { %>
            <details class="mt-3 pt-3 border-t border-gray-100">
              <summary class="text-[10px] font-bold text-gray-400 uppercase tracking-widest cursor-pointer hover:text-gray-600">History (<%= sopHistory.length %>)</summary>
              <ul class="mt-2 space-y-1.5">
                <% sopHistory.forEach(h => { %>
                  <li class="text-[11px] text-gray-600 flex items-center gap-2">
                    <code class="bg-gray-100 px-1 py-0.5 rounded text-[10px]"><%= h.sop_version %></code>
                    <span class="flex-1"><%= new Date(h.signed_at + (h.signed_at.includes('T') ? '' : 'Z')).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day:'numeric', month:'short', year:'numeric' }) %></span>
                    <% if (h.signature_url) { %>
                      <a href="<%= h.signature_url %>" target="_blank" class="text-brand-600 hover:text-brand-700 font-medium">view</a>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            </details>
          <% } %>
        </div>
        <% } %>

        <!-- Links -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Links</h3>
          <dl class="space-y-2.5">
            <% if (crewMember) { %>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Crew Profile</dt><dd><a href="/crew/<%= crewMember.id %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View &rarr;</a></dd></div>
            <% } %>
            <% if (employee.linked_user_id) { %>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">User Account</dt><dd class="text-xs text-gray-900">Linked (ID: <%= employee.linked_user_id %>)</dd></div>
            <% } %>
            <% if (canViewSensitive && employee.payroll_reference) { %>
              <div class="flex justify-between"><dt class="text-xs text-gray-500">Payroll Ref</dt><dd class="text-xs font-mono text-gray-900"><%= employee.payroll_reference %></dd></div>
            <% } %>
          </dl>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TAB: Documents                              -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="tab-documents" class="emp-tab-content" style="display:none;">

    <!-- Key Documents Grid -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-bold text-gray-800">Key Documents</h2>
        <button onclick="document.getElementById('uploadDocModal').classList.remove('hidden')" class="inline-flex items-center px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          Upload Document
        </button>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% keyDocTypes.forEach(kd => {
          const doc = keyDocMap[kd.type];
          const hasDoc = !!doc;
          const isExpired = doc && doc.expiry_date && doc.expiry_date < todayStr;
          const vStatus = doc ? (doc.verification_status || 'pending') : null;
          const vBadge = vStatus ? (verificationBadge[vStatus] || 'bg-gray-100 text-gray-600') : '';
        %>
        <div class="bg-white border <%= hasDoc ? (isExpired ? 'border-red-200' : 'border-gray-200') : 'border-dashed border-gray-300' %> rounded-xl shadow-sm overflow-hidden">
          <!-- Card Header -->
          <div class="px-4 py-3 border-b <%= hasDoc ? 'border-gray-100 bg-gray-50/50' : 'border-gray-200 bg-gray-50' %>">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 <%= hasDoc ? 'text-brand-500' : 'text-gray-400' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= kd.icon %>"/></svg>
                <span class="text-xs font-bold text-gray-700 uppercase tracking-wider"><%= kd.label %></span>
              </div>
              <% if (kd.mandatory) { %><span class="text-[9px] font-bold text-red-600 uppercase">Required</span><% } %>
            </div>
          </div>

          <!-- Card Body -->
          <div class="p-4">
            <% if (hasDoc) { %>
              <!-- Document exists -->
              <% if (isImageFile(doc.original_name || doc.filename)) { %>
                <div class="w-full h-28 bg-gray-100 rounded-lg mb-3 overflow-hidden flex items-center justify-center">
                  <a href="/hr/documents/<%= doc.id %>/download" class="block w-full h-full">
                    <img src="/hr/documents/<%= doc.id %>/download" alt="<%= kd.label %>" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<div class=\'flex items-center justify-center h-full text-gray-400 text-xs\'>Preview unavailable</div>'">
                  </a>
                </div>
              <% } else { %>
                <div class="w-full h-28 bg-gray-50 rounded-lg mb-3 flex flex-col items-center justify-center">
                  <svg class="w-8 h-8 text-gray-300 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  <span class="text-[10px] text-gray-400 font-medium">PDF / Document</span>
                </div>
              <% } %>

              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= vBadge %>"><%= (vStatus || 'pending').replace(/_/g, ' ') %></span>
                  <% if (isExpired) { %><span class="text-[10px] font-bold text-red-600">EXPIRED</span><% } %>
                </div>
                <% if (doc.expiry_date) { %>
                  <p class="text-[10px] text-gray-400">Expires: <span class="<%= isExpired ? 'text-red-600 font-medium' : 'text-gray-600' %>"><%= formatDate(doc.expiry_date) %></span></p>
                <% } %>
                <div class="flex gap-1.5 pt-1">
                  <a href="/hr/documents/<%= doc.id %>/download" class="flex-1 text-center px-2 py-1.5 text-[10px] font-medium text-brand-700 bg-brand-50 hover:bg-brand-100 rounded-lg transition">Download</a>
                  <% if (vStatus === 'pending') { %>
                    <form method="POST" action="/hr/documents/<%= doc.id %>/verify" class="flex-1"><%- include('../partials/csrf') %><input type="hidden" name="action" value="verify"><button type="submit" class="w-full px-2 py-1.5 text-[10px] font-medium text-emerald-700 bg-emerald-50 hover:bg-emerald-100 rounded-lg transition">Verify</button></form>
                  <% } %>
                  <form method="POST" action="/hr/documents/<%= doc.id %>/delete" class="inline" onsubmit="return confirm('Delete this document?')"><%- include('../partials/csrf') %><button type="submit" class="px-2 py-1.5 text-[10px] font-medium text-red-600 hover:bg-red-50 rounded-lg transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button></form>
                </div>
              </div>
            <% } else { %>
              <!-- No document — upload prompt -->
              <div class="flex flex-col items-center justify-center py-4">
                <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mb-3">
                  <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
                </div>
                <p class="text-xs text-gray-500 mb-2">Not uploaded</p>
                <button onclick="openUploadModal('<%= kd.type %>')" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-brand-700 bg-brand-50 hover:bg-brand-100 rounded-lg transition">Upload</button>
              </div>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <!-- Other Documents -->
    <% if (otherDocs.length > 0) { %>
    <div>
      <h2 class="text-sm font-bold text-gray-800 mb-3">Other Documents</h2>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Expiry</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% otherDocs.forEach(doc => {
                const isExpired = doc.expiry_date && doc.expiry_date < todayStr;
                const vBadge = verificationBadge[doc.verification_status] || 'bg-gray-100 text-gray-600';
              %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-4 py-3 text-sm text-gray-700"><%= formatType(doc.document_type) %></td>
                <td class="px-4 py-3">
                  <p class="text-sm font-medium text-gray-900"><%= doc.document_name || doc.original_name %></p>
                  <p class="text-[10px] text-gray-400 mt-0.5"><%= doc.original_name %></p>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  <% if (doc.expiry_date) { %>
                    <span class="text-sm <%= isExpired ? 'text-red-600 font-semibold' : 'text-gray-600' %>"><%= formatDate(doc.expiry_date) %></span>
                    <% if (isExpired) { %><span class="block text-[10px] text-red-500 font-medium">EXPIRED</span><% } %>
                  <% } else { %><span class="text-gray-300 text-sm">-</span><% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= vBadge %>"><%= (doc.verification_status || 'pending').replace(/_/g, ' ') %></span>
                </td>
                <td class="px-4 py-3 text-right">
                  <div class="flex items-center justify-end gap-1">
                    <a href="/hr/documents/<%= doc.id %>/download" class="px-2 py-1 text-xs text-gray-600 bg-gray-100 hover:bg-brand-50 hover:text-brand-700 rounded-lg transition">Download</a>
                    <% if (doc.verification_status === 'pending') { %>
                      <form method="POST" action="/hr/documents/<%= doc.id %>/verify" class="inline"><%- include('../partials/csrf') %><input type="hidden" name="action" value="verify"><button type="submit" class="px-2 py-1 text-xs text-emerald-700 bg-emerald-50 hover:bg-emerald-100 rounded-lg transition">Verify</button></form>
                    <% } %>
                    <form method="POST" action="/hr/documents/<%= doc.id %>/delete" class="inline" onsubmit="return confirm('Delete this document?')"><%- include('../partials/csrf') %><button type="submit" class="px-2 py-1 text-xs text-red-600 hover:bg-red-50 rounded-lg transition">Delete</button></form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No documents</h3>
      <p class="text-gray-500 text-sm mb-4">Upload the first document for this employee.</p>
      <button onclick="document.getElementById('uploadDocModal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Upload Document</button>
    </div>
    <% } %>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TAB: Competencies                           -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="tab-competencies" class="emp-tab-content" style="display:none;">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-bold text-gray-800">Licences & Competencies</h2>
      <button onclick="document.getElementById('addCompModal').classList.remove('hidden')" class="inline-flex items-center px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Competency
      </button>
    </div>

    <% if (competencies.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% competencies.forEach(comp => {
          const isExpired = comp.expiry_date && comp.expiry_date < todayStr;
          const isExpiring = comp.status === 'expiring_soon';
          const cBadge = compStatusBadge[comp.status] || 'bg-gray-100 text-gray-600';
          const borderColor = isExpired ? 'border-red-200' : (isExpiring ? 'border-amber-200' : 'border-gray-200');

          // Find linked document
          const linkedDoc = comp.linked_document_id ? documents.find(d => d.id === comp.linked_document_id) : null;

          // Icon based on type
          const compIcons = {
            traffic_controller_licence: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0',
            white_card: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            first_aid: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
            drivers_licence: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0',
            truck_licence: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10 M13 6h4l3 5v5h-2',
            working_at_heights: 'M13 10V3L4 14h7v7l9-11h-7z',
            confined_space: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
            EWP: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
            forklift: 'M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10 M13 6h4l3 5v5h-2',
          };
          const compIcon = compIcons[comp.competency_type] || 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z';
        %>
        <div class="bg-white border <%= borderColor %> rounded-xl shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <!-- Card Header -->
          <div class="px-4 py-3 bg-gray-50/50 border-b border-gray-100">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg <%= isExpired ? 'bg-red-100' : (isExpiring ? 'bg-amber-100' : 'bg-brand-100') %> flex items-center justify-center">
                  <svg class="w-4 h-4 <%= isExpired ? 'text-red-600' : (isExpiring ? 'text-amber-600' : 'text-brand-600') %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= compIcon %>"/></svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-900"><%= formatType(comp.competency_type) %></p>
                  <% if (comp.competency_name && comp.competency_name !== formatType(comp.competency_type)) { %>
                    <p class="text-[10px] text-gray-500"><%= comp.competency_name %></p>
                  <% } %>
                </div>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= cBadge %>"><%= formatType(comp.status) %></span>
            </div>
          </div>

          <!-- Card Body -->
          <div class="px-4 py-3 space-y-2.5">
            <% if (comp.competency_level) { %>
              <div class="flex justify-between">
                <span class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Level</span>
                <span class="text-xs font-medium text-gray-900"><%= comp.competency_level %></span>
              </div>
            <% } %>
            <% if (comp.issue_date) { %>
              <div class="flex justify-between">
                <span class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Issued</span>
                <span class="text-xs text-gray-600"><%= formatDate(comp.issue_date) %></span>
              </div>
            <% } %>
            <% if (comp.expiry_date) { %>
              <div class="flex justify-between">
                <span class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Expires</span>
                <span class="text-xs <%= isExpired ? 'text-red-600 font-bold' : (isExpiring ? 'text-amber-600 font-medium' : 'text-gray-600') %>"><%= formatDate(comp.expiry_date) %>
                  <% if (isExpired) { %> <span class="text-red-500">(EXPIRED)</span><% } %>
                  <% if (isExpiring && !isExpired) { %> <span class="text-amber-500">(EXPIRING)</span><% } %>
                </span>
              </div>
            <% } %>
            <% if (comp.mandatory_for_role) { %>
              <div class="flex justify-between">
                <span class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Required</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">Mandatory</span>
              </div>
            <% } %>

            <!-- Linked Document -->
            <% if (linkedDoc) { %>
              <div class="pt-2 mt-2 border-t border-gray-100">
                <div class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                  <a href="/hr/documents/<%= linkedDoc.id %>/download" class="text-[10px] text-brand-600 hover:text-brand-700 font-medium truncate"><%= linkedDoc.document_name || linkedDoc.original_name %></a>
                </div>
              </div>
            <% } %>

            <% if (comp.notes) { %>
              <p class="text-[10px] text-gray-500 italic pt-1"><%= comp.notes %></p>
            <% } %>
          </div>

          <!-- Card Footer -->
          <div class="px-4 py-2.5 bg-gray-50/50 border-t border-gray-100 flex justify-end gap-1.5">
            <button onclick="openEditComp(<%= JSON.stringify({id: comp.id, competency_type: comp.competency_type, competency_name: comp.competency_name || '', competency_level: comp.competency_level || '', issue_date: comp.issue_date || '', expiry_date: comp.expiry_date || '', status: comp.status, mandatory_for_role: comp.mandatory_for_role, linked_document_id: comp.linked_document_id || '', notes: comp.notes || ''}) %>)" class="px-2.5 py-1.5 text-[10px] font-medium text-gray-600 bg-white border border-gray-200 hover:bg-gray-50 rounded-lg transition">Edit</button>
            <form method="POST" action="/hr/competencies/<%= comp.id %>/delete" class="inline" onsubmit="return confirm('Remove this competency?')"><%- include('../partials/csrf') %><button type="submit" class="px-2.5 py-1.5 text-[10px] font-medium text-red-600 hover:bg-red-50 rounded-lg transition">Remove</button></form>
          </div>
        </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
        <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-1">No competencies recorded</h3>
        <p class="text-gray-500 text-sm mb-4">Add licences and competencies to track compliance for this employee.</p>
        <button onclick="document.getElementById('addCompModal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Add Competency</button>
      </div>
    <% } %>
  </div>

  <!-- ═══════════════════════════════════════════ -->
  <!-- TAB: Linked Workforce                       -->
  <!-- ═══════════════════════════════════════════ -->
  <div id="tab-workforce" class="emp-tab-content" style="display:none;">
    <% if (crewMember) { %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

        <!-- Crew Member Info -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Crew Profile</h2>
            <a href="/crew/<%= crewMember.id %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View Full Profile &rarr;</a>
          </div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center text-brand-700 font-bold text-lg">
              <%= (crewMember.full_name || '?')[0] %>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= crewMember.full_name %></p>
              <p class="text-xs text-gray-500"><%= crewMember.employee_id || '' %> &middot; <%= crewMember.role ? crewMember.role.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) : '' %></p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-y-3 gap-x-6">
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Phone</p><p class="text-sm text-gray-900 mt-0.5"><%= crewMember.phone || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Email</p><p class="text-sm text-gray-900 mt-0.5"><%= crewMember.email || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Status</p><p class="text-sm text-gray-900 mt-0.5 capitalize"><%= crewMember.status || '-' %></p></div>
            <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Employment</p><p class="text-sm text-gray-900 mt-0.5 capitalize"><%= (crewMember.employment_type || '-').replace(/_/g, ' ') %></p></div>
            <% if (crewMember.white_card) { %>
              <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">White Card</p><p class="text-sm text-gray-900 mt-0.5 font-mono"><%= crewMember.white_card %></p></div>
            <% } %>
            <% if (crewMember.licence_type) { %>
              <div><p class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Licence</p><p class="text-sm text-gray-900 mt-0.5"><%= crewMember.licence_type %></p></div>
            <% } %>
          </div>
        </div>

        <!-- Upcoming Shifts -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Upcoming Shifts</h2>
          <% if (upcomingShifts && upcomingShifts.length > 0) { %>
            <div class="space-y-2">
              <% upcomingShifts.forEach(shift => { %>
              <div class="flex items-center justify-between py-2.5 px-3 bg-gray-50 rounded-lg">
                <div>
                  <p class="text-sm font-medium text-gray-900"><%= shift.job_number %></p>
                  <p class="text-[10px] text-gray-400"><%= shift.client || '' %></p>
                </div>
                <div class="text-right">
                  <span class="text-xs text-gray-600 tabular-nums"><%= formatDate(shift.allocation_date) %></span>
                  <% if (shift.start_time) { %><p class="text-[10px] text-gray-400"><%= shift.start_time %></p><% } %>
                </div>
              </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="text-center py-6">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-sm text-gray-400">No upcoming shifts.</p>
            </div>
          <% } %>
        </div>

        <!-- Worker Portal Access -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Portal Access</h2>
            <% if (crewMember.pin_hash) { %>
              <% if (crewMember.pin_plain) { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">PIN: <span class="font-mono font-bold"><%= crewMember.pin_plain %></span></span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">PIN Set <span class="text-[8px] text-amber-600 ml-1">(reset to view)</span></span>
              <% } %>
            <% } else { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-100 text-gray-500">No Access</span>
            <% } %>
          </div>

          <% if (!crewMember.employee_id) { %>
            <div class="p-2.5 bg-amber-50 border border-amber-200 rounded-lg text-amber-700 text-xs">
              Worker needs an Employee ID before portal access. <a href="/hr/employees/<%= employee.id %>/edit" class="font-medium underline">Edit profile</a>
            </div>
          <% } else { %>
            <% if (crewMember.pin_hash && crewMember.last_worker_login) { %>
            <div class="text-xs text-gray-500 mb-2">
              Last login: <span class="text-gray-700 font-medium"><%= new Date(crewMember.last_worker_login).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
              <% if (crewMember.worker_login_count) { %> (<%= crewMember.worker_login_count %> total)<% } %>
            </div>
            <% } else if (crewMember.pin_hash) { %>
            <p class="text-xs text-gray-400 mb-2">Never logged in</p>
            <% } %>

            <div class="space-y-2">
              <form method="POST" action="/hr/employees/<%= employee.id %>/set-pin" class="flex items-end gap-2">
                <%- include('../partials/csrf') %>
                <div class="flex-1">
                  <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5"><%= crewMember.pin_hash ? 'Reset PIN' : 'Set PIN' %></label>
                  <input type="text" name="pin" inputmode="numeric" pattern="[0-9]{4,6}" maxlength="6" required placeholder="4-6 digits"
                    class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
                </div>
                <button type="submit" class="px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition"><%= crewMember.pin_hash ? 'Reset' : 'Set' %></button>
              </form>
              <div class="flex gap-2">
                <% if (crewMember.pin_hash) { %>
                  <form method="POST" action="/hr/employees/<%= employee.id %>/clear-pin" onsubmit="return confirm('Remove portal access?')" class="flex-1">
                    <%- include('../partials/csrf') %>
                    <button type="submit" class="w-full px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition">Clear PIN</button>
                  </form>
                <% } %>
                <% if (crewMember.email && crewMember.employee_id) { %>
                  <form method="POST" action="/hr/employees/<%= employee.id %>/send-invite" class="flex-1">
                    <%- include('../partials/csrf') %>
                    <button type="submit" class="w-full px-3 py-2 bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-medium rounded-lg border border-blue-200 transition">Email Invite</button>
                  </form>
                <% } %>
              </div>
              <!-- Manager toggle — button label spells out what pressing it
                   will do (Grant / Revoke), and a state pill on the left
                   shows the current value at a glance. Avoids the old
                   "✓ Manager" label which was ambiguous about whether
                   tapping it would turn it on or off. -->
              <div class="pt-3 mt-3 border-t border-gray-100">
                <div class="flex items-start justify-between gap-3 flex-wrap">
                  <div class="flex-1 min-w-[180px]">
                    <div class="flex items-center gap-2">
                      <p class="text-xs font-semibold text-gray-700">Manager portal access</p>
                      <% if (crewMember.is_manager) { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">
                          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                          On
                        </span>
                      <% } else { %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-gray-100 text-gray-500 ring-1 ring-gray-400/20">
                          <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>
                          Off
                        </span>
                      <% } %>
                    </div>
                    <p class="text-[11px] text-gray-500 mt-1">Unlocks shift board, leave approvals and kudos moderation in the worker portal.</p>
                    <p class="text-[10px] text-gray-400 mt-1">
                      <% if (crewMember.is_manager) { %>
                        Currently on. Pressing the button will <strong class="text-red-600">revoke</strong> manager access.
                      <% } else { %>
                        Currently off. Pressing the button will <strong class="text-emerald-700">grant</strong> manager access.
                      <% } %>
                    </p>
                  </div>
                  <form method="POST" action="/hr/employees/<%= employee.id %>/toggle-manager"
                        onsubmit="return confirm('<%= crewMember.is_manager ? "Revoke manager access for " + crewMember.full_name + "? They’ll lose the shift board, leave approvals and kudos moderation tabs." : "Grant manager access to " + crewMember.full_name + "? They’ll get the shift board, leave approvals and kudos moderation tabs in the worker portal." %>');">
                    <%- include('../partials/csrf') %>
                    <input type="hidden" name="enable" value="<%= crewMember.is_manager ? '0' : '1' %>">
                    <button type="submit"
                      class="inline-flex items-center gap-1.5 px-3 py-2 <%= crewMember.is_manager ? 'bg-red-50 hover:bg-red-100 text-red-700 ring-1 ring-red-200' : 'bg-emerald-600 hover:bg-emerald-700 text-white' %> text-xs font-semibold rounded-lg transition whitespace-nowrap">
                      <% if (crewMember.is_manager) { %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                        Revoke access
                      <% } else { %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Grant access
                      <% } %>
                    </button>
                  </form>
                </div>

                <!-- Portal role tier — TC < TL < Supervisor. Hierarchy means
                     a Supervisor sees everything a TL sees, plus extras;
                     a TL sees everything a TC sees, plus the Team Leader
                     Checklist. -->
                <div class="mt-3 pt-3 border-t border-gray-100">
                  <p class="text-xs font-semibold text-gray-700">Portal role</p>
                  <p class="text-[11px] text-gray-500 mt-0.5 mb-2">Each tier inherits the powers below it. Supervisor = full access; Team Leader = TC + Team Leader Checklist; TC = baseline.</p>
                  <form method="POST" action="/hr/employees/<%= employee.id %>/portal-role" class="flex items-center gap-2">
                    <%- include('../partials/csrf') %>
                    <select name="portal_role" class="flex-1 px-3 py-1.5 text-xs border border-gray-300 rounded-lg bg-white text-gray-900">
                      <% var pr = crewMember.portal_role || 'traffic_controller'; %>
                      <option value="traffic_controller" <%= pr === 'traffic_controller' ? 'selected' : '' %>>Traffic Controller</option>
                      <option value="team_leader"        <%= pr === 'team_leader'        ? 'selected' : '' %>>Team Leader</option>
                      <option value="supervisor"         <%= pr === 'supervisor'         ? 'selected' : '' %>>Supervisor</option>
                    </select>
                    <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-700 text-white text-xs font-semibold rounded-lg transition whitespace-nowrap">Save</button>
                  </form>
                </div>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Recent Timesheets -->
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 lg:col-span-2">
          <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Recent Timesheets</h2>
          <% if (recentTimesheets && recentTimesheets.length > 0) { %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200">
                <thead>
                  <tr class="border-b border-gray-200">
                    <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Date</th>
                    <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
                    <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Client</th>
                    <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% recentTimesheets.forEach(ts => { %>
                  <tr class="hover:bg-gray-50">
                    <td class="px-3 py-2 text-xs text-gray-600 tabular-nums"><%= formatDate(ts.work_date) %></td>
                    <td class="px-3 py-2 text-xs font-medium text-gray-900"><%= ts.job_number %></td>
                    <td class="px-3 py-2 text-xs text-gray-500 hidden sm:table-cell"><%= ts.client || '-' %></td>
                    <td class="px-3 py-2 text-xs text-gray-900 tabular-nums"><%= ts.hours_worked || '-' %></td>
                  </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-6">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <p class="text-sm text-gray-400">No timesheets found.</p>
            </div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <!-- No linked crew member — offer to enable portal access -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
        <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-2">Portal Access Not Set Up</h3>
        <p class="text-gray-500 text-sm mb-4 max-w-md mx-auto">This employee doesn't have worker portal access yet. Enable it to let them log in, view shifts, and submit timesheets.</p>
        <% if (employee.email) { %>
          <form method="POST" action="/hr/employees/<%= employee.id %>/enable-portal" class="inline">
            <%- include('../partials/csrf') %>
            <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
              Enable Portal Access
            </button>
          </form>
          <p class="text-[10px] text-gray-400 mt-3">Creates a crew profile and allows you to set a PIN or send an invite email</p>
        <% } else { %>
          <p class="text-amber-600 text-sm font-medium mb-2">Email address required</p>
          <a href="/hr/employees/<%= employee.id %>/edit" class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition">
            Edit Employee → Add Email
          </a>
        <% } %>
      </div>
    <% } %>
  </div>

</div>

