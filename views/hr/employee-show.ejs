      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Level</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Issue Date</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Expiry</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Mandatory</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% competencies.forEach(comp => {
              const todayStr = new Date().toISOString().split('T')[0];
              const isExpired = comp.expiry_date && comp.expiry_date < todayStr;
              const cBadge = compStatusBadge[comp.status] || 'bg-gray-100 text-gray-600';
            %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-3 text-sm text-gray-700"><%= formatType(comp.competency_type) %></td>
              <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= comp.competency_name || '-' %></td>
              <td class="px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= comp.competency_level || '-' %></td>
              <td class="px-4 py-3 text-sm text-gray-600 hidden md:table-cell"><%= formatDate(comp.issue_date) %></td>
              <td class="px-4 py-3">
                <% if (comp.expiry_date) { %>
                  <span class="text-sm <%= isExpired ? 'text-red-600 font-semibold' : 'text-gray-600' %>"><%= formatDate(comp.expiry_date) %></span>
                  <% if (isExpired) { %><span class="block text-[10px] text-red-500 font-medium">EXPIRED</span><% } %>
                <% } else { %><span class="text-gray-300 text-sm">-</span><% } %>
              </td>
              <td class="px-4 py-3"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= cBadge %>"><%= formatType(comp.status) %></span></td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% if (comp.mandatory_for_role) { %><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">Required</span><% } else { %><span class="text-gray-300 text-xs">-</span><% } %>
              </td>
              <td class="px-4 py-3 text-right">
                <form method="POST" action="/hr/competencies/<%= comp.id %>/delete" class="inline" onsubmit="return confirm('Remove this competency?')"><%- include('../partials/csrf') %><button type="submit" class="px-2 py-1 text-xs text-red-600 hover:bg-red-50 rounded-lg transition">Remove</button></form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No competencies</h3>
      <p class="text-gray-500 text-sm mb-4">Add the first licence or competency for this employee.</p>
      <button onclick="document.getElementById('addCompModal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Add Competency</button>
    </div>
    <% } %>
  </div>

  <!-- TAB: Linked Workforce -->
  <% if (crewMember) { %>
  <div id="tab-workforce" class="emp-tab-content hidden">
