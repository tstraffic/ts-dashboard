<div id="blockModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('blockModal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-xl shadow-xl max-w-md w-full p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Block from Allocation</h3>
    <form method="POST" action="/hr/employees/<%= employee.id %>/block" class="space-y-4">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="action" value="block">
      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1">Reason</label>
        <input type="text" name="block_reason" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Reason for blocking...">
      </div>
      <div class="flex items-center gap-3">
        <button type="submit" class="px-5 py-2.5 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition">Block Employee</button>
        <button type="button" onclick="document.getElementById('blockModal').classList.add('hidden')" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</button>
      </div>
    </form>
  </div>
</div>

<%- contentFor('script') %>
<script>
  // Tab switching
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.emp-tab');
    const contents = document.querySelectorAll('.emp-tab-content');

    // Check hash for direct tab link
    const hash = window.location.hash.replace('#', '');
    if (hash && document.getElementById('tab-' + hash)) {
      switchTab(hash);
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        switchTab(target);
        window.location.hash = target;
      });
    });

    function switchTab(target) {
      tabs.forEach(t => {
        t.classList.remove('border-brand-600', 'text-brand-600');
        t.classList.add('border-transparent', 'text-gray-500');
      });
      contents.forEach(c => c.classList.add('hidden'));

      const activeTab = document.querySelector(`[data-tab="${target}"]`);
      const activeContent = document.getElementById('tab-' + target);
      if (activeTab) {
        activeTab.classList.add('border-brand-600', 'text-brand-600');
        activeTab.classList.remove('border-transparent', 'text-gray-500');
      }
      if (activeContent) activeContent.classList.remove('hidden');
    }
  });
</script>
