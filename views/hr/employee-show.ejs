    <div class="flex justify-end mb-4">
      <button onclick="document.getElementById('addCompModal').classList.remove('hidden')" class="inline-flex items-center px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Competency
      </button>
    </div>

    <% if (competencies.length > 0) { %>
