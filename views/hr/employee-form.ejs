      </div>
    </div>

    <% if (typeof showRates !== 'undefined' && showRates) { %>
    <!-- Pay Rates (Admin / Finance only) -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-4">
      <h3 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-1">Pay Rates</h3>
      <p class="text-xs text-gray-400 mb-4">Only visible to Admin and Finance roles. Rates are per hour ($).</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Day Rate</label>
          <input type="number" step="0.01" min="0" name="rate_day" value="<%= val('rate_day') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">OT Rate</label>
          <input type="number" step="0.01" min="0" name="rate_ot" value="<%= val('rate_ot') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">DT Rate</label>
          <input type="number" step="0.01" min="0" name="rate_dt" value="<%= val('rate_dt') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night Rate</label>
          <input type="number" step="0.01" min="0" name="rate_night" value="<%= val('rate_night') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night OT</label>
          <input type="number" step="0.01" min="0" name="rate_night_ot" value="<%= val('rate_night_ot') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night DT</label>
          <input type="number" step="0.01" min="0" name="rate_night_dt" value="<%= val('rate_night_dt') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Travel</label>
          <input type="number" step="0.01" min="0" name="rate_travel" value="<%= val('rate_travel') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Meal</label>
          <input type="number" step="0.01" min="0" name="rate_meal" value="<%= val('rate_meal') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Weekend</label>
          <input type="number" step="0.01" min="0" name="rate_weekend" value="<%= val('rate_weekend') || 0 %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Step 6: Notes (Optional) -->
  <div class="wizard-panel hidden" data-wizard-panel="5">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Notes <span class="text-gray-400 font-normal normal-case text-[10px] ml-1">Optional</span></h2>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Internal Notes</label>
        <textarea name="internal_notes" rows="6"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Private notes about this employee..."><%= val('internal_notes') %></textarea>
        <p class="text-[10px] text-gray-400 mt-0.5">Internal notes are only visible to admin and HR users. Not shared with the employee.</p>
      </div>
    </div>
  </div>

  <!-- Wizard Navigation Buttons -->
  <div class="flex items-center justify-between mt-5" id="wizard-nav-buttons">
    <button type="button" id="wizard-prev" class="hidden px-5 py-2.5 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition inline-flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Previous
    </button>
    <div class="flex items-center gap-3 ml-auto">
      <a href="<%= isEdit ? '/hr/employees/' + employee.id : '/hr/employees' %>" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</a>
      <button type="button" id="wizard-next" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition inline-flex items-center gap-2">
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
      <button type="submit" id="wizard-submit" class="hidden px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition inline-flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <%= isEdit ? 'Update' : 'Add' %> Employee
      </button>
    </div>
  </div>

  <!-- NoScript fallback: show all panels -->
  <noscript>
    <style>.wizard-panel { display: block !important; } .wizard-panel.hidden { display: block !important; } #wizard-steps-nav, #wizard-nav-buttons, #wizard-progress-bar { display: none !important; }</style>
    <div class="flex items-center gap-3 mt-5">
      <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <%= isEdit ? 'Update' : 'Add' %> Employee
      </button>
      <a href="<%= isEdit ? '/hr/employees/' + employee.id : '/hr/employees' %>" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</a>
    </div>
  </noscript>
</form>

<script>
(function() {
  var totalSteps = <%= totalSteps %>;
  var currentStep = 0;
  var panels = document.querySelectorAll('.wizard-panel');
  var navBtns = document.querySelectorAll('[data-wizard-nav]');
  var prevBtn = document.getElementById('wizard-prev');
  var nextBtn = document.getElementById('wizard-next');
  var submitBtn = document.getElementById('wizard-submit');
  var progressBar = document.getElementById('wizard-progress-bar');
  var progressText = document.getElementById('wizard-progress-text');

  function goToStep(step) {
    if (step < 0 || step >= totalSteps) return;

    // Validate current step required fields before moving forward
    if (step > currentStep) {
      var currentPanel = panels[currentStep];
      var requiredFields = currentPanel.querySelectorAll('[required]');
      var valid = true;
      for (var i = 0; i < requiredFields.length; i++) {
        if (!requiredFields[i].value.trim()) {
          requiredFields[i].focus();
          requiredFields[i].classList.add('ring-2', 'ring-red-500', 'border-red-500');
          valid = false;
          break;
        }
      }
      if (!valid) return;
    }

    currentStep = step;

    // Update panels
    panels.forEach(function(panel, i) {
      if (i === currentStep) {
        panel.classList.remove('hidden');
      } else {
        panel.classList.add('hidden');
      }
    });

    // Update nav buttons styling
    navBtns.forEach(function(btn, i) {
      var numSpan = btn.querySelector('.wizard-step-number');
      if (i === currentStep) {
        btn.className = btn.className.replace(/text-gray-\d+/g, '').replace(/hover:text-gray-\d+/g, '').replace(/hover:bg-gray-\d+/g, '').replace(/bg-gray-\d+/g, '');
        btn.classList.add('bg-brand-600', 'text-white', 'shadow-sm');
        btn.classList.remove('text-gray-400', 'hover:text-gray-600', 'hover:bg-gray-50');
        if (numSpan) { numSpan.classList.add('bg-white', 'text-brand-600'); numSpan.classList.remove('bg-gray-200', 'text-gray-500', 'bg-brand-100'); }
      } else if (i < currentStep) {
        btn.classList.remove('bg-brand-600', 'text-white', 'shadow-sm');
        btn.classList.add('text-brand-600', 'bg-brand-50', 'hover:bg-brand-100');
        btn.classList.remove('text-gray-400', 'hover:text-gray-600', 'hover:bg-gray-50');
        if (numSpan) { numSpan.classList.remove('bg-white', 'text-brand-600', 'bg-gray-200', 'text-gray-500'); numSpan.classList.add('bg-brand-100', 'text-brand-600'); }
      } else {
        btn.classList.remove('bg-brand-600', 'text-white', 'shadow-sm', 'text-brand-600', 'bg-brand-50', 'hover:bg-brand-100');
        btn.classList.add('text-gray-400', 'hover:text-gray-600', 'hover:bg-gray-50');
        if (numSpan) { numSpan.classList.remove('bg-white', 'text-brand-600', 'bg-brand-100'); numSpan.classList.add('bg-gray-200', 'text-gray-500'); }
      }
    });

    // Update prev/next/submit buttons
    prevBtn.classList.toggle('hidden', currentStep === 0);
    nextBtn.classList.toggle('hidden', currentStep === totalSteps - 1);
    submitBtn.classList.toggle('hidden', currentStep !== totalSteps - 1);

    // Update progress
    var pct = ((currentStep + 1) / totalSteps * 100).toFixed(1);
    progressBar.style.width = pct + '%';
    progressText.textContent = 'Step ' + (currentStep + 1) + ' of ' + totalSteps;

    // Scroll to top of form
    document.getElementById('wizard-steps-nav').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Nav button clicks
  navBtns.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var targetStep = parseInt(btn.getAttribute('data-wizard-nav'));
      goToStep(targetStep);
    });
  });

  // Prev/Next buttons
  prevBtn.addEventListener('click', function() { goToStep(currentStep - 1); });
  nextBtn.addEventListener('click', function() { goToStep(currentStep + 1); });

  // Clear red ring when user starts typing
  document.getElementById('employee-wizard-form').addEventListener('input', function(e) {
    if (e.target.classList.contains('ring-red-500')) {
      e.target.classList.remove('ring-2', 'ring-red-500', 'border-red-500');
    }
  });

  // Initialize
  goToStep(0);
})();
</script>
