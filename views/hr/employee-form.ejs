<% locals.currentPage = 'hr-employees' %>
<%
  const isEdit = employee !== null && typeof employee !== 'undefined';

  const defaultEmploymentTypes = [
    { val: 'full_time', label: 'Full Time' },
    { val: 'part_time', label: 'Part Time' },
    { val: 'casual', label: 'Casual' },
    { val: 'contractor', label: 'Contractor' },
    { val: 'subcontractor', label: 'Subcontractor' },
  ];

  const employmentTypes = (settingsOptions && settingsOptions.hr_employment_types) || defaultEmploymentTypes;

  const defaultStatuses = [
    { val: 'active', label: 'Active' },
    { val: 'onboarding', label: 'Onboarding' },
    { val: 'on_leave', label: 'On Leave' },
    { val: 'suspended', label: 'Suspended' },
    { val: 'inactive', label: 'Inactive' },
    { val: 'offboarded', label: 'Offboarded' },
  ];

  function val(field) {
    if (!isEdit || !employee[field]) return '';
    return employee[field];
  }

  function checked(field) {
    if (!isEdit) return '';
    return employee[field] ? 'checked' : '';
  }

  function selected(field, value) {
    if (!isEdit) return '';
    return employee[field] === value ? 'selected' : '';
  }
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/hr" class="hover:text-gray-900 transition">HR</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <a href="/hr/employees" class="hover:text-gray-900 transition">Employees</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? employee.first_name + ' ' + employee.last_name : 'New Employee' %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit' : 'Add' %> Employee</h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update employee details and employment information' : 'Add a new employee to the HR system' %></p>
  </div>
</div>

<form method="POST" action="<%= isEdit ? '/hr/employees/' + employee.id : '/hr/employees' %>" class="space-y-5">
  <%- include('../partials/csrf') %>

  <!-- Section 1: Personal Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Personal Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">First Name <span class="text-red-500">*</span></label>
        <input type="text" name="first_name" value="<%= val('first_name') %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Middle Name</label>
        <input type="text" name="middle_name" value="<%= val('middle_name') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Last Name <span class="text-red-500">*</span></label>
        <input type="text" name="last_name" value="<%= val('last_name') %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Preferred Name</label>
        <input type="text" name="preferred_name" value="<%= val('preferred_name') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Phone</label>
        <input type="tel" name="phone" value="<%= val('phone') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Email</label>
        <input type="email" name="email" value="<%= val('email') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <% if (canViewSensitive) { %>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Date of Birth</label>
        <input type="date" name="date_of_birth" value="<%= val('date_of_birth') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <% } %>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Address</label>
        <input type="text" name="address" value="<%= val('address') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Suburb</label>
        <input type="text" name="suburb" value="<%= val('suburb') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">State</label>
        <input type="text" name="state" value="<%= val('state') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. NSW">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Postcode</label>
        <input type="text" name="postcode" value="<%= val('postcode') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. 2000">
      </div>
    </div>
  </div>

  <!-- Section 2: Employment -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Employment</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Employee Code</label>
        <input type="text" name="employee_code" value="<%= val('employee_code') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. EMP-001">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Company</label>
        <input type="text" name="company" value="<%= val('company') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. T&S Traffic Control">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Division</label>
        <input type="text" name="division" value="<%= val('division') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Operations">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Role Title</label>
        <input type="text" name="role_title" value="<%= val('role_title') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Traffic Controller">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Employment Type</label>
        <select name="employment_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select --</option>
          <% employmentTypes.forEach(t => { %>
            <% const typeVal = t.val || t.value || t; const typeLabel = t.label || t; %>
            <option value="<%= typeVal %>" <%= selected('employment_type', typeVal) %>><%= typeLabel %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Employment Status</label>
        <select name="employment_status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% defaultStatuses.forEach(s => { %>
            <option value="<%= s.val %>" <%= selected('employment_status', s.val) %>><%= s.label %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Payment Type</label>
        <select name="payment_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- None --</option>
          <option value="cash" <%= val('payment_type') === 'cash' ? 'selected' : '' %>>Cash</option>
          <option value="tfn" <%= val('payment_type') === 'tfn' ? 'selected' : '' %>>TFN</option>
          <option value="abn" <%= val('payment_type') === 'abn' ? 'selected' : '' %>>ABN</option>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Start Date</label>
        <input type="date" name="start_date" value="<%= val('start_date') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">End Date</label>
        <input type="date" name="end_date" value="<%= val('end_date') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Probation End Date</label>
        <input type="date" name="probation_end_date" value="<%= val('probation_end_date') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Manager</label>
        <select name="manager_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- No Manager --</option>
          <% if (allEmployees) { allEmployees.forEach(e => { %>
            <% if (!isEdit || e.id !== employee.id) { %>
              <option value="<%= e.id %>" <%= isEdit && employee.manager_id == e.id ? 'selected' : '' %>><%= e.first_name %> <%= e.last_name %></option>
            <% } %>
          <% }); } %>
        </select>
      </div>
    </div>
  </div>

  <!-- Section 3: Operational -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Operational</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Traffic Role Level</label>
        <input type="text" name="traffic_role_level" value="<%= val('traffic_role_level') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. TC1, TC2, Supervisor">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Ticket Classification</label>
        <input type="text" name="ticket_classification" value="<%= val('ticket_classification') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Primary Work Region</label>
        <input type="text" name="primary_work_region" value="<%= val('primary_work_region') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Sydney Metro">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Base Location</label>
        <input type="text" name="base_location" value="<%= val('base_location') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Company Vehicle Assigned</label>
        <input type="text" name="company_vehicle_assigned" value="<%= val('company_vehicle_assigned') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Vehicle rego or ID">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Induction Status</label>
        <select name="induction_status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select --</option>
          <option value="not_started" <%= selected('induction_status', 'not_started') %>>Not Started</option>
          <option value="in_progress" <%= selected('induction_status', 'in_progress') %>>In Progress</option>
          <option value="completed" <%= selected('induction_status', 'completed') %>>Completed</option>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">PPE Issued Status</label>
        <select name="ppe_issued_status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select --</option>
          <option value="not_issued" <%= selected('ppe_issued_status', 'not_issued') %>>Not Issued</option>
          <option value="partial" <%= selected('ppe_issued_status', 'partial') %>>Partial</option>
          <option value="fully_issued" <%= selected('ppe_issued_status', 'fully_issued') %>>Fully Issued</option>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Uniform Issued Status</label>
        <select name="uniform_issued_status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select --</option>
          <option value="not_issued" <%= selected('uniform_issued_status', 'not_issued') %>>Not Issued</option>
          <option value="partial" <%= selected('uniform_issued_status', 'partial') %>>Partial</option>
          <option value="fully_issued" <%= selected('uniform_issued_status', 'fully_issued') %>>Fully Issued</option>
        </select>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-4 pt-4 border-t border-gray-100">
      <div class="flex items-center gap-2">
        <input type="checkbox" name="allocatable" id="allocatable" value="1" <%= checked('allocatable') %>
          class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <label for="allocatable" class="text-sm text-gray-700">Allocatable to Jobs</label>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="blocked_from_allocation" id="blocked_from_allocation" value="1" <%= checked('blocked_from_allocation') %>
          class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <label for="blocked_from_allocation" class="text-sm text-gray-700">Blocked from Allocation</label>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="white_card_required" id="white_card_required" value="1" <%= checked('white_card_required') %>
          class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <label for="white_card_required" class="text-sm text-gray-700">White Card Required</label>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" name="medical_required" id="medical_required" value="1" <%= checked('medical_required') %>
          class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <label for="medical_required" class="text-sm text-gray-700">Medical Required</label>
      </div>
    </div>
    <div class="mt-4">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Block Reason</label>
      <input type="text" name="block_reason" value="<%= val('block_reason') %>"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        placeholder="Reason for blocking from allocation (if applicable)">
    </div>
  </div>

  <!-- Section 4: Licences & Cards -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Licences & Cards</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">White Card Number</label>
        <input type="text" name="white_card_number" value="<%= val('white_card_number') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. WC-12345678">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">TC Licence Number</label>
        <input type="text" name="tc_licence_number" value="<%= val('tc_licence_number') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. TC-123456">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">TC Licence State</label>
        <select name="tc_licence_state"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select...</option>
          <% ['NSW','VIC','QLD','SA','WA','TAS','NT','ACT'].forEach(s => { %>
            <option value="<%= s %>" <%= val('tc_licence_state') === s ? 'selected' : '' %>><%= s %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">TC Date of Issue</label>
        <input type="date" name="tc_licence_date_of_issue" value="<%= val('tc_licence_date_of_issue') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Driver's Licence Number</label>
        <input type="text" name="drivers_licence_number" value="<%= val('drivers_licence_number') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. 12345678">
      </div>
    </div>
  </div>

  <!-- Section 5: Emergency Contact -->
  <% if (canViewSensitive) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Emergency Contact</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Contact Name</label>
        <input type="text" name="emergency_contact_name" value="<%= val('emergency_contact_name') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Contact Phone</label>
        <input type="tel" name="emergency_contact_phone" value="<%= val('emergency_contact_phone') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Relationship</label>
        <input type="text" name="emergency_contact_relationship" value="<%= val('emergency_contact_relationship') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Spouse, Parent, Sibling">
      </div>
    </div>
  </div>
  <% } %>

  <!-- Section 5: Notes & Links -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Notes & Links</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Internal Notes</label>
        <textarea name="internal_notes" rows="4"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Private notes about this employee..."><%= val('internal_notes') %></textarea>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Linked Crew Member</label>
          <select name="linked_crew_member_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            <option value="">-- None --</option>
            <% if (crewMembers) { crewMembers.forEach(cm => { %>
              <option value="<%= cm.id %>" <%= isEdit && employee.linked_crew_member_id == cm.id ? 'selected' : '' %>><%= cm.full_name %> (<%= cm.employee_id || 'No ID' %>)</option>
            <% }); } %>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Linked User Account</label>
          <select name="linked_user_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            <option value="">-- None --</option>
            <% if (users) { users.forEach(u => { %>
              <option value="<%= u.id %>" <%= isEdit && employee.linked_user_id == u.id ? 'selected' : '' %>><%= u.full_name %> (<%= u.username %>)</option>
            <% }); } %>
          </select>
        </div>
        <% if (canViewSensitive) { %>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Payroll Reference</label>
          <input type="text" name="payroll_reference" value="<%= val('payroll_reference') %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
            placeholder="External payroll system ID">
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (typeof showRates !== 'undefined' && showRates) { %>
  <!-- Pay Rates (Admin / Finance only) -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
    <h3 class="text-sm font-bold text-gray-900 mb-1">Pay Rates</h3>
    <p class="text-xs text-gray-400 mb-4">Only visible to Admin and Finance roles. Rates are per hour ($).</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Day Rate</label>
        <input type="number" step="0.01" min="0" name="rate_day" value="<%= val('rate_day') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">OT Rate</label>
        <input type="number" step="0.01" min="0" name="rate_ot" value="<%= val('rate_ot') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">DT Rate</label>
        <input type="number" step="0.01" min="0" name="rate_dt" value="<%= val('rate_dt') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night Rate</label>
        <input type="number" step="0.01" min="0" name="rate_night" value="<%= val('rate_night') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night OT</label>
        <input type="number" step="0.01" min="0" name="rate_night_ot" value="<%= val('rate_night_ot') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Night DT</label>
        <input type="number" step="0.01" min="0" name="rate_night_dt" value="<%= val('rate_night_dt') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Travel</label>
        <input type="number" step="0.01" min="0" name="rate_travel" value="<%= val('rate_travel') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Meal</label>
        <input type="number" step="0.01" min="0" name="rate_meal" value="<%= val('rate_meal') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Weekend</label>
        <input type="number" step="0.01" min="0" name="rate_weekend" value="<%= val('rate_weekend') || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>
  <% } %>

  <!-- Submit -->
  <div class="flex items-center gap-3">
    <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <%= isEdit ? 'Update' : 'Add' %> Employee
    </button>
    <a href="<%= isEdit ? '/hr/employees/' + employee.id : '/hr/employees' %>" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</a>
  </div>

</form>
