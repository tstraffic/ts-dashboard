<% locals.currentPage = 'hr-reports' %>
<%
  function formatDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function formatType(type) {
    if (!type) return '-';
    return type.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }

  // Group headcount by company for summary
  const companySummary = {};
  headcountByCompany.forEach(row => {
    if (!companySummary[row.company]) companySummary[row.company] = { total: 0, types: {} };
    companySummary[row.company].total += row.count;
    companySummary[row.company].types[row.employment_type] = row.count;
  });
%>

<div class="space-y-5">

  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">HR Reports</h1>
    <p class="text-sm text-gray-500 mt-1">Workforce analytics, compliance, and staffing insights</p>
  </div>

  <!-- Top-level Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total Active</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= employmentTypes.reduce((sum, t) => sum + t.count, 0) %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <p class="text-[10px] font-bold text-amber-400 uppercase tracking-widest">Expiring (30d)</p>
      <p class="text-2xl font-bold text-amber-600 mt-1"><%= expiringCompetencies.length %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Missing Docs</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= missingDocs.length %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Blocked</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= blockedWorkers.length %></p>
    </div>
  </div>

  <!-- Visual Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

    <!-- Headcount by Status Bar Chart -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Headcount by Status</h2>
      <% if (typeof headcountByStatus !== 'undefined' && headcountByStatus && headcountByStatus.length > 0) { %>
      <%
        const maxStatusCount = headcountByStatus.reduce(function(max, s) { return Math.max(max, s.count); }, 1);
        const statusBarColors = {
          active: 'bg-emerald-500',
          onboarding: 'bg-purple-500',
          on_leave: 'bg-blue-500',
          suspended: 'bg-red-500',
          inactive: 'bg-gray-400',
          offboarded: 'bg-gray-300',
          probation: 'bg-amber-500'
        };
      %>
      <div class="space-y-2.5">
        <% headcountByStatus.forEach(function(s) {
          const barPct = maxStatusCount > 0 ? Math.round((s.count / maxStatusCount) * 100) : 0;
          const barColor = statusBarColors[s.employment_status] || 'bg-gray-400';
        %>
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs font-medium text-gray-600"><%= formatType(s.employment_status) %></span>
            <span class="text-xs font-bold text-gray-900 tabular-nums"><%= s.count %></span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2.5">
            <div class="h-2.5 rounded-full transition-all duration-500 <%= barColor %>" style="width: <%= Math.max(barPct, 3) %>%"></div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="text-sm text-gray-400 text-center py-4">No status data available</p>
      <% } %>
    </div>

    <!-- Licence Expiry Timeline (90 days) -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Licence Expiry Timeline</h2>
      <p class="text-[10px] text-gray-400 mb-3">Next 90 days</p>
      <% if (typeof expiringCompetencies90 !== 'undefined' && expiringCompetencies90 && expiringCompetencies90.length > 0) { %>
      <div class="relative">
        <!-- Timeline bar -->
        <div class="absolute left-3 top-0 bottom-0 w-0.5 bg-gray-200"></div>
        <div class="space-y-3 max-h-[240px] overflow-y-auto">
          <% expiringCompetencies90.slice(0, 12).forEach(function(comp) {
            const daysLeft = comp.days_left != null ? comp.days_left : Math.ceil((new Date(comp.expiry_date) - new Date()) / (1000*60*60*24));
            let dotColor = 'bg-amber-500';
            if (daysLeft <= 7) dotColor = 'bg-red-500';
            else if (daysLeft <= 30) dotColor = 'bg-orange-500';
            else dotColor = 'bg-yellow-400';
          %>
          <div class="flex items-start gap-3 relative pl-7">
            <div class="absolute left-1.5 top-1.5 w-3 h-3 rounded-full border-2 border-white <%= dotColor %> shadow-sm"></div>
            <div class="min-w-0 flex-1">
              <p class="text-xs font-medium text-gray-900 truncate"><%= comp.full_name %></p>
              <p class="text-[10px] text-gray-500 truncate"><%= formatType(comp.competency_type) %></p>
            </div>
            <span class="text-[10px] font-bold shrink-0 tabular-nums <%= daysLeft <= 7 ? 'text-red-600' : daysLeft <= 30 ? 'text-orange-600' : 'text-amber-600' %>"><%= daysLeft %>d</span>
          </div>
          <% }) %>
        </div>
        <% if (expiringCompetencies90.length > 12) { %>
        <p class="text-[10px] text-gray-400 mt-2 pl-7">+ <%= expiringCompetencies90.length - 12 %> more</p>
        <% } %>
      </div>
      <% } else { %>
      <div class="text-center py-6">
        <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-2">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="text-xs text-gray-500">No licences expiring in 90 days</p>
      </div>
      <% } %>
    </div>

    <!-- Compliance Rate Ring Chart -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Compliance Rate</h2>
      <%
        const rate = typeof complianceRate !== 'undefined' ? complianceRate : 100;
        const ringColor = rate >= 90 ? '#10b981' : rate >= 70 ? '#f59e0b' : '#ef4444';
        const circumference = 2 * Math.PI * 54;
        const dashOffset = circumference - (rate / 100) * circumference;
      %>
      <div class="flex flex-col items-center">
        <div class="relative" style="width: 130px; height: 130px;">
          <svg viewBox="0 0 120 120" class="w-full h-full transform -rotate-90">
            <!-- Background ring -->
            <circle cx="60" cy="60" r="54" fill="none" stroke="#f3f4f6" stroke-width="10"/>
            <!-- Progress ring -->
            <circle cx="60" cy="60" r="54" fill="none" stroke="<%= ringColor %>" stroke-width="10"
              stroke-linecap="round"
              stroke-dasharray="<%= circumference %>"
              stroke-dashoffset="<%= dashOffset %>"
              style="transition: stroke-dashoffset 1s ease-in-out;"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-2xl font-bold" style="color: <%= ringColor %>"><%= rate %>%</span>
            <span class="text-[9px] text-gray-400 uppercase font-medium">Compliant</span>
          </div>
        </div>
        <div class="flex items-center gap-4 mt-3 text-[10px] text-gray-500">
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span> Compliant (<%= (typeof totalActive !== 'undefined' ? totalActive : 0) - (typeof blockedCount !== 'undefined' ? blockedCount : 0) %>)</span>
          <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-500 inline-block"></span> Blocked (<%= typeof blockedCount !== 'undefined' ? blockedCount : 0 %>)</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Employment Type Breakdown -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Employment Type Breakdown</h2>
    </div>
    <div class="p-4">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        <% employmentTypes.forEach(t => { %>
        <div class="text-center p-3 bg-gray-50 rounded-lg">
          <p class="text-2xl font-bold text-gray-900"><%= t.count %></p>
          <p class="text-xs text-gray-500 mt-1"><%= formatType(t.employment_type) %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Headcount by Company -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Headcount by Company</h2>
    </div>
    <% if (Object.keys(companySummary).length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Total</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Full Time</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Part Time</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Casual</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Contractor</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Subcontractor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% Object.keys(companySummary).forEach(company => { const data = companySummary[company]; %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= company %></td>
            <td class="px-4 py-3 text-sm font-bold text-gray-900"><%= data.total %></td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= data.types.full_time || 0 %></td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= data.types.part_time || 0 %></td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden md:table-cell"><%= data.types.casual || 0 %></td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden md:table-cell"><%= data.types.contractor || 0 %></td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden lg:table-cell"><%= data.types.subcontractor || 0 %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="p-6 text-center text-sm text-gray-400">No company data available.</div>
    <% } %>
  </div>

  <!-- Headcount by Division -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Headcount by Division</h2>
    </div>
    <% if (headcountByDivision.length > 0) { %>
    <div class="p-4">
      <div class="space-y-2">
        <% const maxDivCount = Math.max(...headcountByDivision.map(d => d.count), 1); %>
        <% headcountByDivision.forEach(d => { %>
        <div class="flex items-center gap-3">
          <span class="text-sm text-gray-700 w-32 shrink-0 truncate"><%= d.division %></span>
          <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
            <div class="bg-brand-500 h-full rounded-full flex items-center justify-end pr-2 transition-all" style="width: <%= Math.max((d.count / maxDivCount) * 100, 8) %>%">
              <span class="text-[10px] text-white font-bold"><%= d.count %></span>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } else { %>
    <div class="p-6 text-center text-sm text-gray-400">No division data available.</div>
    <% } %>
  </div>

  <!-- Expiring Competencies -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Expiring Competencies (Next 30 Days)</h2>
      <a href="/hr/competencies?view=30days" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View All</a>
    </div>
    <% if (expiringCompetencies.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Competency</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Expiry Date</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Days Left</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% expiringCompetencies.forEach(comp => {
            const daysLeft = Math.ceil((new Date(comp.expiry_date) - new Date()) / (1000*60*60*24));
            const urgent = daysLeft <= 7;
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <a href="/hr/employees/<%= comp.employee_id %>" class="text-brand-600 hover:text-brand-700 font-medium text-sm"><%= comp.full_name %></a>
              <% if (comp.employee_code) { %><div class="text-[10px] text-gray-400 mt-0.5"><%= comp.employee_code %></div><% } %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-700"><%= formatType(comp.competency_type) %><% if (comp.competency_name) { %> &mdash; <%= comp.competency_name %><% } %></td>
            <td class="px-4 py-3 text-sm <%= urgent ? 'text-red-600 font-semibold' : 'text-amber-600' %>"><%= formatDate(comp.expiry_date) %></td>
            <td class="px-4 py-3 hidden sm:table-cell">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= urgent ? 'bg-red-50 text-red-700 ring-1 ring-red-600/20' : 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' %>"><%= daysLeft %> day<%= daysLeft !== 1 ? 's' : '' %></span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="p-6 text-center text-sm text-gray-400">No competencies expiring in the next 30 days.</div>
    <% } %>
  </div>

  <!-- Missing Mandatory Documents -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Missing Mandatory Documents</h2>
      <a href="/hr/documents?mandatory=1&verification_status=pending" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View All</a>
    </div>
    <% if (missingDocs.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Company</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Unverified Count</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% missingDocs.forEach(emp => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <a href="/hr/employees/<%= emp.id %>#documents" class="text-brand-600 hover:text-brand-700 font-medium text-sm"><%= emp.full_name %></a>
              <% if (emp.employee_code) { %><div class="text-[10px] text-gray-400 mt-0.5"><%= emp.employee_code %></div><% } %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= emp.company || '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20"><%= emp.unverified_count %> unverified</span>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="p-6 text-center text-sm text-emerald-500">All mandatory documents are verified.</div>
    <% } %>
  </div>

  <!-- Blocked Workers -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Blocked Workers</h2>
    </div>
    <% if (blockedWorkers.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Employee</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden sm:table-cell">Company</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Reason</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% blockedWorkers.forEach(emp => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <a href="/hr/employees/<%= emp.id %>" class="text-brand-600 hover:text-brand-700 font-medium text-sm"><%= emp.full_name %></a>
              <% if (emp.employee_code) { %><div class="text-[10px] text-gray-400 mt-0.5"><%= emp.employee_code %></div><% } %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600 hidden sm:table-cell"><%= emp.company || '-' %></td>
            <td class="px-4 py-3 text-sm text-red-600"><%= emp.block_reason || 'No reason specified' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="p-6 text-center text-sm text-emerald-500">No workers are currently blocked.</div>
    <% } %>
  </div>

</div>
