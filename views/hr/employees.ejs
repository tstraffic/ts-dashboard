<% locals.currentPage = 'hr-employees' %>
<%
  function formatDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  const statusBadge = {
    active:     'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    onboarding: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    on_leave:   'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    suspended:  'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    inactive:   'bg-gray-100 text-gray-500',
    offboarded: 'bg-gray-100 text-gray-500',
  };

  const readinessBadge = {
    ready:                'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    ready_with_warnings:  'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    non_compliant:        'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    blocked:              'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    onboarding:           'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    on_leave:             'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
  };

  const readinessLabel = {
    ready:                'Ready',
    ready_with_warnings:  'Warnings',
    non_compliant:        'Non-Compliant',
    blocked:              'Blocked',
    onboarding:           'Onboarding',
    on_leave:             'On Leave',
  };
%>

<div class="space-y-5">

  <!-- Page Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Employees</h1>
      <p class="text-sm text-gray-500 mt-1">Manage employee records, compliance and workforce readiness</p>
    </div>
    <a href="/hr/employees/new" class="inline-flex items-center justify-center px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Employee
    </a>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Active Employees</p>
      <p class="text-2xl font-bold text-emerald-600 mt-1"><%= stats.totalActive %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-purple-400 uppercase tracking-widest">Onboarding</p>
      <p class="text-2xl font-bold text-purple-600 mt-1"><%= stats.totalOnboarding %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Blocked</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= stats.totalBlocked %></p>
    </div>
  </div>

  <!-- Payment Type Tabs -->
  <div class="flex gap-2 overflow-x-auto pb-1">
    <a href="/hr/employees" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all <%= !filters.payment_type ? 'bg-brand-600 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
      All <span class="text-xs font-bold opacity-70"><%= stats.totalActive %></span>
    </a>
    <a href="/hr/employees?payment_type=cash" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all <%= filters.payment_type === 'cash' ? 'bg-emerald-600 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
      Cash <span class="text-xs font-bold opacity-70"><%= stats.totalCash %></span>
    </a>
    <a href="/hr/employees?payment_type=tfn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all <%= filters.payment_type === 'tfn' ? 'bg-blue-600 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
      TFN <span class="text-xs font-bold opacity-70"><%= stats.totalTfn %></span>
    </a>
    <a href="/hr/employees?payment_type=abn" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition-all <%= filters.payment_type === 'abn' ? 'bg-purple-600 text-white shadow-sm' : 'bg-white border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
      ABN <span class="text-xs font-bold opacity-70"><%= stats.totalAbn %></span>
    </a>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <form method="GET" action="/hr/employees" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3">
      <% if (filters.payment_type) { %><input type="hidden" name="payment_type" value="<%= filters.payment_type %>"><% } %>
      <select name="company" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Companies</option>
        <% if (filterOptions && filterOptions.companies) { filterOptions.companies.forEach(c => { %>
          <option value="<%= c %>" <%= filters.company === c ? 'selected' : '' %>><%= c %></option>
        <% }); } %>
      </select>
      <select name="division" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Divisions</option>
        <% if (filterOptions && filterOptions.divisions) { filterOptions.divisions.forEach(d => { %>
          <option value="<%= d %>" <%= filters.division === d ? 'selected' : '' %>><%= d %></option>
        <% }); } %>
      </select>
      <select name="employment_type" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Types</option>
        <option value="full_time" <%= filters.employment_type === 'full_time' ? 'selected' : '' %>>Full Time</option>
        <option value="part_time" <%= filters.employment_type === 'part_time' ? 'selected' : '' %>>Part Time</option>
        <option value="casual" <%= filters.employment_type === 'casual' ? 'selected' : '' %>>Casual</option>
        <option value="contractor" <%= filters.employment_type === 'contractor' ? 'selected' : '' %>>Contractor</option>
        <option value="subcontractor" <%= filters.employment_type === 'subcontractor' ? 'selected' : '' %>>Subcontractor</option>
      </select>
      <select name="status" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Statuses</option>
        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="onboarding" <%= filters.status === 'onboarding' ? 'selected' : '' %>>Onboarding</option>
        <option value="on_leave" <%= filters.status === 'on_leave' ? 'selected' : '' %>>On Leave</option>
        <option value="suspended" <%= filters.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
        <option value="offboarded" <%= filters.status === 'offboarded' ? 'selected' : '' %>>Offboarded</option>
      </select>
      <div class="flex-1 min-w-0 sm:min-w-[200px]">
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search name, code, role..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg border border-gray-300 transition">Search</button>
    </form>
  </div>

  <!-- Employees Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (employees && employees.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Code</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Full Name</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Company</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Division</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Role</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Type</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Readiness</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Manager</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Start Date</th>
            <th class="px-3 sm:px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Next Expiry</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% employees.forEach(emp => { %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-3 sm:px-4 py-3 text-gray-500 font-mono text-xs"><%= emp.employee_code || '-' %></td>
            <td class="px-3 sm:px-4 py-3">
              <a href="/hr/employees/<%= emp.id %>" class="text-brand-600 hover:text-brand-700 font-medium text-sm"><%= emp.first_name %><% if (emp.middle_name) { %> <%= emp.middle_name %><% } %> <%= emp.last_name %></a>
              <div class="flex items-center gap-1.5 mt-0.5">
                <% if (emp.payment_type) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold uppercase
                    <%= emp.payment_type === 'cash' ? 'bg-emerald-50 text-emerald-600' : emp.payment_type === 'tfn' ? 'bg-blue-50 text-blue-600' : emp.payment_type === 'abn' ? 'bg-purple-50 text-purple-600' : 'bg-gray-50 text-gray-500' %>"><%= emp.payment_type %></span>
                <% } %>
                <span class="sm:hidden text-[10px] text-gray-400"><%= emp.company || '' %><% if (emp.role_title) { %> &middot; <%= emp.role_title %><% } %></span>
              </div>
            </td>
            <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs hidden sm:table-cell"><%= emp.company || '-' %></td>
            <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs hidden md:table-cell"><%= emp.division || '-' %></td>
            <td class="px-3 sm:px-4 py-3 text-gray-600 text-xs hidden md:table-cell"><%= emp.role_title || '-' %></td>
            <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs hidden lg:table-cell"><%= emp.employment_type ? emp.employment_type.replace(/_/g, ' ') : '-' %></td>
            <td class="px-3 sm:px-4 py-3">
              <% const sBadge = statusBadge[emp.employment_status] || statusBadge.inactive; %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= sBadge %>">
                <%= (emp.employment_status || 'unknown').replace(/_/g, ' ') %>
              </span>
            </td>
            <td class="px-3 sm:px-4 py-3">
              <% if (emp.readiness) { %>
                <% const rBadge = readinessBadge[emp.readiness.status] || 'bg-gray-100 text-gray-500'; %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= rBadge %>">
                  <%= readinessLabel[emp.readiness.status] || emp.readiness.status %>
                </span>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
            <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs hidden lg:table-cell"><%= emp.manager_name || '-' %></td>
            <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs tabular-nums hidden xl:table-cell"><%= formatDate(emp.start_date) %></td>
            <td class="px-3 sm:px-4 py-3 hidden xl:table-cell">
              <% if (emp.next_expiry) { %>
                <span class="text-xs text-amber-600"><%= formatDate(emp.next_expiry) %></span>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div class="px-4 py-3 border-t border-gray-200 text-xs text-gray-500">
      Showing <%= employees.length %> employee<%= employees.length !== 1 ? 's' : '' %>
    </div>
    <% } else { %>
    <div class="p-6 text-center">
      <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No employees found</h3>
      <p class="text-gray-500 text-sm mb-1">No employees match the current filters.</p>
      <p class="text-gray-400 text-xs mb-4">Try adjusting your search criteria or add a new employee.</p>
      <a href="/hr/employees/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Employee
      </a>
    </div>
    <% } %>
  </div>

</div>
