<% locals.currentPage = 'dockets-admin' %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-5">
  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Signed Dockets</h1>
      <p class="text-sm text-gray-500 mt-0.5">Worker-signed dockets coming off the field.</p>
    </div>
    <div class="text-xs text-gray-500"><%= counts.total || 0 %> in last 30 days · <%= counts.no_client || 0 %> with no client on site</div>
  </div>

  <form method="GET" action="/dockets" class="flex flex-wrap items-end gap-2">
    <div class="flex-1 min-w-[200px]">
      <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Search</label>
      <input type="text" name="q" value="<%= search %>" placeholder="Worker, job number, client, client rep…"
        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
    </div>
    <div>
      <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Type</label>
      <select name="docket_type" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        <option value="">All</option>
        <option value="daily_docket"  <%= docketType === 'daily_docket'  ? 'selected' : '' %>>Daily docket</option>
        <option value="completion"    <%= docketType === 'completion'    ? 'selected' : '' %>>Completion</option>
        <option value="delivery"      <%= docketType === 'delivery'      ? 'selected' : '' %>>Delivery</option>
      </select>
    </div>
    <div>
      <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Signed since</label>
      <input type="date" name="since" value="<%= since %>"
        class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
    </div>
    <label class="inline-flex items-center gap-1.5 text-sm text-gray-700 mb-1.5">
      <input type="checkbox" name="no_client" value="1" <%= noClient ? 'checked' : '' %> class="h-4 w-4 rounded border-gray-300 text-brand-600">
      No client on site
    </label>
    <button type="submit" class="px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700">Apply</button>
    <% if (search || since || docketType || noClient) { %><a href="/dockets" class="text-sm text-gray-500 hover:text-gray-700 ml-1">Clear</a><% } %>
  </form>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (rows.length === 0) { %>
      <div class="px-5 py-12 text-center text-sm text-gray-500">No dockets match these filters.</div>
    <% } else { %>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs font-semibold text-gray-500 uppercase tracking-wide">
          <tr>
            <th class="text-left px-5 py-2.5">Signed</th>
            <th class="text-left px-3 py-2.5">Worker</th>
            <th class="text-left px-3 py-2.5 hidden md:table-cell">Job</th>
            <th class="text-left px-3 py-2.5 hidden sm:table-cell">Client rep</th>
            <th class="text-right px-3 py-2.5 hidden sm:table-cell">Hours</th>
            <th class="text-center px-3 py-2.5 hidden sm:table-cell">Sigs</th>
            <th class="text-right px-5 py-2.5"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% rows.forEach(function (r) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-2.5 text-gray-600 whitespace-nowrap"><%= new Date(r.signed_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></td>
              <td class="px-3 py-2.5 font-medium text-gray-900"><%= r.crew_name || '#' + r.crew_member_id %></td>
              <td class="px-3 py-2.5 text-gray-700 hidden md:table-cell">
                <% if (r.job_number) { %>
                  <a href="/jobs/<%= r.job_id %>" class="font-medium text-brand-700 hover:underline"><%= r.job_number %></a>
                  <% if (r.job_client) { %><span class="text-gray-500">— <%= r.job_client %></span><% } %>
                <% } else { %><span class="text-gray-400">—</span><% } %>
              </td>
              <td class="px-3 py-2.5 hidden sm:table-cell">
                <% if (r.no_client_on_site) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[11px] font-semibold bg-amber-50 text-amber-700 ring-1 ring-amber-600/10">No client on site</span>
                <% } else { %><span class="text-gray-700"><%= r.client_name || '—' %></span><% } %>
              </td>
              <td class="px-3 py-2.5 text-right text-gray-700 hidden sm:table-cell tabular-nums"><%= r.total_hours ? r.total_hours.toFixed ? r.total_hours.toFixed(2) : r.total_hours : '—' %></td>
              <td class="px-3 py-2.5 text-center hidden sm:table-cell">
                <span class="inline-flex items-center gap-0.5 text-[11px]">
                  <span class="<%= r.has_worker_sig ? 'text-emerald-600' : 'text-gray-300' %>" title="Worker signature">W</span>
                  <span class="<%= r.has_client_sig ? 'text-emerald-600' : (r.no_client_on_site ? 'text-amber-500' : 'text-gray-300') %>" title="Client signature">·C</span>
                </span>
              </td>
              <td class="px-5 py-2.5 text-right">
                <a href="/dockets/<%= r.id %>" class="text-sm text-brand-700 font-semibold hover:underline">Open</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
