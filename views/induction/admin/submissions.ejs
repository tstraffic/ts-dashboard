<% locals.currentPage = 'induction' %>

<%
  const STATUS_BADGES = {
    submitted: { label: 'Pending', color: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' },
    approved:  { label: 'Approved', color: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' },
    rejected:  { label: 'Rejected', color: 'bg-red-50 text-red-700 ring-1 ring-red-600/20' },
    converted: { label: 'Employee', color: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' },
  };

  const PAYMENT_BADGES = {
    tfn:  { label: 'TFN',  color: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' },
    abn:  { label: 'ABN',  color: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' },
    cash: { label: 'Cash', color: 'bg-gray-100 text-gray-600' },
  };

  function timeAgo(dateStr) {
    if (!dateStr) return '-';
    const now = new Date();
    const then = new Date(dateStr);
    const diffMs = now - then;
    const diffMins = Math.floor(diffMs / 60000);
    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return diffMins + 'm ago';
    const diffHrs = Math.floor(diffMins / 60);
    if (diffHrs < 24) return diffHrs + 'h ago';
    const diffDays = Math.floor(diffHrs / 24);
    if (diffDays === 1) return '1 day ago';
    if (diffDays < 30) return diffDays + ' days ago';
    return then.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function docCount(s) {
    let filled = 0;
    let total = 3;
    if (s.white_card_number) filled++;
    if (s.tc_licence_number) filled++;
    if (s.has_injuries !== null && s.has_injuries !== undefined) filled++;
    return { filled, total };
  }
%>

<div class="space-y-5">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Induction</h1>
      <p class="text-sm text-gray-500 mt-1">Manage soft induction submissions</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <button onclick="copyLink('')" class="inline-flex items-center gap-1.5 px-3 py-2 bg-brand-50 hover:bg-brand-100 text-brand-700 text-xs font-semibold rounded-lg border border-brand-200 transition" title="Copy induction link (TFN/ABN)">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
        Copy Induction Link
      </button>
      <button onclick="copyLink('cash')" class="inline-flex items-center gap-1.5 px-3 py-2 bg-gray-50 hover:bg-gray-100 text-gray-700 text-xs font-semibold rounded-lg border border-gray-200 transition" title="Copy cash induction link">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
        Copy Cash Link
      </button>
    </div>
  </div>

  <!-- Status Tabs (also show the count — clicking switches the filter) -->
  <%
    function tabUrl(statusVal) {
      const p = [];
      if (statusVal) p.push('status=' + encodeURIComponent(statusVal));
      if (filters.payment_type) p.push('payment_type=' + encodeURIComponent(filters.payment_type));
      if (filters.search) p.push('search=' + encodeURIComponent(filters.search));
      if (filters.date_from) p.push('date_from=' + encodeURIComponent(filters.date_from));
      if (filters.date_to) p.push('date_to=' + encodeURIComponent(filters.date_to));
      return '/induction/admin/submissions' + (p.length ? '?' + p.join('&') : '');
    }
    const activeStatus = filters.status || '';
    const tabs = [
      { key: '',          label: 'All',      count: stats.total,     dot: 'bg-gray-400',   active: 'bg-white text-gray-900 ring-1 ring-gray-300 shadow-sm' },
      { key: 'submitted', label: 'Pending',  count: stats.submitted, dot: 'bg-amber-500',  active: 'bg-amber-50 text-amber-800 ring-1 ring-amber-300 shadow-sm' },
      { key: 'approved',  label: 'Approved', count: stats.approved,  dot: 'bg-emerald-500', active: 'bg-emerald-50 text-emerald-800 ring-1 ring-emerald-300 shadow-sm' },
      { key: 'rejected',  label: 'Rejected', count: stats.rejected,  dot: 'bg-red-500',    active: 'bg-red-50 text-red-800 ring-1 ring-red-300 shadow-sm' },
    ];
  %>
  <div class="flex flex-wrap items-center gap-2">
    <% tabs.forEach(function (t) { const isOn = activeStatus === t.key; %>
      <a href="<%= tabUrl(t.key) %>" class="inline-flex items-center gap-2 px-3.5 py-2 rounded-xl text-sm font-semibold transition <%= isOn ? t.active : 'bg-gray-50 text-gray-600 hover:bg-gray-100 border border-gray-200' %>">
        <span class="w-2 h-2 rounded-full <%= t.dot %>"></span>
        <%= t.label %>
        <span class="inline-flex items-center justify-center px-1.5 min-w-[1.5rem] h-5 rounded-full text-[11px] font-bold <%= isOn ? 'bg-white/70 text-gray-900' : 'bg-gray-200 text-gray-600' %>"><%= t.count %></span>
      </a>
    <% }) %></div>

  <!-- Filter Bar -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <form method="GET" action="/induction/admin/submissions" id="filterForm" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3">
      <%- include('../../partials/csrf') %>

      <!-- Search -->
      <div class="flex-1 min-w-0 sm:min-w-[200px]">
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search name or email..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>

      <!-- Keep status in sync with the active tab so the form reloads into the same view -->
      <input type="hidden" name="status" value="<%= filters.status || '' %>">

      <!-- Payment Type -->
      <select name="payment_type" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Types</option>
        <option value="cash" <%= filters.payment_type === 'cash' ? 'selected' : '' %>>Cash</option>
        <option value="tfn" <%= filters.payment_type === 'tfn' ? 'selected' : '' %>>TFN</option>
        <option value="abn" <%= filters.payment_type === 'abn' ? 'selected' : '' %>>ABN</option>
      </select>

      <!-- Date From -->
      <input type="date" name="date_from" value="<%= filters.date_from || '' %>"
        class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
        title="From date">

      <!-- Date To -->
      <input type="date" name="date_to" value="<%= filters.date_to || '' %>"
        class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
        title="To date">

      <!-- Filter Button -->
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Filter</button>

      <!-- Reset -->
      <% if (filters.search || filters.status || filters.payment_type || filters.date_from || filters.date_to) { %>
        <a href="/induction/admin/submissions" class="text-sm text-gray-400 hover:text-gray-600 transition">Reset</a>
      <% } %>
    </form>
  </div>

  <!-- Results Table -->
  <form id="deleteForm" method="POST" action="/induction/admin/submissions/delete">
    <%- include('../../partials/csrf') %>

    <!-- Bulk Actions Bar (hidden until checkboxes selected) -->
    <div id="bulkBar" class="hidden bg-red-50 border border-red-200 rounded-xl shadow-sm px-4 py-3 mb-3 flex items-center justify-between">
      <span class="text-sm text-red-700 font-medium">
        <span id="selectedCount">0</span> selected
      </span>
      <button type="button" onclick="confirmDelete()" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-semibold rounded-lg transition">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete Selected
      </button>
    </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (submissions.length === 0) { %>
      <div class="p-6 text-center">
        <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-1">No submissions found</h3>
        <p class="text-gray-500 text-sm mb-1">Induction submissions will appear here once workers complete the online form.</p>
        <p class="text-gray-400 text-xs">Share the induction links using the buttons above.</p>
      </div>
    <% } else { %>

      <!-- Desktop Table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-3 py-3 w-10">
                <input type="checkbox" id="selectAll" onchange="toggleAll(this)" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500 cursor-pointer">
              </th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Name</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Phone</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Payment</th>
              <th class="px-4 py-3 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">Can Drive?</th>
              <th class="px-4 py-3 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">Documents</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Submitted</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% submissions.forEach(function(s) {
              const sb = STATUS_BADGES[s.status] || { label: s.status, color: 'bg-gray-100 text-gray-600' };
              const pb = PAYMENT_BADGES[s.payment_type] || { label: s.payment_type, color: 'bg-gray-100 text-gray-600' };
              const docs = docCount(s);
            %>
              <tr class="hover:bg-gray-50 transition-colors">
                <!-- Checkbox -->
                <td class="px-3 py-3">
                  <input type="checkbox" name="ids" value="<%= s.id %>" onchange="updateBulkBar()" class="row-check rounded border-gray-300 text-brand-600 focus:ring-brand-500 cursor-pointer">
                </td>
                <!-- Name -->
                <td class="px-4 py-3">
                  <span class="font-medium text-gray-900"><%= s.full_name %></span>
                  <div class="text-xs text-gray-400 mt-0.5"><%= s.email %></div>
                </td>

                <!-- Phone -->
                <td class="px-4 py-3 text-gray-600 whitespace-nowrap"><%= s.phone || '-' %></td>

                <!-- Payment Type -->
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full <%= pb.color %>"><%= pb.label %></span>
                </td>

                <!-- Can Drive -->
                <td class="px-4 py-3 text-center">
                  <% if (s.can_drive === 'yes') { %>
                    <span class="inline-flex items-center text-emerald-600" title="Can drive<%= s.can_drive_truck === 'yes' ? ' (incl. truck)' : '' %>">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center text-red-400">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </span>
                  <% } %>
                </td>

                <!-- Documents -->
                <td class="px-4 py-3 text-center">
                  <span class="text-xs font-medium <%= docs.filled === docs.total ? 'text-emerald-600' : 'text-amber-600' %>"><%= docs.filled %>/<%= docs.total %></span>
                </td>

                <!-- Status -->
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full <%= sb.color %>"><%= sb.label %></span>
                </td>

                <!-- Submitted -->
                <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap" title="<%= s.submitted_at ? new Date(s.submitted_at).toLocaleString('en-AU') : '' %>">
                  <%= timeAgo(s.submitted_at) %>
                </td>

                <!-- Actions -->
                <td class="px-4 py-3 text-right">
                  <div class="inline-flex items-center gap-1 justify-end">
                    <% if (s.status === 'submitted') { %>
                      <form method="POST" action="/induction/admin/submissions/<%= s.id %>/status" class="inline" onclick="event.stopPropagation()">
                        <%- include('../../partials/csrf') %>
                        <input type="hidden" name="status" value="approved">
                        <button type="submit" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-semibold text-white bg-emerald-600 hover:bg-emerald-700 rounded-lg transition">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                          Approve
                        </button>
                      </form>
                      <form method="POST" action="/induction/admin/submissions/<%= s.id %>/status" class="inline" onsubmit="return confirm('Reject <%= s.full_name.replace(/\'/g, '&#39;') %>\'s induction?')" onclick="event.stopPropagation()">
                        <%- include('../../partials/csrf') %>
                        <input type="hidden" name="status" value="rejected">
                        <input type="hidden" name="review_notes" value="Quick rejection from list">
                        <button type="submit" class="inline-flex items-center gap-1 px-2 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 rounded-lg transition" title="Reject">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                      </form>
                    <% } %>
                    <a href="/induction/admin/submissions/<%= s.id %>"
                      class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-brand-600 hover:text-brand-700 hover:bg-brand-50 rounded-lg transition">
                      View
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile Card Layout -->
      <div class="md:hidden divide-y divide-gray-100">
        <% submissions.forEach(function(s) {
          const sb = STATUS_BADGES[s.status] || { label: s.status, color: 'bg-gray-100 text-gray-600' };
          const pb = PAYMENT_BADGES[s.payment_type] || { label: s.payment_type, color: 'bg-gray-100 text-gray-600' };
          const docs = docCount(s);
        %>
          <div class="flex items-start p-4 hover:bg-gray-50 transition-colors gap-3">
            <input type="checkbox" name="ids" value="<%= s.id %>" onchange="updateBulkBar()" class="row-check mt-1 rounded border-gray-300 text-brand-600 focus:ring-brand-500 cursor-pointer flex-shrink-0">
            <a href="/induction/admin/submissions/<%= s.id %>" class="block min-w-0 flex-1">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0 flex-1">
                <p class="font-medium text-gray-900 truncate"><%= s.full_name %></p>
                <p class="text-xs text-gray-400 mt-0.5 truncate"><%= s.email %></p>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full flex-shrink-0 <%= sb.color %>"><%= sb.label %></span>
            </div>
            <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
              <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-semibold <%= pb.color %>"><%= pb.label %></span>
              <% if (s.phone) { %>
                <span><%= s.phone %></span>
              <% } %>
              <span class="ml-auto text-gray-400"><%= timeAgo(s.submitted_at) %></span>
            </div>
            <div class="flex items-center gap-3 mt-1.5 text-xs text-gray-500">
              <span>Drive: <% if (s.can_drive === 'yes') { %><span class="text-emerald-600 font-medium">Yes</span><% } else { %><span class="text-red-500 font-medium">No</span><% } %></span>
              <span>Docs: <span class="<%= docs.filled === docs.total ? 'text-emerald-600' : 'text-amber-600' %> font-medium"><%= docs.filled %>/<%= docs.total %></span></span>
            </div>
            </a>
            <% if (s.status === 'submitted') { %>
              <div class="flex gap-2 mt-3">
                <form method="POST" action="/induction/admin/submissions/<%= s.id %>/status" class="flex-1">
                  <%- include('../../partials/csrf') %>
                  <input type="hidden" name="status" value="approved">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-1 px-3 py-2 text-xs font-semibold text-white bg-emerald-600 hover:bg-emerald-700 rounded-lg transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    Approve
                  </button>
                </form>
                <form method="POST" action="/induction/admin/submissions/<%= s.id %>/status" class="flex-1" onsubmit="return confirm('Reject this induction?')">
                  <%- include('../../partials/csrf') %>
                  <input type="hidden" name="status" value="rejected">
                  <input type="hidden" name="review_notes" value="Quick rejection from list">
                  <button type="submit" class="w-full inline-flex items-center justify-center gap-1 px-3 py-2 text-xs font-semibold text-red-700 bg-red-50 hover:bg-red-100 border border-red-200 rounded-lg transition">
                    Reject
                  </button>
                </form>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <!-- Footer -->
      <div class="px-4 py-3 border-t border-gray-200 text-xs text-gray-500">
        Showing <%= submissions.length %> submission<%= submissions.length !== 1 ? 's' : '' %>
      </div>
    <% } %>
  </div>
  </form>

</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="fixed inset-0 bg-black/40 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6">
    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 class="text-lg font-bold text-gray-900 text-center">Delete Submissions?</h3>
    <p class="text-sm text-gray-500 text-center mt-2">
      This will permanently delete <span id="deleteCount" class="font-semibold text-red-600">0</span> submission(s) and their uploaded documents. This cannot be undone.
    </p>
    <div class="flex gap-3 mt-6">
      <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition">Cancel</button>
      <button type="button" onclick="submitDelete()" class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition">Delete</button>
    </div>
  </div>
</div>

<!-- Copy Link Toast -->
<div id="copyToast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-sm px-4 py-2 rounded-lg shadow-lg transition-all duration-300 opacity-0 pointer-events-none z-50">
  Link copied to clipboard!
</div>

<script>
  function toggleAll(master) {
    var checks = document.querySelectorAll('.row-check');
    checks.forEach(function(cb) { cb.checked = master.checked; });
    updateBulkBar();
  }

  function updateBulkBar() {
    var checks = document.querySelectorAll('.row-check:checked');
    var bar = document.getElementById('bulkBar');
    var countEl = document.getElementById('selectedCount');
    var selectAll = document.getElementById('selectAll');
    var allChecks = document.querySelectorAll('.row-check');

    countEl.textContent = checks.length;

    if (checks.length > 0) {
      bar.classList.remove('hidden');
    } else {
      bar.classList.add('hidden');
    }

    // Update select-all checkbox state
    if (selectAll) {
      selectAll.checked = allChecks.length > 0 && checks.length === allChecks.length;
      selectAll.indeterminate = checks.length > 0 && checks.length < allChecks.length;
    }
  }

  function confirmDelete() {
    var count = document.querySelectorAll('.row-check:checked').length;
    if (count === 0) return;
    document.getElementById('deleteCount').textContent = count;
    document.getElementById('deleteModal').classList.remove('hidden');
  }

  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
  }

  function submitDelete() {
    document.getElementById('deleteForm').submit();
  }

  function copyLink(type) {
    var url = window.location.origin + '/induction' + (type ? '/' + type : '');
    navigator.clipboard.writeText(url).then(function() {
      var toast = document.getElementById('copyToast');
      toast.style.opacity = '1';
      toast.style.pointerEvents = 'auto';
      setTimeout(function() {
        toast.style.opacity = '0';
        toast.style.pointerEvents = 'none';
      }, 2000);
    }).catch(function() {
      prompt('Copy this link:', url);
    });
  }
</script>
