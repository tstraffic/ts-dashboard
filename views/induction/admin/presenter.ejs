<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= moduleTitle %> — Presenter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwindcss.config={theme:{extend:{colors:{brand:{50:'#EBF3FF',100:'#D6E7FF',200:'#ADC9FF',300:'#85ABFF',400:'#5C8DFF',500:'#2B7FFF',600:'#1D6AE5',700:'#1554CC',800:'#0D3FB2',900:'#052A99',950:'#001A66'}}}}}</script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 100vw;
      height: 100vh;
      overflow: hidden;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #052A99;
      color: #fff;
      cursor: none;
      user-select: none;
      -webkit-user-select: none;
    }

    body.cursor-visible { cursor: default; }

    /* ── Slide Stage ── */
    #stage {
      position: relative;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }

    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 80px 100px;
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      pointer-events: none;
      will-change: opacity, transform;
    }

    .slide.active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }

    .slide.exit-left {
      opacity: 0;
      transform: translateX(-40px);
    }

    /* ── Layout: Title ── */
    .slide.layout-title {
      justify-content: center;
      align-items: center;
      text-align: center;
      background: radial-gradient(ellipse at 30% 50%, rgba(43, 127, 255, 0.25) 0%, transparent 60%),
                  radial-gradient(ellipse at 70% 80%, rgba(21, 84, 204, 0.2) 0%, transparent 50%),
                  linear-gradient(135deg, #052A99 0%, #001A66 50%, #052A99 100%);
    }

    .slide.layout-title .slide-icon {
      font-size: 4rem;
      margin-bottom: 2rem;
      animation: float 6s ease-in-out infinite;
    }

    .slide.layout-title h1 {
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.1;
      background: linear-gradient(135deg, #fff 0%, #ADC9FF 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
    }

    .slide.layout-title .subtitle {
      font-size: clamp(1.1rem, 2vw, 1.6rem);
      font-weight: 300;
      color: rgba(173, 201, 255, 0.8);
      max-width: 700px;
      line-height: 1.6;
    }

    .slide.layout-title .logo-mark {
      position: absolute;
      bottom: 100px;
      opacity: 0.15;
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #ADC9FF;
    }

    /* ── Layout: Content ── */
    .slide.layout-content {
      justify-content: flex-start;
      align-items: flex-start;
      padding-top: 100px;
      background: linear-gradient(180deg, #052A99 0%, #001A66 100%);
    }

    .slide.layout-content h2 {
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
      color: #fff;
    }

    .slide.layout-content .slide-subtitle {
      font-size: 1.1rem;
      color: rgba(173, 201, 255, 0.6);
      font-weight: 400;
      margin-bottom: 2.5rem;
    }

    .slide.layout-content .content-body {
      font-size: clamp(1rem, 1.5vw, 1.25rem);
      line-height: 1.9;
      color: rgba(255, 255, 255, 0.88);
      max-width: 900px;
    }

    .slide.layout-content .content-body p { margin-bottom: 1.25rem; }
    .slide.layout-content .content-body strong { color: #5C8DFF; font-weight: 600; }

    /* ── Layout: Split ── */
    .slide.layout-split {
      padding: 80px 80px;
      justify-content: flex-start;
      align-items: flex-start;
      background: linear-gradient(135deg, #052A99 0%, #001A66 100%);
    }

    .slide.layout-split h2 {
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
      width: 100%;
    }

    .slide.layout-split .slide-subtitle {
      font-size: 1.1rem;
      color: rgba(173, 201, 255, 0.6);
      margin-bottom: 2.5rem;
      width: 100%;
    }

    .slide.layout-split .split-columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      width: 100%;
      flex: 1;
    }

    .slide.layout-split .split-col {
      font-size: 1.1rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.88);
      padding: 2rem;
      background: rgba(255, 255, 255, 0.04);
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .slide.layout-split .split-col strong { color: #5C8DFF; }

    /* ── Layout: List ── */
    .slide.layout-list {
      justify-content: flex-start;
      align-items: flex-start;
      padding-top: 100px;
      background: linear-gradient(180deg, #052A99 0%, #001A66 100%);
    }

    .slide.layout-list h2 {
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }

    .slide.layout-list .slide-subtitle {
      font-size: 1.1rem;
      color: rgba(173, 201, 255, 0.6);
      margin-bottom: 2.5rem;
    }

    .slide.layout-list .content-body {
      width: 100%;
      max-width: 1000px;
    }

    .slide.layout-list .content-body ul,
    .slide.layout-list .content-body ol {
      list-style: none;
      padding: 0;
    }

    .slide.layout-list .content-body li {
      position: relative;
      padding: 1rem 1.5rem 1rem 3rem;
      margin-bottom: 0.75rem;
      font-size: clamp(1rem, 1.4vw, 1.2rem);
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      transition: background 0.3s ease, transform 0.3s ease;
    }

    .slide.layout-list .content-body li::before {
      content: '';
      position: absolute;
      left: 1.25rem;
      top: 50%;
      transform: translateY(-50%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #2B7FFF;
    }

    .slide.layout-list .content-body li strong { color: #85ABFF; }

    /* ── Layout: Highlight ── */
    .slide.layout-highlight {
      justify-content: center;
      align-items: center;
      text-align: center;
      background: radial-gradient(ellipse at 50% 50%, rgba(43, 127, 255, 0.15) 0%, transparent 70%),
                  linear-gradient(135deg, #052A99, #001A66);
    }

    .slide.layout-highlight .highlight-card {
      max-width: 800px;
      padding: 3.5rem 4rem;
      background: linear-gradient(135deg, rgba(43, 127, 255, 0.15), rgba(92, 141, 255, 0.08));
      border: 1px solid rgba(92, 141, 255, 0.2);
      border-radius: 24px;
      backdrop-filter: blur(20px);
      box-shadow: 0 25px 80px rgba(0, 0, 0, 0.3),
                  inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .slide.layout-highlight .slide-icon {
      font-size: 3rem;
      margin-bottom: 1.5rem;
    }

    .slide.layout-highlight h2 {
      font-size: clamp(1.6rem, 3vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
      color: #fff;
    }

    .slide.layout-highlight .content-body {
      font-size: clamp(1.05rem, 1.5vw, 1.3rem);
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.85);
    }

    .slide.layout-highlight .content-body strong { color: #85ABFF; }

    /* ── Layout: Quiz ── */
    .slide.layout-quiz {
      justify-content: center;
      align-items: center;
      text-align: center;
      background: radial-gradient(ellipse at 50% 30%, rgba(92, 141, 255, 0.12) 0%, transparent 60%),
                  linear-gradient(180deg, #052A99, #001A66);
    }

    .slide.layout-quiz .quiz-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1.25rem;
      background: rgba(43, 127, 255, 0.2);
      border: 1px solid rgba(43, 127, 255, 0.3);
      border-radius: 100px;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #85ABFF;
      margin-bottom: 2rem;
    }

    .slide.layout-quiz h2 {
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
      max-width: 850px;
      line-height: 1.3;
    }

    .slide.layout-quiz .content-body {
      max-width: 800px;
      font-size: clamp(1.05rem, 1.4vw, 1.25rem);
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.85);
      text-align: left;
    }

    .slide.layout-quiz .content-body p { margin-bottom: 1rem; }
    .slide.layout-quiz .content-body strong { color: #5C8DFF; }

    /* ── Top Bar ── */
    #top-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.75rem 1.5rem;
      background: linear-gradient(180deg, rgba(5, 42, 153, 0.95) 0%, rgba(5, 42, 153, 0) 100%);
      backdrop-filter: blur(12px);
      opacity: 0;
      transform: translateY(-10px);
      transition: opacity 0.35s ease, transform 0.35s ease;
      pointer-events: none;
    }

    #top-bar.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    #top-bar .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-weight: 700;
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.8);
    }

    #top-bar .logo-icon {
      width: 32px;
      height: 32px;
      background: linear-gradient(135deg, #2B7FFF, #1554CC);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.7rem;
      color: #fff;
      letter-spacing: 0.05em;
    }

    #top-bar .module-name {
      font-weight: 400;
      color: rgba(173, 201, 255, 0.5);
      margin-left: 0.5rem;
    }

    .top-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.06);
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.8rem;
      font-weight: 500;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .top-btn:hover {
      background: rgba(255, 255, 255, 0.12);
      color: #fff;
      border-color: rgba(255, 255, 255, 0.2);
    }

    /* ── Bottom Bar ── */
    #bottom-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 0 0 0.5rem;
    }

    #progress-track {
      width: 100%;
      height: 3px;
      background: rgba(255, 255, 255, 0.08);
    }

    #progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #2B7FFF, #5C8DFF);
      border-radius: 0 3px 3px 0;
      transition: width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 0 12px rgba(43, 127, 255, 0.4);
    }

    #bottom-info {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.6rem 1.5rem;
    }

    #slide-counter {
      font-size: 0.85rem;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.5);
      font-variant-numeric: tabular-nums;
      min-width: 80px;
    }

    #slide-counter .current {
      color: #fff;
      font-weight: 700;
      font-size: 1rem;
      display: inline-block;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    #slide-counter .current.bump {
      transform: scale(1.3);
    }

    #bottom-module {
      font-size: 0.8rem;
      color: rgba(173, 201, 255, 0.35);
      font-weight: 400;
    }

    #bottom-keys {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.2);
      display: flex;
      gap: 0.75rem;
    }

    #bottom-keys kbd {
      padding: 0.15rem 0.45rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      font-family: inherit;
      font-size: 0.7rem;
    }

    /* ── Click Zones ── */
    #click-prev, #click-next {
      position: fixed;
      top: 0;
      bottom: 60px;
      z-index: 50;
      cursor: none;
    }

    body.cursor-visible #click-prev { cursor: w-resize; }
    body.cursor-visible #click-next { cursor: e-resize; }

    #click-prev { left: 0; width: 30%; }
    #click-next { right: 0; width: 70%; }

    /* ── Animations ── */
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .animate-in { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }

    /* ── Ambient Glow ── */
    .ambient-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.08;
      pointer-events: none;
    }

    .orb-1 {
      width: 600px; height: 600px;
      background: #2B7FFF;
      top: -200px; right: -100px;
    }

    .orb-2 {
      width: 400px; height: 400px;
      background: #5C8DFF;
      bottom: -150px; left: -50px;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .slide { padding: 60px 30px; }
      .slide.layout-split { padding: 60px 30px; }
      .slide.layout-split .split-columns { grid-template-columns: 1fr; gap: 1.5rem; }
      .slide.layout-highlight .highlight-card { padding: 2rem 2.5rem; }
      #bottom-keys { display: none; }
    }
  </style>
</head>
<body class="cursor-visible">

  <!-- Top Bar -->
  <div id="top-bar">
    <div class="logo">
      <div class="logo-icon">T&S</div>
      <span>T&S Operations</span>
      <span class="module-name">— <%= moduleTitle %></span>
    </div>
    <div style="display:flex;gap:0.5rem;">
      <button class="top-btn" onclick="toggleFullscreen()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
        <span id="fs-label">Fullscreen</span>
      </button>
      <a href="/induction/admin/presentations" class="top-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Exit
      </a>
    </div>
  </div>

  <!-- Stage -->
  <div id="stage"></div>

  <!-- Click Zones -->
  <div id="click-prev" onclick="prevSlide()"></div>
  <div id="click-next" onclick="nextSlide()"></div>

  <!-- Bottom Bar -->
  <div id="bottom-bar">
    <div id="progress-track">
      <div id="progress-fill" style="width: 0%"></div>
    </div>
    <div id="bottom-info">
      <div id="slide-counter">
        <span class="current">1</span> / <span id="total-count"><%= totalSlides %></span>
      </div>
      <div id="bottom-module"><%= moduleTitle %></div>
      <div id="bottom-keys">
        <span><kbd>←</kbd> <kbd>→</kbd> Navigate</span>
        <span><kbd>F</kbd> Fullscreen</span>
        <span><kbd>Esc</kbd> Exit</span>
      </div>
    </div>
  </div>

  <script>
    // ── Data ──
    const slides = <%- JSON.stringify(slides) %>;
    const totalSlides = <%= totalSlides %>;
    let currentIndex = 0;
    let isAnimating = false;

    // ── Build Slides ──
    const stage = document.getElementById('stage');

    function buildSlide(slide, index) {
      const el = document.createElement('div');
      el.className = 'slide layout-' + (slide.layout || 'content');
      el.dataset.index = index;
      if (index === 0) el.classList.add('active');

      let html = '';

      // Ambient orbs
      html += '<div class="ambient-orb orb-1"></div>';
      html += '<div class="ambient-orb orb-2"></div>';

      switch (slide.layout) {
        case 'title':
          if (slide.icon) html += '<div class="slide-icon animate-in">' + slide.icon + '</div>';
          html += '<h1 class="animate-in delay-1">' + (slide.title || '') + '</h1>';
          if (slide.subtitle) html += '<div class="subtitle animate-in delay-2">' + slide.subtitle + '</div>';
          html += '<div class="logo-mark animate-in delay-3">T&S OPERATIONS</div>';
          break;

        case 'split':
          html += '<h2 class="animate-in">' + (slide.title || '') + '</h2>';
          if (slide.subtitle) html += '<div class="slide-subtitle animate-in delay-1">' + slide.subtitle + '</div>';
          html += '<div class="split-columns animate-in delay-2">' + (slide.content || '') + '</div>';
          break;

        case 'list':
          if (slide.icon) html += '<div class="slide-icon animate-in" style="font-size:2rem;margin-bottom:0.5rem;align-self:flex-start;">' + slide.icon + '</div>';
          html += '<h2 class="animate-in delay-1">' + (slide.title || '') + '</h2>';
          if (slide.subtitle) html += '<div class="slide-subtitle animate-in delay-1">' + slide.subtitle + '</div>';
          html += '<div class="content-body animate-in delay-2">' + (slide.content || '') + '</div>';
          break;

        case 'highlight':
          html += '<div class="highlight-card">';
          if (slide.icon) html += '<div class="slide-icon animate-in">' + slide.icon + '</div>';
          html += '<h2 class="animate-in delay-1">' + (slide.title || '') + '</h2>';
          html += '<div class="content-body animate-in delay-2">' + (slide.content || '') + '</div>';
          html += '</div>';
          break;

        case 'quiz':
          html += '<div class="quiz-badge animate-in">&#9889; Knowledge Check</div>';
          html += '<h2 class="animate-in delay-1">' + (slide.title || '') + '</h2>';
          html += '<div class="content-body animate-in delay-2">' + (slide.content || '') + '</div>';
          break;

        default: // content
          if (slide.icon) html += '<div style="font-size:2rem;margin-bottom:0.5rem;align-self:flex-start;" class="animate-in">' + slide.icon + '</div>';
          html += '<h2 class="animate-in delay-1">' + (slide.title || '') + '</h2>';
          if (slide.subtitle) html += '<div class="slide-subtitle animate-in delay-1">' + slide.subtitle + '</div>';
          html += '<div class="content-body animate-in delay-2">' + (slide.content || '') + '</div>';
          break;
      }

      el.innerHTML = html;
      return el;
    }

    slides.forEach(function(slide, i) {
      stage.appendChild(buildSlide(slide, i));
    });

    // ── Navigation ──
    function goToSlide(index, direction) {
      if (isAnimating || index < 0 || index >= totalSlides || index === currentIndex) return;
      isAnimating = true;

      const allSlides = stage.querySelectorAll('.slide');
      const current = allSlides[currentIndex];
      const next = allSlides[index];
      const goingForward = index > currentIndex;

      // Set initial position for incoming slide
      next.style.transition = 'none';
      next.style.opacity = '0';
      next.style.transform = goingForward ? 'translateX(40px)' : 'translateX(-40px)';

      // Force reflow
      void next.offsetWidth;

      // Re-enable transitions
      next.style.transition = '';

      // Exit current
      current.classList.remove('active');
      current.classList.add(goingForward ? 'exit-left' : '');
      if (!goingForward) {
        current.style.transform = 'translateX(40px)';
        current.style.opacity = '0';
      }

      // Enter next
      next.classList.add('active');
      next.classList.remove('exit-left');
      next.style.opacity = '1';
      next.style.transform = 'translateX(0)';

      currentIndex = index;
      updateUI();

      setTimeout(function() {
        isAnimating = false;
        // Clean up
        allSlides.forEach(function(s, i) {
          if (i !== currentIndex) {
            s.classList.remove('active', 'exit-left');
            s.style.transition = 'none';
            s.style.opacity = '0';
            s.style.transform = 'translateX(40px)';
            void s.offsetWidth;
            s.style.transition = '';
          }
        });
      }, 550);
    }

    function nextSlide() { goToSlide(currentIndex + 1); }
    function prevSlide() { goToSlide(currentIndex - 1); }

    function updateUI() {
      // Counter
      const counterEl = document.querySelector('#slide-counter .current');
      counterEl.textContent = currentIndex + 1;
      counterEl.classList.add('bump');
      setTimeout(function() { counterEl.classList.remove('bump'); }, 300);

      // Progress
      var pct = totalSlides > 1 ? ((currentIndex) / (totalSlides - 1)) * 100 : 100;
      document.getElementById('progress-fill').style.width = pct + '%';
    }

    // ── Keyboard ──
    document.addEventListener('keydown', function(e) {
      switch(e.key) {
        case 'ArrowRight':
        case ' ':
          e.preventDefault();
          nextSlide();
          break;
        case 'ArrowLeft':
          e.preventDefault();
          prevSlide();
          break;
        case 'Escape':
          window.location.href = '/induction/admin/presentations';
          break;
        case 'f':
        case 'F':
          e.preventDefault();
          toggleFullscreen();
          break;
      }
    });

    // ── Touch / Swipe ──
    let touchStartX = 0;
    let touchStartY = 0;

    document.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    document.addEventListener('touchend', function(e) {
      const dx = e.changedTouches[0].screenX - touchStartX;
      const dy = e.changedTouches[0].screenY - touchStartY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
        if (dx < 0) nextSlide();
        else prevSlide();
      }
    }, { passive: true });

    // ── Fullscreen ──
    function toggleFullscreen() {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(function() {});
      } else {
        document.exitFullscreen().catch(function() {});
      }
    }

    document.addEventListener('fullscreenchange', function() {
      var label = document.getElementById('fs-label');
      label.textContent = document.fullscreenElement ? 'Exit Fullscreen' : 'Fullscreen';
    });

    // ── Top Bar Hover ──
    let hideTimer;
    const topBar = document.getElementById('top-bar');

    document.addEventListener('mousemove', function(e) {
      document.body.classList.add('cursor-visible');
      clearTimeout(hideTimer);

      if (e.clientY < 80) {
        topBar.classList.add('visible');
      } else {
        topBar.classList.remove('visible');
      }

      hideTimer = setTimeout(function() {
        document.body.classList.remove('cursor-visible');
        topBar.classList.remove('visible');
      }, 3000);
    });

    // ── Init ──
    updateUI();
  </script>
</body>
</html>