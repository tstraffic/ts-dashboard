<div class="p-4 md:p-6 max-w-6xl mx-auto">
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Training Presentations</h1>
      <p class="text-gray-500 text-sm mt-1">Launch and track hard induction training sessions</p>
    </div>
    <a href="/induction/admin/submissions" class="text-sm text-brand-600 hover:text-brand-700 font-medium">
      &larr; Back to Submissions
    </a>
  </div>

  <!-- In-person sign-off launcher -->
  <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-xl shadow-sm p-5 mb-6 text-white">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h2 class="text-lg font-bold">In-person SOP sign-off</h2>
        <p class="text-emerald-100 text-sm mt-1">Start a session to collect signatures from a room of attendees on their own phones (QR code).</p>
      </div>
      <div class="flex items-center gap-2">
        <a href="/induction/admin/sop-documents" class="inline-flex items-center gap-2 px-4 py-2 bg-white/15 hover:bg-white/25 text-white text-sm font-medium rounded-lg transition border border-white/20">
          SOP documents
        </a>
        <a href="/induction/admin/acknowledgements" class="inline-flex items-center gap-2 px-4 py-2 bg-white/15 hover:bg-white/25 text-white text-sm font-medium rounded-lg transition border border-white/20">
          Signed list
        </a>
        <form method="POST" action="/induction/admin/sign-session/start" class="flex items-center gap-2">
          <%- include('../../partials/csrf') %>
          <input type="text" name="title" placeholder="Session label (e.g. 7 May induction)"
                 class="px-3 py-2 rounded-lg bg-white/15 border border-white/20 text-white text-sm placeholder-white/60 focus:outline-none focus:ring-2 focus:ring-white/40" />
          <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-white text-emerald-700 hover:bg-emerald-50 text-sm font-bold rounded-lg transition shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 16a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1v-3zM16 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1V4zM16 16h2v2h-2zM18 18h2v2h-2zM12 12h2v2h-2z"/></svg>
            Start sign-off
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Launch Cards -->
  <div class="grid md:grid-cols-2 gap-6 mb-8">
    <!-- Employee Guide -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
      <div class="bg-gradient-to-r from-brand-600 to-brand-700 p-6 text-white">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <div>
            <h2 class="text-lg font-bold">T&S Employee Guide</h2>
            <p class="text-brand-200 text-sm">Module 1 — Company Overview</p>
          </div>
        </div>
        <p class="text-brand-100 text-sm">Company values, PPE requirements, vehicle rules, Traffio, and workplace conduct.</p>
      </div>
      <div class="p-4 flex items-center justify-between">
        <span class="text-sm text-gray-500">~40 slides + quiz</span>
        <div class="flex items-center gap-2">
          <button onclick="navigator.clipboard.writeText(window.location.origin+'/training/employee-guide').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.innerHTML='<svg class=&quot;w-4 h-4 inline mr-1&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; viewBox=&quot;0 0 24 24&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3&quot;/></svg>Copy Link'},1500)})" class="inline-flex items-center gap-1 px-3 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            Copy Link
          </button>
          <a href="/training/employee-guide" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-brand-600 text-white rounded-lg text-sm font-medium hover:bg-brand-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Open Training
          </a>
        </div>
      </div>
    </div>

    <!-- TC Training — same shape as Employee Guide so the two modules
         feel equivalent. Standalone shareable link via /training/traffic-control,
         plus the legacy projector route for in-person presentations. -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
      <div class="bg-gradient-to-r from-amber-500 to-orange-600 p-6 text-white">
        <div class="flex items-center gap-3 mb-2">
          <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <div>
            <h2 class="text-lg font-bold">Traffic Control Training</h2>
            <p class="text-amber-100 text-sm">Module 1 — Field Operations</p>
          </div>
        </div>
        <p class="text-amber-100 text-sm">Start of shift, set-up steps, safety culture, equipment handling, emergency response, and regulations.</p>
      </div>
      <div class="p-4 flex items-center justify-between">
        <span class="text-sm text-gray-500">~40 slides + quiz</span>
        <div class="flex items-center gap-2">
          <button onclick="navigator.clipboard.writeText(window.location.origin+'/training/traffic-control').then(()=>{this.textContent='Copied!';setTimeout(()=>{this.innerHTML='<svg class=&quot;w-4 h-4 inline mr-1&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; viewBox=&quot;0 0 24 24&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3&quot;/></svg>Copy Link'},1500)})" class="inline-flex items-center gap-1 px-3 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            Copy Link
          </button>
          <a href="/training/traffic-control" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 bg-amber-600 text-white rounded-lg text-sm font-medium hover:bg-amber-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Open Training
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Presentation History -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="font-semibold text-gray-900">Presentation History</h2>
    </div>
    <% if (presentations.length === 0) { %>
    <div class="p-6 text-center text-gray-400">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"/></svg>
      <p class="font-medium">No presentations yet</p>
      <p class="text-sm mt-1">Launch a presentation above to get started</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left font-medium text-gray-500">Module</th>
            <th class="px-6 py-3 text-left font-medium text-gray-500">Presenter</th>
            <th class="px-6 py-3 text-left font-medium text-gray-500">Attendees</th>
            <th class="px-6 py-3 text-left font-medium text-gray-500">Date</th>
            <th class="px-6 py-3 text-left font-medium text-gray-500">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% presentations.forEach(p => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-3">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium <%= p.module === 'employee_guide' ? 'bg-brand-100 text-brand-700' : 'bg-amber-100 text-amber-700' %>">
                <%= p.module === 'employee_guide' ? 'Employee Guide' : 'TC Training 1' %>
              </span>
            </td>
            <td class="px-6 py-3 text-gray-900"><%= p.presenter_name %></td>
            <td class="px-6 py-3 text-gray-600"><%= p.attendee_names || '—' %></td>
            <td class="px-6 py-3 text-gray-600"><%= new Date(p.started_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
            <td class="px-6 py-3">
              <% if (p.completed_at) { %>
              <span class="inline-flex items-center gap-1 text-green-700 text-xs font-medium">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Completed
              </span>
              <% } else { %>
              <span class="text-amber-600 text-xs font-medium">In Progress</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
