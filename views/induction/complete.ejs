<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Application Submitted | T&S Traffic Control</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwindcss.config={theme:{extend:{colors:{brand:{50:'#EBF3FF',100:'#D6E7FF',200:'#ADC9FF',300:'#85ABFF',400:'#5C8DFF',500:'#2B7FFF',600:'#1D6AE5',700:'#1554CC',800:'#0D3FB2',900:'#052A99',950:'#001A66'}}},fontFamily:{sans:['"Inter"','system-ui','-apple-system','sans-serif']}}}}</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    /* Animated checkmark */
    .check-circle {
      width: 96px; height: 96px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
      animation: pulse-ring 2s ease-out infinite, scale-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      opacity: 0;
      transform: scale(0);
    }
    @keyframes scale-in {
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes pulse-ring {
      0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.35); }
      70% { box-shadow: 0 0 0 20px rgba(34, 197, 94, 0); }
      100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
    }

    /* Checkmark draw animation */
    .check-path {
      stroke-dasharray: 60;
      stroke-dashoffset: 60;
      animation: draw-check 0.5s 0.4s ease forwards;
    }
    @keyframes draw-check {
      to { stroke-dashoffset: 0; }
    }

    /* Fade-up stagger */
    .fade-up {
      opacity: 0;
      transform: translateY(20px);
      animation: fade-up 0.6s ease forwards;
    }
    .fade-up-1 { animation-delay: 0.5s; }
    .fade-up-2 { animation-delay: 0.7s; }
    .fade-up-3 { animation-delay: 0.9s; }
    .fade-up-4 { animation-delay: 1.1s; }
    .fade-up-5 { animation-delay: 1.3s; }
    @keyframes fade-up {
      to { opacity: 1; transform: translateY(0); }
    }

    /* Confetti */
    .confetti-piece {
      position: fixed;
      width: 10px;
      height: 10px;
      top: -20px;
      opacity: 0;
      animation: confetti-fall linear forwards;
      z-index: 50;
    }
    @keyframes confetti-fall {
      0% { opacity: 1; top: -5%; transform: rotate(0deg) scale(1); }
      25% { opacity: 1; }
      100% { opacity: 0; top: 105%; transform: rotate(720deg) scale(0.4); }
    }

    /* Subtle background animation */
    .bg-animated {
      background-size: 400% 400%;
      animation: gradient-shift 12s ease infinite;
    }
    @keyframes gradient-shift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    /* Step item hover */
    .step-item {
      transition: all 0.2s ease;
    }
    .step-item:hover {
      transform: translateX(4px);
    }

    /* Card entrance */
    .card-enter {
      opacity: 0;
      transform: scale(0.95) translateY(10px);
      animation: card-enter 0.7s 0.15s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes card-enter {
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* Glow effect behind card */
    .card-glow {
      position: absolute;
      inset: -2px;
      border-radius: 1.25rem;
      background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(43,127,255,0.15), rgba(34,197,94,0.1));
      filter: blur(20px);
      z-index: -1;
      animation: glow-pulse 3s ease-in-out infinite alternate;
    }
    @keyframes glow-pulse {
      0% { opacity: 0.5; }
      100% { opacity: 0.8; }
    }
  </style>
</head>
<body class="min-h-screen bg-animated flex items-center justify-center p-4 font-sans" style="background: linear-gradient(-45deg, #052A99, #1554CC, #1D6AE5, #2B7FFF); background-size: 400% 400%;">

  <!-- Confetti container (JS fills this) -->
  <div id="confetti"></div>

  <!-- Main card -->
  <div class="relative max-w-lg w-full">
    <div class="card-glow"></div>
    <div class="card-enter bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl p-8 md:p-10 text-center relative overflow-hidden">

      <!-- Subtle top accent bar -->
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-green-400 via-brand-500 to-green-400"></div>

      <!-- Animated checkmark -->
      <div class="flex justify-center mb-7">
        <div class="check-circle">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none">
            <path class="check-path" d="M5 13l4 4L19 7" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="fade-up fade-up-1 text-2xl md:text-3xl font-bold text-gray-900 tracking-tight">
        You're All Set!
      </h1>
      <p class="fade-up fade-up-2 text-gray-500 mt-2 text-base md:text-lg leading-relaxed max-w-sm mx-auto">
        Thank you for completing your T&S induction. We've received everything and our team is on it.
      </p>

      <!-- Divider -->
      <div class="fade-up fade-up-2 w-12 h-0.5 bg-gradient-to-r from-transparent via-gray-200 to-transparent mx-auto my-6"></div>

      <!-- What happens next -->
      <div class="fade-up fade-up-3 bg-gradient-to-br from-gray-50 to-brand-50/40 border border-gray-100 rounded-xl p-5 mb-6 text-left">
        <h3 class="font-semibold text-gray-800 text-sm uppercase tracking-wide mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          What Happens Next
        </h3>
        <div class="space-y-3">
          <div class="step-item flex items-start gap-3">
            <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xs font-bold mt-0.5">1</div>
            <div>
              <p class="text-sm font-medium text-gray-800">Application Review</p>
              <p class="text-xs text-gray-500 mt-0.5">Our team will review your details and uploaded documents</p>
            </div>
          </div>
          <div class="step-item flex items-start gap-3">
            <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xs font-bold mt-0.5">2</div>
            <div>
              <p class="text-sm font-medium text-gray-800">Hard Induction Invite</p>
              <p class="text-xs text-gray-500 mt-0.5">If approved, you'll be invited for in-person safety training</p>
            </div>
          </div>
          <div class="step-item flex items-start gap-3">
            <div class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center text-xs font-bold mt-0.5">3</div>
            <div>
              <p class="text-sm font-medium text-gray-800">We'll Be In Touch</p>
              <p class="text-xs text-gray-500 mt-0.5">Expect a call or email from us within a few business days</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Brand footer -->
      <div class="fade-up fade-up-4 flex items-center justify-center gap-3 mb-5">
        <img src="/images/logo-colour.jpg" alt="T&S Traffic Control" class="h-11 w-auto rounded-lg shadow-sm">
        <div class="text-left">
          <p class="font-bold text-gray-900 text-sm tracking-tight">T&S Traffic Control</p>
          <p class="text-[11px] text-gray-400 font-medium italic">"A Safe Way Home"</p>
        </div>
      </div>

      <!-- Close prompt -->
      <p class="fade-up fade-up-5 text-xs text-gray-400 mt-2">You can safely close this page now.</p>
    </div>
  </div>

  <script>
    // Confetti burst
    (function() {
      var container = document.getElementById('confetti');
      var colors = ['#2B7FFF', '#22c55e', '#facc15', '#f97316', '#a855f7', '#ec4899', '#1D6AE5', '#14b8a6'];
      var shapes = ['circle', 'square', 'triangle'];

      for (var i = 0; i < 60; i++) {
        var piece = document.createElement('div');
        piece.className = 'confetti-piece';
        var color = colors[Math.floor(Math.random() * colors.length)];
        var shape = shapes[Math.floor(Math.random() * shapes.length)];
        var size = 6 + Math.random() * 10;
        var left = Math.random() * 100;
        var duration = 2.5 + Math.random() * 2;
        var delay = Math.random() * 1.2;

        piece.style.left = left + '%';
        piece.style.width = size + 'px';
        piece.style.height = size + 'px';
        piece.style.backgroundColor = color;
        piece.style.animationDuration = duration + 's';
        piece.style.animationDelay = delay + 's';

        if (shape === 'circle') {
          piece.style.borderRadius = '50%';
        } else if (shape === 'triangle') {
          piece.style.width = '0';
          piece.style.height = '0';
          piece.style.backgroundColor = 'transparent';
          piece.style.borderLeft = (size/2) + 'px solid transparent';
          piece.style.borderRight = (size/2) + 'px solid transparent';
          piece.style.borderBottom = size + 'px solid ' + color;
        } else {
          piece.style.borderRadius = '2px';
        }

        container.appendChild(piece);
      }

      // Clean up confetti after animations
      setTimeout(function() {
        container.innerHTML = '';
      }, 6000);
    })();
  </script>
</body>
</html>
