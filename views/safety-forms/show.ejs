<% locals.currentPage = 'safety-forms' %>

<%
  // Helper: render an answer of arbitrary shape into HTML-ish text.
  function renderValue(v) {
    if (v == null || v === '') return '<span class="text-gray-300">—</span>';
    if (Array.isArray(v)) {
      if (!v.length) return '<span class="text-gray-300">— (none selected)</span>';
      return v.map(x => '<span class="inline-block px-2 py-0.5 mr-1 mb-1 rounded text-[11px] bg-brand-50 text-brand-700 ring-1 ring-brand-600/10">' + escapeHtml(String(x)) + '</span>').join('');
    }
    if (typeof v === 'boolean') return v ? '<span class="text-emerald-700 font-semibold">Yes</span>' : '<span class="text-gray-500">No</span>';
    if (typeof v === 'object') {
      var rows = Object.keys(v).map(function (k) { return '<dt class="text-xs text-gray-500 mt-1">' + prettifyKey(k) + '</dt><dd class="text-sm text-gray-800">' + renderValue(v[k]) + '</dd>'; });
      return '<dl class="space-y-1">' + rows.join('') + '</dl>';
    }
    return escapeHtml(String(v));
  }
  function escapeHtml(s) { return s.replace(/[&<>"']/g, function (c) { return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]; }); }
  function prettifyKey(k) { return k.replace(/_/g, ' ').replace(/\b\w/g, function (l) { return l.toUpperCase(); }); }

  // Photo-tag → human heading (matches the keys persistFormPhotos sets).
  var TAG_LABEL = {
    arrow_board:    'Arrow board',
    setup:          'Site setup',
    team:           'Team / PPE',
    interior:       'Vehicle interior',
    equipment_cage: 'Equipment cage',
    fuel_gauge:     'Fuel gauge',
    other:          'Other',
  };
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-5">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <a href="/safety-forms" class="text-sm text-brand-600 font-medium inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to submissions
      </a>
      <h1 class="mt-1 text-2xl font-bold text-gray-900"><%= formLabel %></h1>
      <p class="text-sm text-gray-500">
        Submitted <%= new Date(sub.submitted_at).toLocaleString('en-AU', { weekday:'short', day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
        <% if (sub.signed_name) { %> by <span class="font-medium"><%= sub.signed_name %></span><% } %>
      </p>
    </div>
    <a href="/safety-forms/<%= sub.id %>/pdf" target="_blank"
       class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM14 2v6h6M9 13h6M9 17h4"/></svg>
      Download PDF
    </a>
  </div>

  <!-- Header card: who / what / when -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
    <div>
      <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Worker</p>
      <p class="font-medium text-gray-900"><%= sub.crew_name || '#' + sub.crew_member_id %></p>
      <% if (sub.employee_code) { %><p class="text-xs text-gray-500"><%= sub.employee_code %></p><% } %>
    </div>
    <div>
      <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Job</p>
      <% if (sub.job_id) { %>
        <a href="/jobs/<%= sub.job_id %>" class="font-medium text-brand-700 hover:underline"><%= sub.job_number %></a>
        <p class="text-xs text-gray-500"><%= sub.job_client || sub.job_name || '' %></p>
      <% } else { %><p class="text-gray-400">—</p><% } %>
    </div>
    <div>
      <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Shift</p>
      <% if (sub.allocation_id) { %>
        <p class="font-medium text-gray-900"><%= sub.allocation_date || '—' %></p>
        <p class="text-xs text-gray-500"><%= (sub.shift_start || '') %><% if (sub.shift_end) { %> – <%= sub.shift_end %><% } %></p>
      <% } else { %><p class="text-gray-400">Not bound to a shift</p><% } %>
    </div>
  </div>

  <!-- Answers -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-3 border-b border-gray-100">
      <h2 class="text-sm font-semibold text-gray-900">Answers</h2>
    </div>
    <% if (!parsed || (typeof parsed === 'object' && Object.keys(parsed).length === 0)) { %>
      <div class="px-5 py-8 text-center text-sm text-gray-500">No answers captured.</div>
    <% } else { %>
      <dl class="divide-y divide-gray-100">
        <%
          // Common pattern: most forms keep the answers under data.answers (Risk
          // Assessment) or as top-level keys (Vehicle Pre-Start). Try both.
          var entries = Object.keys(parsed).map(function (k) { return [k, parsed[k]]; });
          if (parsed && parsed.answers && typeof parsed.answers === 'object') {
            entries = Object.keys(parsed.answers).map(function (k) { return [k, parsed.answers[k]]; });
            // Append any top-level non-"answers" keys (notes, signature flag, etc.)
            Object.keys(parsed).forEach(function (k) { if (k !== 'answers') entries.push([k, parsed[k]]); });
          }
        %>
        <% entries.forEach(function (pair) { var k = pair[0]; var v = pair[1]; %>
          <div class="px-5 py-3 grid grid-cols-1 sm:grid-cols-3 gap-2">
            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide sm:col-span-1"><%= prettifyKey(k) %></dt>
            <dd class="sm:col-span-2 text-sm text-gray-800"><%- renderValue(v) %></dd>
          </div>
        <% }) %>
      </dl>
    <% } %>
  </div>

  <!-- Photos grouped by tag -->
  <% if (photos.length) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-900">Photos <span class="text-gray-400 font-normal">(<%= photos.length %>)</span></h2>
      </div>
      <div class="p-5 space-y-5">
        <% Object.keys(photosByTag).forEach(function (tag) { var group = photosByTag[tag]; %>
          <div>
            <p class="text-xs font-semibold text-gray-600 uppercase tracking-wide mb-2"><%= TAG_LABEL[tag] || prettifyKey(tag) %> <span class="text-gray-400 font-normal">(<%= group.length %>)</span></p>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
              <% group.forEach(function (p) { %>
                <a href="/safety-forms/<%= sub.id %>/photos/<%= p.id %>" target="_blank" class="block group">
                  <div class="aspect-square bg-gray-100 rounded-lg overflow-hidden ring-1 ring-gray-200 group-hover:ring-brand-500">
                    <img src="/safety-forms/<%= sub.id %>/photos/<%= p.id %>" alt="" loading="lazy" class="w-full h-full object-cover">
                  </div>
                </a>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Signature -->
  <% if (sub.signature_data) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-2">Signature</h2>
      <% if (sub.signed_name) { %><p class="text-xs text-gray-500 mb-2">Signed by <span class="font-medium text-gray-700"><%= sub.signed_name %></span></p><% } %>
      <img src="<%= sub.signature_data %>" alt="Signature" class="max-h-32 border border-gray-200 rounded-lg bg-gray-50 p-2">
    </div>
  <% } %>
</div>
