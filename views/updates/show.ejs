<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Back Link -->
  <div class="mb-6">
    <a href="/updates" class="inline-flex items-center text-slate-400 hover:text-amber-400 transition">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back to Updates
    </a>
  </div>

  <!-- Update Card -->
  <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-700">
      <div class="flex items-start justify-between">
        <div>
          <div class="flex items-center space-x-2 mb-1">
            <a href="/jobs/<%= update.job_id %>" class="text-amber-400 hover:text-amber-300 font-semibold text-lg"><%= update.job_number %></a>
            <span class="text-slate-500">-</span>
            <span class="text-white font-medium text-lg"><%= update.client %></span>
          </div>
          <div class="text-sm text-slate-400">
            Week ending: <span class="text-slate-300"><%= update.week_ending ? new Date(update.week_ending).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></span>
          </div>
        </div>
        <div class="text-right text-sm text-slate-400">
          <div>Submitted by <span class="text-slate-300"><%= update.submitted_by_name || 'Unknown' %></span></div>
          <% if (update.created_at) { %>
            <div class="text-xs text-slate-500 mt-1"><%= new Date(update.created_at).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="px-6 py-5 space-y-6">
      <!-- Summary -->
      <div>
        <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Summary</h3>
        <p class="text-slate-300 whitespace-pre-wrap"><%= update.summary || 'No summary provided.' %></p>
      </div>

      <!-- Milestones -->
      <% if (update.milestones) { %>
        <div>
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Milestones Achieved</h3>
          <p class="text-slate-300 whitespace-pre-wrap"><%= update.milestones %></p>
        </div>
      <% } %>

      <!-- Issues / Risks -->
      <% if (update.issues_risks) { %>
        <div>
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Issues / Risks</h3>
          <p class="text-slate-300 whitespace-pre-wrap"><%= update.issues_risks %></p>
        </div>
      <% } %>

      <!-- Blockers / Support Needed -->
      <% if (update.blockers) { %>
        <div>
          <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Blockers / Support Needed</h3>
          <p class="text-slate-300 whitespace-pre-wrap"><%= update.blockers %></p>
        </div>
      <% } %>
    </div>
  </div>
</div>
