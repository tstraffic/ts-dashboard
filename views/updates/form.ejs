<%
  const isEdit = !!update;
  const formAction = '/updates';
  const selectedJobId = (isEdit && update.job_id) ? update.job_id : (prefillJobId || '');
  const returnTo = (typeof locals !== 'undefined' && locals.returnTo) ? locals.returnTo : '/projects#updates';
  // Calculate next Friday for default week ending
  const today = new Date();
  const dayOfWeek = today.getDay();
  const daysUntilFriday = (5 - dayOfWeek + 7) % 7 || 7;
  const nextFriday = new Date(today);
  nextFriday.setDate(today.getDate() + daysUntilFriday);
  const defaultWeekEnding = nextFriday.toISOString().split('T')[0];
%>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Submit Weekly Update</h1>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <form method="POST" action="<%= formAction %>">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="return_to" value="<%= returnTo %>">

      <div class="space-y-6">
        <!-- Job -->
        <div>
          <% const prefillJob = selectedJobId ? jobs.find(j => String(j.id) === String(selectedJobId)) : null; %>
          <% if (prefillJob) { %>
            <input type="hidden" name="job_id" value="<%= prefillJob.id %>">
            <label class="block text-sm font-medium text-gray-600 mb-1">Job</label>
            <div class="w-full bg-gray-100 border border-gray-300 text-gray-900 rounded-lg px-3 py-2 font-medium"><%= prefillJob.job_number %> - <%= prefillJob.client %></div>
          <% } else { %>
            <label for="job_id" class="block text-sm font-medium text-gray-600 mb-1">Job <span class="text-red-600">*</span></label>
            <select id="job_id" name="job_id" required class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="">Select a job...</option>
              <% jobs.forEach(function(job) { %>
                <option value="<%= job.id %>"><%= job.job_number %> - <%= job.client %></option>
              <% }) %>
            </select>
          <% } %>
        </div>

        <!-- Week Ending -->
        <div>
          <label for="week_ending" class="block text-sm font-medium text-gray-600 mb-1">Week Ending <span class="text-red-600">*</span></label>
          <input type="date" id="week_ending" name="week_ending" required value="<%= isEdit && update.week_ending ? new Date(update.week_ending).toISOString().split('T')[0] : defaultWeekEnding %>" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Summary -->
        <div>
          <label for="summary" class="block text-sm font-medium text-gray-600 mb-1">Summary <span class="text-red-600">*</span></label>
          <textarea id="summary" name="summary" rows="4" required class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Summary of progress this week..."><%= isEdit && update.summary ? update.summary : '' %></textarea>
        </div>

        <!-- Milestones Achieved -->
        <div>
          <label for="milestones" class="block text-sm font-medium text-gray-600 mb-1">Milestones Achieved</label>
          <textarea id="milestones" name="milestones" rows="3" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Key milestones completed this week..."><%= isEdit && update.milestones ? update.milestones : '' %></textarea>
        </div>

        <!-- Issues / Risks -->
        <div>
          <label for="issues_risks" class="block text-sm font-medium text-gray-600 mb-1">Issues / Risks</label>
          <textarea id="issues_risks" name="issues_risks" rows="3" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Any issues or risks identified..."><%= isEdit && update.issues_risks ? update.issues_risks : '' %></textarea>
        </div>

        <!-- Blockers / Support Needed -->
        <div>
          <label for="blockers" class="block text-sm font-medium text-gray-600 mb-1">Blockers / Support Needed</label>
          <textarea id="blockers" name="blockers" rows="3" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500" placeholder="Any blockers or support needed..."><%= isEdit && update.blockers ? update.blockers : '' %></textarea>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex items-center justify-end space-x-3 mt-6 pt-6 border-t border-gray-200">
        <a href="/projects#updates" class="px-4 py-2 bg-white text-gray-600 rounded-lg hover:bg-gray-100 transition font-medium">Cancel</a>
        <button type="submit" class="px-6 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-semibold">
          Submit Update
        </button>
      </div>
    </form>
  </div>
</div>
