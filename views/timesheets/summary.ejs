<% locals.currentPage = 'timesheets' %>

<%
  // Format week dates for display
  const monDate = new Date(weekOf);
  const sunDate = new Date(weekEnd);
  const fmtOpts = { weekday: 'short', day: '2-digit', month: 'short' };
  const yearOpts = { year: 'numeric' };
  const weekLabel = monDate.toLocaleDateString('en-AU', fmtOpts) + ' - ' + sunDate.toLocaleDateString('en-AU', { ...fmtOpts, ...yearOpts });
%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Weekly Summary</h1>
    <p class="text-slate-400 text-sm mt-1">Crew hours overview by week</p>
  </div>
</div>

<!-- Sub-navigation -->
<div class="flex items-center gap-1 mb-6 border-b border-slate-700 pb-3">
  <a href="/timesheets" class="px-4 py-2 text-sm font-medium rounded-lg text-slate-400 hover:text-white hover:bg-slate-700/50 transition-colors">Timesheets</a>
  <a href="/timesheets/crew" class="px-4 py-2 text-sm font-medium rounded-lg text-slate-400 hover:text-white hover:bg-slate-700/50 transition-colors">Crew Members</a>
  <a href="/timesheets/summary" class="px-4 py-2 text-sm font-medium rounded-lg bg-slate-700 text-white">Weekly Summary</a>
</div>

<!-- Week Selector -->
<div class="bg-slate-800 border border-slate-700 rounded-xl p-4 mb-6">
  <form method="GET" action="/timesheets/summary" class="flex flex-wrap items-end gap-4">
    <div class="min-w-[180px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Week Of</label>
      <input type="date" name="week_of" value="<%= weekOf %>"
        class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent">
    </div>
    <div>
      <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-medium rounded-lg transition-colors">Navigate</button>
    </div>
    <!-- Prev / Next Week -->
    <div class="flex gap-2 ml-auto">
      <%
        const prevMon = new Date(monDate);
        prevMon.setDate(prevMon.getDate() - 7);
        const nextMon = new Date(monDate);
        nextMon.setDate(nextMon.getDate() + 7);
      %>
      <a href="/timesheets/summary?week_of=<%= prevMon.toISOString().split('T')[0] %>" class="px-3 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors" title="Previous week">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <a href="/timesheets/summary?week_of=<%= nextMon.toISOString().split('T')[0] %>" class="px-3 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors" title="Next week">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </form>
</div>

<!-- Week Label -->
<div class="mb-6">
  <h2 class="text-lg font-semibold text-white"><%= weekLabel %></h2>
</div>

<!-- Summary Table -->
<% if (summary.length === 0) { %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-8 text-center">
    <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    <p class="text-slate-500 text-sm">No timesheet entries for this week.</p>
    <a href="/timesheets/new" class="inline-block mt-3 text-amber-400 hover:text-amber-300 text-sm font-medium">Log a timesheet</a>
  </div>
<% } else { %>
<div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700">
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Crew Member</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Jobs Worked</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-slate-400 uppercase tracking-wide">Entries</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-slate-400 uppercase tracking-wide">Total Hours</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-slate-400 uppercase tracking-wide">Approved</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700">
      <% summary.forEach(s => { %>
      <tr class="hover:bg-slate-700/50">
        <td class="px-4 py-3 text-white font-medium">
          <a href="/timesheets?crew_member_id=<%= s.crew_member_id %>&week_of=<%= weekOf %>" class="hover:text-amber-400 transition-colors"><%= s.full_name %></a>
        </td>
        <td class="px-4 py-3 text-slate-300">
          <% if (s.jobs_worked) { %>
            <% s.jobs_worked.split(',').forEach(jn => { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-700 text-slate-300 mr-1 mb-1"><%= jn %></span>
            <% }) %>
          <% } else { %>
            -
          <% } %>
        </td>
        <td class="px-4 py-3 text-center text-slate-300"><%= s.entry_count %></td>
        <td class="px-4 py-3 text-center text-white font-semibold">
          <span class="<%= (s.total_hours || 0) > 50 ? 'text-amber-400' : '' %>"><%= parseFloat(s.total_hours || 0).toFixed(1) %></span>
        </td>
        <td class="px-4 py-3 text-center">
          <% if (s.approved_count === s.entry_count) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-900/60 text-emerald-300"><%= s.approved_count %>/<%= s.entry_count %></span>
          <% } else { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-900/60 text-amber-300"><%= s.approved_count %>/<%= s.entry_count %></span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr class="border-t-2 border-slate-600 bg-slate-700/30">
        <td class="px-4 py-3 text-white font-semibold" colspan="2">Grand Total</td>
        <td class="px-4 py-3 text-center text-slate-300 font-medium"><%= summary.reduce((sum, s) => sum + s.entry_count, 0) %></td>
        <td class="px-4 py-3 text-center text-amber-400 font-bold text-base"><%= grandTotal %></td>
        <td class="px-4 py-3 text-center text-slate-300 font-medium">
          <%= summary.reduce((sum, s) => sum + s.approved_count, 0) %>/<%= summary.reduce((sum, s) => sum + s.entry_count, 0) %>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
<div class="mt-3 text-xs text-slate-500"><%= summary.length %> crew member<%= summary.length !== 1 ? 's' : '' %> worked this week</div>
<% } %>
