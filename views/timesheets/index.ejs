<% locals.currentPage = 'timesheets' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Timesheets</h1>
    <p class="text-gray-500 text-sm mt-1">Track crew hours and approve timesheets</p>
  </div>
  <a href="/timesheets/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Log Timesheet</a>
</div>

<!-- Sub-navigation -->
<div class="flex items-center gap-1 mb-6 border-b border-gray-200 pb-3">
  <a href="/timesheets" class="px-4 py-2 text-sm font-medium rounded-lg bg-brand-50 text-brand-700">Timesheets</a>
  <a href="/timesheets/crew" class="px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors">Crew Members</a>
  <a href="/timesheets/summary" class="px-4 py-2 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors">Weekly Summary</a>
</div>

<!-- Stats Bar -->
<div class="grid grid-cols-2 sm:grid-cols-2 gap-4 mb-6">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Total Hours</div>
    <div class="text-2xl font-bold text-gray-900"><%= stats.totalHours %></div>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Pending Approval</div>
    <div class="text-2xl font-bold <%= stats.pendingApproval > 0 ? 'text-orange-600' : 'text-gray-900' %>"><%= stats.pendingApproval %></div>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" action="/timesheets" class="flex flex-wrap items-end gap-4">
    <!-- Job -->
    <div class="min-w-[180px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
        <% }) %>
      </select>
    </div>
    <!-- Crew Member -->
    <div class="min-w-[180px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Crew Member</label>
      <select name="crew_member_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Crew</option>
        <% crew.forEach(c => { %>
          <option value="<%= c.id %>" <%= filters.crew_member_id == c.id ? 'selected' : '' %>><%= c.full_name %></option>
        <% }) %>
      </select>
    </div>
    <!-- Date -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Date</label>
      <input type="date" name="work_date" value="<%= filters.work_date || '' %>"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <!-- Approved -->
    <div class="min-w-[140px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Approved</label>
      <select name="approved" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All</option>
        <option value="0" <%= filters.approved === '0' ? 'selected' : '' %>>Pending</option>
        <option value="1" <%= filters.approved === '1' ? 'selected' : '' %>>Approved</option>
      </select>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Apply</button>
      <a href="/timesheets" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/timesheets.csv?job_id=<%= filters.job_id || '' %>&crew_member_id=<%= filters.crew_member_id || '' %>&work_date=<%= filters.work_date || '' %>&approved=<%= filters.approved || '' %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export CSV
      </a>
    </div>
  </form>
</div>

<!-- Timesheets Table -->
<% if (timesheets.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <svg class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-gray-400 text-sm">No timesheet entries found.</p>
    <a href="/timesheets/new" class="inline-block mt-3 text-brand-600 hover:text-brand-600 text-sm font-medium">Log a timesheet</a>
  </div>
<% } else { %>
<form method="POST" action="/timesheets/approve-bulk" id="bulkApproveForm">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-3 py-3 text-left">
            <input type="checkbox" id="selectAll" class="rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500" title="Select all">
          </th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Crew Member</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Start</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">End</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Break</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Hours</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Shift</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Approved</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% timesheets.forEach(t => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-3 py-3">
            <% if (!t.approved) { %>
              <input type="checkbox" name="timesheet_ids" value="<%= t.id %>" class="bulk-checkbox rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500">
            <% } %>
          </td>
          <td class="px-4 py-3 text-gray-600 text-xs">
            <%= new Date(t.work_date).toLocaleDateString('en-AU', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric' }) %>
          </td>
          <td class="px-4 py-3 text-gray-900 font-medium"><%= t.crew_name %></td>
          <td class="px-4 py-3">
            <a href="/projects/<%= t.job_id %>" class="text-brand-600 hover:text-brand-600 text-xs"><%= t.job_number %></a>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= t.start_time %></td>
          <td class="px-4 py-3 text-gray-600"><%= t.end_time %></td>
          <td class="px-4 py-3 text-gray-500"><%= t.break_minutes %>m</td>
          <td class="px-4 py-3 text-gray-900 font-medium"><%= parseFloat(t.total_hours).toFixed(1) %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (t.shift_type === 'night') { %>bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20
              <% } else if (t.shift_type === 'split') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20<% } %>">
              <%= t.shift_type %>
            </span>
          </td>
          <td class="px-4 py-3">
            <% if (t.approved) { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Approved</span>
            <% } else { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-50 text-orange-700 ring-1 ring-orange-600/20">Pending</span>
            <% } %>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <% if (!t.approved) { %>
                <form method="POST" action="/timesheets/<%= t.id %>/approve" class="inline">
                  <button type="submit" class="text-emerald-600 hover:text-emerald-600 transition" title="Approve">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </button>
                </form>
              <% } %>
              <form method="POST" action="/timesheets/<%= t.id %>/delete" class="inline" onsubmit="return confirm('Delete this timesheet entry?')">
                <button type="submit" class="text-red-600 hover:text-red-600 transition" title="Delete">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Bulk Approve Button -->
  <div class="mt-4 flex items-center justify-between">
    <div class="text-xs text-gray-400"><%= timesheets.length %> entr<%= timesheets.length !== 1 ? 'ies' : 'y' %> found</div>
    <button type="submit" id="bulkApproveBtn" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed" disabled>
      Approve Selected
    </button>
  </div>
</form>
<% } %>

<script>
  // Select all checkbox
  const selectAll = document.getElementById('selectAll');
  const bulkBtn = document.getElementById('bulkApproveBtn');
  if (selectAll) {
    selectAll.addEventListener('change', function() {
      document.querySelectorAll('.bulk-checkbox').forEach(cb => { cb.checked = this.checked; });
      updateBulkBtn();
    });
    document.querySelectorAll('.bulk-checkbox').forEach(cb => {
      cb.addEventListener('change', updateBulkBtn);
    });
  }
  function updateBulkBtn() {
    if (!bulkBtn) return;
    const checked = document.querySelectorAll('.bulk-checkbox:checked').length;
    bulkBtn.disabled = checked === 0;
    bulkBtn.textContent = checked > 0 ? `Approve Selected (${checked})` : 'Approve Selected';
  }
</script>
