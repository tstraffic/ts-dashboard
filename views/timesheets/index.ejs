<% locals.currentPage = 'timesheets' %>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Timesheets</h1>
    <p class="text-gray-500 text-sm mt-0.5">Crew hours &middot; approvals &middot; overtime tracking</p>
  </div>
  <a href="/timesheets/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    Log Timesheet
  </a>
</div>

<!-- Sub-navigation -->
<div class="flex items-center gap-1 mb-5 border-b border-gray-200 pb-2">
  <a href="/timesheets" class="px-3 py-1.5 text-sm font-medium rounded-lg bg-brand-50 text-brand-700">Timesheets</a>
  <a href="/timesheets/crew" class="px-3 py-1.5 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors">Crew Members</a>
  <a href="/timesheets/summary" class="px-3 py-1.5 text-sm font-medium rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors">Weekly Summary</a>
</div>

<!-- Stats Bar -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total Hours</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.totalHours %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-orange-400 uppercase tracking-widest">Pending</p>
    <p class="text-xl font-bold <%= stats.pendingApproval > 0 ? 'text-orange-600' : 'text-gray-300' %> mt-0.5"><%= stats.pendingApproval %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Approved</p>
    <p class="text-xl font-bold text-emerald-600 mt-0.5"><%= stats.approvedCount %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-brand-500 uppercase tracking-widest">Crew Logged</p>
    <p class="text-xl font-bold text-brand-600 mt-0.5"><%= stats.uniqueCrew %></p>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/timesheets" data-module="timesheets" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1 min-w-0 sm:min-w-[160px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
        <% }) %>
      </select>
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[140px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Crew</label>
        <select name="crew_member_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Crew</option>
          <% crew.forEach(c => { %>
            <option value="<%= c.id %>" <%= filters.crew_member_id == c.id ? 'selected' : '' %>><%= c.full_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Date</label>
        <input type="date" name="work_date" value="<%= filters.work_date || '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[100px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="approved" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <option value="0" <%= filters.approved === '0' ? 'selected' : '' %>>Pending</option>
          <option value="1" <%= filters.approved === '1' ? 'selected' : '' %>>Approved</option>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Apply</button>
      <a href="/timesheets" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/timesheets.csv?job_id=<%= filters.job_id || '' %>&crew_member_id=<%= filters.crew_member_id || '' %>&work_date=<%= filters.work_date || '' %>&approved=<%= filters.approved || '' %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="hidden sm:inline">CSV</span>
      </a>
    </div>
  </form>
</div>

<!-- Timesheets Table -->
<% if (timesheets.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No timesheets found</h3>
    <p class="text-gray-500 text-sm mb-1">Timesheets record crew hours, shift types, and on-site roles for each job.</p>
    <p class="text-gray-400 text-xs mb-4">Log timesheets to track labour costs, calculate overtime, and manage approvals.</p>
    <a href="/timesheets/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Log Timesheet
    </a>
  </div>
<% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <% const tsSortParams = '&job_id=' + encodeURIComponent(filters.job_id || '') + '&crew_member_id=' + encodeURIComponent(filters.crew_member_id || '') + '&work_date=' + encodeURIComponent(filters.work_date || '') + '&approved=' + encodeURIComponent(filters.approved || ''); %>
        <tr class="border-b border-gray-200">
          <th class="px-2 py-2.5 text-left w-8">
            <input type="checkbox" id="select-all" class="rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500" title="Select all">
          </th>
          <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Date', field: 'work_date', currentSort: sort, currentOrder: order, baseUrl: '/timesheets', extraParams: tsSortParams }) %></th>
          <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Crew', field: 'crew_name', currentSort: sort, currentOrder: order, baseUrl: '/timesheets', extraParams: tsSortParams }) %></th>
          <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Job</th>
          <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Time</th>
          <th class="px-3 py-2.5 text-right"><%- include('../partials/sort-header', { label: 'Hours', field: 'total_hours', currentSort: sort, currentOrder: order, baseUrl: '/timesheets', extraParams: tsSortParams }) %></th>
          <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Shift</th>
          <th class="px-3 py-2.5 text-center"><%- include('../partials/sort-header', { label: 'Status', field: 'approved', currentSort: sort, currentOrder: order, baseUrl: '/timesheets', extraParams: tsSortParams }) %></th>
          <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest w-16">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% timesheets.forEach(t => { %>
        <tr class="hover:bg-gray-50 <%= !t.approved ? 'bg-orange-50/30' : '' %>">
          <td class="px-2 py-2">
            <input type="checkbox" name="timesheet_ids" value="<%= t.id %>" class="bulk-checkbox rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500">
          </td>
          <td class="px-3 py-2 text-gray-600 text-xs tabular-nums">
            <%= new Date(t.work_date).toLocaleDateString('en-AU', { weekday: 'short', day: '2-digit', month: 'short' }) %>
          </td>
          <td class="px-3 py-2 text-gray-900 font-medium text-xs"><%= t.crew_name %></td>
          <td class="px-3 py-2 hidden sm:table-cell">
            <a href="/projects/<%= t.job_id %>" class="text-brand-600 hover:text-brand-700 text-xs"><%= t.job_number %></a>
          </td>
          <td class="px-3 py-2 text-gray-500 text-xs hidden md:table-cell tabular-nums"><%= t.start_time %>-<%= t.end_time %> <span class="text-gray-300">(<%= t.break_minutes %>m brk)</span></td>
          <td class="px-3 py-2 text-right text-xs tabular-nums">
            <span class="font-semibold <%= parseFloat(t.total_hours) > 10 ? 'text-red-600' : parseFloat(t.total_hours) > 8 ? 'text-amber-600' : 'text-gray-900' %>"><%= parseFloat(t.total_hours).toFixed(1) %></span>
            <% if (t.overtime_hours && parseFloat(t.overtime_hours) > 0) { %>
              <span class="text-amber-600 text-[9px] font-medium ml-0.5">(<%= parseFloat(t.overtime_hours).toFixed(1) %>h OT)</span>
            <% } else if (parseFloat(t.total_hours) > 8) { %>
              <span class="text-[9px] font-bold text-amber-600 ml-0.5">OT</span>
            <% } %>
          </td>
          <td class="px-3 py-2 hidden lg:table-cell">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium
              <% if (t.shift_type === 'night') { %>bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20
              <% } else if (t.shift_type === 'split') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20<% } %>">
              <%= t.shift_type %>
            </span>
          </td>
          <td class="px-3 py-2 text-center">
            <% if (t.approved) { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Approved</span>
            <% } else { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-orange-50 text-orange-700 ring-1 ring-orange-600/20">Pending</span>
            <% } %>
          </td>
          <td class="px-3 py-2 text-right">
            <div class="flex items-center justify-end gap-1">
              <% if (!t.approved) { %>
                <form method="POST" action="/timesheets/<%= t.id %>/approve" class="inline">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="p-1 text-emerald-600 hover:bg-emerald-50 rounded transition" title="Approve">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </button>
                </form>
              <% } %>
              <form method="POST" action="/timesheets/<%= t.id %>/delete" class="inline" onsubmit="return confirm('Delete this entry?')">
                <%- include('../partials/csrf') %>
                <button type="submit" class="p-1 text-red-400 hover:text-red-600 hover:bg-red-50 rounded transition" title="Delete">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="mt-2 text-xs text-gray-400"><%= timesheets.length %> entr<%= timesheets.length !== 1 ? 'ies' : 'y' %></div>
  <%- include('../partials/bulk-actions', { actions: [{ value: 'approve', label: 'Approve Selected' }, { value: 'delete', label: 'Delete Selected' }], formAction: '/timesheets/bulk' }) %>
<% } %>
