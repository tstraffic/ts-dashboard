<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>T&S Operations Dashboard</title>

  <!-- PWA Meta Tags -->
  <meta name="theme-color" content="#020817">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="T&S Ops">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="application-name" content="T&S Operations">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <link rel="manifest" href="/manifest-admin.json">
  <link rel="icon" type="image/jpeg" href="/images/logo-colour.jpg">
  <link rel="apple-touch-icon" href="/images/logo-colour.jpg">

  <!-- Inter Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#EFF6FF',
              100: '#DBEAFE',
              200: '#BFDBFE',
              300: '#93C5FD',
              400: '#60A5FA',
              500: '#2B7FFF',
              600: '#1D6AE5',
              700: '#1555C0',
              800: '#0F3F8E',
              900: '#0A2D66',
              950: '#051B3F',
            }
          },
          boxShadow: {
            'card': '0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.06)',
            'card-hover': '0 10px 25px -5px rgba(0,0,0,0.08), 0 4px 10px -5px rgba(0,0,0,0.04)',
            'glow': '0 0 20px rgba(43,127,255,0.15)',
          },
          borderRadius: {
            '2xl': '1rem',
            '3xl': '1.25rem',
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css?v=126">
  <link rel="stylesheet" href="/css/chat.css?v=3">
  <style>/* Hide Tailwind CDN dev indicator */#__tailwind_indicator,div[style*="z-index: 2147483647"]{display:none!important}</style>
  <!-- Remove dark-glass early if user explicitly chose light mode -->
  <script>(function(){try{if(localStorage.getItem('ts-theme-2')==='light'){document.addEventListener('DOMContentLoaded',function(){document.body.classList.remove('dark-glass');});}}catch(e){}})();</script>
</head>
<body class="h-full text-gray-900 font-sans antialiased dark-glass">
  <div class="flex h-full">
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 min-h-screen">
      <%- include('partials/header') %>

      <main class="flex-1 overflow-auto min-w-0">
      <div class="px-3 sm:px-4 md:px-6 lg:px-8 py-4 sm:py-6">
        <% if (typeof flash_success !== 'undefined' && flash_success.length > 0) { %>
          <% flash_success.forEach(msg => { %>
            <div class="flash-msg mb-4 p-3.5 bg-emerald-50 border border-emerald-200/80 rounded-xl text-emerald-800 text-sm flex items-center gap-3 shadow-sm">
              <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="flex-1 font-medium"><%= msg %></span>
              <button onclick="this.parentElement.style.opacity='0';this.parentElement.style.transform='translateY(-8px)';setTimeout(()=>this.parentElement.remove(),200)" class="text-emerald-400 hover:text-emerald-600 flex-shrink-0 p-1 rounded-lg hover:bg-emerald-100 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          <% }) %>
        <% } %>
        <% if (typeof flash_error !== 'undefined' && flash_error.length > 0) { %>
          <% flash_error.forEach(msg => { %>
            <div class="flash-msg mb-4 p-3.5 bg-red-50 border border-red-200/80 rounded-xl text-red-800 text-sm flex items-center gap-3 shadow-sm">
              <div class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01"/></svg>
              </div>
              <span class="flex-1 font-medium"><%= msg %></span>
              <button onclick="this.parentElement.style.opacity='0';this.parentElement.style.transform='translateY(-8px)';setTimeout(()=>this.parentElement.remove(),200)" class="text-red-400 hover:text-red-600 flex-shrink-0 p-1 rounded-lg hover:bg-red-100 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          <% }) %>
        <% } %>

        <%- body %>
      </div>
      <%- include('partials/footer') %>
    </main>
    </div>
  </div>

  <script src="/js/step-wizard.js"></script>
  <script src="/js/app.js"></script>
  <script src="/js/dropzone.js"></script>
  <script src="/js/chat.js?v=3"></script>
  <%- script %>

  <!-- Register admin service worker -->
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/admin-sw.js?v=28', { updateViaCache: 'none' })
        .then(function(reg) {
          reg.update();
          console.log('Admin SW registered, scope:', reg.scope);
        })
        .catch(function(err) { console.log('Admin SW registration failed:', err); });
      // Auto-refresh when new SW activates
      navigator.serviceWorker.addEventListener('message', function(e) {
        if (e.data && e.data.type === 'SW_UPDATED') window.location.reload();
      });
    }
  </script>

  <!-- Global Lightbox overlay for images & documents -->
  <div id="lightbox-overlay" class="fixed inset-0 z-[9999] bg-black/90 hidden flex-col items-center justify-center" style="display:none;">
    <div class="absolute top-0 left-0 right-0 flex items-center justify-between px-4 py-3 bg-gradient-to-b from-black/60 to-transparent z-10">
      <span id="lightbox-title" class="text-white text-sm font-medium truncate max-w-[70%]"></span>
      <div class="flex items-center gap-3">
        <a id="lightbox-download" href="#" download class="text-white/80 hover:text-white p-2" title="Download">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </a>
        <a id="lightbox-newtab" href="#" target="_blank" class="text-white/80 hover:text-white p-2" title="Open in new tab">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        <button id="lightbox-close" class="text-white hover:text-red-400 p-2 -mr-2" title="Close">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <img id="lightbox-img" src="" alt="" class="hidden max-w-[95vw] max-h-[85vh] object-contain rounded shadow-2xl select-none" draggable="false">
    <iframe id="lightbox-iframe" src="" class="hidden rounded shadow-2xl bg-white" style="width:90vw;height:85vh;"></iframe>
  </div>
  <script>
  (function(){
    var overlay = document.getElementById('lightbox-overlay');
    var img = document.getElementById('lightbox-img');
    var iframe = document.getElementById('lightbox-iframe');
    var title = document.getElementById('lightbox-title');
    var dl = document.getElementById('lightbox-download');
    var nt = document.getElementById('lightbox-newtab');
    var closeBtn = document.getElementById('lightbox-close');
    if (!overlay) return;

    function openLightbox(href, name, isImage) {
      img.classList.add('hidden'); iframe.classList.add('hidden');
      if (isImage) { img.src = href; img.classList.remove('hidden'); }
      else { iframe.src = href; iframe.classList.remove('hidden'); }
      title.textContent = name || '';
      dl.href = href; nt.href = href;
      overlay.style.display = 'flex'; overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      overlay.style.display = 'none'; overlay.classList.add('hidden');
      img.src = ''; iframe.src = '';
      document.body.style.overflow = '';
    }

    closeBtn.addEventListener('click', closeLightbox);
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && overlay.style.display === 'flex') closeLightbox();
    });

    // Delegate clicks on any [data-lightbox] links
    document.addEventListener('click', function(e) {
      var link = e.target.closest('[data-lightbox]');
      if (!link) return;
      e.preventDefault();
      var href = link.getAttribute('href') || link.getAttribute('data-lightbox');
      var name = link.getAttribute('data-lightbox-name') || link.getAttribute('title') || '';
      var mime = (link.getAttribute('data-lightbox-mime') || '').toLowerCase();
      var isImage = mime.startsWith('image/') || /\.(jpg|jpeg|png|gif|webp|heic)$/i.test(href);
      openLightbox(href, name, isImage);
    });
  })();
  </script>
</body>
</html>
