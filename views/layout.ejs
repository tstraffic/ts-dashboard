<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>T&S Operations Dashboard</title>

  <!-- PWA Meta Tags -->
  <meta name="theme-color" content="#1D6AE5">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="T&S Ops">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="application-name" content="T&S Operations">
  <link rel="manifest" href="/manifest-admin.json">
  <link rel="apple-touch-icon" href="/images/logo-colour.jpg">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#EFF6FF',
              100: '#DBEAFE',
              200: '#BFDBFE',
              300: '#93C5FD',
              400: '#60A5FA',
              500: '#2B7FFF',
              600: '#1D6AE5',
              700: '#1555C0',
              800: '#0F3F8E',
              900: '#0A2D66',
              950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css">
  <style>/* Hide Tailwind CDN dev indicator */#__tailwind_indicator,div[style*="z-index: 2147483647"]{display:none!important}</style>
</head>
<body class="h-full bg-gray-50 text-gray-900">
  <div class="flex h-full">
    <%- include('partials/sidebar') %>

    <div class="flex-1 flex flex-col min-w-0 min-h-screen">
      <%- include('partials/header') %>

      <main class="flex-1 overflow-auto min-w-0">
      <div class="px-3 sm:px-4 md:px-6 lg:px-8 py-4 sm:py-6">
        <% if (typeof flash_success !== 'undefined' && flash_success.length > 0) { %>
          <% flash_success.forEach(msg => { %>
            <div class="mb-4 p-3 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-800 text-sm flex items-center justify-between">
              <span><%= msg %></span>
              <button onclick="this.parentElement.remove()" class="text-emerald-600 hover:text-emerald-800 ml-2 flex-shrink-0">&times;</button>
            </div>
          <% }) %>
        <% } %>
        <% if (typeof flash_error !== 'undefined' && flash_error.length > 0) { %>
          <% flash_error.forEach(msg => { %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm flex items-center justify-between">
              <span><%= msg %></span>
              <button onclick="this.parentElement.remove()" class="text-red-600 hover:text-red-800 ml-2 flex-shrink-0">&times;</button>
            </div>
          <% }) %>
        <% } %>

        <%- body %>
      </div>
      <%- include('partials/footer') %>
    </main>
    </div>
  </div>

  <script src="/js/step-wizard.js"></script>
  <script src="/js/app.js"></script>
  <%- script %>

  <!-- Register admin service worker -->
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/admin-sw.js')
        .then(function(reg) { console.log('Admin SW registered, scope:', reg.scope); })
        .catch(function(err) { console.log('Admin SW registration failed:', err); });
    }
  </script>
</body>
</html>
