<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>T&S Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/custom.css">
</head>
<body class="h-full bg-slate-900 text-slate-100">
  <%- include('partials/header') %>

  <div class="flex flex-1" style="min-height: calc(100vh - 64px);">
    <%- include('partials/sidebar') %>

    <main class="flex-1 overflow-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
        <% if (typeof flash_success !== 'undefined' && flash_success.length > 0) { %>
          <% flash_success.forEach(msg => { %>
            <div class="mb-4 p-3 bg-emerald-900/50 border border-emerald-700 rounded-lg text-emerald-300 text-sm flex items-center justify-between">
              <span><%= msg %></span>
              <button onclick="this.parentElement.remove()" class="text-emerald-400 hover:text-emerald-200">&times;</button>
            </div>
          <% }) %>
        <% } %>
        <% if (typeof flash_error !== 'undefined' && flash_error.length > 0) { %>
          <% flash_error.forEach(msg => { %>
            <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm flex items-center justify-between">
              <span><%= msg %></span>
              <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-200">&times;</button>
            </div>
          <% }) %>
        <% } %>

        <%- body %>
      </div>
      <%- include('partials/footer') %>
    </main>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
