<%
  const isEdit = !!item;
  const formAction = isEdit ? '/compliance/' + item.id : '/compliance';
  const pageTitle = isEdit ? 'Edit Plan' : 'New Plan';
  const cancelHref = (typeof returnTo !== 'undefined' && returnTo) ? returnTo : '/compliance';

  const TYPE_LABELS = {
    traffic_guidance:    'TGS (Traffic Guidance Scheme)',
    tmp_approval:        'CTMP (Construction Traffic Mgmt Plan)',
    spa:                 'SPA (Swept Path Analysis)',
    sza:                 'SZA (Speed Zone Authorisation)',
    rol:                 'ROL (Road Occupancy Licence)',
    council_permit:      'Council Permit',
    bus_approval:        'Bus Approval',
    police_notification: 'Police Notification',
    letter_drop:         'Letter Drop',
    other:               'Other',
  };

  const STATUS_BADGE = {
    not_started: 'bg-gray-100 text-gray-700 ring-gray-200',
    started:     'bg-amber-50 text-amber-700 ring-amber-200',
    submitted:   'bg-blue-50 text-blue-700 ring-blue-200',
    approved:    'bg-emerald-50 text-emerald-700 ring-emerald-200',
    rejected:    'bg-rose-50 text-rose-700 ring-rose-200',
    expired:     'bg-orange-50 text-orange-700 ring-orange-200',
  };

  // Group sub-plans by item_type so we can render a section per type.
  const groupedSubPlans = {};
  (subPlans || []).forEach(s => {
    (groupedSubPlans[s.item_type] = groupedSubPlans[s.item_type] || []).push(s);
  });

  const planNumber = isEdit ? item.plan_number : null;
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <a href="<%= cancelHref %>" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-3">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    </a>
    <div class="flex items-center justify-between flex-wrap gap-2">
      <h1 class="text-2xl font-bold text-gray-900"><%= pageTitle %><% if (isEdit) { %> <span class="text-gray-400 font-mono text-lg">#<%= planNumber %></span><% } %></h1>
      <div class="flex items-center gap-2 flex-wrap">
        <% if (isEdit && typeof tender !== 'undefined' && tender) { %>
          <a href="/tenders/<%= tender.id %>" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-semibold bg-purple-50 text-purple-700 ring-1 ring-purple-600/20 hover:bg-purple-100">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            Tender <%= tender.tender_number %>
          </a>
        <% } %>
        <% if (isEdit) { %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium ring-1 ring-inset <%= STATUS_BADGE[item.status] || STATUS_BADGE.not_started %>">
            <%= (item.status || 'not_started').replace(/_/g, ' ') %>
          </span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Parent fields form -->
  <form method="POST" action="<%= formAction %>" id="planForm" class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    <%- include('../partials/csrf') %>
    <input type="hidden" name="return_to" value="<%= cancelHref %>">
    <% if (!isEdit) { %><input type="hidden" name="is_parent" value="1"><% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="md:col-span-2">
        <label for="title" class="block text-sm font-medium text-gray-700 mb-1.5">Plan Name <span class="text-rose-500">*</span></label>
        <input type="text" id="title" name="title" required
          value="<%= isEdit ? (item.title || '') : '' %>"
          placeholder="e.g. Canterbury Road Project"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
      </div>

      <div>
        <label for="job_id" class="block text-sm font-medium text-gray-700 mb-1.5">Project / Job</label>
        <select id="job_id" name="job_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">— None —</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>" <%= (isEdit && item.job_id == j.id) || (!isEdit && prefillJobId == j.id) ? 'selected' : '' %>>
              <%= j.job_number %> — <%= j.project_name || j.client || '' %>
            </option>
          <% }) %>
        </select>
      </div>

      <% var tendersList = (typeof tenders !== 'undefined' && Array.isArray(tenders)) ? tenders : [];
         var prefillTender = (typeof prefillTenderId !== 'undefined') ? prefillTenderId : ''; %>
      <div>
        <label for="tender_id" class="block text-sm font-medium text-gray-700 mb-1.5">Tender <span class="text-gray-400 font-normal">(optional)</span></label>
        <select id="tender_id" name="tender_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">— None —</option>
          <% tendersList.forEach(t => { %>
            <option value="<%= t.id %>" <%= (isEdit && item.tender_id == t.id) || (!isEdit && String(prefillTender) === String(t.id)) ? 'selected' : '' %>>
              <%= t.tender_number %> — <%= t.title %>
            </option>
          <% }) %>
        </select>
      </div>

      <div>
        <label for="client_id" class="block text-sm font-medium text-gray-700 mb-1.5">Client</label>
        <select id="client_id" name="client_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">— None —</option>
          <% clients.forEach(c => { %>
            <option value="<%= c.id %>" <%= (isEdit && item.client_id == c.id) || (!isEdit && prefillClientId == c.id) ? 'selected' : '' %>>
              <%= c.company_name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div>
        <label for="pm_id" class="block text-sm font-medium text-gray-700 mb-1.5">Project PM</label>
        <select id="pm_id" name="pm_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">— Unassigned —</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= (isEdit && item.assigned_to_id == u.id) ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>

      <div>
        <label for="client_request_date" class="block text-sm font-medium text-gray-700 mb-1.5">Client Request Date</label>
        <input type="date" id="client_request_date" name="client_request_date"
          value="<%= isEdit ? (item.client_request_date || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
      </div>

      <div class="md:col-span-2">
        <label for="notes" class="block text-sm font-medium text-gray-700 mb-1.5">Plan Notes</label>
        <textarea id="notes" name="notes" rows="2"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"><%= isEdit ? (item.notes || '') : '' %></textarea>
      </div>
    </div>

    <% if (!isEdit) { %>
      <!-- Type & quantity grid (create only). Tick a type, set how many,
           and pick an owner — each sub-plan of that type lands assigned
           to the chosen user. -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h2 class="text-sm font-semibold text-gray-900 mb-1">Sub-plans to generate</h2>
        <p class="text-sm text-gray-500 mb-4">Tick each type you need, set how many, and pick an owner for that type. Each one becomes its own slot with a system reference (e.g. <code class="px-1.5 py-0.5 bg-gray-100 rounded">TSTGS3100-1</code>) you can name and upload to.</p>
        <div class="space-y-2.5">
          <% subPlanTypes.forEach(t => { %>
            <div class="border border-gray-200 rounded-lg hover:border-brand-300 hover:bg-brand-50/40 has-[:checked]:border-brand-400 has-[:checked]:bg-brand-50">
              <label class="grid grid-cols-[1fr_auto_minmax(0,200px)] items-center gap-3 px-4 py-3 cursor-pointer">
                <span class="flex items-center gap-2.5 text-sm text-gray-800">
                  <input type="checkbox" class="type-toggle w-4 h-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500" data-type="<%= t %>">
                  <%= TYPE_LABELS[t] || t %>
                </span>
                <input type="number" name="count_<%= t %>" min="1" max="20" value="1" disabled
                  class="count-input w-16 px-2 py-1 text-sm text-center border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 disabled:bg-gray-50 disabled:text-gray-400">
                <select name="owner_<%= t %>" disabled
                  class="owner-input w-full px-2 py-1 text-sm bg-white border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 disabled:bg-gray-50 disabled:text-gray-400">
                  <option value="">— Owner —</option>
                  <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.full_name %></option><% }) %>
                </select>
              </label>
              <% if (t === 'other') { %>
                <div class="px-4 pb-3 -mt-1 hidden other-desc-wrap space-y-1.5" id="otherDescList">
                  <p class="text-[11px] text-gray-500">Describe each one — one row per "Other" you're generating.</p>
                  <!-- Description inputs are rendered by JS when count or checkbox changes -->
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
      <script>
        // Toggle: ticking a type enables its count + owner inputs.
        // Disabled inputs aren't submitted, so unticked types vanish.
        document.querySelectorAll('.type-toggle').forEach(cb => {
          cb.addEventListener('change', e => {
            const card = e.target.closest('.border');
            const countInput = card.querySelector('.count-input');
            countInput.disabled = !cb.checked;
            card.querySelector('.owner-input').disabled = !cb.checked;
            if (cb.dataset.type === 'other') {
              renderOtherDescriptions(card, cb.checked);
              if (cb.checked) {
                const first = card.querySelector('.other-desc-row input');
                if (first) first.focus(); else countInput.focus();
                return;
              }
            }
            if (cb.checked) countInput.focus();
          });
        });

        // Other gets one description input per count. When count changes
        // we add/remove rows so each "Other" sub-plan has its own label.
        function renderOtherDescriptions(card, checked) {
          const wrap = card.querySelector('.other-desc-wrap');
          if (!wrap) return;
          wrap.classList.toggle('hidden', !checked);
          if (!checked) { wrap.querySelectorAll('.other-desc-row').forEach(r => r.remove()); return; }
          const count = Math.max(1, parseInt(card.querySelector('.count-input').value, 10) || 1);
          // Preserve current values when re-rendering
          const existing = Array.from(wrap.querySelectorAll('.other-desc-row input')).map(i => i.value);
          wrap.querySelectorAll('.other-desc-row').forEach(r => r.remove());
          for (let i = 1; i <= count; i++) {
            const row = document.createElement('div');
            row.className = 'other-desc-row flex items-center gap-2';
            row.innerHTML = `
              <span class="text-[11px] font-mono text-gray-400 w-6 shrink-0">#${i}</span>
              <input type="text" name="other_description_${i}" maxlength="120"
                placeholder="What is Other #${i}? e.g. RMS letter, environmental approval…"
                class="flex-1 px-3 py-2 text-sm bg-white border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
            `;
            const input = row.querySelector('input');
            if (existing[i - 1] != null) input.value = existing[i - 1];
            wrap.appendChild(row);
          }
        }

        // Re-render description rows when the "Other" count changes
        document.querySelectorAll('.type-toggle[data-type="other"]').forEach(cb => {
          const card = cb.closest('.border');
          const countInput = card.querySelector('.count-input');
          countInput.addEventListener('input', () => {
            if (cb.checked) renderOtherDescriptions(card, true);
          });
        });
      </script>
    <% } %>
    <% if (!isEdit) { %>
      <!-- Inline submit on create flow (edit flow shows buttons at the bottom of the page) -->
      <div class="mt-6 pt-6 border-t border-gray-200 flex items-center justify-end gap-3">
        <a href="<%= cancelHref %>" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-lg">Create Plan</button>
      </div>
    <% } %>
  </form>

  <% if (isEdit) {
    // Plan-wide tallies — sums across every sub-plan, regardless of
    // status, so the totals stay visible even before submission.
    let totalHours = 0, totalCharge = 0, totalCouncilFee = 0, submittedCount = 0;
    (subPlans || []).forEach(s => {
      totalHours += parseFloat(s.hours_spent) || 0;
      if (s.charge_client) totalCharge += parseFloat(s.charge_amount) || 0;
      if (s.council_fee_paid) totalCouncilFee += parseFloat(s.council_fee_amount) || 0;
      if (['submitted','approved'].includes(s.status)) submittedCount += 1;
    });
    const fmtMoney = n => '$' + (Math.round(n * 100) / 100).toFixed(2);
    const fmtHours = n => (Math.round(n * 100) / 100) + ' hr' + (n === 1 ? '' : 's');
    // Internal cost / profit — admin + finance only. Cost = hours×rate +
    // council fees; profit = client charge − cost. Council fees are a
    // pass-through expense to T&S, so they belong in cost.
    const hourlyRate = parseFloat((systemConfig && systemConfig.internal_hourly_rate) || 40) || 40;
    const totalLabourCost = totalHours * hourlyRate;
    const totalCost = totalLabourCost + totalCouncilFee;
    const totalProfit = totalCharge - totalCost;
  %>
    <!-- Sub-plan grid (edit only) -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Sub-plans</h2>
          <p class="text-sm text-gray-500">Each sub-plan becomes "submitted" the moment you upload its files. Use the buttons after that to approve or reject.</p>
        </div>
      </div>

      <% if (subPlans && subPlans.length > 0) { %>
        <!-- Plan totals strip — rolls up hours and money across all sub-plans.
             Cost + profit tiles only render for admin/finance (canSeeCost). -->
        <div class="grid grid-cols-2 <%= canSeeCost ? 'sm:grid-cols-3 lg:grid-cols-6' : 'sm:grid-cols-4' %> gap-3 mb-5 p-4 bg-gradient-to-br from-brand-50 to-blue-50 border border-brand-100 rounded-lg">
          <div>
            <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Sub-plans</div>
            <div class="text-lg font-bold text-gray-900 mt-0.5"><%= submittedCount %> / <%= subPlans.length %> <span class="text-xs font-normal text-gray-500">submitted</span></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Total hours</div>
            <div class="text-lg font-bold text-gray-900 mt-0.5"><%= fmtHours(totalHours) %></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">To charge client</div>
            <div class="text-lg font-bold text-emerald-700 mt-0.5"><%= fmtMoney(totalCharge) %></div>
          </div>
          <div>
            <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Council fees</div>
            <div class="text-lg font-bold text-amber-700 mt-0.5"><%= fmtMoney(totalCouncilFee) %></div>
          </div>
          <% if (canSeeCost) { %>
            <div title="Hours × $<%= hourlyRate %>/hr + council fees">
              <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold flex items-center gap-1">
                T&amp;S cost
                <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m0 0v.01M12 12a3 3 0 100-6 3 3 0 000 6z"/></svg>
              </div>
              <div class="text-lg font-bold text-gray-900 mt-0.5"><%= fmtMoney(totalCost) %></div>
              <div class="text-[10px] text-gray-500 leading-tight">labour <%= fmtMoney(totalLabourCost) %></div>
            </div>
            <div>
              <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Profit / Loss</div>
              <div class="text-lg font-bold mt-0.5 <%= totalProfit >= 0 ? 'text-emerald-700' : 'text-rose-700' %>">
                <%= (totalProfit >= 0 ? '' : '-') + fmtMoney(Math.abs(totalProfit)) %>
              </div>
              <div class="text-[10px] text-gray-500 leading-tight">
                <% if (totalCharge > 0) { %>
                  margin <%= ((totalProfit / totalCharge) * 100).toFixed(1) %>%
                <% } else { %>
                  no client charge yet
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
        <% if (canSeeCost) { %>
          <div class="mb-5 -mt-3 px-1 text-[11px] text-gray-500 italic">Cost + profit visible to admin &amp; finance only · internal rate $<%= hourlyRate %>/hr</div>
        <% } %>
      <% } %>

      <% if (!subPlans || subPlans.length === 0) { %>
        <div class="text-center py-8 text-sm text-gray-500 bg-gray-50 rounded-lg">No sub-plans yet. Add one below.</div>
      <% } %>

      <% subPlanTypes.forEach(t => { const list = groupedSubPlans[t] || []; %>
        <% if (list.length > 0) { %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold text-gray-700"><%= TYPE_LABELS[t] || t %> <span class="text-gray-400">(<%= list.length %>)</span></h3>
              <form method="POST" action="/compliance/<%= item.id %>/sub-plans" class="inline">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="item_type" value="<%= t %>">
                <button type="submit" class="text-xs font-medium text-brand-600 hover:text-brand-700">+ Add another</button>
              </form>
            </div>
            <div class="space-y-3">
              <% list.forEach(sub => { %>
                <%- include('./_sub_plan_card', { sub, docs: (subPlanDocs && subPlanDocs[sub.id]) || [], parentId: item.id, statusBadge: STATUS_BADGE }) %>
              <% }) %>
            </div>
          </div>
        <% } %>
      <% }) %>

      <script>
        // "Charge client" / "Council fee" toggles enable their matching
        // amount input — same pattern as the create-page count grid.
        document.querySelectorAll('.charge-toggle').forEach(cb => {
          cb.addEventListener('change', e => {
            const target = document.getElementById(cb.dataset.target);
            if (!target) return;
            target.disabled = !cb.checked;
            if (cb.checked) target.focus();
          });
        });
      </script>

      <!-- Add a sub-plan of any type -->
      <details class="mt-4 group">
        <summary class="cursor-pointer inline-flex items-center text-sm font-medium text-brand-600 hover:text-brand-700 list-none">
          <svg class="w-4 h-4 mr-1 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add a sub-plan
        </summary>
        <form method="POST" action="/compliance/<%= item.id %>/sub-plans" class="mt-3 space-y-2" id="addSubPlanForm">
          <%- include('../partials/csrf') %>
          <div class="flex items-center gap-2">
            <select name="item_type" id="addSubPlanType" required class="flex-1 px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
              <% subPlanTypes.forEach(t => { %>
                <option value="<%= t %>"><%= TYPE_LABELS[t] || t %></option>
              <% }) %>
            </select>
            <button type="submit" class="px-3 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-lg">Add</button>
          </div>
          <%/* Description input only renders + submits when "Other" is picked. Disabled
               otherwise so it never lands on the body for non-Other types. */%>
          <div id="addSubPlanOtherDesc" class="hidden">
            <input type="text" name="other_description" maxlength="120" disabled
              placeholder='What is this Other? e.g. "Methodologies", "Staging"'
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
            <p class="mt-1 text-[11px] text-gray-500">Lets you tell several Other rows apart on the register.</p>
          </div>
        </form>
        <script>
          (function () {
            var sel  = document.getElementById('addSubPlanType');
            var wrap = document.getElementById('addSubPlanOtherDesc');
            if (!sel || !wrap) return;
            var input = wrap.querySelector('input[name="other_description"]');
            function sync() {
              var isOther = sel.value === 'other';
              wrap.classList.toggle('hidden', !isOther);
              input.disabled = !isOther;
              if (isOther) input.focus();
            }
            sel.addEventListener('change', sync);
            sync();
          })();
        </script>
      </details>
    </div>

    <!-- Bottom-of-page submit row. Buttons sit outside #planForm but
         submit it via the HTML5 form attribute, so the parent fields at
         the top get saved together with whatever the user touched in
         the sub-plan grid. -->
    <div class="mt-6 flex items-center justify-end gap-3">
      <a href="<%= cancelHref %>" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">Cancel</a>
      <button type="submit" form="planForm" class="px-4 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-lg">Update Plan</button>
    </div>
  <% } %>
</div>
