<%
  // Renders the inside of the Invoice column for one item. Used both at
  // initial render time AND when JS swaps the cell after an action.
  // Note: the wrapping <td> is rendered by the parent template.
%>
<% if (item.invoiced) { %>
  <div class="flex items-start gap-1.5 flex-wrap">
    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-700">
      <svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      INVOICED
    </span>
    <% if (item.invoice_number) { %>
      <span class="text-[11px] font-mono text-emerald-700"><%= item.invoice_number %></span>
    <% } %>
  </div>
  <% if (item.invoiced_at) { %>
    <p class="text-[10px] text-gray-400 mt-0.5"><%= formatDate(item.invoiced_at) %><% if (item.invoiced_by_name) { %> · <%= item.invoiced_by_name.split(' ')[0] %><% } %></p>
  <% } %>
  <% if (canMarkInvoiced) { %>
    <button type="button" onclick="event.stopPropagation(); unmarkInvoiced(<%= item.id %>)"
      class="mt-1 text-[10px] text-gray-500 hover:text-red-600 underline transition">undo</button>
  <% } %>
<% } else if (item.ready_for_invoice) { %>
  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-700">
    <svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
    READY
  </span>
  <% if (item.ready_for_invoice_at) { %>
    <p class="text-[10px] text-gray-400 mt-0.5"><%= formatDate(item.ready_for_invoice_at) %><% if (item.ready_for_invoice_by_name) { %> · <%= item.ready_for_invoice_by_name.split(' ')[0] %><% } %></p>
  <% } %>
  <% if (canMarkInvoiced) { %>
    <button type="button" onclick='event.stopPropagation(); openInvoiceModal(<%= item.id %>, <%- JSON.stringify(item.title || "") %>, <%- JSON.stringify(item.invoice_number || "") %>)'
      class="mt-1 inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold text-white bg-emerald-600 hover:bg-emerald-500 rounded transition">
      Mark invoiced →
    </button>
    <button type="button" onclick="event.stopPropagation(); unmarkReady(<%= item.id %>)"
      class="ml-1 text-[10px] text-gray-500 hover:text-red-600 underline transition">undo</button>
  <% } else { %>
    <p class="text-[10px] text-gray-400 mt-0.5 italic">awaiting accounts</p>
  <% } %>
<% } else { %>
  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-500">—</span>
  <button type="button" onclick="event.stopPropagation(); markReadyForInvoice(<%= item.id %>)"
    class="block mt-1 text-[10px] font-semibold text-amber-600 hover:text-amber-700 hover:underline transition">
    Mark ready
  </button>
<% } %>
