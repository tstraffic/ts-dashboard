<%
  const isEdit = !!item;
  const formAction = isEdit ? '/compliance/' + item.id : '/compliance';
  const pageTitle = isEdit ? 'Edit Plan / Approval' : 'New Plan / Approval';
  const selectedJobId = (isEdit && item.job_id) ? item.job_id : (prefillJobId || '');
  const selectedClientId = (isEdit && item.client_id) ? item.client_id : (prefillClientId || '');
  const cancelHref = (typeof returnTo !== 'undefined' && returnTo) ? returnTo : '/compliance';

  const typeOptions = [
    { value: 'traffic_guidance',     label: 'TGS (Traffic Guidance Scheme)' },
    { value: 'tmp_approval',         label: 'CTMP (Construction Traffic Mgmt Plan)' },
    { value: 'spa',                  label: 'SPA (Special Permit Application)' },
    { value: 'rol',                  label: 'ROL (Road Occupancy Licence)' },
    { value: 'council_permit',       label: 'Council Permit' },
    { value: 'police_notification',  label: 'Police Notification' },
    { value: 'letter_drop',         label: 'Letter Drop' },
    { value: 'other',               label: 'Other' },
  ];
  const statusOptions = [
    { value: 'not_started', label: 'Not Started' },
    { value: 'submitted',   label: 'Submitted' },
    { value: 'approved',    label: 'Approved' },
    { value: 'rejected',    label: 'Rejected' },
    { value: 'expired',     label: 'Expired' },
  ];
%>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-6">
    <a href="<%= cancelHref %>" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-3">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    </a>
    <h1 class="text-2xl font-bold text-gray-900"><%= pageTitle %></h1>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <form method="POST" action="<%= formAction %>" id="complianceForm" onsubmit="return validateAssignment()">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="return_to" value="<%= cancelHref %>">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Item Type(s) - Multi-select checkboxes -->
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-600 mb-2">Type(s) <span class="text-red-600">*</span></label>
          <% const selectedTypes = isEdit && item.item_types ? item.item_types.split(',') : (isEdit && item.item_type ? [item.item_type] : []); %>
          <div class="flex flex-wrap gap-3">
            <% typeOptions.forEach(function(opt) { %>
              <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border transition-colors
                <%= selectedTypes.includes(opt.value) ? 'border-brand-500 bg-brand-50' : 'border-gray-200 bg-white hover:bg-gray-50' %>">
                <input type="checkbox" name="item_types" value="<%= opt.value %>"
                  <%= selectedTypes.includes(opt.value) ? 'checked' : '' %>
                  class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
                <span class="text-sm font-medium text-gray-700"><%= opt.label %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <!-- Title -->
        <div>
          <label for="title" class="block text-sm font-medium text-gray-600 mb-1">Title <span class="text-red-600">*</span></label>
          <input type="text" id="title" name="title" required value="<%= isEdit ? item.title : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. CTMP for Main St works, ROL #12345...">
        </div>

        <!-- Project / Client assignment (full width) -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 mb-2">
            <label class="block text-sm font-medium text-gray-600">Assign To <span class="text-red-600">*</span></label>
            <span class="text-xs text-gray-400">— select a project, a client, or both</span>
          </div>
          <div id="assignment-error" class="hidden mb-2 text-sm text-red-600 flex items-center gap-1">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Please select at least a project or a client.
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <!-- Project -->
            <div>
              <label for="job_id" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Project</label>
              <select id="job_id" name="job_id" onchange="clearAssignmentError()"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <option value="">No project</option>
                <% jobs.forEach(function(job) { %>
                  <option value="<%= job.id %>" <%= String(selectedJobId) === String(job.id) ? 'selected' : '' %>><%= job.job_number %> – <%= job.client %></option>
                <% }) %>
              </select>
            </div>
            <!-- Client -->
            <div>
              <label for="client_id" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Client</label>
              <select id="client_id" name="client_id" onchange="clearAssignmentError()"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <option value="">No client</option>
                <% clients.forEach(function(c) { %>
                  <option value="<%= c.id %>" <%= String(selectedClientId) === String(c.id) ? 'selected' : '' %>><%= c.company_name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <!-- Authority / External Approver -->
        <div>
          <label for="authority_approver" class="block text-sm font-medium text-gray-600 mb-1">Authority / External Approver</label>
          <input type="text" id="authority_approver" name="authority_approver"
            value="<%= isEdit && item.authority_approver ? item.authority_approver : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. TfNSW, Council name, RMS...">
        </div>

        <!-- Internal Approver -->
        <div>
          <label for="internal_approver_id" class="block text-sm font-medium text-gray-600 mb-1">Internal Approver</label>
          <select id="internal_approver_id" name="internal_approver_id" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Select approver...</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.id %>" <%= isEdit && item.internal_approver_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
            <% }) %>
          </select>
        </div>

        <!-- Assigned To -->
        <div>
          <label for="assigned_to_id" class="block text-sm font-medium text-gray-600 mb-1">Assigned To</label>
          <select id="assigned_to_id" name="assigned_to_id" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Unassigned</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.id %>" <%= isEdit && item.assigned_to_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
            <% }) %>
          </select>
        </div>

        <!-- Designer -->
        <div>
          <label for="designer" class="block text-sm font-medium text-gray-600 mb-1">Designer</label>
          <input type="text" id="designer" name="designer"
            value="<%= isEdit && item.designer ? item.designer : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Plan designer name...">
        </div>

        <!-- File / Document Link -->
        <div>
          <label for="file_link" class="block text-sm font-medium text-gray-600 mb-1">File / Document Link</label>
          <input type="url" id="file_link" name="file_link"
            value="<%= isEdit && item.file_link ? item.file_link : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="https://...">
        </div>

        <!-- Status -->
        <div>
          <label for="status" class="block text-sm font-medium text-gray-600 mb-1">Status</label>
          <select id="status" name="status" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <% statusOptions.forEach(function(opt) { %>
              <option value="<%= opt.value %>" <%= (isEdit ? item.status : 'not_started') === opt.value ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>

        <!-- Due Date -->
        <div>
          <label for="due_date" class="block text-sm font-medium text-gray-600 mb-1">Due Date</label>
          <input type="date" id="due_date" name="due_date"
            value="<%= isEdit && item.due_date ? item.due_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Submitted Date -->
        <div>
          <label for="submitted_date" class="block text-sm font-medium text-gray-600 mb-1">Submitted Date</label>
          <input type="date" id="submitted_date" name="submitted_date"
            value="<%= isEdit && item.submitted_date ? item.submitted_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Approved Date -->
        <div>
          <label for="approved_date" class="block text-sm font-medium text-gray-600 mb-1">Approved Date</label>
          <input type="date" id="approved_date" name="approved_date"
            value="<%= isEdit && item.approved_date ? item.approved_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Expiry Date -->
        <div>
          <label for="expiry_date" class="block text-sm font-medium text-gray-600 mb-1">Expiry Date</label>
          <input type="date" id="expiry_date" name="expiry_date"
            value="<%= isEdit && item.expiry_date ? item.expiry_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Reference Number -->
        <div>
          <label for="reference_number" class="block text-sm font-medium text-gray-600 mb-1">Reference Number</label>
          <div class="flex gap-2">
            <input type="text" id="reference_number" name="reference_number"
              value="<%= isEdit && item.reference_number ? item.reference_number : '' %>"
              class="flex-1 bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="Auto-generated or manual entry">
            <button type="button" id="generateRefBtn" onclick="generateRefNumber()"
              class="px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition-colors whitespace-nowrap"
              title="Generate next reference number">Generate</button>
          </div>
        </div>

        <!-- Client PM -->
        <div>
          <label for="client_pm" class="block text-sm font-medium text-gray-600 mb-1">Client PM</label>
          <input type="text" id="client_pm" name="client_pm"
            value="<%= isEdit && item.client_pm ? item.client_pm : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Client project manager">
        </div>

        <!-- Approvals & Notifications (checkboxes row) -->
        <div class="md:col-span-2 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Approvals & Notifications</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="rol_required" value="1" <%= isEdit && item.rol_required ? 'checked' : '' %>
                class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
              <span class="text-sm text-gray-700">ROL Required</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="bus_approvals_required" value="1" <%= isEdit && item.bus_approvals_required ? 'checked' : '' %>
                class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
              <span class="text-sm text-gray-700">Bus Approvals</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="police_notification" value="1" <%= isEdit && item.police_notification ? 'checked' : '' %>
                class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
              <span class="text-sm text-gray-700">Police Notified</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="letter_drop" value="1" <%= isEdit && item.letter_drop ? 'checked' : '' %>
                class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
              <span class="text-sm text-gray-700">Letter Drop</span>
            </label>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-3">
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">ROL Response</label>
              <input type="text" name="rol_response" value="<%= isEdit && item.rol_response ? item.rol_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Response details">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Bus Approvals Response</label>
              <input type="text" name="bus_approvals_response" value="<%= isEdit && item.bus_approvals_response ? item.bus_approvals_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Response details">
            </div>
          </div>
        </div>

        <!-- Action Required -->
        <div class="md:col-span-2">
          <label for="action_required" class="block text-sm font-medium text-gray-600 mb-1">Action Required</label>
          <input type="text" id="action_required" name="action_required"
            value="<%= isEdit && item.action_required ? item.action_required : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="What needs to happen next">
        </div>

        <!-- Costs & Billing -->
        <div class="md:col-span-2 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Costs & Billing</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Costs ($)</label>
              <input type="number" name="costs" step="0.01" min="0" value="<%= isEdit && item.costs ? item.costs : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="0.00">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Charge Amount ($)</label>
              <input type="number" name="charge_amount" step="0.01" min="0" value="<%= isEdit && item.charge_amount ? item.charge_amount : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="0.00">
            </div>
            <div class="flex items-end">
              <label class="flex items-center gap-2 cursor-pointer pb-2">
                <input type="checkbox" name="charge_client" value="1" <%= isEdit && item.charge_client ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-sm text-gray-700">Charge Client</span>
              </label>
            </div>
            <div class="flex items-end">
              <label class="flex items-center gap-2 cursor-pointer pb-2">
                <input type="checkbox" name="invoiced" value="1" <%= isEdit && item.invoiced ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-emerald-500 focus:ring-emerald-500">
                <span class="text-sm text-gray-700">Invoiced</span>
              </label>
            </div>
          </div>
          <div class="mt-3">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Invoice Number</label>
            <input type="text" name="invoice_number" value="<%= isEdit && item.invoice_number ? item.invoice_number : '' %>"
              class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 max-w-xs"
              placeholder="INV-001">
          </div>
        </div>

        <!-- Notes -->
        <div class="md:col-span-2">
          <label for="notes" class="block text-sm font-medium text-gray-600 mb-1">Comments</label>
          <textarea id="notes" name="notes" rows="3"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Additional comments..."><%= isEdit && item.notes ? item.notes : '' %></textarea>
        </div>

        <!-- Council Fee (shown for council_permit type) -->
        <div class="md:col-span-2 p-4 bg-amber-50 rounded-lg border border-amber-200" id="council-fee-section" style="display: none;">
          <h3 class="text-sm font-semibold text-amber-800 mb-3">Council Fee</h3>
          <div class="space-y-4">
            <div>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="hidden" name="council_fee_paid" value="0">
                <input type="checkbox" id="council_fee_paid" name="council_fee_paid" value="1"
                  <%= isEdit && item.council_fee_paid ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2">
                <span class="text-sm font-medium text-gray-700">Council fee has been paid</span>
              </label>
            </div>
            <div id="council-fee-amount-row" style="display: none;">
              <label for="council_fee_amount" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fee Amount ($)</label>
              <input type="number" id="council_fee_amount" name="council_fee_amount" step="0.01" min="0"
                value="<%= isEdit && item.council_fee_amount ? item.council_fee_amount : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 max-w-xs"
                placeholder="0.00">
            </div>
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
        <% if (isEdit) { %>
          <form method="POST" action="/compliance/<%= item.id %>/delete" onsubmit="return confirm('Delete this item?')" style="display:inline;">
            <%- include('../partials/csrf') %>
            <input type="hidden" name="return_to" value="<%= cancelHref %>">
            <button type="submit" class="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition text-sm font-medium">Delete</button>
          </form>
        <% } else { %>
          <div></div>
        <% } %>
        <div class="flex gap-3">
          <a href="<%= cancelHref %>" class="px-4 py-2 bg-white text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition font-medium text-sm">Cancel</a>
          <button type="submit" class="px-6 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-semibold text-sm">
            <%= isEdit ? 'Update Item' : 'Create Item' %>
          </button>
        </div>
      </div>
    </form>

    <% if (isEdit) { %>
    <!-- Documents & Attachments -->
    <div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Documents & Attachments</h3>

      <% const docs = (typeof documents !== 'undefined') ? documents : []; %>
      <% if (docs.length > 0) { %>
      <div class="space-y-2 mb-4">
        <% docs.forEach(function(doc) { %>
        <div class="flex items-center justify-between bg-gray-50 rounded-lg border border-gray-200 px-3 py-2.5">
          <div class="flex items-center gap-2.5 min-w-0">
            <% if (doc.mime_type && doc.mime_type.startsWith('image/')) { %>
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <% } else if (doc.original_name && doc.original_name.match(/\.pdf$/i)) { %>
              <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            <% } else { %>
              <svg class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <% } %>
            <a href="/compliance/<%= item.id %>/documents/<%= doc.filename %>" target="_blank" class="text-sm text-brand-600 hover:underline truncate"><%= doc.original_name %></a>
            <span class="text-xs text-gray-400 flex-shrink-0"><%= doc.file_size ? (doc.file_size / 1024).toFixed(0) + ' KB' : '' %></span>
            <% if (doc.uploaded_by_name) { %><span class="text-xs text-gray-400 flex-shrink-0">by <%= doc.uploaded_by_name %></span><% } %>
          </div>
          <form method="POST" action="/compliance/<%= item.id %>/documents/<%= doc.id %>/delete" class="inline" onsubmit="return confirm('Delete this document?')">
            <%- include('../partials/csrf') %>
            <button type="submit" class="p-1 text-gray-300 hover:text-red-600 transition" title="Delete">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </form>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="text-sm text-gray-400 mb-4">No documents uploaded yet.</p>
      <% } %>

      <form method="POST" action="/compliance/<%= item.id %>/upload" enctype="multipart/form-data">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="return_to" value="/compliance/<%= item.id %>/edit<%= (typeof returnTo !== 'undefined' && returnTo) ? '?return_to=' + encodeURIComponent(returnTo) : '' %>">
        <div class="flex items-end gap-3">
          <div class="flex-1">
            <label class="block text-sm font-medium text-gray-600 mb-1">Upload Files</label>
            <input type="file" name="documents" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.jpg,.jpeg,.png,.gif,.webp,.dwg,.dxf"
              class="w-full text-sm text-gray-500 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 cursor-pointer">
          </div>
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">Upload</button>
        </div>
        <p class="text-xs text-gray-400 mt-2">PDF, Word, Excel, images, DWG/DXF. Max 25MB per file, up to 10 files.</p>
      </form>
    </div>
    <% } %>

  </div>
</div>

<script>
function validateAssignment() {
  const jobId = document.getElementById('job_id').value;
  const clientId = document.getElementById('client_id').value;
  if (!jobId && !clientId) {
    const err = document.getElementById('assignment-error');
    err.classList.remove('hidden');
    err.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Highlight both selects
    ['job_id','client_id'].forEach(id => {
      document.getElementById(id).classList.add('border-red-400', 'ring-1', 'ring-red-400');
    });
    return false;
  }
  return true;
}
function clearAssignmentError() {
  document.getElementById('assignment-error').classList.add('hidden');
  ['job_id','client_id'].forEach(id => {
    document.getElementById(id).classList.remove('border-red-400', 'ring-1', 'ring-red-400');
  });
}
// Show/hide council fee section based on item type
function toggleCouncilFee() {
  var type = document.getElementById('item_type').value;
  var section = document.getElementById('council-fee-section');
  if (type === 'council_permit') {
    section.style.display = '';
  } else {
    section.style.display = 'none';
  }
}
// Show/hide fee amount based on paid checkbox
function toggleFeeAmount() {
  var paid = document.getElementById('council_fee_paid').checked;
  document.getElementById('council-fee-amount-row').style.display = paid ? '' : 'none';
}
document.getElementById('item_type').addEventListener('change', toggleCouncilFee);
document.getElementById('council_fee_paid').addEventListener('change', toggleFeeAmount);
toggleCouncilFee();
toggleFeeAmount();

// Auto-generate reference number
function generateRefNumber() {
  var type = document.getElementById('item_type').value;
  var btn = document.getElementById('generateRefBtn');
  btn.textContent = '...';
  btn.disabled = true;
  fetch('/compliance/api/next-ref?item_type=' + encodeURIComponent(type))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      document.getElementById('reference_number').value = data.reference_number;
      btn.textContent = 'Generate';
      btn.disabled = false;
    })
    .catch(function() {
      btn.textContent = 'Generate';
      btn.disabled = false;
    });
}

// Auto-generate ref on type change for new items only
<% if (!isEdit) { %>
document.getElementById('item_type').addEventListener('change', function() {
  if (!document.getElementById('reference_number').value) {
    generateRefNumber();
  }
});
<% } %>
</script>
