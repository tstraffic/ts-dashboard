<%
  const isEdit = !!item;
  const formAction = isEdit ? '/compliance/' + item.id : '/compliance';
  const pageTitle = isEdit ? 'Edit Plan / Approval' : 'New Plan / Approval';
  const selectedJobId = (isEdit && item.job_id) ? item.job_id : (prefillJobId || '');
  const selectedClientId = (isEdit && item.client_id) ? item.client_id : (prefillClientId || '');
  const cancelHref = (typeof returnTo !== 'undefined' && returnTo) ? returnTo : '/compliance';

  const typeOptions = [
    { value: 'traffic_guidance',     label: 'TGS (Traffic Guidance Scheme)' },
    { value: 'tmp_approval',         label: 'CTMP (Construction Traffic Mgmt Plan)' },
    { value: 'spa',                  label: 'SPA (Swept Path Analysis)' },
    { value: 'sza',                  label: 'SZA (Speed Zone Authorisation)' },
    { value: 'rol',                  label: 'ROL (Road Occupancy Licence)' },
    { value: 'council_permit',       label: 'Council Permit' },
    { value: 'bus_approval',        label: 'Bus Approval' },
    { value: 'police_notification',  label: 'Police Notification' },
    { value: 'letter_drop',         label: 'Letter Drop' },
    { value: 'other',               label: 'Other' },
  ];
  const statusOptions = [
    { value: 'not_started', label: 'Not Started' },
    { value: 'started',     label: 'Started' },
    { value: 'submitted',   label: 'Submitted' },
    { value: 'approved',    label: 'Approved' },
    { value: 'rejected',    label: 'Rejected' },
    { value: 'expired',     label: 'Expired' },
  ];
%>

<% if (typeof isParent !== 'undefined' && isParent) { %>
  <%- include('./_parent_form') %>
<% } else { %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-6">
    <a href="<%= cancelHref %>" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-3">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    </a>
    <h1 class="text-2xl font-bold text-gray-900"><%= pageTitle %></h1>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <form method="POST" action="<%= formAction %>" id="complianceForm" onsubmit="return validateAssignment()">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="return_to" value="<%= cancelHref %>">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- Status — prominent, colour-coded, top of the form so it's the
             first thing you see when opening an item. Submitting via the
             radio that backs the buttons keeps the existing POST handler
             happy with no route changes. -->
        <div class="md:col-span-2">
          <div class="bg-gradient-to-br from-gray-50 to-white border border-gray-200 rounded-xl p-4">
            <div class="flex items-center justify-between mb-2.5">
              <label class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Status</label>
              <span class="text-[10px] text-gray-400 hidden sm:inline">Click to change</span>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-6 gap-2" id="statusButtonRow">
              <% statusOptions.forEach(function(opt) { %>
                <% const selected = (isEdit ? item.status : 'not_started') === opt.value; %>
                <label class="cursor-pointer">
                  <input type="radio" name="status" value="<%= opt.value %>" <%= selected ? 'checked' : '' %>
                    class="sr-only" onchange="updateStatusButtons()">
                  <div class="status-btn px-2 py-2 text-center text-xs sm:text-sm font-semibold rounded-lg border-2 transition select-none"
                    data-status="<%= opt.value %>">
                    <%= opt.label %>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- Item Type(s) - Multi-select checkboxes -->
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-600 mb-2">Type(s) <span class="text-red-600">*</span></label>
          <% const selectedTypes = isEdit && item.item_types ? item.item_types.split(',') : (isEdit && item.item_type ? [item.item_type] : []); %>
          <div class="flex flex-wrap gap-3">
            <% typeOptions.forEach(function(opt) { %>
              <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border transition-colors
                <%= selectedTypes.includes(opt.value) ? 'border-brand-500 bg-brand-50' : 'border-gray-200 bg-white hover:bg-gray-50' %>">
                <input type="checkbox" name="item_types" value="<%= opt.value %>"
                  <%= selectedTypes.includes(opt.value) ? 'checked' : '' %>
                  class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
                <span class="text-sm font-medium text-gray-700"><%= opt.label %></span>
              </label>
            <% }) %>
          </div>
          <!-- Other description (shown when 'Other' is ticked) -->
          <div id="other-description-field" class="hidden mt-2">
            <input type="text" name="other_description" value="<%= isEdit && item.other_description ? item.other_description : '' %>"
              placeholder="Describe the other type..."
              class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <!-- TGS Quantity (shown when TGS selected) -->
          <div id="tgs-quantity-field" class="hidden mt-3">
            <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg border border-blue-200">
              <label class="text-sm font-medium text-blue-800 whitespace-nowrap">Number of TGS Plans</label>
              <input type="number" name="tgs_quantity" id="tgs_quantity" min="1" value="<%= isEdit && item.tgs_quantity ? item.tgs_quantity : 1 %>"
                class="w-20 bg-white border border-blue-300 text-gray-900 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
              <span class="text-xs text-blue-600">Plans appear as TSTGS3001-1, TSTGS3001-2, etc.</span>
            </div>
          </div>
        </div>

        <!-- Title -->
        <div>
          <label for="title" class="block text-sm font-medium text-gray-600 mb-1">Title <span class="text-red-600">*</span></label>
          <input type="text" id="title" name="title" required value="<%= isEdit ? item.title : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. CTMP for Main St works, ROL #12345...">
        </div>

        <!-- Project / Client assignment (full width) -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-2 mb-2">
            <label class="block text-sm font-medium text-gray-600">Assign To <span class="text-red-600">*</span></label>
            <span class="text-xs text-gray-400">— select a project, a client, or both</span>
          </div>
          <div id="assignment-error" class="hidden mb-2 text-sm text-red-600 flex items-center gap-1">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Please select at least a project or a client.
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <!-- Project -->
            <div>
              <div class="flex items-center justify-between mb-1">
                <label for="job_id" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">Project</label>
                <button type="button" onclick="toggleQuickAdd('project')" class="text-xs text-brand-600 hover:text-brand-700 font-medium" id="toggleProjectBtn">+ Add new</button>
              </div>
              <select id="job_id" name="job_id" onchange="clearAssignmentError()"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <option value="">No project</option>
                <% jobs.forEach(function(job) { %>
                  <option value="<%= job.id %>" <%= String(selectedJobId) === String(job.id) ? 'selected' : '' %>><%= job.job_number %> - <%= job.project_name ? job.project_name + ' (' + job.client + ')' : job.client %></option>
                <% }) %>
              </select>
              <!-- Inline quick-add project -->
              <div id="quickAddProject" class="hidden mt-2 p-3 bg-brand-50 border border-brand-200 rounded-lg">
                <div class="grid grid-cols-2 gap-2 mb-2">
                  <input type="text" id="qa_job_number" placeholder="Job number *" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                  <input type="text" id="qa_suburb" placeholder="Suburb *" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                </div>
                <div class="grid grid-cols-2 gap-2 mb-2">
                  <input type="date" id="qa_start_date" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                  <select id="qa_project_client" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                    <option value="">Client (optional)</option>
                    <% clients.forEach(function(c) { %>
                      <option value="<%= c.id %>"><%= c.company_name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" onclick="saveQuickProject()" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-500 transition">Create Project</button>
                  <button type="button" onclick="toggleQuickAdd('project')" class="px-3 py-1.5 text-gray-500 text-xs font-medium hover:text-gray-700">Cancel</button>
                  <span id="projectQuickMsg" class="text-xs text-emerald-600 hidden ml-auto"></span>
                </div>
              </div>
            </div>
            <!-- Client -->
            <div>
              <div class="flex items-center justify-between mb-1">
                <label for="client_id" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider">Client</label>
                <button type="button" onclick="toggleQuickAdd('client')" class="text-xs text-brand-600 hover:text-brand-700 font-medium" id="toggleClientBtn">+ Add new</button>
              </div>
              <select id="client_id" name="client_id" onchange="clearAssignmentError()"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                <option value="">No client</option>
                <% clients.forEach(function(c) { %>
                  <option value="<%= c.id %>" <%= String(selectedClientId) === String(c.id) ? 'selected' : '' %>><%= c.company_name %></option>
                <% }) %>
              </select>
              <!-- Inline quick-add client -->
              <div id="quickAddClient" class="hidden mt-2 p-3 bg-brand-50 border border-brand-200 rounded-lg">
                <div class="mb-2">
                  <input type="text" id="qa_company_name" placeholder="Company name *" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" onclick="saveQuickClient()" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-500 transition">Create Client</button>
                  <button type="button" onclick="toggleQuickAdd('client')" class="px-3 py-1.5 text-gray-500 text-xs font-medium hover:text-gray-700">Cancel</button>
                  <span id="clientQuickMsg" class="text-xs text-emerald-600 hidden ml-auto"></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Authority / External Approver -->
        <div>
          <label for="authority_approver" class="block text-sm font-medium text-gray-600 mb-1">Authority / External Approver</label>
          <input type="text" id="authority_approver" name="authority_approver"
            value="<%= isEdit && item.authority_approver ? item.authority_approver : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. TfNSW, Council name, RMS...">
        </div>

        <!-- Internal Approver -->
        <div>
          <label for="internal_approver_id" class="block text-sm font-medium text-gray-600 mb-1">Internal Approver</label>
          <select id="internal_approver_id" name="internal_approver_id" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Select approver...</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.id %>" <%= isEdit && item.internal_approver_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
            <% }) %>
          </select>
        </div>

        <!-- Assigned To -->
        <div>
          <label for="assigned_to_id" class="block text-sm font-medium text-gray-600 mb-1">Assigned To</label>
          <select id="assigned_to_id" name="assigned_to_id" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Unassigned</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.id %>" <%= isEdit && item.assigned_to_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
            <% }) %>
          </select>
          <% if (isEdit && typeof linkedTask !== 'undefined' && linkedTask) { %>
            <div class="mt-2 flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full
                <%= linkedTask.status === 'complete' ? 'bg-green-50 text-green-700' : linkedTask.status === 'in_progress' ? 'bg-blue-50 text-blue-700' : 'bg-amber-50 text-amber-700' %>">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Linked Task: <%= linkedTask.status.replace(/_/g, ' ') %>
              </span>
              <a href="/tasks/<%= linkedTask.id %>/edit" class="text-brand-600 hover:text-brand-700 underline">View Task</a>
            </div>
          <% } else if (isEdit && !item.assigned_to_id) { %>
            <p class="mt-1 text-xs text-gray-400">Assign someone to auto-create a linked task</p>
          <% } %>
        </div>

        <!-- Designer -->
        <div>
          <label for="designer" class="block text-sm font-medium text-gray-600 mb-1">Designer</label>
          <select id="designer" name="designer" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Select designer...</option>
            <% (typeof users !== 'undefined' ? users : []).forEach(function(u) { %>
              <option value="<%= u.full_name %>" <%= isEdit && item.designer === u.full_name ? 'selected' : '' %>><%= u.full_name %></option>
            <% }) %>
          </select>
        </div>

        <!-- File / Document Link -->
        <div>
          <label for="file_link" class="block text-sm font-medium text-gray-600 mb-1">File / Document Link</label>
          <input type="url" id="file_link" name="file_link"
            value="<%= isEdit && item.file_link ? item.file_link : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="https://...">
        </div>

        <!-- (Status moved to a prominent segmented control at the top of the form) -->

        <!-- Received Date (TGS/CTMP only) -->
        <div id="received-date-field" class="hidden">
          <label for="received_date" class="block text-sm font-medium text-gray-600 mb-1">Received Date</label>
          <input type="date" id="received_date" name="received_date"
            value="<%= isEdit && item.received_date ? item.received_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Submitted Date (hidden until type selected) -->
        <div id="submitted-date-field" class="<%= isEdit ? '' : 'hidden' %>">
          <label for="submitted_date" class="block text-sm font-medium text-gray-600 mb-1" id="submitted-date-label">Submitted Date</label>
          <input type="date" id="submitted_date" name="submitted_date"
            value="<%= isEdit && item.submitted_date ? item.submitted_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Due Date (hidden for TGS/CTMP) -->
        <div id="due-date-field">
          <label for="due_date" class="block text-sm font-medium text-gray-600 mb-1">Due Date</label>
          <input type="date" id="due_date" name="due_date"
            value="<%= isEdit && item.due_date ? item.due_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Approved Date (hidden for TGS/CTMP) -->
        <div id="approved-date-field">
          <label for="approved_date" class="block text-sm font-medium text-gray-600 mb-1">Approved Date</label>
          <input type="date" id="approved_date" name="approved_date"
            value="<%= isEdit && item.approved_date ? item.approved_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Expiry Date (hidden for TGS/CTMP) -->
        <div id="expiry-date-field">
          <label for="expiry_date" class="block text-sm font-medium text-gray-600 mb-1">Expiry Date</label>
          <input type="date" id="expiry_date" name="expiry_date"
            value="<%= isEdit && item.expiry_date ? item.expiry_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Start/Finish Dates (ROL, Council, SZA) -->
        <div id="start-date-field" class="hidden">
          <label for="start_date" class="block text-sm font-medium text-gray-600 mb-1">Start Date</label>
          <input type="date" id="start_date" name="start_date"
            value="<%= isEdit && item.start_date ? item.start_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div id="finish-date-field" class="hidden">
          <label for="finish_date" class="block text-sm font-medium text-gray-600 mb-1">Finish Date</label>
          <input type="date" id="finish_date" name="finish_date"
            value="<%= isEdit && item.finish_date ? item.finish_date.split('T')[0] : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <!-- SZA + ROL info note -->
        <div id="sza-rol-note" class="hidden md:col-span-2">
          <div class="flex items-center gap-2 p-2 bg-violet-50 rounded-lg border border-violet-200 text-xs text-violet-700">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            SZA uses the same start/finish dates as ROL
          </div>
        </div>

        <!-- Reference Number -->
        <div>
          <label for="reference_number" class="block text-sm font-medium text-gray-600 mb-1">Reference Number</label>
          <div class="flex gap-2">
            <input type="text" id="reference_number" name="reference_number"
              value="<%= isEdit && item.reference_number ? item.reference_number : '' %>"
              class="flex-1 bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="Auto-generated or manual entry">
            <button type="button" id="generateRefBtn" onclick="generateRefNumber()"
              class="px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition-colors whitespace-nowrap"
              title="Generate next reference number">Generate</button>
          </div>
        </div>

        <!-- Client PM -->
        <div>
          <label for="client_pm" class="block text-sm font-medium text-gray-600 mb-1">Client PM</label>
          <input type="text" id="client_pm" name="client_pm"
            value="<%= isEdit && item.client_pm ? item.client_pm : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Client project manager">
        </div>

        <!-- Dynamic Response Fields (based on selected types) -->
        <div class="md:col-span-2 p-4 bg-gray-50 rounded-lg border border-gray-200" id="responses-section">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Responses & Status</h3>
          <div id="response-fields" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- ROL response (shown when ROL type selected) -->
            <div data-response-for="rol" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">ROL Response</label>
              <input type="text" name="rol_response" value="<%= isEdit && item.rol_response ? item.rol_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="e.g. Approved 10pm, NEED 9pm or extra day">
              <label class="flex items-center gap-2 mt-2 cursor-pointer">
                <input type="checkbox" name="rol_required" value="1" <%= isEdit && item.rol_required ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-xs text-gray-600">ROL Submitted</span>
              </label>
            </div>
            <!-- CTMP response -->
            <div data-response-for="tmp_approval" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">CTMP Response</label>
              <input type="text" name="tmp_response" value="<%= isEdit && item.tmp_response ? item.tmp_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="CTMP status or response">
            </div>
            <!-- SPA response -->
            <div data-response-for="spa" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">SPA Response</label>
              <input type="text" name="spa_response" value="<%= isEdit && item.spa_response ? item.spa_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="SPA status or response">
            </div>
            <!-- SZA response -->
            <div data-response-for="sza" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">SZA Response</label>
              <input type="text" name="sza_response" value="<%= isEdit && item.sza_response ? item.sza_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Speed Zone Authorisation status or response">
            </div>
            <!-- Council response + fee -->
            <div data-response-for="council_permit" class="hidden sm:col-span-2">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div>
                  <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Council Response</label>
                  <input type="text" name="council_response" value="<%= isEdit && item.council_response ? item.council_response : '' %>"
                    class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                    placeholder="Council approval status">
                </div>
                <div class="p-3 bg-amber-50 rounded-lg border border-amber-200">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" id="council_fee_paid" name="council_fee_paid" value="1"
                      <%= isEdit && item.council_fee_paid ? 'checked' : '' %>
                      class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2">
                    <span class="text-sm font-medium text-amber-800">Council fee paid</span>
                  </label>
                  <div id="council-fee-amount-row" class="mt-2" style="display: none;">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Fee Amount ($)</label>
                    <input type="number" id="council_fee_amount" name="council_fee_amount" step="0.01" min="0"
                      value="<%= isEdit && item.council_fee_amount ? item.council_fee_amount : '' %>"
                      class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                      placeholder="0.00">
                  </div>
                </div>
              </div>
            </div>
            <!-- Bus Approvals response -->
            <div data-response-for="bus_approval" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Bus Approvals Response</label>
              <input type="text" name="bus_approvals_response" value="<%= isEdit && item.bus_approvals_response ? item.bus_approvals_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Bus approvals status">
              <label class="flex items-center gap-2 mt-2 cursor-pointer">
                <input type="checkbox" name="bus_approvals_required" value="1" <%= isEdit && item.bus_approvals_required ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-xs text-gray-600">Bus Approval Submitted</span>
              </label>
            </div>
            <!-- Police Notification response -->
            <div data-response-for="police_notification" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Police Notification</label>
              <input type="text" name="police_response" value="<%= isEdit && item.police_response ? item.police_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Notification reference or status">
              <label class="flex items-center gap-2 mt-2 cursor-pointer">
                <input type="checkbox" name="police_notification" value="1" <%= isEdit && item.police_notification ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-xs text-gray-600">Police Notified</span>
              </label>
            </div>
            <!-- Letter Drop response -->
            <div data-response-for="letter_drop" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Letter Drop</label>
              <input type="text" name="letter_drop_response" value="<%= isEdit && item.letter_drop_response ? item.letter_drop_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="Letter drop details or date">
              <label class="flex items-center gap-2 mt-2 cursor-pointer">
                <input type="checkbox" name="letter_drop" value="1" <%= isEdit && item.letter_drop ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-xs text-gray-600">Letter Drop Completed</span>
              </label>
            </div>
            <!-- TGS response -->
            <div data-response-for="traffic_guidance" class="hidden">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">TGS Response</label>
              <input type="text" name="tgs_response" value="<%= isEdit && item.tgs_response ? item.tgs_response : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="TGS status or approval details">
            </div>
          </div>
          <p id="no-responses-msg" class="text-sm text-gray-400 hidden">Select type(s) above to see response fields.</p>
        </div>

        <!-- Revision Tracking (TGS/CTMP only) -->
        <div id="revision-section" class="md:col-span-2 <%= (isEdit && (item.revision_required || item.revision_count > 0)) ? '' : 'hidden' %>" data-has-revisions="<%= (isEdit && (item.revision_required || item.revision_count > 0)) ? '1' : '0' %>">
          <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest">Revision Tracking</h3>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="revision_required" value="1" <%= isEdit && item.revision_required ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-red-500 focus:ring-red-500">
                <span class="text-xs font-medium text-red-600">Revision Required</span>
              </label>
            </div>

            <% const revs = (typeof revisions !== 'undefined') ? revisions : []; %>
            <% if (revs.length > 0) { %>
            <div class="space-y-2 mb-3">
              <% revs.forEach(function(rev) { %>
              <div class="revision-row" id="rev-row-<%= rev.id %>">
                <!-- View mode -->
                <div class="rev-view flex items-center gap-3 bg-white rounded-lg border border-gray-200 px-3 py-2">
                  <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700 text-xs font-bold flex-shrink-0">R<%= rev.revision_number %></span>
                  <span class="text-sm text-gray-700"><%= rev.revision_date ? new Date(rev.revision_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : 'No date' %></span>
                  <span class="text-sm text-gray-500 flex-1 truncate"><%= rev.notes || '' %></span>
                  <% if (rev.client_issued) { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-purple-50 text-purple-700 ring-1 ring-purple-600/20 flex-shrink-0">Client Issued</span>
                  <% } %>
                  <% if (isEdit) { %>
                  <button type="button" onclick="toggleRevEdit(<%= rev.id %>)" class="p-1 text-gray-300 hover:text-brand-600 transition" title="Edit revision">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </button>
                  <button type="button" onclick="deleteRevision(<%= item.id %>, <%= rev.id %>, <%= rev.revision_number %>)" class="p-1 text-gray-300 hover:text-red-600 transition" title="Delete revision">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                  <% } %>
                </div>
                <!-- Edit mode (hidden by default) -->
                <% if (isEdit) { %>
                <div class="rev-edit hidden bg-white rounded-lg border-2 border-brand-200 px-3 py-2" data-compliance-id="<%= item.id %>" data-rev-id="<%= rev.id %>">
                  <div class="flex items-end gap-3 flex-wrap">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700 text-xs font-bold flex-shrink-0">R<%= rev.revision_number %></span>
                    <div class="flex-shrink-0">
                      <label class="block text-xs text-gray-500 mb-1">Date</label>
                      <input type="date" name="revision_date" value="<%= rev.revision_date || '' %>" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                    </div>
                    <div class="flex-1 min-w-[150px]">
                      <label class="block text-xs text-gray-500 mb-1">Notes</label>
                      <input type="text" name="revision_notes" value="<%= rev.notes || '' %>" placeholder="What changed in this revision..."
                        class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                    </div>
                    <label class="flex items-center gap-1.5 cursor-pointer flex-shrink-0 pb-1">
                      <input type="checkbox" name="client_issued" value="1" <%= rev.client_issued ? 'checked' : '' %> class="w-4 h-4 bg-white border-gray-300 rounded text-purple-600 focus:ring-purple-500">
                      <span class="text-xs font-medium text-purple-700">Client Issued</span>
                    </label>
                    <button type="button" onclick="saveRevEdit(this)" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition whitespace-nowrap">Save</button>
                    <button type="button" onclick="toggleRevEdit(<%= rev.id %>)" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition whitespace-nowrap">Cancel</button>
                  </div>
                </div>
                <% } %>
              </div>
              <% }) %>
            </div>
            <% } else { %>
            <p class="text-sm text-gray-400 mb-3">No revisions logged yet.</p>
            <% } %>

            <% if (isEdit) { %>
            <div id="add-revision-section" class="pt-3 border-t border-gray-200 <%= (item.revision_required || item.revision_count > 0) ? '' : 'hidden' %>">
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Add Revision</p>
              <div class="flex items-end gap-3 flex-wrap" id="add-revision-row">
                <div class="flex-shrink-0">
                  <label class="block text-xs text-gray-500 mb-1">Date</label>
                  <input type="date" id="new_revision_date" class="bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                </div>
                <div class="flex-1 min-w-[150px]">
                  <label class="block text-xs text-gray-500 mb-1">Notes</label>
                  <input type="text" id="new_revision_notes" placeholder="What changed in this revision..."
                    class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
                </div>
                <label class="flex items-center gap-1.5 cursor-pointer flex-shrink-0 pb-1">
                  <input type="checkbox" id="new_revision_client_issued" class="w-4 h-4 bg-white border-gray-300 rounded text-purple-600 focus:ring-purple-500">
                  <span class="text-xs font-medium text-purple-700">Client Issued</span>
                </label>
                <button type="button" onclick="addRevision()" class="px-3 py-1.5 bg-amber-500 hover:bg-amber-400 text-white text-xs font-medium rounded-lg transition whitespace-nowrap">+ Add</button>
              </div>
            </div>
            <% } else { %>
            <p class="text-xs text-gray-400 italic">Save this item first, then add revisions.</p>
            <% } %>
          </div>
        </div>

        <!-- Action Required -->
        <div class="md:col-span-2">
          <label for="action_required" class="block text-sm font-medium text-gray-600 mb-1">Action Required</label>
          <input type="text" id="action_required" name="action_required"
            value="<%= isEdit && item.action_required ? item.action_required : '' %>"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="What needs to happen next">
        </div>

        <!-- Costs & Billing -->
        <div class="md:col-span-2 p-4 bg-gray-50 rounded-lg border border-gray-200">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Costs & Billing</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Costs ($)</label>
              <input type="number" name="costs" step="0.01" min="0" value="<%= isEdit && item.costs ? item.costs : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="0.00">
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Charge Amount ($)</label>
              <input type="number" name="charge_amount" step="0.01" min="0" value="<%= isEdit && item.charge_amount ? item.charge_amount : '' %>"
                class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                placeholder="0.00">
            </div>
            <div class="flex items-end">
              <label class="flex items-center gap-2 cursor-pointer pb-2">
                <input type="checkbox" name="charge_client" value="1" <%= isEdit && item.charge_client ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500">
                <span class="text-sm text-gray-700">Charge Client</span>
              </label>
            </div>
            <div class="flex items-end">
              <label class="flex items-center gap-2 cursor-pointer pb-2">
                <input type="checkbox" name="invoiced" value="1" <%= isEdit && item.invoiced ? 'checked' : '' %>
                  class="w-4 h-4 bg-white border-gray-300 rounded text-emerald-500 focus:ring-emerald-500">
                <span class="text-sm text-gray-700">Invoiced</span>
              </label>
            </div>
          </div>
          <div class="mt-3">
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Invoice Number</label>
            <input type="text" name="invoice_number" value="<%= isEdit && item.invoice_number ? item.invoice_number : '' %>"
              class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 max-w-xs"
              placeholder="INV-001">
          </div>
        </div>

        <!-- Notes -->
        <div class="md:col-span-2">
          <label for="notes" class="block text-sm font-medium text-gray-600 mb-1">Comments</label>
          <textarea id="notes" name="notes" rows="3"
            class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Additional comments..."><%= isEdit && item.notes ? item.notes : '' %></textarea>
        </div>

        <!-- Council fee is now inside the council_permit response field above -->
      </div>

      <!-- Ready for Invoice banner -->
      <% if (isEdit && item.ready_for_invoice && !item.invoiced) { %>
      <div class="mt-4 p-3 bg-amber-50 border border-amber-200 rounded-lg flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-sm font-medium text-amber-800">Ready for Invoice</span>
          <span class="text-xs text-amber-600">Marked <%= item.ready_for_invoice_at ? new Date(item.ready_for_invoice_at).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '' %></span>
        </div>
        <button type="button" onclick="unmarkInvoice()" class="px-3 py-1 text-xs font-medium text-amber-700 bg-amber-100 hover:bg-amber-200 rounded-lg transition">Unmark</button>
      </div>
      <% } %>
      <% if (isEdit && item.invoiced) { %>
      <div class="mt-4 p-3 bg-emerald-50 border border-emerald-200 rounded-lg flex items-center gap-2">
        <svg class="w-5 h-5 text-emerald-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="text-sm font-medium text-emerald-800">Invoiced</span>
        <% if (item.invoice_number) { %><span class="text-xs text-emerald-600 ml-1">(<%= item.invoice_number %>)</span><% } %>
      </div>
      <% } %>

      <% if (isEdit) { %>
      <!-- Documents & Attachments (above buttons) -->
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Documents & Attachments</h3>
        <% const docsInline = (typeof documents !== 'undefined') ? documents : []; %>
        <% if (docsInline.length > 0) { %>
        <div class="space-y-2 mb-4">
          <% docsInline.forEach(function(doc) { %>
          <div class="flex items-center justify-between bg-gray-50 rounded-lg border border-gray-200 px-3 py-2.5">
            <div class="flex items-center gap-2.5 min-w-0">
              <% if (doc.mime_type && doc.mime_type.startsWith('image/')) { %>
                <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <% } else if (doc.original_name && doc.original_name.match(/\.pdf$/i)) { %>
                <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
              <% } else { %>
                <svg class="w-5 h-5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              <% } %>
              <a href="/compliance/<%= item.id %>/documents/<%= doc.filename %>" target="_blank" class="text-sm text-brand-600 hover:underline truncate"><%= doc.original_name %></a>
              <span class="text-xs text-gray-400 flex-shrink-0"><%= doc.file_size ? (doc.file_size / 1024).toFixed(0) + ' KB' : '' %></span>
              <% if (doc.uploaded_by_name) { %><span class="text-xs text-gray-400 flex-shrink-0">by <%= doc.uploaded_by_name %></span><% } %>
            </div>
            <button type="button" onclick="deleteDocument(<%= item.id %>, <%= doc.id %>)" class="p-1 text-gray-300 hover:text-red-600 transition flex-shrink-0" title="Delete">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="text-sm text-gray-400 mb-4">No documents uploaded yet.</p>
        <% } %>
      </div>
      <% } %>

    </form>

    <% if (isEdit) { %>
    <!-- Upload Files (separate form for multipart) -->
    <div class="mt-6 pt-6 border-t border-gray-200">
      <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-3">Upload Files</h3>
      <form method="POST" action="/compliance/<%= item.id %>/upload" enctype="multipart/form-data">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="return_to" value="/compliance/<%= item.id %>/edit<%= (typeof returnTo !== 'undefined' && returnTo) ? '?return_to=' + encodeURIComponent(returnTo) : '' %>">
        <div data-dropzone>
          <input type="file" name="documents" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.jpg,.jpeg,.png,.gif,.webp,.dwg,.dxf">
          <div class="dropzone-label">
            <svg class="w-8 h-8 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
            <p class="text-sm text-gray-500">Drag & drop files here or <span class="text-brand-600 font-medium">click to browse</span></p>
            <p class="text-xs text-gray-400 mt-1">PDF, Word, Excel, images, DWG/DXF. Max 25MB per file, up to 10 files.</p>
          </div>
        </div>
        <div class="mt-3 flex justify-end">
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">Upload</button>
        </div>
      </form>
    </div>
    <% } %>

    <!-- Buttons (outside both forms — uses JS to submit main form) -->
    <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-200">
      <div class="flex items-center gap-2">
        <% if (isEdit) { %>
          <button type="button" onclick="deleteItem()" class="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition text-sm font-medium">Delete</button>
        <% } %>
        <% if (isEdit && typeof item !== 'undefined' && item && !item.ready_for_invoice && !item.invoiced && item.charge_client) { %>
          <button type="button" onclick="markReadyForInvoice()" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-white rounded-lg transition text-sm font-medium">Ready for Invoice</button>
        <% } %>
      </div>
      <div class="flex gap-3">
        <a href="<%= cancelHref %>" class="px-4 py-2 bg-white text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition font-medium text-sm">Cancel</a>
        <button type="button" onclick="document.getElementById('complianceForm').requestSubmit()" class="px-6 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-semibold text-sm">
          <%= isEdit ? 'Update Item' : 'Create Item' %>
        </button>
      </div>
    </div>

  </div>
</div>

<script>
// Status segmented control — paint colour on the active button so you
// always know what state the item is in at a glance. The radio inputs
// behind the buttons are what actually post.
const STATUS_BTN_COLORS = {
  not_started: { active: 'border-gray-700 bg-gray-100 text-gray-900',         inactive: 'border-gray-200 bg-white text-gray-500 hover:border-gray-300 hover:bg-gray-50' },
  started:     { active: 'border-purple-500 bg-purple-50 text-purple-700',    inactive: 'border-gray-200 bg-white text-gray-500 hover:border-purple-300 hover:bg-purple-50/40' },
  submitted:   { active: 'border-blue-500 bg-blue-50 text-blue-700',          inactive: 'border-gray-200 bg-white text-gray-500 hover:border-blue-300 hover:bg-blue-50/40' },
  approved:    { active: 'border-emerald-500 bg-emerald-50 text-emerald-700', inactive: 'border-gray-200 bg-white text-gray-500 hover:border-emerald-300 hover:bg-emerald-50/40' },
  rejected:    { active: 'border-red-500 bg-red-50 text-red-700',             inactive: 'border-gray-200 bg-white text-gray-500 hover:border-red-300 hover:bg-red-50/40' },
  expired:     { active: 'border-amber-500 bg-amber-50 text-amber-700',       inactive: 'border-gray-200 bg-white text-gray-500 hover:border-amber-300 hover:bg-amber-50/40' },
};
function updateStatusButtons() {
  document.querySelectorAll('#statusButtonRow .status-btn').forEach(btn => {
    const status = btn.dataset.status;
    const radio = btn.parentElement.querySelector('input[type="radio"]');
    const colors = STATUS_BTN_COLORS[status] || STATUS_BTN_COLORS.not_started;
    const base = 'status-btn px-2 py-2 text-center text-xs sm:text-sm font-semibold rounded-lg border-2 transition select-none';
    btn.className = base + ' ' + (radio.checked ? colors.active : colors.inactive);
  });
}
document.addEventListener('DOMContentLoaded', updateStatusButtons);

function validateAssignment() {
  const jobId = document.getElementById('job_id').value;
  const clientId = document.getElementById('client_id').value;
  if (!jobId && !clientId) {
    const err = document.getElementById('assignment-error');
    err.classList.remove('hidden');
    err.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Highlight both selects
    ['job_id','client_id'].forEach(id => {
      document.getElementById(id).classList.add('border-red-400', 'ring-1', 'ring-red-400');
    });
    return false;
  }
  return true;
}
function clearAssignmentError() {
  document.getElementById('assignment-error').classList.add('hidden');
  ['job_id','client_id'].forEach(id => {
    document.getElementById(id).classList.remove('border-red-400', 'ring-1', 'ring-red-400');
  });
}
// Show/hide fee amount based on paid checkbox
function toggleFeeAmount() {
  var paid = document.getElementById('council_fee_paid');
  var row = document.getElementById('council-fee-amount-row');
  if (paid && row) row.style.display = paid.checked ? '' : 'none';
}
var councilFeePaid = document.getElementById('council_fee_paid');
if (councilFeePaid) councilFeePaid.addEventListener('change', toggleFeeAmount);
toggleFeeAmount();

// Toggle "Other" description field
function updateOtherField() {
  var otherChecked = document.querySelector('input[name="item_types"][value="other"]');
  var field = document.getElementById('other-description-field');
  if (field) field.classList.toggle('hidden', !(otherChecked && otherChecked.checked));
}
document.querySelectorAll('input[name="item_types"]').forEach(function(cb) {
  cb.addEventListener('change', updateOtherField);
});
updateOtherField();

// Toggle response fields and new conditional fields based on selected type checkboxes
function updateResponseFields() {
  var checked = Array.from(document.querySelectorAll('input[name="item_types"]:checked')).map(function(cb) { return cb.value; });
  var anyVisible = false;
  document.querySelectorAll('[data-response-for]').forEach(function(el) {
    var type = el.getAttribute('data-response-for');
    var show = checked.includes(type);
    el.classList.toggle('hidden', !show);
    if (show) anyVisible = true;
  });
  var msg = document.getElementById('no-responses-msg');
  var section = document.getElementById('responses-section');
  if (msg) msg.classList.toggle('hidden', anyVisible);
  if (section) section.classList.toggle('hidden', !anyVisible && checked.length === 0);

  // TGS/CTMP specific fields
  var isTgsCtmp = checked.includes('traffic_guidance') || checked.includes('tmp_approval');
  var isTgs = checked.includes('traffic_guidance');

  // TGS quantity field
  var qtyField = document.getElementById('tgs-quantity-field');
  if (qtyField) qtyField.classList.toggle('hidden', !isTgs);

  // Received date (TGS/CTMP only)
  var receivedField = document.getElementById('received-date-field');
  if (receivedField) receivedField.classList.toggle('hidden', !isTgsCtmp);

  // Hide ALL date fields when nothing selected; show appropriate ones based on type
  var noTypeSelected = checked.length === 0;
  var dueField = document.getElementById('due-date-field');
  var approvedField = document.getElementById('approved-date-field');
  var expiryField = document.getElementById('expiry-date-field');
  var submittedField = document.getElementById('submitted-date-field');
  if (dueField) dueField.classList.toggle('hidden', noTypeSelected || isTgsCtmp);
  if (approvedField) approvedField.classList.toggle('hidden', noTypeSelected || isTgsCtmp);
  if (expiryField) expiryField.classList.toggle('hidden', noTypeSelected || isTgsCtmp);
  if (submittedField) submittedField.classList.toggle('hidden', noTypeSelected);

  // Contextual date labels based on selected types
  var typeLabel = isTgs ? 'TGS' : checked.includes('tmp_approval') ? 'CTMP' : '';
  var isRol = checked.includes('rol');
  var isCouncil = checked.includes('council_permit');
  var isSza = checked.includes('sza');
  var isSpa = checked.includes('spa');

  // Build prefix for labels (e.g. "TGS" or "ROL" or "TGS / ROL")
  var prefixes = [];
  if (isTgs) prefixes.push('TGS');
  if (checked.includes('tmp_approval')) prefixes.push('CTMP');
  if (isRol) prefixes.push('ROL');
  if (isCouncil) prefixes.push('Council');
  if (isSza) prefixes.push('SZA');
  if (isSpa) prefixes.push('SPA');
  var prefix = prefixes.length > 0 ? prefixes.join(' / ') + ' ' : '';

  // Received date label
  var receivedLabel = document.querySelector('#received-date-field label');
  if (receivedLabel) receivedLabel.textContent = (isTgs ? 'TGS' : 'CTMP') + ' Received Date';

  // Submitted date label
  var submittedLabel = document.getElementById('submitted-date-label');
  if (submittedLabel) submittedLabel.textContent = isTgsCtmp ? (typeLabel + ' Submission Date') : (prefix + 'Submitted Date');

  // Approved date label
  var approvedLabel = document.querySelector('#approved-date-field label');
  if (approvedLabel) approvedLabel.textContent = prefix + 'Approved Date';

  // Due date label
  var dueLabel = document.querySelector('#due-date-field label');
  if (dueLabel) dueLabel.textContent = prefix + 'Due Date';

  // Expiry date label
  var expiryLabel = document.querySelector('#expiry-date-field label');
  if (expiryLabel) expiryLabel.textContent = prefix + 'Expiry Date';

  // Revision section (TGS/CTMP, or if item already has revisions)
  var revSection = document.getElementById('revision-section');
  var hasRevisions = revSection && revSection.getAttribute('data-has-revisions') === '1';
  if (revSection) revSection.classList.toggle('hidden', !isTgsCtmp && !hasRevisions);

  // Start/Finish dates (ROL, Council, SZA)
  var isRolCouncilSza = isRol || isCouncil || isSza;
  var startField = document.getElementById('start-date-field');
  var finishField = document.getElementById('finish-date-field');
  if (startField) startField.classList.toggle('hidden', !isRolCouncilSza);
  if (finishField) finishField.classList.toggle('hidden', !isRolCouncilSza);

  // Start/Finish date labels
  var startPrefix = isRol ? 'ROL' : isCouncil ? 'Council' : isSza ? 'SZA' : '';
  var startLabel = document.querySelector('#start-date-field label');
  var finishLabel = document.querySelector('#finish-date-field label');
  if (startLabel) startLabel.textContent = startPrefix + ' Start Date';
  if (finishLabel) finishLabel.textContent = startPrefix + ' Finish Date';

  // SZA + ROL note
  var szaRolNote = document.getElementById('sza-rol-note');
  if (szaRolNote) szaRolNote.classList.toggle('hidden', !(checked.includes('sza') && checked.includes('rol')));
}
document.querySelectorAll('input[name="item_types"]').forEach(function(cb) {
  cb.addEventListener('change', updateResponseFields);
});
updateResponseFields();

// Auto-generate reference number
function generateRefNumber() {
  var checked = document.querySelectorAll('input[name="item_types"]:checked');
  var type = checked.length > 0 ? checked[0].value : '';
  var btn = document.getElementById('generateRefBtn');
  if (btn) { btn.textContent = '...'; btn.disabled = true; }
  fetch('/compliance/api/next-ref?item_type=' + encodeURIComponent(type))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      document.getElementById('reference_number').value = data.reference_number;
      if (btn) { btn.textContent = 'Generate'; btn.disabled = false; }
      clearRefWarning();
    })
    .catch(function() {
      if (btn) { btn.textContent = 'Generate'; btn.disabled = false; }
    });
}

// Auto-fill ref number on NEW items when type checkbox changes (if field is empty)
<% if (!isEdit) { %>
document.querySelectorAll('input[name="item_types"]').forEach(function(cb) {
  cb.addEventListener('change', function() {
    var refInput = document.getElementById('reference_number');
    if (!refInput.value) generateRefNumber();
  });
});
<% } %>

// Duplicate reference number check
var refInput = document.getElementById('reference_number');
var refWarning = null;
function clearRefWarning() {
  if (refWarning) { refWarning.remove(); refWarning = null; }
}
if (refInput) {
  refInput.addEventListener('blur', function() {
    var val = refInput.value.trim();
    if (!val) { clearRefWarning(); return; }
    fetch('/compliance/api/check-ref?reference_number=' + encodeURIComponent(val) + '&exclude_id=<%= isEdit && item ? item.id : '' %>')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        clearRefWarning();
        if (data.exists) {
          refWarning = document.createElement('p');
          refWarning.className = 'text-xs text-amber-600 mt-1 font-medium';
          refWarning.textContent = 'Warning: Reference number "' + val + '" is already in use (' + data.title + '). You can still save, but consider using a unique number.';
          refInput.parentNode.appendChild(refWarning);
        }
      });
  });
}

// Delete item via fetch (avoids nested form issue)
function unmarkInvoice() {
  if (!confirm('Unmark this item as ready for invoice?')) return;
  <% if (isEdit) { %>
  fetch('/compliance/<%= item.id %>/unmark-invoice', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/x-www-form-urlencoded' }),
    body: 'return_to=' + encodeURIComponent(window.location.href)
  }).then(function() { window.location.reload(); });
  <% } %>
}

function markReadyForInvoice() {
  if (!confirm('Mark this item as ready for invoice? Admin/accounts team will be notified.')) return;
  <% if (isEdit) { %>
  fetch('/compliance/<%= item.id %>/ready-for-invoice', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/x-www-form-urlencoded' }),
    body: 'return_to=' + encodeURIComponent(window.location.href)
  }).then(function() { window.location.reload(); });
  <% } %>
}

function deleteItem() {
  if (!confirm('Delete this item? This cannot be undone.')) return;
  <% if (isEdit) { %>
  fetch('/compliance/<%= item.id %>/delete', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/x-www-form-urlencoded' }),
    body: 'return_to=<%= encodeURIComponent(cancelHref) %>'
  }).then(function() { window.location.href = '<%= cancelHref %>'; });
  <% } %>
}

// Quick-add toggle
function toggleQuickAdd(type) {
  var el = type === 'project' ? document.getElementById('quickAddProject') : document.getElementById('quickAddClient');
  el.classList.toggle('hidden');
}

// Quick-add client
function saveQuickClient() {
  var name = document.getElementById('qa_company_name').value.trim();
  if (!name) { document.getElementById('qa_company_name').focus(); return; }
  fetch('/clients', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json', 'Accept': 'application/json' }),
    body: JSON.stringify({ company_name: name })
  }).then(function(r) {
    if (!r.ok) return r.text().then(function(t) { throw new Error('HTTP ' + r.status); });
    return r.json();
  }).then(function(data) {
    if (data.success && data.client) {
      // Add to client dropdown and select it
      var sel = document.getElementById('client_id');
      var opt = new Option(data.client.company_name, data.client.id, true, true);
      sel.add(opt);
      // Also add to the project's client dropdown
      var projClientSel = document.getElementById('qa_project_client');
      if (projClientSel) projClientSel.add(new Option(data.client.company_name, data.client.id));
      // Show success + hide form
      var msg = document.getElementById('clientQuickMsg');
      msg.textContent = 'Created!';
      msg.classList.remove('hidden');
      document.getElementById('qa_company_name').value = '';
      clearAssignmentError();
      setTimeout(function() { document.getElementById('quickAddClient').classList.add('hidden'); msg.classList.add('hidden'); }, 1200);
    } else {
      alert('Failed to create client.');
    }
  }).catch(function() { alert('Error creating client.'); });
}

// Quick-add project
function saveQuickProject() {
  var jobNum = document.getElementById('qa_job_number').value.trim();
  var suburb = document.getElementById('qa_suburb').value.trim();
  var startDate = document.getElementById('qa_start_date').value;
  var clientId = document.getElementById('qa_project_client').value;
  if (!jobNum) { document.getElementById('qa_job_number').focus(); return; }
  if (!suburb) { document.getElementById('qa_suburb').focus(); return; }
  if (!startDate) { document.getElementById('qa_start_date').focus(); return; }
  fetch('/projects', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json', 'Accept': 'application/json' }),
    body: JSON.stringify({ job_number: jobNum, suburb: suburb, start_date: startDate, client_id: clientId, status: 'active' })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success && data.job) {
      // Add to project dropdown and select it
      var sel = document.getElementById('job_id');
      var label = data.job.job_number + ' – ' + (data.job.client || suburb);
      var opt = new Option(label, data.job.id, true, true);
      sel.add(opt);
      // Show success + hide form
      var msg = document.getElementById('projectQuickMsg');
      msg.textContent = 'Created!';
      msg.classList.remove('hidden');
      document.getElementById('qa_job_number').value = '';
      document.getElementById('qa_suburb').value = '';
      document.getElementById('qa_start_date').value = '';
      clearAssignmentError();
      setTimeout(function() { document.getElementById('quickAddProject').classList.add('hidden'); msg.classList.add('hidden'); }, 1200);
    } else {
      alert('Failed to create project. ' + (data.error || ''));
    }
  }).catch(function() { alert('Error creating project.'); });
}

// Auto-generate ref on type change for new items only
<% if (!isEdit) { %>
document.querySelectorAll('input[name="item_types"]').forEach(function(cb) {
  cb.addEventListener('change', function() {
    if (!document.getElementById('reference_number').value) {
      generateRefNumber();
    }
  });
});
<% } %>

// Toggle inline edit for a revision row
function deleteDocument(complianceId, docId) {
  if (!confirm('Delete this document?')) return;
  var csrf = document.querySelector('meta[name="csrf-token"]').content;
  fetch('/compliance/' + complianceId + '/documents/' + docId + '/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: JSON.stringify({ return_to: '/compliance/' + complianceId + '/edit' })
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) window.location.reload();
    else alert(data.error || 'Failed to delete');
  }).catch(function() { alert('Failed to delete document'); });
}

function deleteRevision(complianceId, revId, revNum) {
  if (!confirm('Delete revision ' + revNum + '?')) return;
  var csrf = document.querySelector('meta[name="csrf-token"]').content;
  fetch('/compliance/' + complianceId + '/revisions/' + revId + '/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'x-csrf-token': csrf }
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) window.location.reload();
    else alert(data.error || 'Failed to delete');
  }).catch(function() { alert('Failed to delete revision'); });
}

function saveRevEdit(btn) {
  var wrap = btn.closest('.rev-edit');
  var complianceId = wrap.getAttribute('data-compliance-id');
  var revId = wrap.getAttribute('data-rev-id');
  var revDate = wrap.querySelector('[name="revision_date"]').value;
  var revNotes = wrap.querySelector('[name="revision_notes"]').value;
  var clientIssued = wrap.querySelector('[name="client_issued"]').checked ? '1' : '0';
  var csrf = document.querySelector('meta[name="csrf-token"]').content;
  fetch('/compliance/' + complianceId + '/revisions/' + revId + '/edit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: 'revision_date=' + encodeURIComponent(revDate) + '&revision_notes=' + encodeURIComponent(revNotes) + '&client_issued=' + clientIssued
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.success) window.location.reload();
    else alert(data.error || 'Failed to save');
  }).catch(function() { alert('Failed to save revision'); });
}

function toggleRevEdit(revId) {
  var row = document.getElementById('rev-row-' + revId);
  if (!row) return;
  var view = row.querySelector('.rev-view');
  var edit = row.querySelector('.rev-edit');
  if (edit.classList.contains('hidden')) {
    view.classList.add('hidden');
    edit.classList.remove('hidden');
  } else {
    view.classList.remove('hidden');
    edit.classList.add('hidden');
  }
}

// Toggle add-revision section when revision_required checkbox changes
(function() {
  var revReqBox = document.querySelector('input[name="revision_required"]');
  var addRevSection = document.getElementById('add-revision-section');
  if (revReqBox && addRevSection) {
    revReqBox.addEventListener('change', function() {
      addRevSection.classList.toggle('hidden', !this.checked);
    });
  }
})();

// Add revision via fetch
function addRevision() {
  <% if (isEdit) { %>
  var dateInput = document.getElementById('new_revision_date');
  var notesInput = document.getElementById('new_revision_notes');
  var clientIssuedInput = document.getElementById('new_revision_client_issued');
  var revDate = dateInput.value;
  var revNotes = notesInput.value;
  if (!revDate) { dateInput.focus(); return; }
  var formData = new URLSearchParams();
  formData.append('revision_date', revDate);
  formData.append('revision_notes', revNotes);
  formData.append('client_issued', clientIssuedInput.checked ? '1' : '0');
  formData.append('return_to', window.location.href);
  fetch('/compliance/<%= item ? item.id : '' %>/revisions', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/x-www-form-urlencoded' }),
    body: formData.toString()
  }).then(function() { window.location.reload(); });
  <% } %>
}
</script>

<% } %>
