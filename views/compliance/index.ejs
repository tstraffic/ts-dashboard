<% locals.currentPage = 'compliance' %>

<%
  const typeLabels = {
    tmp_approval: 'TMP Approval',
    council_permit: 'Council Permit',
    traffic_guidance: 'Traffic Guidance',
    insurance: 'Insurance',
    swms_review: 'SWMS Review',
    induction: 'Induction',
    road_occupancy: 'Road Occupancy',
    utility_clearance: 'Utility Clearance',
    environmental: 'Environmental',
    other: 'Other'
  };
  const statusColors = {
    not_started: 'bg-slate-600 text-slate-200',
    submitted: 'bg-blue-600 text-blue-100',
    approved: 'bg-emerald-600 text-emerald-100',
    rejected: 'bg-red-600 text-red-100',
    expired: 'bg-brand-700 text-brand-100'
  };
  const statusLabels = {
    not_started: 'Not Started',
    submitted: 'Submitted',
    approved: 'Approved',
    rejected: 'Rejected',
    expired: 'Expired'
  };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">Compliance & Approvals</h1>
    <a href="/compliance/new" class="inline-flex items-center px-4 py-2 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Item
    </a>
  </div>

  <!-- Filters -->
  <form method="GET" action="/compliance" class="bg-slate-800 border border-slate-700 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
      <!-- Status -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Status</label>
        <select name="status" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Statuses</option>
          <option value="not_started" <%= filters.status === 'not_started' ? 'selected' : '' %>>Not Started</option>
          <option value="submitted" <%= filters.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
          <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="expired" <%= filters.status === 'expired' ? 'selected' : '' %>>Expired</option>
        </select>
      </div>

      <!-- Item Type -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Type</label>
        <select name="item_type" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Types</option>
          <% Object.keys(typeLabels).forEach(function(key) { %>
            <option value="<%= key %>" <%= filters.item_type === key ? 'selected' : '' %>><%= typeLabels[key] %></option>
          <% }) %>
        </select>
      </div>

      <!-- Job -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Job</label>
        <select name="job_id" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Jobs</option>
          <% jobs.forEach(function(job) { %>
            <option value="<%= job.id %>" <%= filters.job_id == job.id ? 'selected' : '' %>><%= job.job_number %> - <%= job.client %></option>
          <% }) %>
        </select>
      </div>

      <!-- Apply -->
      <div>
        <button type="submit" class="w-full px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-500 transition font-medium">Apply Filters</button>
      </div>
    </div>
  </form>

  <!-- Compliance Table -->
  <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
    <% if (items.length === 0) { %>
      <div class="p-8 text-center text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <p>No compliance items found.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-700">
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Title</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Job</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Due Date</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Approver</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700">
            <% items.forEach(function(item) { %>
              <%
                const isOverdue = item.due_date && item.status !== 'approved' && new Date(item.due_date) < new Date();
                // Format type: replace underscores, title case
                const formattedType = item.item_type ? item.item_type.replace(/_/g, ' ').replace(/\b\w/g, function(l) { return l.toUpperCase(); }) : '-';
              %>
              <tr class="hover:bg-slate-750 hover:bg-opacity-50">
                <td class="px-4 py-3 text-white font-medium"><%= item.title %></td>
                <td class="px-4 py-3 text-slate-300"><%= formattedType %></td>
                <td class="px-4 py-3">
                  <% if (item.job_id) { %>
                    <a href="/jobs/<%= item.job_id %>" class="text-brand-400 hover:text-brand-300"><%= item.job_number %></a>
                  <% } else { %>
                    <span class="text-slate-500">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= statusColors[item.status] || 'bg-slate-600 text-slate-200' %>"><%= statusLabels[item.status] || item.status %></span>
                </td>
                <td class="px-4 py-3 <%= isOverdue ? 'text-red-400 font-semibold' : 'text-slate-300' %>">
                  <% if (item.due_date) { %>
                    <%= new Date(item.due_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    <% if (isOverdue) { %><span class="text-xs ml-1">OVERDUE</span><% } %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td class="px-4 py-3 text-slate-300"><%= item.approver_name || '-' %></td>
                <td class="px-4 py-3">
                  <a href="/compliance/<%= item.id %>/edit" class="text-slate-400 hover:text-brand-400 transition" title="Edit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
