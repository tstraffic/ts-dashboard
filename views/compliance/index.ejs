<% locals.currentPage = 'compliance' %>

<%
  const TYPE_CONFIG = {
    traffic_guidance: { label: 'TGS', short: 'TGS', color: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' },
    tmp_approval:     { label: 'CTMP',       short: 'CTMP',    color: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20' },
    spa:              { label: 'SPA',         short: 'SPA',     color: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20' },
    sza:              { label: 'SZA',         short: 'SZA',     color: 'bg-violet-50 text-violet-700 ring-1 ring-violet-600/20' },
    rol:              { label: 'ROL',         short: 'ROL',     color: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20' },
    council_permit:   { label: 'Council Permit', short: 'Council', color: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' },
    bus_approval:     { label: 'Bus Approval', short: 'Bus', color: 'bg-pink-50 text-pink-700 ring-1 ring-pink-600/20' },
    police_notification: { label: 'Police Notification', short: 'Police', color: 'bg-slate-100 text-slate-700 ring-1 ring-slate-600/20' },
    letter_drop:      { label: 'Letter Drop', short: 'Letter', color: 'bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20' },
    road_occupancy:   { label: 'Road Occupancy Licence', short: 'ROL', color: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20' },
    swms_review:      { label: 'SWMS Review', short: 'SWMS', color: 'bg-sky-50 text-sky-700 ring-1 ring-sky-600/20' },
    permit:           { label: 'Permit',      short: 'Permit', color: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20' },
    inspection:       { label: 'Inspection',  short: 'Inspect', color: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' },
    environmental:    { label: 'Environmental', short: 'Enviro', color: 'bg-green-50 text-green-700 ring-1 ring-green-600/20' },
  };
  const STATUS_CONFIG = {
    not_started: { label: 'Not Started', color: 'bg-gray-100 text-gray-600' },
    started:     { label: 'Started',     color: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20' },
    submitted:   { label: 'Submitted',   color: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' },
    approved:    { label: 'Approved',    color: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' },
    rejected:    { label: 'Rejected',    color: 'bg-red-50 text-red-700 ring-1 ring-red-600/20' },
    expired:     { label: 'Expired',     color: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' },
  };
  const MAIN_TYPES = ['traffic_guidance','tmp_approval','spa','rol'];

  function buildUrl(overrides) {
    const q = Object.assign({}, filters, overrides);
    return '/compliance?' + Object.keys(q).filter(k => q[k] !== '' && q[k] != null).map(k => k + '=' + encodeURIComponent(q[k])).join('&');
  }
  const todayStr = new Date().toISOString().split('T')[0];
  const soonStr = new Date(Date.now() + 14*24*60*60*1000).toISOString().split('T')[0];

  // Expiry band calculations
  const day7Str = new Date(Date.now() + 7*24*60*60*1000).toISOString().split('T')[0];
  const day30Str = new Date(Date.now() + 30*24*60*60*1000).toISOString().split('T')[0];
  const day60Str = new Date(Date.now() + 60*24*60*60*1000).toISOString().split('T')[0];

  let expiryExpired = 0, expiry7d = 0, expiry30d = 0, expiry60d = 0, expiryOk = 0;
  items.forEach(function(item) {
    if (!item.expiry_date) { expiryOk++; return; }
    if (item.expiry_date < todayStr) { expiryExpired++; }
    else if (item.expiry_date <= day7Str) { expiry7d++; }
    else if (item.expiry_date <= day30Str) { expiry30d++; }
    else if (item.expiry_date <= day60Str) { expiry60d++; }
    else { expiryOk++; }
  });
  const expiryTotal = expiryExpired + expiry7d + expiry30d + expiry60d + expiryOk;

  function getExpiryRowClass(item) {
    if (!item.expiry_date) return '';
    if (item.expiry_date < todayStr) return 'bg-red-50/70';
    if (item.expiry_date <= day7Str) return 'bg-red-50/50';
    if (item.expiry_date <= day30Str) return 'bg-amber-50/50';
    if (item.expiry_date <= day60Str) return 'bg-yellow-50/40';
    return '';
  }
%>

<!-- Header -->
<div class="flex items-center justify-between mb-5">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Plans &amp; Approvals</h1>
      <p class="text-sm text-gray-500 mt-0.5">TGS plans, CTMPs, SPAs, ROLs and other approvals</p>
    </div>
    <a href="/compliance/new" class="inline-flex items-center px-4 py-2 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition text-sm">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Item
    </a>
  </div>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-xl font-bold text-gray-900"><%= summary.total %></div>
      <div class="text-xs text-gray-500 mt-0.5">Total</div>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-xl font-bold text-emerald-600"><%= summary.approved %></div>
      <div class="text-xs text-gray-500 mt-0.5">Approved</div>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-xl font-bold text-blue-600"><%= summary.pending %></div>
      <div class="text-xs text-gray-500 mt-0.5">Pending</div>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-xl font-bold text-red-600"><%= summary.overdue %></div>
      <div class="text-xs text-gray-500 mt-0.5">Overdue</div>
    </div>
    <div class="bg-white border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-xl font-bold text-amber-600"><%= summary.expiringSoon %></div>
      <div class="text-xs text-gray-500 mt-0.5">Expiring Soon</div>
    </div>
    <a href="<%= buildUrl({ invoice_state: 'ready', view: filters.view, ref: filters.ref }) %>"
      class="bg-white border border-amber-200 rounded-lg p-3 text-center hover:bg-amber-50 transition cursor-pointer ring-1 ring-amber-100">
      <div class="text-xl font-bold text-amber-700"><%= summary.readyForInvoice %></div>
      <div class="text-xs text-amber-700/80 mt-0.5 font-medium">Ready for Invoice</div>
      <% if (summary.readyForInvoiceValue > 0) { %>
        <div class="text-[10px] text-amber-600/70 tabular-nums mt-0.5">$<%= summary.readyForInvoiceValue.toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
      <% } %>
    </a>
    <a href="<%= buildUrl({ invoice_state: 'invoiced', view: filters.view, ref: filters.ref }) %>"
      class="bg-white border border-emerald-200 rounded-lg p-3 text-center hover:bg-emerald-50 transition cursor-pointer ring-1 ring-emerald-100">
      <div class="text-xl font-bold text-emerald-700"><%= summary.invoicedLast30 %></div>
      <div class="text-xs text-emerald-700/80 mt-0.5 font-medium">Invoiced (30d)</div>
      <% if (summary.invoicedLast30Value > 0) { %>
        <div class="text-[10px] text-emerald-600/70 tabular-nums mt-0.5">$<%= summary.invoicedLast30Value.toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></div>
      <% } %>
    </a>
  </div>

  <!-- Expiry Urgency Bar -->
  <% if (expiryTotal > 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-4">
    <div class="flex items-center justify-between mb-2">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Expiry Distribution</p>
      <p class="text-[10px] text-gray-400"><%= expiryTotal %> items</p>
    </div>
    <div class="flex h-4 rounded-full overflow-hidden bg-gray-100">
      <% if (expiryExpired > 0) { %><div class="bg-red-500 transition-all" style="width: <%= (expiryExpired / expiryTotal * 100) %>%" title="Expired: <%= expiryExpired %>"></div><% } %>
      <% if (expiry7d > 0) { %><div class="bg-red-300 transition-all" style="width: <%= (expiry7d / expiryTotal * 100) %>%" title="Within 7 days: <%= expiry7d %>"></div><% } %>
      <% if (expiry30d > 0) { %><div class="bg-amber-400 transition-all" style="width: <%= (expiry30d / expiryTotal * 100) %>%" title="7-30 days: <%= expiry30d %>"></div><% } %>
      <% if (expiry60d > 0) { %><div class="bg-yellow-300 transition-all" style="width: <%= (expiry60d / expiryTotal * 100) %>%" title="30-60 days: <%= expiry60d %>"></div><% } %>
      <% if (expiryOk > 0) { %><div class="bg-emerald-400 transition-all" style="width: <%= (expiryOk / expiryTotal * 100) %>%" title="OK: <%= expiryOk %>"></div><% } %>
    </div>
    <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
      <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-red-500 inline-block"></span> Expired (<%= expiryExpired %>)</span>
      <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-red-300 inline-block"></span> &le; 7 days (<%= expiry7d %>)</span>
      <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-amber-400 inline-block"></span> 7-30 days (<%= expiry30d %>)</span>
      <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-yellow-300 inline-block"></span> 30-60 days (<%= expiry60d %>)</span>
      <span class="flex items-center gap-1.5 text-[10px] text-gray-500"><span class="w-2.5 h-2.5 rounded-full bg-emerald-400 inline-block"></span> OK (<%= expiryOk %>)</span>
    </div>
  </div>
  <% } %>

  <!-- Filters Panel -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-4">
    <!-- Type Chips -->
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider self-center mr-1">Type</span>
      <a href="<%= buildUrl({ item_type: '', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === '' ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
        All
      </a>
      <a href="<%= buildUrl({ item_type: 'traffic_guidance', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === 'traffic_guidance' ? 'bg-blue-600 text-white' : 'bg-blue-50 text-blue-700 hover:bg-blue-100' %>">
        TGS
      </a>
      <a href="<%= buildUrl({ item_type: 'tmp_approval', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === 'tmp_approval' ? 'bg-purple-600 text-white' : 'bg-purple-50 text-purple-700 hover:bg-purple-100' %>">
        CTMP
      </a>
      <a href="<%= buildUrl({ item_type: 'spa', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === 'spa' ? 'bg-orange-600 text-white' : 'bg-orange-50 text-orange-700 hover:bg-orange-100' %>">
        SPA
      </a>
      <a href="<%= buildUrl({ item_type: 'rol', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === 'rol' ? 'bg-teal-600 text-white' : 'bg-teal-50 text-teal-700 hover:bg-teal-100' %>">
        ROL
      </a>
      <a href="<%= buildUrl({ item_type: 'council_permit', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.item_type === 'council_permit' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100' %>">
        Council
      </a>
    </div>

    <!-- Invoice workflow chips -->
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider self-center mr-1">Invoice</span>
      <a href="<%= buildUrl({ invoice_state: '', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= !filters.invoice_state ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
        All
      </a>
      <a href="<%= buildUrl({ invoice_state: 'pending', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.invoice_state === 'pending' ? 'bg-gray-700 text-white' : 'bg-gray-50 text-gray-700 hover:bg-gray-100' %>">
        Pending
      </a>
      <a href="<%= buildUrl({ invoice_state: 'ready', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.invoice_state === 'ready' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100' %>">
        Ready for Invoice
      </a>
      <a href="<%= buildUrl({ invoice_state: 'invoiced', view: filters.view, ref: filters.ref }) %>"
        class="px-3 py-1 rounded-full text-sm font-medium transition <%= filters.invoice_state === 'invoiced' ? 'bg-emerald-600 text-white' : 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100' %>">
        Invoiced
      </a>
    </div>

    <!-- Second filter row -->
    <form method="GET" action="/compliance" id="filterForm">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="item_type" value="<%= filters.item_type %>">
      <input type="hidden" name="invoice_state" value="<%= filters.invoice_state %>">
      <div class="flex flex-wrap gap-3 items-center">

        <!-- View toggle -->
        <div class="flex rounded-lg overflow-hidden border border-gray-200 text-sm">
          <a href="<%= buildUrl({ view: 'all', ref: '' }) %>"
            class="px-3 py-1.5 font-medium transition <%= view === 'all' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">All</a>
          <a href="<%= buildUrl({ view: 'week', ref: '' }) %>"
            class="px-3 py-1.5 font-medium transition border-l border-gray-200 <%= view === 'week' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">Weekly</a>
          <a href="<%= buildUrl({ view: 'month', ref: '' }) %>"
            class="px-3 py-1.5 font-medium transition border-l border-gray-200 <%= view === 'month' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">Monthly</a>
        </div>

        <!-- Period nav (only for week/month) -->
        <% if (view !== 'all' && periodLabel) { %>
          <div class="flex items-center gap-1">
            <a href="<%= buildUrl({ ref: prevRef }) %>" class="p-1.5 rounded hover:bg-gray-100 text-gray-500 transition" title="Previous">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </a>
            <span class="text-sm font-medium text-gray-700 min-w-36 text-center"><%= periodLabel %></span>
            <a href="<%= buildUrl({ ref: nextRef }) %>" class="p-1.5 rounded hover:bg-gray-100 text-gray-500 transition" title="Next">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        <% } %>

        <!-- Status -->
        <select name="status" onchange="document.getElementById('filterForm').submit()" class="bg-white border border-gray-200 text-gray-700 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Statuses</option>
          <option value="not_started" <%= filters.status === 'not_started' ? 'selected' : '' %>>Not Started</option>
          <option value="started"     <%= filters.status === 'started'     ? 'selected' : '' %>>Started</option>
          <option value="submitted"   <%= filters.status === 'submitted'   ? 'selected' : '' %>>Submitted</option>
          <option value="approved"    <%= filters.status === 'approved'    ? 'selected' : '' %>>Approved</option>
          <option value="rejected"    <%= filters.status === 'rejected'    ? 'selected' : '' %>>Rejected</option>
          <option value="expired"     <%= filters.status === 'expired'     ? 'selected' : '' %>>Expired</option>
        </select>

        <!-- Date Range -->
        <div class="flex items-center gap-1.5">
          <label class="text-xs text-gray-400 font-medium whitespace-nowrap">From</label>
          <input type="date" name="date_from" value="<%= filters.date_from || '' %>"
            onchange="document.getElementById('filterForm').submit()"
            class="bg-white border border-gray-200 text-gray-700 rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div class="flex items-center gap-1.5">
          <label class="text-xs text-gray-400 font-medium whitespace-nowrap">To</label>
          <input type="date" name="date_to" value="<%= filters.date_to || '' %>"
            onchange="document.getElementById('filterForm').submit()"
            class="bg-white border border-gray-200 text-gray-700 rounded-lg px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>

        <!-- Project -->
        <select name="job_id" onchange="document.getElementById('filterForm').submit()" class="bg-white border border-gray-200 text-gray-700 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Projects</option>
          <% jobs.forEach(function(job) { %>
            <option value="<%= job.id %>" <%= filters.job_id == job.id ? 'selected' : '' %>><%= job.job_number %> - <%= job.project_name ? job.project_name + ' (' + job.client + ')' : job.client %></option>
          <% }) %>
        </select>

        <% if (filters.status || filters.job_id || filters.date_from || filters.date_to) { %>
          <a href="<%= buildUrl({ status: '', job_id: '', date_from: '', date_to: '' }) %>" class="text-sm text-gray-400 hover:text-gray-600 transition">Clear filters</a>
        <% } %>

        <!-- Export -->
        <a href="/exports/compliance.csv?status=<%= filters.status %>&item_type=<%= filters.item_type %>&job_id=<%= filters.job_id %>"
          class="ml-auto px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Export CSV
        </a>
      </div>
    </form>
  </div>

  <!-- Bulk Actions Bar (hidden until items selected) -->
  <div id="bulkBar" class="hidden bg-white border-2 border-brand-500 rounded-xl shadow-sm p-3 mb-4 flex items-center justify-between">
    <span class="text-sm text-gray-600"><span id="selectedCount" class="text-gray-900 font-bold">0</span> item(s) selected</span>
    <div class="flex items-center gap-2 flex-wrap">
      <button onclick="bulkUpdateStatus('submitted')" class="px-3 py-1.5 text-xs font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-500 transition">Mark Submitted</button>
      <button onclick="bulkReadyForInvoice()" class="px-3 py-1.5 text-xs font-medium bg-amber-500 text-white rounded-lg hover:bg-amber-400 transition">Ready for Invoice</button>
      <% if (user.role === 'admin' || user.role === 'finance' || user.role === 'accounts') { %>
        <button onclick="bulkMarkInvoiced()" class="px-3 py-1.5 text-xs font-medium bg-teal-600 text-white rounded-lg hover:bg-teal-500 transition">Mark Invoiced</button>
      <% } %>
      <button onclick="bulkDelete()" class="px-3 py-1.5 text-xs font-medium bg-red-600 text-white rounded-lg hover:bg-red-500 transition">Delete Selected</button>
    </div>
  </div>

  <!-- Register Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (items.length === 0) { %>
      <div class="py-6 text-center text-gray-400">
        <svg class="w-10 h-10 mx-auto mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-sm">No items found<% if (view !== 'all') { %> for this <%= view === 'week' ? 'week' : 'month' %><% } %>.</p>
        <a href="/compliance/new" class="mt-3 inline-block text-sm text-brand-600 hover:text-brand-700 font-medium">+ Add first item</a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-2 py-2 w-10">
                <input type="checkbox" id="selectAll" onclick="toggleSelectAll(this)" class="w-4 h-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500 focus:ring-offset-0 cursor-pointer">
              </th>
              <th class="hidden md:table-cell px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Ref</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Title</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
              <th class="hidden lg:table-cell px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Project</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
              <th class="hidden md:table-cell px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Client Req</th>
              <th class="hidden sm:table-cell px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Due Date</th>
              <th class="hidden lg:table-cell px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Assigned</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Invoice</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% monthGroups.forEach(function(group) { %>
              <%
                const rowHidden = group.open ? '' : 'hidden';
                const chevronClass = group.open ? 'rotate-90' : '';
              %>
              <tr class="month-header bg-gray-50 hover:bg-gray-100 cursor-pointer" data-month-toggle="<%= group.key %>" data-open="<%= group.open ? '1' : '0' %>">
                <td colspan="10" class="px-2 py-2">
                  <div class="flex items-center gap-2">
                    <svg class="month-chevron w-3.5 h-3.5 text-gray-500 transition-transform <%= chevronClass %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-xs font-bold text-gray-700 uppercase tracking-wider"><%= group.label %></span>
                    <span class="text-[11px] text-gray-400">(<%= group.items.length %>)</span>
                  </div>
                </td>
              </tr>
            <% group.items.forEach(function(item, idx) {
              const tc = TYPE_CONFIG[item.item_type] || { label: item.item_type, short: item.item_type, color: 'bg-gray-100 text-gray-600' };
              const sc = STATUS_CONFIG[item.status] || { label: item.status, color: 'bg-gray-100 text-gray-600' };
              const isOverdue = item.due_date && item.due_date < todayStr && !['submitted','approved','expired'].includes(item.status);
              const isDueSoon = !isOverdue && item.due_date && item.due_date > todayStr && item.due_date <= soonStr && !['submitted','approved','expired'].includes(item.status);
              const isExpiryNear = item.expiry_date && item.expiry_date >= todayStr && item.expiry_date <= soonStr && ['submitted','approved'].includes(item.status);
              const isExpired = item.expiry_date && item.expiry_date < todayStr;
              const returnTo = '/compliance?' + Object.keys(filters).filter(k => filters[k]).map(k => k + '=' + encodeURIComponent(filters[k])).join('&');
            %>
              <tr class="month-row <%= rowHidden %> <%= (item.revision_required || item.revision_count > 0) ? 'bg-orange-50/60 border-l-[3px] border-l-orange-400' : item.ready_for_invoice && !item.invoiced ? 'bg-amber-50/50 border-l-2 border-l-amber-400' : item.invoiced ? 'bg-emerald-50/30' : getExpiryRowClass(item) %> hover:bg-gray-50 transition-colors cursor-pointer" data-month-row="<%= group.key %>" data-expiry-class="<%= getExpiryRowClass(item) %>" onclick="if(!event.target.closest('a,button,input,.row-checkbox')){window.location.href='/compliance/<%= item.id %>/edit?return_to=<%= encodeURIComponent(returnTo) %>'}">
                <td class="px-2 py-2">
                  <input type="checkbox" class="row-checkbox w-4 h-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500 focus:ring-offset-0 cursor-pointer" data-id="<%= item.id %>" onclick="updateBulkBar()">
                </td>
                <td class="hidden md:table-cell px-2 py-2 whitespace-nowrap">
                  <% if ((item.parent_id == null) && (item.plan_number != null)) { %>
                    <%
                      const subCount = (subPlansByParent[item.id] || []).length;
                    %>
                    <button type="button" class="sub-plans-toggle inline-flex items-center gap-1.5 text-xs font-mono font-semibold text-brand-700 hover:text-brand-800"
                      data-target="exp-<%= item.id %>" onclick="event.stopPropagation();"
                      title="Click to see <%= subCount %> sub-plan<%= subCount === 1 ? '' : 's' %>">
                      <svg class="w-3.5 h-3.5 chevron transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                      #<%= item.plan_number %>
                      <span class="text-[10px] font-sans font-normal text-gray-400">(<%= subCount %>)</span>
                    </button>
                  <% } else if (item.reference_number) { %>
                    <span class="text-xs font-mono text-gray-600"><%= item.reference_number %></span>
                    <% if (item.item_type === 'traffic_guidance' && item.tgs_quantity > 1) { %>
                      <div class="flex flex-wrap gap-0.5 mt-0.5">
                        <% for (var qi = 1; qi <= item.tgs_quantity; qi++) { %>
                          <span class="text-[10px] font-mono text-blue-600 bg-blue-50 px-1 rounded"><%= item.reference_number %>-<%= qi %></span>
                        <% } %>
                      </div>
                    <% } %>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <td class="px-2 py-2 font-medium text-gray-900 max-w-[14rem]">
                  <span class="truncate block"><%= item.title %></span>
                  <span class="title-invoice-badge" data-id="<%= item.id %>">
                    <% if (item.ready_for_invoice && !item.invoiced) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded bg-amber-100 text-amber-700 mt-0.5">READY FOR INVOICE</span>
                    <% } else if (item.invoiced) { %>
                      <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded bg-emerald-100 text-emerald-700 mt-0.5">INVOICED<%= item.invoice_number ? ' — ' + item.invoice_number : '' %></span>
                    <% } %>
                  </span>
                  <% if (item.item_type === 'council_permit' && item.council_fee_amount > 0) { %>
                    <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded mt-0.5 <%= item.council_fee_paid ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200' : 'bg-rose-50 text-rose-700 ring-1 ring-rose-200' %>">
                      Council fee $<%= item.council_fee_amount.toLocaleString() %> <%= item.council_fee_paid ? '· paid' : '· unpaid' %>
                    </span>
                  <% } %>
                  <% if (item.authority_approver) { %>
                    <span class="text-xs text-gray-400"><%= item.authority_approver %></span>
                  <% } %>
                </td>
                <td class="px-2 py-2">
                  <div class="flex flex-wrap gap-1">
                    <% if ((item.parent_id == null) && (item.plan_number != null)) { %>
                      <%
                        // Parent row: show a per-sub-plan-type badge cluster derived
                        // from the actual children, not the placeholder item_type.
                        const subTypes = (subPlansByParent[item.id] || []).map(s => s.item_type);
                        const counts = {};
                        subTypes.forEach(t => { counts[t] = (counts[t] || 0) + 1; });
                      %>
                      <% Object.keys(counts).forEach(function(t) {
                        const ttc = TYPE_CONFIG[t] || { short: t, color: 'bg-gray-100 text-gray-600' };
                      %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full <%= ttc.color %>"><%= ttc.short %><% if (counts[t] > 1) { %> <span class="ml-1 opacity-70">×<%= counts[t] %></span><% } %></span>
                      <% }) %>
                      <% if (subTypes.length === 0) { %>
                        <span class="text-[11px] text-gray-400 italic">empty plan</span>
                      <% } %>
                    <% } else { %>
                      <% const displayItemTypes = (item.item_types || item.item_type || '').split(',').filter(Boolean); %>
                      <% displayItemTypes.forEach(function(t) {
                        const ttc = TYPE_CONFIG[t] || { short: t, color: 'bg-gray-100 text-gray-600' };
                      %>
                        <span class="inline-flex items-center px-2 py-0.5 text-xs font-semibold rounded-full <%= ttc.color %>"><%= ttc.short %></span>
                      <% }) %>
                      <% if (item.revision_count > 0) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-amber-100 text-amber-700">Rev <%= item.revision_count %></span>
                      <% } %>
                      <% if (item.revision_required && !item.revision_count) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-red-100 text-red-700">REV REQ</span>
                      <% } %>
                    <% } %>
                  </div>
                </td>
                <td class="hidden lg:table-cell px-2 py-2">
                  <% if (item.job_id) { %>
                    <a href="/projects/<%= item.job_id %>" class="text-brand-600 hover:text-brand-700 font-medium"><%= item.job_number %></a>
                    <% if (item.client_id) { %>
                      <a href="/clients/<%= item.client_id %>" class="block text-xs text-gray-400 hover:text-brand-500 truncate max-w-24"><%= item.job_client %></a>
                    <% } else { %>
                      <div class="text-xs text-gray-400 truncate max-w-24"><%= item.job_client %></div>
                    <% } %>
                  <% } else if (item.client_id || item.client_name) { %>
                    <a href="/clients/<%= item.client_id %>" class="text-brand-600 hover:text-brand-700 font-medium text-sm"><%= item.client_name %></a>
                    <div class="text-xs text-gray-400">Client only</div>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <td class="px-2 py-2 status-cell" data-id="<%= item.id %>" data-status="<%= item.status %>">
                  <button type="button"
                    onclick="event.stopPropagation(); openStatusPopover(event, <%= item.id %>, '<%= item.status %>')"
                    class="status-pill inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold rounded-full <%= sc.color %> hover:ring-1 hover:ring-gray-300 transition cursor-pointer"
                    title="Click to change status">
                    <%= sc.label %>
                    <svg class="w-2.5 h-2.5 opacity-60" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                </td>
                <td class="hidden md:table-cell px-2 py-2 whitespace-nowrap text-gray-700">
                  <% if (item.client_request_date) { %>
                    <%= formatDate(item.client_request_date) %>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <td class="hidden sm:table-cell px-2 py-2 whitespace-nowrap">
                  <% if (item.due_date) { %>
                    <span class="<%= isOverdue ? 'text-red-600 font-semibold' : isDueSoon ? 'text-amber-600 font-medium' : 'text-gray-700' %>">
                      <%= formatDate(item.due_date) %>
                    </span>
                    <% if (isOverdue) { %><span class="block text-xs text-red-500 font-medium">OVERDUE</span><% } %>
                    <% if (isDueSoon) { %><span class="block text-xs text-amber-500 font-medium">DUE SOON</span><% } %>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                  <%
                    const itemTypes = (item.item_types || item.item_type || '').split(',');
                    const hasStartFinish = (itemTypes.includes('rol') || itemTypes.includes('council_permit') || itemTypes.includes('sza')) && (item.start_date || item.finish_date);
                  %>
                  <% if (hasStartFinish) { %>
                    <div class="text-[10px] text-teal-600 mt-0.5">
                      <%= item.start_date ? formatDate(item.start_date) : '?' %> – <%= item.finish_date ? formatDate(item.finish_date) : '?' %>
                    </div>
                  <% } %>
                </td>
                <td class="hidden lg:table-cell px-2 py-2">
                  <% if (item.assigned_name) { %>
                    <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                      <span class="w-5 h-5 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-semibold text-xs flex-shrink-0"><%= item.assigned_name.charAt(0) %></span>
                      <%= item.assigned_name.split(' ')[0] %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-300">—</span>
                  <% } %>
                </td>
                <!-- Invoice column: state pill + per-row action.
                     The cell content is re-rendered client-side after each
                     action, so no full page reload — scroll position stays put. -->
                <% const canMarkInvoiced = ['admin', 'finance', 'accounts'].includes(user.role); %>
                <td class="px-2 py-2 align-top whitespace-nowrap invoice-cell"
                    data-id="<%= item.id %>"
                    data-title="<%= (item.title || '').replace(/"/g, '&quot;') %>">
                  <%- include('partials/_invoice_cell', { item, canMarkInvoiced, formatDate }) %>
                </td>

              </tr>
              <% if ((item.parent_id == null) && (item.plan_number != null)) { %>
                <%
                  const subList = subPlansByParent[item.id] || [];
                  const subBadge = { not_started:'bg-gray-100 text-gray-700', started:'bg-amber-50 text-amber-700', submitted:'bg-blue-50 text-blue-700', approved:'bg-emerald-50 text-emerald-700', rejected:'bg-rose-50 text-rose-700', expired:'bg-orange-50 text-orange-700' };
                  let planHours = 0, planCharge = 0, planFee = 0;
                  subList.forEach(s => {
                    planHours += parseFloat(s.hours_spent) || 0;
                    if (s.charge_client) planCharge += parseFloat(s.charge_amount) || 0;
                    if (s.council_fee_paid) planFee += parseFloat(s.council_fee_amount) || 0;
                  });
                  const fmt$ = n => '$' + (Math.round(n * 100) / 100).toFixed(2);
                %>
                <tr id="exp-<%= item.id %>" class="hidden bg-gray-50/50 month-row" data-month-row="<%= group.key %>" data-sub-expansion="1">
                  <td colspan="9" class="px-6 py-3 border-l-2 border-l-brand-300">
                    <% if (subList.length === 0) { %>
                      <div class="text-xs text-gray-500 italic">No sub-plans yet — open the Plan to add some.</div>
                    <% } else { %>
                      <div class="text-[11px] uppercase tracking-wide text-gray-400 font-semibold mb-2">Sub-plans (#<%= item.plan_number %>)</div>
                      <table class="w-full text-xs">
                        <thead class="text-gray-500">
                          <tr class="text-left">
                            <th class="font-medium pb-1.5 pr-3">Reference</th>
                            <th class="font-medium pb-1.5 pr-3">Description</th>
                            <th class="font-medium pb-1.5 pr-3">Owner</th>
                            <th class="font-medium pb-1.5 pr-3">Status</th>
                            <th class="font-medium pb-1.5 pr-3">Files</th>
                            <th class="font-medium pb-1.5 pr-3">Hours</th>
                            <th class="font-medium pb-1.5 pr-3">Charge</th>
                            <th class="font-medium pb-1.5 pr-3">Council fee</th>
                            <th class="font-medium pb-1.5 pr-3">Expires</th>
                            <th class="font-medium pb-1.5 pr-3">Flags</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% subList.forEach(s => { %>
                            <tr class="border-t border-gray-200">
                              <td class="py-1.5 pr-3 font-mono text-gray-700"><%= s.reference_number %></td>
                              <td class="py-1.5 pr-3 text-gray-700"><%= s.description || '—' %></td>
                              <td class="py-1.5 pr-3 text-gray-600"><%= s.owner_name || '—' %></td>
                              <td class="py-1.5 pr-3">
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-bold <%= subBadge[s.status] || subBadge.not_started %>"><%= (s.status || 'not_started').replace(/_/g, ' ') %></span>
                              </td>
                              <td class="py-1.5 pr-3 text-gray-600"><%= s.doc_count || 0 %></td>
                              <td class="py-1.5 pr-3 text-gray-600"><%= parseFloat(s.hours_spent) ? (Math.round(s.hours_spent * 100) / 100) + 'h' : '—' %></td>
                              <td class="py-1.5 pr-3 text-gray-700"><%= s.charge_client ? fmt$(parseFloat(s.charge_amount) || 0) : '—' %></td>
                              <td class="py-1.5 pr-3 text-gray-700"><%= s.council_fee_paid ? fmt$(parseFloat(s.council_fee_amount) || 0) : '—' %></td>
                              <td class="py-1.5 pr-3 text-gray-600"><%= s.expiry_date || '—' %></td>
                              <td class="py-1.5 pr-3">
                                <% if ((s.item_type === 'rol' || s.item_type === 'road_occupancy') && s.extension_required) { %>
                                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-200">extension</span>
                                <% } %>
                              </td>
                            </tr>
                          <% }) %>
                          <tr class="border-t-2 border-gray-300 bg-brand-50/40">
                            <td class="py-2 pr-3 font-semibold text-gray-700" colspan="5">Plan totals</td>
                            <td class="py-2 pr-3 font-semibold text-gray-900"><%= (Math.round(planHours * 100) / 100) %>h</td>
                            <td class="py-2 pr-3 font-semibold text-emerald-700"><%= fmt$(planCharge) %></td>
                            <td class="py-2 pr-3 font-semibold text-amber-700"><%= fmt$(planFee) %></td>
                            <td class="py-2 pr-3" colspan="2"></td>
                          </tr>
                        </tbody>
                      </table>
                      <div class="mt-2">
                        <a href="/compliance/<%= item.id %>/edit?return_to=<%= encodeURIComponent(returnTo) %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Open Plan →</a>
                      </div>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            <% }) %>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="px-4 py-2 border-t border-gray-100 bg-gray-50 text-xs text-gray-400">
        Showing <%= items.length %> item<%= items.length !== 1 ? 's' : '' %>
        <% if (view !== 'all' && periodLabel) { %> for <%= periodLabel %><% } %>
      </div>
    <% } %>
  </div>

<script>
// Month-section collapse. Each month bucket has a header row that
// toggles visibility of the regular item rows in that month. Sub-plan
// expansion rows stay hidden when re-opening a month — the user
// re-opens those individually via their own chevron.
document.querySelectorAll('[data-month-toggle]').forEach(header => {
  header.addEventListener('click', () => {
    const key = header.dataset.monthToggle;
    const willOpen = header.dataset.open !== '1';
    header.dataset.open = willOpen ? '1' : '0';
    header.querySelector('.month-chevron')?.classList.toggle('rotate-90', willOpen);
    document.querySelectorAll('[data-month-row="' + CSS.escape(key) + '"]').forEach(row => {
      if (!willOpen) {
        row.classList.add('hidden');
      } else if (!row.dataset.subExpansion) {
        row.classList.remove('hidden');
      }
    });
  });
});

// Sub-plan expansion toggles. Clicking the chevron on a parent row flips
// the hidden sibling row that holds its sub-plan grid.
document.querySelectorAll('.sub-plans-toggle').forEach(btn => {
  btn.addEventListener('click', e => {
    const target = document.getElementById(btn.dataset.target);
    if (!target) return;
    target.classList.toggle('hidden');
    btn.querySelector('.chevron')?.classList.toggle('rotate-180');
  });
});

function getSelectedIds() {
  return Array.from(document.querySelectorAll('.row-checkbox:checked')).map(cb => cb.dataset.id);
}

function updateBulkBar() {
  const ids = getSelectedIds();
  const bar = document.getElementById('bulkBar');
  const count = document.getElementById('selectedCount');
  const selectAll = document.getElementById('selectAll');
  const allBoxes = document.querySelectorAll('.row-checkbox');

  count.textContent = ids.length;
  bar.classList.toggle('hidden', ids.length === 0);

  if (allBoxes.length > 0) {
    const allChecked = ids.length === allBoxes.length;
    const someChecked = ids.length > 0 && !allChecked;
    selectAll.checked = allChecked;
    selectAll.indeterminate = someChecked;
  }
}

function toggleSelectAll(el) {
  document.querySelectorAll('.row-checkbox').forEach(cb => { cb.checked = el.checked; });
  updateBulkBar();
}

// Bulk actions still trigger a reload (multiple rows changing) but we
// preserve scroll position via sessionStorage so the user lands back where
// they were instead of jumping to the top.
function preserveScrollOnReload() {
  try { sessionStorage.setItem('compliance:scrollY', String(window.scrollY)); } catch (e) {}
}
(function restoreScrollAfterReload() {
  try {
    const y = sessionStorage.getItem('compliance:scrollY');
    if (y != null) {
      sessionStorage.removeItem('compliance:scrollY');
      // Wait a tick so the page has laid out
      requestAnimationFrame(() => window.scrollTo(0, parseInt(y, 10) || 0));
    }
  } catch (e) {}
})();

function bulkDelete() {
  const ids = getSelectedIds();
  if (ids.length === 0) return;
  if (!confirm('Delete ' + ids.length + ' selected item(s)? This cannot be undone.')) return;
  preserveScrollOnReload();
  fetch('/compliance/bulk-delete', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json' }),
    body: JSON.stringify({ ids: ids })
  }).then(r => { if (r.ok) window.location.reload(); else { sessionStorage.removeItem('compliance:scrollY'); showToast('Failed to delete items.', 'error'); } });
}

function bulkUpdateStatus(status) {
  const ids = getSelectedIds();
  if (ids.length === 0) return;
  const label = status.charAt(0).toUpperCase() + status.slice(1);
  if (!confirm('Mark ' + ids.length + ' item(s) as ' + label + '?')) return;
  preserveScrollOnReload();
  fetch('/compliance/bulk-status', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json' }),
    body: JSON.stringify({ ids: ids, status: status })
  }).then(r => { if (r.ok) window.location.reload(); else { sessionStorage.removeItem('compliance:scrollY'); showToast('Failed to update items.', 'error'); } });
}

function bulkReadyForInvoice() {
  const ids = getSelectedIds();
  if (ids.length === 0) return;
  preserveScrollOnReload();
  fetch('/compliance/bulk-ready-invoice', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json' }),
    body: JSON.stringify({ ids: ids })
  }).then(r => { if (r.ok) window.location.reload(); else { sessionStorage.removeItem('compliance:scrollY'); showToast('Failed to update.', 'error'); } });
}

function bulkMarkInvoiced() {
  const ids = getSelectedIds();
  if (ids.length === 0) return;
  // Open modal in bulk mode — invoice number applies to all selected items
  openInvoiceModal(ids, ids.length + ' selected items', '', '', true);
}

// ------------------------------------------------------------------------
// Per-row invoice flow — no confirms, no reloads. Everything updates the
// row's invoice cell in place and shows a small toast with Undo.
// ------------------------------------------------------------------------

const CAN_MARK_INVOICED = <%= ['admin','finance','accounts'].includes(user.role) ? 'true' : 'false' %>;

// Render one invoice cell from a fresh state object returned by the server.
// Mirrors views/compliance/partials/_invoice_cell.ejs — keep these in sync.
function fmtDateAU(dateStr) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('en-AU', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
function escapeHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}
function escapeJs(s) { return String(s == null ? '' : s).replace(/\\/g, '\\\\').replace(/'/g, "\\'"); }

function renderInvoiceCell(item) {
  const id = item.id;
  if (item.invoiced) {
    let html = '<div class="flex items-start gap-1.5 flex-wrap">'
      + '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-100 text-emerald-700">'
      + '<svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
      + 'INVOICED</span>';
    if (item.invoice_number) html += '<span class="text-[11px] font-mono text-emerald-700">' + escapeHtml(item.invoice_number) + '</span>';
    html += '</div>';
    if (item.invoiced_at) {
      html += '<p class="text-[10px] text-gray-400 mt-0.5">' + fmtDateAU(item.invoiced_at);
      if (item.invoiced_by_name) html += ' · ' + escapeHtml(item.invoiced_by_name.split(' ')[0]);
      html += '</p>';
    }
    if (CAN_MARK_INVOICED) {
      html += '<button type="button" onclick="event.stopPropagation(); unmarkInvoiced(' + id + ')" class="mt-1 text-[10px] text-gray-500 hover:text-red-600 underline transition">undo</button>';
    }
    return html;
  }
  if (item.ready_for_invoice) {
    let html = '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-700">'
      + '<svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>'
      + 'READY</span>';
    if (item.ready_for_invoice_at) {
      html += '<p class="text-[10px] text-gray-400 mt-0.5">' + fmtDateAU(item.ready_for_invoice_at);
      if (item.ready_for_invoice_by_name) html += ' · ' + escapeHtml(item.ready_for_invoice_by_name.split(' ')[0]);
      html += '</p>';
    }
    if (CAN_MARK_INVOICED) {
      const td = document.querySelector('.invoice-cell[data-id="' + id + '"]');
      const title = td ? td.dataset.title : '';
      html += '<button type="button" onclick="event.stopPropagation(); openInvoiceModal(' + id + ', \'' + escapeJs(title) + '\', \'' + escapeJs(item.invoice_number || '') + '\', \'' + escapeJs(item.charge_amount || '') + '\')"'
        + ' class="mt-1 inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold text-white bg-emerald-600 hover:bg-emerald-500 rounded transition">'
        + 'Mark invoiced →</button>';
      html += '<button type="button" onclick="event.stopPropagation(); unmarkReady(' + id + ')" class="ml-1 text-[10px] text-gray-500 hover:text-red-600 underline transition">undo</button>';
    } else {
      html += '<p class="text-[10px] text-gray-400 mt-0.5 italic">awaiting accounts</p>';
    }
    return html;
  }
  // Pending
  return '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-500">—</span>'
    + '<button type="button" onclick="event.stopPropagation(); markReadyForInvoice(' + id + ')"'
    + ' class="block mt-1 text-[10px] font-semibold text-amber-600 hover:text-amber-700 hover:underline transition">Mark ready</button>';
}

function updateInvoiceCell(item) {
  const td = document.querySelector('.invoice-cell[data-id="' + item.id + '"]');
  if (td) td.innerHTML = renderInvoiceCell(item);
  const badge = document.querySelector('.title-invoice-badge[data-id="' + item.id + '"]');
  if (badge) badge.innerHTML = renderTitleBadge(item);
  updateRowTint(item);
}

function renderTitleBadge(item) {
  if (item.ready_for_invoice && !item.invoiced) {
    return '<span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded bg-amber-100 text-amber-700 mt-0.5">READY FOR INVOICE</span>';
  }
  if (item.invoiced) {
    return '<span class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-bold rounded bg-emerald-100 text-emerald-700 mt-0.5">INVOICED'
      + (item.invoice_number ? ' — ' + escapeHtml(item.invoice_number) : '')
      + '</span>';
  }
  return '';
}

// Repaint the row's background to match its new invoice state without a
// page reload. Mirrors the server-side priority in the row template:
// revision wins (left untouched here — invoice actions don't change it),
// then ready-for-invoice (amber), then invoiced (emerald), otherwise
// fall back to the expiry-based tint we stashed on the row at render time.
function updateRowTint(item) {
  const td = document.querySelector('.invoice-cell[data-id="' + item.id + '"]');
  if (!td) return;
  const tr = td.closest('tr');
  if (!tr) return;
  if (tr.classList.contains('bg-orange-50/60')) return;
  ['bg-amber-50/50','border-l-2','border-l-amber-400',
   'bg-emerald-50/30',
   'bg-red-50/70','bg-red-50/50','bg-yellow-50/40'].forEach(c => tr.classList.remove(c));
  if (item.ready_for_invoice && !item.invoiced) {
    tr.classList.add('bg-amber-50/50','border-l-2','border-l-amber-400');
  } else if (item.invoiced) {
    tr.classList.add('bg-emerald-50/30');
  } else {
    const expiry = (tr.dataset.expiryClass || '').trim();
    if (expiry) expiry.split(/\s+/).forEach(c => tr.classList.add(c));
  }
}

// POST helper — returns a Promise that resolves with the parsed JSON or rejects
function postJson(url, body) {
  const fd = new URLSearchParams();
  fd.set('_csrf', document.querySelector('input[name="_csrf"]').value);
  if (body) Object.keys(body).forEach(k => fd.set(k, body[k]));
  return fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
    body: fd.toString(),
  }).then(r => {
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  });
}

function markReadyForInvoice(id) {
  postJson('/compliance/' + id + '/ready-for-invoice')
    .then(data => {
      if (data && data.item) updateInvoiceCell(data.item);
      showToast('Marked ready for invoice', 'success', { undo: () => unmarkReady(id, /*silent=*/true) });
    })
    .catch(() => showToast('Failed to mark ready', 'error'));
}

function unmarkReady(id, silent) {
  postJson('/compliance/' + id + '/unmark-invoice')
    .then(data => {
      // Endpoint doesn't return the item shape, so build a minimal one
      const item = (data && data.item) ? data.item : { id, ready_for_invoice: 0, invoiced: 0 };
      updateInvoiceCell(item);
      if (!silent) showToast('Reverted to pending', 'info');
    })
    .catch(() => showToast('Failed to undo', 'error'));
}

function unmarkInvoiced(id) {
  postJson('/compliance/' + id + '/unmark-invoiced')
    .then(data => {
      if (data && data.item) updateInvoiceCell(data.item);
      showToast('Invoiced mark removed', 'info');
    })
    .catch(() => showToast('Failed to undo (admin/accounts only)', 'error'));
}

// Invoice number modal — works for single or bulk mode
let invoiceModalState = { id: null, ids: null, isBulk: false };
function openInvoiceModal(idOrIds, label, prefilledNumber, prefilledCharge, isBulk) {
  invoiceModalState.isBulk = !!isBulk;
  if (isBulk) { invoiceModalState.ids = idOrIds; invoiceModalState.id = null; }
  else        { invoiceModalState.id = idOrIds;  invoiceModalState.ids = null; }
  document.getElementById('invoiceModalLabel').textContent = label;
  const inp = document.getElementById('invoiceNumberInput');
  inp.value = prefilledNumber || '';
  const chargeInp = document.getElementById('invoiceChargeInput');
  // Bulk mode shares one charge value across rows — leave it blank since
  // a single charge rarely makes sense for a multi-row mark.
  chargeInp.value = (!isBulk && prefilledCharge) ? String(prefilledCharge) : '';
  // Focus charge if number is already known, otherwise number first.
  document.getElementById('invoiceModal').classList.remove('hidden');
  setTimeout(() => (prefilledNumber ? chargeInp : inp).focus(), 50);
}
function closeInvoiceModal() {
  document.getElementById('invoiceModal').classList.add('hidden');
}
function submitInvoiceModal() {
  const num = document.getElementById('invoiceNumberInput').value.trim();
  const chargeRaw = document.getElementById('invoiceChargeInput').value.trim();
  const charge = parseFloat(chargeRaw);
  if (!Number.isFinite(charge) || charge <= 0) {
    showToast('Enter a charge amount before marking invoiced', 'error');
    document.getElementById('invoiceChargeInput').focus();
    return;
  }
  if (invoiceModalState.isBulk) {
    // Bulk affects many rows — easier to reload, but preserve scroll first.
    preserveScrollOnReload();
    fetch('/compliance/bulk-invoiced', {
      method: 'POST',
      headers: csrfHeaders({ 'Content-Type': 'application/json' }),
      body: JSON.stringify({ ids: invoiceModalState.ids, invoice_number: num, charge_amount: charge })
    }).then(r => { if (r.ok) window.location.reload(); else { sessionStorage.removeItem('compliance:scrollY'); showToast('Failed to mark invoiced', 'error'); } });
  } else {
    closeInvoiceModal();
    postJson('/compliance/' + invoiceModalState.id + '/mark-invoiced', { invoice_number: num, charge_amount: charge })
      .then(data => {
        if (data && data.item) updateInvoiceCell(data.item);
        showToast('Marked invoiced' + (num ? ' (' + num + ')' : ''), 'success', {
          undo: () => unmarkInvoiced(invoiceModalState.id),
        });
      })
      .catch(() => showToast('Failed to mark invoiced', 'error'));
  }
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeInvoiceModal();
  if (e.key === 'Enter' && !document.getElementById('invoiceModal').classList.contains('hidden')
      && (document.activeElement === document.getElementById('invoiceNumberInput')
          || document.activeElement === document.getElementById('invoiceChargeInput'))) {
    e.preventDefault();
    submitInvoiceModal();
  }
});

// Status quick-change popover --------------------------------------------
// Mirror of EJS STATUS_CONFIG, used to repaint the pill in-place.
const STATUS_CONFIG_JS = {
  not_started: { label: 'Not Started', color: 'bg-gray-100 text-gray-600' },
  started:     { label: 'Started',     color: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20' },
  submitted:   { label: 'Submitted',   color: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' },
  approved:    { label: 'Approved',    color: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' },
  rejected:    { label: 'Rejected',    color: 'bg-red-50 text-red-700 ring-1 ring-red-600/20' },
  expired:     { label: 'Expired',     color: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' },
};
let statusPopoverState = { id: null, currentStatus: null };

function openStatusPopover(event, id, currentStatus) {
  statusPopoverState = { id, currentStatus };
  const pop = document.getElementById('statusPopover');
  // Mark the current option with a check
  pop.querySelectorAll('[data-status]').forEach(btn => {
    const check = btn.querySelector('.popover-check');
    if (btn.dataset.status === currentStatus) check.classList.remove('hidden');
    else check.classList.add('hidden');
  });
  // Show first so we can measure
  pop.classList.remove('hidden');
  // Position next to the clicked pill, clamped to viewport
  const trigger = event.currentTarget.getBoundingClientRect();
  const popRect = pop.getBoundingClientRect();
  let top = trigger.bottom + 6;
  let left = trigger.left;
  if (left + popRect.width > window.innerWidth - 8) left = window.innerWidth - popRect.width - 8;
  if (top + popRect.height > window.innerHeight - 8) top = trigger.top - popRect.height - 6;
  pop.style.top = top + 'px';
  pop.style.left = Math.max(8, left) + 'px';
}
function closeStatusPopover() {
  document.getElementById('statusPopover').classList.add('hidden');
  statusPopoverState = { id: null, currentStatus: null };
}
function selectStatus(newStatus) {
  if (!statusPopoverState.id) return;
  const id = statusPopoverState.id;
  const oldStatus = statusPopoverState.currentStatus;
  closeStatusPopover();
  if (newStatus === oldStatus) return; // no-op
  // Optimistic update
  updateStatusCell(id, newStatus);
  fetch('/compliance/bulk-status', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json' }),
    body: JSON.stringify({ ids: [String(id)], status: newStatus })
  }).then(r => {
    if (!r.ok) throw new Error('HTTP ' + r.status);
    showToast('Status changed to ' + (STATUS_CONFIG_JS[newStatus]?.label || newStatus), 'success', {
      undo: () => {
        updateStatusCell(id, oldStatus);
        fetch('/compliance/bulk-status', {
          method: 'POST',
          headers: csrfHeaders({ 'Content-Type': 'application/json' }),
          body: JSON.stringify({ ids: [String(id)], status: oldStatus })
        }).catch(() => showToast('Failed to undo', 'error'));
      }
    });
  }).catch(() => {
    // Revert on failure
    updateStatusCell(id, oldStatus);
    showToast('Failed to change status', 'error');
  });
}
function updateStatusCell(id, status) {
  const td = document.querySelector('.status-cell[data-id="' + id + '"]');
  if (!td) return;
  const cfg = STATUS_CONFIG_JS[status] || { label: status, color: 'bg-gray-100 text-gray-600' };
  td.dataset.status = status;
  // Repaint the existing button so onclick handler stays intact
  const btn = td.querySelector('.status-pill');
  if (!btn) return;
  btn.className = 'status-pill inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold rounded-full ' + cfg.color + ' hover:ring-1 hover:ring-gray-300 transition cursor-pointer';
  // Replace text node, keep the chevron svg
  const svg = btn.querySelector('svg');
  btn.textContent = cfg.label + ' ';
  if (svg) btn.appendChild(svg);
  // Update onclick to capture the new status
  btn.onclick = function(e) { e.stopPropagation(); openStatusPopover(e, parseInt(id, 10), status); };
}
// Close on outside click / Escape
document.addEventListener('click', e => {
  const pop = document.getElementById('statusPopover');
  if (!pop.classList.contains('hidden') && !pop.contains(e.target) && !e.target.closest('.status-pill')) {
    closeStatusPopover();
  }
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeStatusPopover(); });
// Reposition on scroll/resize so it stays anchored
window.addEventListener('scroll', () => closeStatusPopover(), true);
window.addEventListener('resize', () => closeStatusPopover());

// Toast helper -------------------------------------------------------------
function showToast(message, type, options) {
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const palette = {
    success: 'bg-emerald-600 text-white',
    error:   'bg-red-600 text-white',
    info:    'bg-gray-800 text-white',
  };
  const toast = document.createElement('div');
  toast.className = 'flex items-center gap-3 px-4 py-2.5 rounded-lg shadow-lg text-sm font-medium ' + (palette[type] || palette.info);
  toast.style.transition = 'opacity 200ms';
  const msg = document.createElement('span'); msg.textContent = message; toast.appendChild(msg);
  let timer;
  if (options && typeof options.undo === 'function') {
    const undoBtn = document.createElement('button');
    undoBtn.type = 'button';
    undoBtn.textContent = 'Undo';
    undoBtn.className = 'ml-2 underline font-semibold text-white/90 hover:text-white';
    undoBtn.onclick = () => { clearTimeout(timer); options.undo(); toast.remove(); };
    toast.appendChild(undoBtn);
  }
  const close = document.createElement('button');
  close.type = 'button'; close.textContent = '×';
  close.className = 'ml-1 text-white/70 hover:text-white text-lg leading-none';
  close.onclick = () => { clearTimeout(timer); toast.remove(); };
  toast.appendChild(close);
  container.appendChild(toast);
  timer = setTimeout(() => {
    toast.style.opacity = '0';
    setTimeout(() => toast.remove(), 220);
  }, options && options.duration ? options.duration : 4000);
}
</script>

<!-- Toast container for in-place feedback (no jarring reloads) -->
<div id="toastContainer" class="fixed bottom-4 right-4 space-y-2 z-50 max-w-sm"></div>

<!-- Status quick-change popover. Anchored next to whichever pill the user clicks -->
<div id="statusPopover" class="hidden fixed z-50 bg-white border border-gray-200 rounded-xl shadow-2xl p-2 min-w-[180px]"
  onclick="event.stopPropagation()">
  <div class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 px-2 pt-1">Change status</div>
  <div class="grid gap-1" id="statusPopoverOptions">
    <% [
      { value: 'not_started', label: 'Not Started', cls: 'bg-gray-100 text-gray-700' },
      { value: 'started',     label: 'Started',     cls: 'bg-purple-50 text-purple-700' },
      { value: 'submitted',   label: 'Submitted',   cls: 'bg-blue-50 text-blue-700' },
      { value: 'approved',    label: 'Approved',    cls: 'bg-emerald-50 text-emerald-700' },
      { value: 'rejected',    label: 'Rejected',    cls: 'bg-red-50 text-red-700' },
      { value: 'expired',     label: 'Expired',     cls: 'bg-amber-50 text-amber-700' },
    ].forEach(function(opt) { %>
      <button type="button" data-status="<%= opt.value %>" onclick="selectStatus('<%= opt.value %>')"
        class="flex items-center justify-between w-full px-2.5 py-1.5 text-xs font-semibold rounded-lg hover:bg-gray-100 transition text-left">
        <span class="inline-flex px-2 py-0.5 text-[10px] font-bold rounded-full <%= opt.cls %>"><%= opt.label %></span>
        <svg class="popover-check w-4 h-4 text-emerald-600 hidden" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      </button>
    <% }) %>
  </div>
</div>

<!-- Invoice number modal (single or bulk) -->
<div id="invoiceModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm" onclick="if(event.target===this)closeInvoiceModal()">
  <div class="min-h-full flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
      <div class="p-5 border-b border-gray-200">
        <h2 class="text-lg font-bold text-gray-900">Mark as invoiced</h2>
        <p class="text-xs text-gray-500 mt-0.5" id="invoiceModalLabel"></p>
      </div>
      <div class="p-5 space-y-3">
        <div>
          <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Invoice number (optional)</label>
          <input type="text" id="invoiceNumberInput" placeholder="e.g. INV-1042"
            class="w-full px-2 py-2.5 border border-gray-300 rounded-lg text-sm font-mono focus:outline-none focus:ring-2 focus:ring-brand-500">
          <p class="text-[10px] text-gray-400 mt-1.5">Leave blank if you don't have a number yet — you can add it later by editing the item.</p>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Charge to client <span class="text-rose-500">*</span></label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-sm text-gray-400 pointer-events-none">$</span>
            <input type="number" id="invoiceChargeInput" min="0.01" step="0.01" placeholder="0.00"
              class="w-full pl-7 pr-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <p class="text-[10px] text-gray-400 mt-1.5">Required. Locks the price you're billing the client for this row.</p>
        </div>
      </div>
      <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
        <button type="button" onclick="closeInvoiceModal()" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
        <button type="button" onclick="submitInvoiceModal()" class="px-5 py-2.5 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg">Mark invoiced</button>
      </div>
    </div>
  </div>
</div>
