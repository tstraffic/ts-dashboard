<% locals.currentPage = 'defects' %>

<%
  function daysAgo(dateStr) {
    if (!dateStr) return null;
    return Math.floor((new Date(today) - new Date(dateStr)) / (1000 * 60 * 60 * 24));
  }
  function daysUntil(dateStr) {
    if (!dateStr) return null;
    return Math.ceil((new Date(dateStr) - new Date(today)) / (1000 * 60 * 60 * 24));
  }
  function formatShortDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' });
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Defects</h1>
    <p class="text-gray-500 text-sm mt-0.5">Defect register &middot; rectification tracking</p>
  </div>
  <a href="/defects/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    Report Defect
  </a>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.total %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Open</p>
    <p class="text-xl font-bold <%= stats.open > 0 ? 'text-amber-600' : 'text-gray-300' %> mt-0.5"><%= stats.open %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Critical / Major</p>
    <p class="text-xl font-bold <%= stats.criticalMajor > 0 ? 'text-red-600' : 'text-gray-300' %> mt-0.5"><%= stats.criticalMajor %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Overdue</p>
    <p class="text-xl font-bold <%= stats.overdue > 0 ? 'text-red-600' : 'text-gray-300' %> mt-0.5"><%= stats.overdue %></p>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/defects" data-module="defects" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1 min-w-0 sm:min-w-[180px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
        <% }) %>
      </select>
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Severity</label>
        <select name="severity" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% settingsOptions.defect_severity.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.severity === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% settingsOptions.defect_status.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/defects" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/defects.csv?job_id=<%= filters.job_id || '' %>&severity=<%= filters.severity || '' %>&status=<%= filters.status || '' %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="hidden sm:inline">CSV</span>
      </a>
    </div>
  </form>
</div>

<!-- Defects Table -->
<% if (defects.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No defects reported</h3>
    <p class="text-gray-500 text-sm mb-1">Defects track damaged equipment, site issues, and snags that need rectification.</p>
    <p class="text-gray-400 text-xs mb-4">Report defects to assign owners, track rectification progress, and close them out.</p>
    <a href="/defects/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Report Defect
    </a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <% const defSortParams = '&job_id=' + encodeURIComponent(filters.job_id || '') + '&severity=' + encodeURIComponent(filters.severity || '') + '&status=' + encodeURIComponent(filters.status || ''); %>
      <tr class="border-b border-gray-200">
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Defect', field: 'title', currentSort: sort, currentOrder: order, baseUrl: '/defects', extraParams: defSortParams }) %></th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Job</th>
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Severity', field: 'severity', currentSort: sort, currentOrder: order, baseUrl: '/defects', extraParams: defSortParams }) %></th>
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Status', field: 'status', currentSort: sort, currentOrder: order, baseUrl: '/defects', extraParams: defSortParams }) %></th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Age</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Assigned</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Reported By</th>
        <th class="px-3 py-2.5 text-right hidden sm:table-cell"><%- include('../partials/sort-header', { label: 'Target', field: 'reported_date', currentSort: sort, currentOrder: order, baseUrl: '/defects', extraParams: defSortParams }) %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% defects.forEach(defect => {
        const isOverdue = defect.target_close_date && defect.target_close_date < today && !['closed','deferred'].includes(defect.status);
        const isCritical = defect.severity === 'critical';
        const isOpen = !['closed','deferred'].includes(defect.status);
        const age = daysAgo(defect.reported_date);
        const targetDays = daysUntil(defect.target_close_date);
      %>
      <tr class="hover:bg-gray-50 <%= isCritical && isOpen ? 'border-l-4 border-l-red-500' : isOverdue ? 'border-l-4 border-l-amber-400' : '' %>">
        <td class="px-3 py-2.5">
          <a href="/defects/<%= defect.id %>" class="text-brand-600 hover:text-brand-700 font-semibold text-sm hover:underline"><%= defect.defect_number %></a>
          <p class="text-gray-400 text-xs truncate max-w-[180px]"><%= defect.title %></p>
          <p class="text-gray-400 text-[10px] lg:hidden"><%= defect.job_number %></p>
        </td>
        <td class="px-3 py-2.5 hidden lg:table-cell">
          <span class="text-xs text-gray-600"><%= defect.job_number %></span>
        </td>
        <td class="px-3 py-2.5">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
            <% if (defect.severity === 'critical') { %>bg-red-100 text-red-800
            <% } else if (defect.severity === 'major') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (defect.severity === 'moderate') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else { %>bg-gray-100 text-gray-600<% } %>">
            <%= (defect.severity || 'minor').toUpperCase() %>
          </span>
        </td>
        <td class="px-3 py-2.5">
          <form method="POST" action="/defects/<%= defect.id %>/status" class="inline">
            <%- include('../partials/csrf') %>
            <select name="status" onchange="this.form.submit()" class="text-[10px] font-bold px-2 py-1 rounded-full border-0 cursor-pointer appearance-none
              <% if (defect.status === 'open') { %>bg-gray-100 text-gray-600
              <% } else if (defect.status === 'investigating') { %>bg-blue-50 text-blue-700
              <% } else if (defect.status === 'rectification') { %>bg-amber-50 text-amber-700
              <% } else if (defect.status === 'closed') { %>bg-emerald-50 text-emerald-700
              <% } else if (defect.status === 'deferred') { %>bg-purple-50 text-purple-700
              <% } else { %>bg-gray-50 text-gray-600<% } %> focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="open" <%= defect.status === 'open' ? 'selected' : '' %>>Open</option>
              <option value="investigating" <%= defect.status === 'investigating' ? 'selected' : '' %>>Investigating</option>
              <option value="rectification" <%= defect.status === 'rectification' ? 'selected' : '' %>>Rectification</option>
              <option value="closed" <%= defect.status === 'closed' ? 'selected' : '' %>>Closed</option>
              <option value="deferred" <%= defect.status === 'deferred' ? 'selected' : '' %>>Deferred</option>
            </select>
          </form>
        </td>
        <!-- Days Open -->
        <td class="px-3 py-2.5 text-center hidden sm:table-cell">
          <% if (age !== null && isOpen) { %>
            <span class="inline-flex items-center justify-center min-w-[2rem] px-1.5 py-0.5 rounded-full text-[10px] font-bold
              <%= age > 30 ? 'bg-red-50 text-red-700 ring-1 ring-red-600/20' : age > 14 ? 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' : 'bg-gray-100 text-gray-600' %>"><%= age %>d</span>
          <% } else if (!isOpen) { %>
            <span class="text-gray-300 text-[10px]">Closed</span>
          <% } else { %>
            <span class="text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-xs hidden md:table-cell">
          <% if (defect.assigned_to_name) { %>
            <span class="text-gray-600"><%= defect.assigned_to_name %></span>
          <% } else { %>
            <span class="text-gray-300 italic">Unassigned</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-xs text-gray-500 hidden xl:table-cell"><%= defect.reported_by_name || '-' %></td>
        <td class="px-3 py-2.5 text-right hidden sm:table-cell">
          <% if (defect.target_close_date) { %>
            <%
              let targetColor = 'text-gray-500';
              let targetLabel = formatShortDate(defect.target_close_date);
              if (isOverdue) {
                targetColor = 'text-red-600 font-semibold';
                targetLabel = Math.abs(targetDays) + 'd overdue';
              } else if (isOpen && targetDays !== null && targetDays <= 3) {
                targetColor = 'text-amber-600';
              }
            %>
            <span class="text-xs <%= targetColor %>"><%= targetLabel %></span>
            <% if (isOverdue) { %>
              <span class="block text-[10px] text-red-500">OVERDUE</span>
            <% } %>
          <% } else { %>
            <span class="text-gray-300 text-xs">-</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-2 text-xs text-gray-400"><%= defects.length %> defect<%= defects.length !== 1 ? 's' : '' %> found</div>
<% } %>
