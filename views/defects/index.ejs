<% locals.currentPage = 'defects' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Defects & Snag List</h1>
    <p class="text-slate-400 text-sm mt-1">Track and manage all defects, snags, and rectification items</p>
  </div>
  <a href="/defects/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Report Defect</a>
</div>

<!-- Filter Bar -->
<div class="bg-slate-800 border border-slate-700 rounded-xl p-4 mb-6">
  <form method="GET" action="/defects" class="flex flex-wrap items-end gap-4">
    <!-- Job -->
    <div class="min-w-[200px] flex-1">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
        <% }) %>
      </select>
    </div>
    <!-- Severity -->
    <div class="min-w-[140px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Severity</label>
      <select name="severity" class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Severities</option>
        <option value="minor" <%= filters.severity === 'minor' ? 'selected' : '' %>>Minor</option>
        <option value="moderate" <%= filters.severity === 'moderate' ? 'selected' : '' %>>Moderate</option>
        <option value="major" <%= filters.severity === 'major' ? 'selected' : '' %>>Major</option>
        <option value="critical" <%= filters.severity === 'critical' ? 'selected' : '' %>>Critical</option>
      </select>
    </div>
    <!-- Status -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Statuses</option>
        <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
        <option value="investigating" <%= filters.status === 'investigating' ? 'selected' : '' %>>Investigating</option>
        <option value="rectification" <%= filters.status === 'rectification' ? 'selected' : '' %>>Rectification</option>
        <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
        <option value="deferred" <%= filters.status === 'deferred' ? 'selected' : '' %>>Deferred</option>
      </select>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/defects" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Defects Table -->
<% if (defects.length === 0) { %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-8 text-center">
    <svg class="w-12 h-12 text-slate-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
    <p class="text-slate-500 text-sm">No defects found matching your filters.</p>
    <a href="/defects/new" class="text-brand-400 text-sm hover:underline mt-2 inline-block">Report the first defect</a>
  </div>
<% } else { %>
<div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700">
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Defect #</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Date</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Title</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Job</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Severity</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Assigned To</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Target Close</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700">
      <% defects.forEach(defect => { %>
      <tr class="hover:bg-slate-700/50 cursor-pointer" onclick="window.location='/defects/<%= defect.id %>'">
        <td class="px-4 py-3 font-medium">
          <a href="/defects/<%= defect.id %>" class="text-blue-400 hover:text-blue-300 hover:underline"><%= defect.defect_number %></a>
        </td>
        <td class="px-4 py-3 text-slate-400 text-xs"><%= defect.reported_date || '-' %></td>
        <td class="px-4 py-3 text-slate-300 font-medium max-w-[200px] truncate"><%= defect.title %></td>
        <td class="px-4 py-3 text-slate-400 text-xs"><%= defect.job_number %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (defect.severity === 'critical') { %>bg-red-900/60 text-red-300
            <% } else if (defect.severity === 'major') { %>bg-orange-900/60 text-brand-300
            <% } else if (defect.severity === 'moderate') { %>bg-blue-900/60 text-blue-300
            <% } else { %>bg-slate-700 text-slate-300<% } %>">
            <%= defect.severity || 'minor' %>
          </span>
        </td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (defect.status === 'open') { %>bg-slate-700 text-slate-300
            <% } else if (defect.status === 'investigating') { %>bg-blue-900/60 text-blue-300
            <% } else if (defect.status === 'rectification') { %>bg-orange-900/60 text-brand-300
            <% } else if (defect.status === 'closed') { %>bg-emerald-900/60 text-emerald-300
            <% } else if (defect.status === 'deferred') { %>bg-purple-900/60 text-purple-300
            <% } else { %>bg-slate-700 text-slate-300<% } %>">
            <%= defect.status || 'open' %>
          </span>
        </td>
        <td class="px-4 py-3 text-slate-300"><%= defect.assigned_to_name || '<span class="text-slate-500">Unassigned</span>' %></td>
        <td class="px-4 py-3 text-slate-400 text-xs"><%= defect.target_close_date || '-' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-slate-500"><%= defects.length %> defect<%= defects.length !== 1 ? 's' : '' %> found</div>
<% } %>
