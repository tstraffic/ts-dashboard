<%
  const severityColors = {
    critical: 'bg-red-100 text-red-700',
    major: 'bg-orange-100 text-orange-700',
    moderate: 'bg-amber-100 text-amber-700',
    minor: 'bg-gray-100 text-gray-600'
  };
  const statusColors = {
    open: 'bg-red-100 text-red-700',
    in_progress: 'bg-blue-100 text-blue-700',
    resolved: 'bg-emerald-100 text-emerald-700',
    closed: 'bg-gray-100 text-gray-600'
  };
  const statusLabels = { open: 'Open', in_progress: 'In Progress', resolved: 'Resolved', closed: 'Closed' };
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <h1 class="text-2xl font-bold text-gray-900"><%= defect.defect_number %></h1>
        <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-semibold <%= severityColors[defect.severity] || 'bg-gray-100 text-gray-600' %>"><%= defect.severity.charAt(0).toUpperCase() + defect.severity.slice(1) %></span>
        <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-semibold <%= statusColors[defect.status] || 'bg-gray-100 text-gray-600' %>"><%= statusLabels[defect.status] || defect.status %></span>
      </div>
      <p class="text-gray-500 text-sm"><%= defect.job_number %> &mdash; <%= defect.client %></p>
    </div>
    <div class="flex gap-2">
      <a href="/defects/<%= defect.id %>/edit" class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-medium text-sm">Edit</a>
      <a href="/defects" class="px-4 py-2 bg-white text-gray-600 border border-gray-200 rounded-lg hover:bg-gray-50 transition font-medium text-sm">Back</a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Title & Description -->
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-2"><%= defect.title %></h2>
        <% if (defect.description) { %>
          <p class="text-gray-600 text-sm whitespace-pre-wrap"><%= defect.description %></p>
        <% } else { %>
          <p class="text-gray-400 text-sm italic">No description provided.</p>
        <% } %>
        <% if (defect.location) { %>
          <div class="mt-4 pt-4 border-t border-gray-100">
            <p class="text-xs font-medium text-gray-400 uppercase mb-1">Location</p>
            <p class="text-sm text-gray-700"><%= defect.location %></p>
          </div>
        <% } %>
      </div>

      <!-- Photo -->
      <% if (defect.photo_path) { %>
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h3 class="text-sm font-bold text-gray-800 mb-3">Photo</h3>
        <a href="<%= defect.photo_path %>" target="_blank" class="block">
          <img src="<%= defect.photo_path %>" alt="Defect photo" class="rounded-xl border border-gray-200 max-w-full shadow-sm hover:shadow-md transition-shadow cursor-pointer">
        </a>
      </div>
      <% } %>

      <!-- Quick Status Update -->
      <div class="bg-white border border-gray-200 rounded-2xl p-6">
        <h3 class="text-sm font-bold text-gray-800 mb-3">Update Status</h3>
        <form method="POST" action="/defects/<%= defect.id %>/status">
          <%- include('../partials/csrf') %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
              <label for="status" class="block text-xs font-medium text-gray-500 mb-1">Status</label>
              <select id="status" name="status" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 text-sm">
                <option value="open" <%= defect.status === 'open' ? 'selected' : '' %>>Open</option>
                <option value="in_progress" <%= defect.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                <option value="resolved" <%= defect.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                <option value="closed" <%= defect.status === 'closed' ? 'selected' : '' %>>Closed</option>
              </select>
            </div>
          </div>
          <div class="mb-4">
            <label for="rectification_notes" class="block text-xs font-medium text-gray-500 mb-1">Rectification Notes</label>
            <textarea id="rectification_notes" name="rectification_notes" rows="2" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 text-sm" placeholder="How was this resolved..."><%= defect.rectification_notes || '' %></textarea>
          </div>
          <button type="submit" class="px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-medium text-sm">Update</button>
        </form>
      </div>
    </div>

    <!-- Sidebar Details -->
    <div class="space-y-6">
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <h3 class="text-sm font-bold text-gray-800 mb-3">Details</h3>
        <dl class="space-y-3">
          <div>
            <dt class="text-xs font-medium text-gray-400">Reported By</dt>
            <dd class="text-sm text-gray-900 mt-0.5"><%= defect.reported_by_name %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-400">Assigned To</dt>
            <dd class="text-sm text-gray-900 mt-0.5"><%= defect.assigned_to_name || 'Unassigned' %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-400">Reported Date</dt>
            <dd class="text-sm text-gray-900 mt-0.5"><%= defect.reported_date ? new Date(defect.reported_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) : '—' %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-gray-400">Target Close</dt>
            <dd class="text-sm text-gray-900 mt-0.5"><%= defect.target_close_date ? new Date(defect.target_close_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) : '—' %></dd>
          </div>
          <% if (defect.actual_close_date) { %>
          <div>
            <dt class="text-xs font-medium text-gray-400">Actual Close</dt>
            <dd class="text-sm text-emerald-600 font-medium mt-0.5"><%= new Date(defect.actual_close_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) %></dd>
          </div>
          <% } %>
        </dl>
      </div>

      <% if (defect.rectification_notes) { %>
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <h3 class="text-sm font-bold text-gray-800 mb-2">Rectification Notes</h3>
        <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= defect.rectification_notes %></p>
      </div>
      <% } %>

      <!-- Activity History -->
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider">Activity History</h3>
        </div>
        <%- include('../partials/activity-timeline', { activities: typeof activities !== 'undefined' ? activities : [], entityLink: '' }) %>
      </div>
    </div>
  </div>
</div>
