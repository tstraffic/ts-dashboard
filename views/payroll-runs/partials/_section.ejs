<%
  const ACCENT = {
    amber:   { ring: 'ring-amber-200',   chip: 'bg-amber-100 text-amber-800',     headBg: 'bg-amber-50',   headText: 'text-amber-900' },
    emerald: { ring: 'ring-emerald-200', chip: 'bg-emerald-100 text-emerald-800', headBg: 'bg-emerald-50', headText: 'text-emerald-900' },
    sky:     { ring: 'ring-sky-200',     chip: 'bg-sky-100 text-sky-800',         headBg: 'bg-sky-50',     headText: 'text-sky-900' },
    gray:    { ring: 'ring-gray-300',    chip: 'bg-gray-200 text-gray-800',       headBg: 'bg-gray-50',    headText: 'text-gray-900' },
  };
  const a = ACCENT[accent] || ACCENT.gray;
  const showGst = accent === 'amber'; // Cash only
  const showTfnExtras = section.key === 'tfn'; // Super, Tax, Net columns

  // Bucket UI flair
  const BUCKET_BADGE = {
    day_normal:    'text-gray-700',
    day_ot:        'text-orange-700',
    day_dt:        'text-red-700',
    night_normal:  'text-indigo-700',
    night_ot:      'text-orange-700',
    night_dt:      'text-red-700',
    weekend:       'text-purple-700',
    public_holiday:'text-rose-700',
  };
%>

<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden ring-1 <%= a.ring %>">
  <div class="<%= a.headBg %> px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2">
    <div class="flex items-center gap-2">
      <h2 class="text-base font-bold <%= a.headText %> uppercase tracking-wider"><%= section.label %> Workers</h2>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-bold <%= a.chip %>"><%= lines.length %></span>
    </div>
    <div class="flex items-center gap-3 text-xs <%= a.headText %> flex-wrap">
      <span><%= sectTotals.hours.toFixed(2) %> hrs</span>
      <span class="opacity-50">·</span>
      <span class="font-bold tabular-nums">$<%= fmtMoney(sectTotals.total) %></span>
      <% if (showGst) { %>
        <span class="opacity-50">·</span>
        <span class="opacity-80 tabular-nums">+ GST $<%= fmtMoney(sectTotals.gst) %></span>
        <span class="opacity-50">·</span>
        <span class="font-bold tabular-nums">= $<%= fmtMoney(sectTotals.with_gst) %></span>
      <% } %>
      <% if (showTfnExtras) { %>
        <span class="opacity-50">·</span>
        <span class="opacity-80 tabular-nums" title="Tax withheld (PAYG estimate)">Tax −$<%= fmtMoney(sectTotals.tfn_tax) %></span>
        <span class="opacity-50">·</span>
        <span class="font-bold tabular-nums" title="Total − tax = workers' take-home">Net $<%= fmtMoney(sectTotals.tfn_net) %></span>
        <span class="opacity-50">·</span>
        <span class="opacity-80 tabular-nums" title="Super contribution (12% of wages)">Super $<%= fmtMoney(sectTotals.tfn_super) %></span>
      <% } %>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest sticky left-0 bg-gray-50 z-10">Worker</th>
          <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">BSB / Acc</th>
          <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Bucket</th>
          <% dowLabels.forEach(d => { %>
            <th class="px-1 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest"><%= d %></th>
          <% }) %>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Hrs</th>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Rate</th>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Sub</th>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Wages</th>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Allow.</th>
          <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Total</th>
          <% if (showTfnExtras) { %>
            <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest" title="Tax withheld (PAYG estimate)">Tax</th>
            <th class="px-2 py-2 text-right text-[10px] font-bold text-emerald-600 uppercase tracking-widest" title="Take-home pay (Total − Tax)">Net</th>
            <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest" title="Super contribution (12% of wages)">Super</th>
          <% } %>
          <th class="px-2 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest">Paid</th>
          <th class="px-2 py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% lines.forEach(l => { %>
          <%
            const sectionBucketKeys = section.buckets || ['day_normal', 'day_ot', 'day_dt', 'night_normal', 'night_ot', 'night_dt', 'weekend', 'public_holiday'];
            const activeKeys = sectionBucketKeys.filter(k => (l.buckets[k] && l.buckets[k].total_hours > 0));
            const rowSpan = Math.max(activeKeys.length, 1);
          %>
          <% if (activeKeys.length === 0) { %>
            <tr class="<%= l.paid ? 'opacity-60' : '' %>">
              <td class="px-3 py-2 sticky left-0 bg-white z-[5] <%= l.paid ? 'opacity-100' : '' %>">
                <p class="font-semibold text-gray-900 text-sm leading-tight"><%= l.full_name %></p>
                <% if (l.employee_code) { %>
                  <p class="text-[10px] text-gray-400 font-mono mt-0.5"><%= l.employee_code %></p>
                <% } else if (!l.employee_id && !runLocked) { %>
                  <button onclick="openMatch(<%= l.id %>)" class="text-[10px] font-semibold text-amber-600 hover:underline mt-0.5">⚠ Link to employee</button>
                <% } else if (!l.employee_id && runLocked) { %>
                  <span class="text-[10px] font-semibold text-gray-400 mt-0.5">⚠ Unlinked</span>
                <% } %>
                <% if (l.classification_name) { %><p class="text-[10px] text-emerald-600 mt-0.5"><%= l.classification_name %></p><% } %>
              </td>
              <td class="px-2 py-2 text-[11px] font-mono text-gray-600 leading-tight">
                <% if (l.bsb || l.acc_number) { %><%= l.bsb || '—' %><br><%= l.acc_number || '—' %><% } else { %><span class="text-gray-300">—</span><% } %>
              </td>
              <td colspan="10" class="px-2 py-2 text-xs text-gray-400 italic">No hours</td>
              <% if (showTfnExtras) { %>
                <td class="px-2 py-2 text-right text-xs text-gray-300">—</td>
                <td class="px-2 py-2 text-right text-xs text-gray-300">—</td>
                <td class="px-2 py-2 text-right text-xs text-gray-300">—</td>
              <% } %>
              <td class="px-2 py-2 text-center"><input type="checkbox" disabled class="w-4 h-4 rounded border-gray-300"></td>
              <td class="px-2 py-2 text-right">
                <% if (!runLocked) { %>
                  <button onclick="openEdit(<%= l.id %>)" class="px-2 py-1 text-[11px] font-semibold text-brand-600 hover:bg-brand-50 rounded">Edit</button>
                <% } %>
              </td>
            </tr>
          <% } else { %>
            <% activeKeys.forEach((bk, idx) => { const b = l.buckets[bk]; const isFirst = idx === 0; const isLast = idx === activeKeys.length - 1; %>
              <tr class="<%= l.paid ? 'opacity-60' : '' %>">
                <% if (isFirst) { %>
                  <td rowspan="<%= rowSpan %>" class="px-3 py-2 align-top sticky left-0 bg-white z-[5] <%= l.paid ? 'opacity-100' : '' %>">
                    <p class="font-semibold text-gray-900 text-sm leading-tight"><%= l.full_name %></p>
                    <% if (l.employee_code) { %>
                      <p class="text-[10px] text-gray-400 font-mono mt-0.5"><%= l.employee_code %></p>
                    <% } else if (!l.employee_id && !runLocked) { %>
                      <button onclick="openMatch(<%= l.id %>)" class="text-[10px] font-semibold text-amber-600 hover:underline mt-0.5">⚠ Link to employee</button>
                    <% } else if (!l.employee_id && runLocked) { %>
                      <span class="text-[10px] font-semibold text-gray-400 mt-0.5">⚠ Unlinked</span>
                    <% } %>
                    <% if (l.classification_name) { %>
                      <p class="text-[10px] text-emerald-600 mt-0.5">⚖ <%= l.classification_name %></p>
                    <% } %>
                    <% if (l.paid_ref) { %>
                      <p class="text-[10px] text-emerald-600 font-mono mt-0.5"><%= l.paid_ref %></p>
                    <% } %>
                  </td>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 align-top text-[11px] font-mono text-gray-600 leading-tight">
                    <% if (l.bsb || l.acc_number) { %>
                      <%= l.bsb || '—' %><br><%= l.acc_number || '—' %>
                    <% } else { %>
                      <span class="text-gray-300">—</span>
                    <% } %>
                  </td>
                <% } %>
                <td class="px-2 py-1.5 text-xs font-semibold <%= BUCKET_BADGE[bk] || 'text-gray-700' %>"><%= bucketLabels[bk] || bk %></td>
                <% for (let i=0;i<7;i++) { const h = b.hours && b.hours[i]; %>
                  <td class="px-1 py-1.5 text-center text-xs tabular-nums <%= h ? 'text-gray-900' : 'text-gray-300' %>"><%= h || '·' %></td>
                <% } %>
                <td class="px-2 py-1.5 text-right text-xs font-semibold tabular-nums text-gray-900"><%= b.total_hours.toFixed(2) %></td>
                <td class="px-2 py-1.5 text-right text-xs tabular-nums text-gray-700">$<%= fmtMoney(b.rate) %></td>
                <td class="px-2 py-1.5 text-right text-xs tabular-nums text-gray-900">$<%= fmtMoney(b.total_wages) %></td>
                <% if (isFirst) { %>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-xs font-semibold tabular-nums text-gray-900 align-middle">$<%= fmtMoney(l.total_wages) %></td>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-xs tabular-nums text-gray-700 align-middle">
                    <% if (l.total_allowance > 0) { %>
                      $<%= fmtMoney(l.total_allowance) %>
                      <p class="text-[9px] text-gray-400 font-normal mt-0.5">
                        <% if (l.travel_allowance) { %>T $<%= l.travel_allowance %><% } %>
                        <% if (l.meal_allowance) { %> M $<%= l.meal_allowance %><% } %>
                        <% if (l.other_allowance) { %> O $<%= l.other_allowance %><% } %>
                      </p>
                    <% } else { %>
                      <span class="text-gray-300">—</span>
                    <% } %>
                  </td>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-sm font-bold tabular-nums text-gray-900 align-middle">$<%= fmtMoney(l.grand_total) %></td>
                  <% if (showTfnExtras) { %>
                    <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-xs tabular-nums text-rose-700 align-middle">−$<%= fmtMoney(l.tfn_tax || 0) %></td>
                    <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-sm font-semibold tabular-nums text-emerald-700 align-middle">$<%= fmtMoney(l.tfn_net || 0) %></td>
                    <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right text-xs tabular-nums text-gray-700 align-middle">$<%= fmtMoney(l.tfn_super || 0) %></td>
                  <% } %>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-center align-middle">
                    <input type="checkbox" <%= l.paid ? 'checked' : '' %> onchange="togglePaid(<%= l.id %>, this.checked)" class="w-4 h-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500">
                  </td>
                  <td rowspan="<%= rowSpan %>" class="px-2 py-2 text-right align-middle">
                    <% if (!runLocked) { %>
                      <button onclick="openEdit(<%= l.id %>)" class="px-2 py-1 text-[11px] font-semibold text-brand-600 hover:bg-brand-50 rounded">Edit</button>
                    <% } %>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          <% } %>
        <% }) %>
      </tbody>
      <tfoot class="bg-gray-50 border-t-2 border-gray-300">
        <tr>
          <td colspan="11" class="px-3 py-2 text-right text-xs font-bold text-gray-700 uppercase tracking-widest">
            <%= section.label %> Total
          </td>
          <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-gray-900">$<%= fmtMoney(sectTotals.total) %></td>
          <% if (showTfnExtras) { %>
            <td class="px-2 py-2 text-right text-xs font-semibold tabular-nums text-rose-700">−$<%= fmtMoney(sectTotals.tfn_tax) %></td>
            <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-emerald-700">$<%= fmtMoney(sectTotals.tfn_net) %></td>
            <td class="px-2 py-2 text-right text-xs font-semibold tabular-nums text-gray-700">$<%= fmtMoney(sectTotals.tfn_super) %></td>
          <% } %>
          <td colspan="2"></td>
        </tr>
        <% if (showGst) { %>
          <tr>
            <td colspan="11" class="px-3 py-1.5 text-right text-xs text-gray-600 uppercase tracking-widest">GST 10%</td>
            <td class="px-2 py-1.5 text-right text-xs tabular-nums text-gray-700">$<%= fmtMoney(sectTotals.gst) %></td>
            <td colspan="2"></td>
          </tr>
          <tr class="bg-amber-50">
            <td colspan="11" class="px-3 py-2 text-right text-xs font-bold text-amber-900 uppercase tracking-widest">Total + GST</td>
            <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-amber-900">$<%= fmtMoney(sectTotals.with_gst) %></td>
            <td colspan="2"></td>
          </tr>
        <% } %>
        <% if (showTfnExtras) { %>
          <tr class="bg-emerald-50">
            <td colspan="<%= 11 + 1 %>" class="px-3 py-2 text-right text-xs font-bold text-emerald-900 uppercase tracking-widest" title="Total cost to T&S = Total payable + Super">Total employer cost</td>
            <td colspan="2" class="px-2 py-2 text-right text-xs text-emerald-800">
              <span class="opacity-70">Total $<%= fmtMoney(sectTotals.total) %> + Super $<%= fmtMoney(sectTotals.tfn_super) %> =</span>
            </td>
            <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-emerald-900">$<%= fmtMoney((parseFloat(sectTotals.total) || 0) + (parseFloat(sectTotals.tfn_super) || 0)) %></td>
            <td colspan="2"></td>
          </tr>
        <% } %>
      </tfoot>
    </table>
  </div>
</div>
