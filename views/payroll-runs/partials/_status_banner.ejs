<%
  // Renders the approval-workflow banner + action buttons for a pay run.
  // Caller passes: run, runLocked, canApprove, canUnlock, submittedBy, approvedBy, paidBy
  function fmtDt(s) {
    if (!s) return '';
    const d = new Date(String(s).replace(' ', 'T') + (String(s).includes('T') ? '' : 'Z'));
    if (isNaN(d.getTime())) return '';
    return d.toLocaleString('en-AU', { day: 'numeric', month: 'short', year: 'numeric', hour: 'numeric', minute: '2-digit', timeZone: 'Australia/Sydney' });
  }
  const status = run.status || 'draft';
%>

<%
  let toneBg = 'bg-gray-50', toneBorder = 'border-gray-200', toneText = 'text-gray-700', toneAccent = 'text-gray-500';
  let pillBg = 'bg-gray-100', pillText = 'text-gray-700', pillRing = 'ring-gray-300';
  let icon = '';
  let title = 'Draft';
  let detail = 'Edit lines, allowances and totals freely. When everything looks right, send it to Saadat for approval.';
  if (status === 'pending_approval') {
    toneBg = 'bg-amber-50'; toneBorder = 'border-amber-200'; toneText = 'text-amber-900'; toneAccent = 'text-amber-700';
    pillBg = 'bg-amber-100'; pillText = 'text-amber-800'; pillRing = 'ring-amber-300';
    title = 'Pending Saadat\'s approval';
    detail = 'Locked for edits. ' + (submittedBy ? ('Submitted by ' + (submittedBy.full_name || submittedBy.username)) : 'Submitted') + (run.submitted_for_approval_at ? ' on ' + fmtDt(run.submitted_for_approval_at) : '') + '.';
  } else if (status === 'approved') {
    toneBg = 'bg-blue-50'; toneBorder = 'border-blue-200'; toneText = 'text-blue-900'; toneAccent = 'text-blue-700';
    pillBg = 'bg-blue-100'; pillText = 'text-blue-800'; pillRing = 'ring-blue-300';
    title = 'Approved — ready to pay';
    detail = (approvedBy ? ('Approved by ' + (approvedBy.full_name || approvedBy.username)) : 'Approved') + (run.approved_at ? ' on ' + fmtDt(run.approved_at) : '') + '. Locked for edits.';
  } else if (status === 'paid') {
    toneBg = 'bg-emerald-50'; toneBorder = 'border-emerald-200'; toneText = 'text-emerald-900'; toneAccent = 'text-emerald-700';
    pillBg = 'bg-emerald-100'; pillText = 'text-emerald-800'; pillRing = 'ring-emerald-300';
    title = 'Paid';
    detail = (paidBy ? ('Marked paid by ' + (paidBy.full_name || paidBy.username)) : 'Marked paid') + (run.paid_at ? ' on ' + fmtDt(run.paid_at) : '') + '. Locked.';
  } else if (status === 'finalized') {
    title = 'Finalized (legacy)';
    detail = 'This run was finalized under the old workflow. Edits are blocked.';
  }
%>

<div class="<%= toneBg %> border <%= toneBorder %> rounded-xl p-4">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-widest <%= pillBg %> <%= pillText %> ring-1 <%= pillRing %>"><%= statusLabel(status) %></span>
        <h2 class="text-sm font-bold <%= toneText %>"><%= title %></h2>
      </div>
      <p class="text-xs <%= toneAccent %> mt-1"><%= detail %></p>
    </div>

    <div class="flex items-center gap-2 flex-wrap">
      <% if (status === 'draft' || status === 'finalized') { %>
        <form method="POST" action="/payroll/runs/<%= run.id %>/submit-for-approval" onsubmit="return confirm('Send this pay run to Saadat for approval? You won\'t be able to edit lines until it\'s approved or unlocked.')">
          <%- include('../../partials/csrf') %>
          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg shadow-sm transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Request approval
          </button>
        </form>
        <% if (canApprove) { %>
          <form method="POST" action="/payroll/runs/<%= run.id %>/approve" onsubmit="return confirm('Approve this pay run directly (skip finance review)? Lines will be locked and finance will be notified to release payment.')">
            <%- include('../../partials/csrf') %>
            <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg shadow-sm transition" title="You're the approver — skip the request step and approve directly">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Approve directly
            </button>
          </form>
        <% } %>
      <% } %>

      <% if (status === 'pending_approval') { %>
        <% if (canApprove) { %>
          <form method="POST" action="/payroll/runs/<%= run.id %>/approve" onsubmit="return confirm('Approve this pay run? Once approved, lines will be locked and finance will be notified to release payment.')">
            <%- include('../../partials/csrf') %>
            <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg shadow-sm transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Approve &amp; release for payment
            </button>
          </form>
        <% } else { %>
          <span class="text-[11px] text-amber-700 italic">Awaiting Saadat</span>
        <% } %>
        <form method="POST" action="/payroll/runs/<%= run.id %>/recall" onsubmit="return confirm('Recall this pay run from approval? It will go back to draft so you can edit it.')">
          <%- include('../../partials/csrf') %>
          <button type="submit" class="px-3 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-semibold rounded-lg">Recall</button>
        </form>
      <% } %>

      <% if (status === 'approved') { %>
        <form method="POST" action="/payroll/runs/<%= run.id %>/mark-paid" onsubmit="return confirm('Mark this pay run as PAID? Workers should already have been paid before doing this.')">
          <%- include('../../partials/csrf') %>
          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg shadow-sm transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Mark paid
          </button>
        </form>
      <% } %>

      <% if (runLocked && canUnlock) { %>
        <form method="POST" action="/payroll/runs/<%= run.id %>/unlock" onsubmit="return confirm('Unlock this pay run? It will go back to draft and finance will be notified to make changes.')">
          <%- include('../../partials/csrf') %>
          <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-gray-300 hover:bg-rose-50 hover:border-rose-300 hover:text-rose-700 text-gray-700 text-xs font-semibold rounded-lg">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
            Unlock for edits
          </button>
        </form>
      <% } else if (runLocked) { %>
        <span class="text-[11px] text-gray-500 italic">Unlock requires Saadat or Sajid</span>
      <% } %>
    </div>
  </div>
</div>
