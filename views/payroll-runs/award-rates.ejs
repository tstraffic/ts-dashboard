<% locals.currentPage = 'pay-runs' %>
<%
  function fmtMoney(n) { const v = parseFloat(n) || 0; return v.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5 max-w-7xl">
  <div class="flex items-center justify-between gap-3 flex-wrap">
    <div>
      <a href="/payroll/rates" class="text-sm text-brand-600 hover:underline">← Worker Rates</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">Award Classifications</h1>
      <p class="text-sm text-gray-500 mt-1">Fair Work classification rates. TFN workers can be assigned a classification — the rates here override their direct rate fields. Soft-deleting keeps historical pay runs intact.</p>
    </div>
    <button onclick="openClassModal()" class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      Add classification
    </button>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (!classifications || classifications.length === 0) { %>
      <div class="p-10 text-center">
        <p class="text-sm text-gray-500 font-semibold">No classifications yet</p>
        <p class="text-xs text-gray-400 mt-1">Add one to start auto-filling TFN worker rates from a Fair Work award.</p>
        <button onclick="openClassModal()" class="inline-block mt-3 text-sm font-semibold text-brand-600">Add your first classification →</button>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Classification</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Award</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Effective</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Day</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Day OT</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Day DT</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Night</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">N OT</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">N DT</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Wknd</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">PH</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Meal</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Fares</th>
              <th class="px-2 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% classifications.forEach(c => { %>
              <tr class="<%= c.active ? '' : 'opacity-50 bg-gray-50' %>">
                <td class="px-3 py-2 font-semibold text-gray-900"><%= c.classification %><% if (!c.active) { %> <span class="text-[10px] text-gray-400">(inactive)</span><% } %></td>
                <td class="px-2 py-2 text-xs text-gray-600"><%= c.award_name || '—' %></td>
                <td class="px-2 py-2 text-xs text-gray-600 tabular-nums">
                  <%= fmtDate(c.effective_from) %><% if (c.effective_to) { %> → <%= fmtDate(c.effective_to) %><% } %>
                </td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_day) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_day_ot) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_day_dt) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_night) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_night_ot) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_night_dt) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_weekend) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_public_holiday) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_meal) %></td>
                <td class="px-2 py-2 text-xs text-right tabular-nums">$<%= fmtMoney(c.rate_fares_daily) %></td>
                <td class="px-2 py-2 text-center whitespace-nowrap">
                  <button onclick='editClass(<%- JSON.stringify(c) %>)' class="px-2 py-1 text-[11px] font-semibold text-brand-600 hover:bg-brand-50 rounded">Edit</button>
                  <% if (c.active) { %>
                    <form method="POST" action="/payroll/award-rates/<%= c.id %>/delete" class="inline" onsubmit="return confirm('Deactivate <%= c.classification %>? Existing pay runs are unaffected.')">
                      <%- include('../partials/csrf') %>
                      <button type="submit" class="px-2 py-1 text-[11px] font-semibold text-red-600 hover:bg-red-50 rounded">Deactivate</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Classification edit modal -->
<div id="classModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm overflow-y-auto" onclick="if(event.target===this)closeClassModal()">
  <div class="min-h-full flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-3xl">
      <form method="POST" action="/payroll/award-rates" id="classForm">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="id" id="classId" value="">

        <div class="p-5 border-b border-gray-200">
          <h2 class="text-lg font-bold text-gray-900" id="classTitle">Add classification</h2>
        </div>

        <div class="p-5 space-y-4 max-h-[70vh] overflow-y-auto">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Classification *</label>
              <input type="text" name="classification" required placeholder="CW1, Level 3, etc." class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm">
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Award name</label>
              <input type="text" name="award_name" placeholder="Building & Construction General On-site Award 2020" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm">
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Effective from *</label>
              <input type="date" name="effective_from" required class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm tabular-nums">
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Effective to (optional)</label>
              <input type="date" name="effective_to" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm tabular-nums">
            </div>
          </div>

          <div>
            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Hourly rates ($/h)</p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              <% [['rate_day','Day'],['rate_day_ot','Day OT'],['rate_day_dt','Day DT'],['rate_night','Night'],['rate_night_ot','Night OT'],['rate_night_dt','Night DT'],['rate_weekend','Weekend'],['rate_public_holiday','Public Holiday']].forEach(([k,l]) => { %>
                <div>
                  <label class="block text-xs font-semibold text-gray-700 mb-1"><%= l %></label>
                  <input type="number" step="0.01" min="0" name="<%= k %>" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm tabular-nums">
                </div>
              <% }) %>
            </div>
          </div>

          <div>
            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Allowances</p>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Meal allowance ($/shift ≥ 10h)</label>
                <input type="number" step="0.01" min="0" name="rate_meal" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Daily fares ($/day)</label>
                <input type="number" step="0.01" min="0" name="rate_fares_daily" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Notes</label>
            <textarea name="notes" rows="2" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
          </div>
        </div>

        <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
          <button type="button" onclick="closeClassModal()" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
          <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openClassModal() {
    const f = document.getElementById('classForm');
    f.reset();
    document.getElementById('classId').value = '';
    document.getElementById('classTitle').textContent = 'Add classification';
    f.querySelector('input[name="effective_from"]').value = '<%= new Date().toISOString().slice(0,10) %>';
    document.getElementById('classModal').classList.remove('hidden');
  }
  function editClass(c) {
    const f = document.getElementById('classForm');
    f.reset();
    document.getElementById('classId').value = c.id;
    document.getElementById('classTitle').textContent = 'Edit ' + c.classification;
    f.querySelector('input[name="classification"]').value = c.classification || '';
    f.querySelector('input[name="award_name"]').value = c.award_name || '';
    f.querySelector('input[name="effective_from"]').value = c.effective_from || '';
    f.querySelector('input[name="effective_to"]').value = c.effective_to || '';
    ['rate_day','rate_day_ot','rate_day_dt','rate_night','rate_night_ot','rate_night_dt','rate_weekend','rate_public_holiday','rate_meal','rate_fares_daily'].forEach(k => {
      f.querySelector('input[name="' + k + '"]').value = c[k] || 0;
    });
    f.querySelector('textarea[name="notes"]').value = c.notes || '';
    document.getElementById('classModal').classList.remove('hidden');
  }
  function closeClassModal() { document.getElementById('classModal').classList.add('hidden'); }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeClassModal(); });
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
