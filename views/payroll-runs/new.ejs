<% locals.currentPage = 'pay-runs' %>
<div class="max-w-2xl mx-auto space-y-5">
  <div>
    <a href="/payroll/runs" class="text-sm text-brand-600 hover:underline">← Pay Runs</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2">New Pay Run</h1>
    <p class="text-sm text-gray-500 mt-1">Pick the run type. Traffic Control imports a Traffio CSV; Management is a direct-entry salary period.</p>
  </div>

  <!-- Type picker -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <a href="/payroll/runs/new?type=traffic_control"
      class="block p-4 rounded-xl border-2 transition <%= runType === 'traffic_control' ? 'border-brand-500 bg-brand-50/50 ring-2 ring-brand-500/20' : 'border-gray-200 bg-white hover:border-brand-300' %>">
      <div class="flex items-center gap-2 mb-1">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-700 ring-1 ring-blue-600/20">TC</span>
        <p class="font-semibold text-gray-900 text-sm">Traffic Control</p>
      </div>
      <p class="text-xs text-gray-500">Upload a Traffio Person Dockets CSV. Hours are bucketed Mon→Sun and split Day/Night.</p>
    </a>
    <a href="/payroll/runs/new?type=management"
      class="block p-4 rounded-xl border-2 transition <%= runType === 'management' ? 'border-brand-500 bg-brand-50/50 ring-2 ring-brand-500/20' : 'border-gray-200 bg-white hover:border-brand-300' %>">
      <div class="flex items-center gap-2 mb-1">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-violet-50 text-violet-700 ring-1 ring-violet-600/20">MGMT</span>
        <p class="font-semibold text-gray-900 text-sm">Management</p>
      </div>
      <p class="text-xs text-gray-500">Direct-entry salary period. Auto-fills one Salary line per employee flagged for management payroll <span class="font-semibold">(<%= mgmtCount %> currently)</span>.</p>
    </a>
  </div>

  <% if (runType === 'traffic_control') { %>
    <form method="POST" action="/payroll/runs" enctype="multipart/form-data" class="bg-white border border-gray-200 rounded-xl p-6 space-y-5 shadow-sm">
      <input type="hidden" name="pay_run_type" value="traffic_control">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Traffio CSV file <span class="text-red-500">*</span></label>
        <input type="file" name="csv" accept=".csv,text/csv" required
          class="block w-full text-sm text-gray-700 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 cursor-pointer">
        <p class="text-xs text-gray-400 mt-1.5">Up to 10 MB. Period is auto-detected from the file (you can override below).</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period start (optional)</label>
          <input type="date" name="period_start" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period end (optional)</label>
          <input type="date" name="period_end" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Label (optional)</label>
        <input type="text" name="label" placeholder="e.g. WE 26.04.26"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <p class="text-xs text-gray-400 mt-1.5">Defaults to "WE DD.MM.YY" using the period end date.</p>
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Notes (optional)</label>
        <textarea name="notes" rows="2"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-xs text-blue-900">
        <p class="font-semibold mb-1">How matching works</p>
        <ol class="list-decimal list-inside space-y-0.5 text-blue-800">
          <li>Match on <span class="font-mono">employee_reference → employee_code</span></li>
          <li>Otherwise exact name match (case-insensitive)</li>
          <li>Otherwise the worker lands in the <strong>Unclassified</strong> bucket — you can match them on the next page</li>
        </ol>
        <p class="mt-2">Rates are pulled from each employee's <span class="font-mono">rate_day</span> / <span class="font-mono">rate_night</span> at import time and snapshotted onto the line.</p>
      </div>

      <div class="flex items-center justify-end gap-2 pt-2">
        <a href="/payroll/runs" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</a>
        <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">
          Import &amp; preview →
        </button>
      </div>
    </form>
  <% } else { %>
    <form method="POST" action="/payroll/runs" class="bg-white border border-gray-200 rounded-xl p-6 space-y-5 shadow-sm">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="pay_run_type" value="management">

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period start <span class="text-red-500">*</span></label>
          <input type="date" name="period_start" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period end <span class="text-red-500">*</span></label>
          <input type="date" name="period_end" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Label (optional)</label>
        <input type="text" name="label" placeholder="e.g. Management — WE 26.04.26"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-500 uppercase tracking-widest mb-1.5">Notes (optional)</label>
        <textarea name="notes" rows="2"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
      </div>

      <div class="bg-violet-50 border border-violet-200 rounded-lg p-3 text-xs text-violet-900">
        <p class="font-semibold mb-1">What happens on save</p>
        <ul class="list-disc list-inside space-y-0.5 text-violet-800">
          <li>One starter <strong>Salary</strong> line is added per employee with <span class="font-mono">on_management_payroll = 1</span> <span class="font-semibold">(<%= mgmtCount %> currently)</span>.</li>
          <li>Salary uses each employee's <span class="font-mono">weekly_salary</span>; super uses <span class="font-mono">salary &times; super_rate</span>.</li>
          <li>You can edit lines, add extra income sources (Director fee, Bonus, …), or remove people on the next page.</li>
        </ul>
      </div>

      <div class="flex items-center justify-end gap-2 pt-2">
        <a href="/payroll/runs" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</a>
        <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Create Management run →</button>
      </div>
    </form>
  <% } %>
</div>

<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
