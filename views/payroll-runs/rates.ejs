<% locals.currentPage = 'pay-runs' %>

<div class="space-y-5">
  <div class="flex items-center justify-between gap-3 flex-wrap">
    <div>
      <a href="/payroll/runs" class="text-sm text-brand-600 hover:underline">← Pay Runs</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">Worker Rates</h1>
      <p class="text-sm text-gray-500 mt-1">Set day &amp; night rates, payment type (Cash / TFN / ABN), and BSB / account for each worker. These pre-fill on every pay run.</p>
    </div>
    <div class="flex items-center gap-2">
      <input type="search" id="filter" placeholder="Search…" class="px-3 py-2 border border-gray-300 rounded-lg text-sm w-48">
      <select id="ptFilter" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <option value="">All sections</option>
        <option value="cash">Cash</option>
        <option value="tfn">TFN</option>
        <option value="abn">ABN</option>
        <option value="">Unclassified</option>
      </select>
    </div>
  </div>

  <form method="POST" action="/payroll/rates" class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <%- include('../partials/csrf') %>

    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Worker</th>
            <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Section</th>
            <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Day rate</th>
            <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Night rate</th>
            <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">BSB</th>
            <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Account</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100" id="ratesTbody">
          <% employees.forEach(e => { %>
            <tr data-name="<%= e.full_name.toLowerCase() %>" data-pt="<%= e.payment_type || '' %>">
              <td class="px-3 py-2">
                <p class="font-semibold text-gray-900 text-sm"><%= e.full_name %></p>
                <% if (e.employee_code) { %>
                  <p class="text-[10px] text-gray-400 font-mono"><%= e.employee_code %></p>
                <% } %>
              </td>
              <td class="px-2 py-1">
                <select name="rows[<%= e.id %>][payment_type]" class="px-2 py-1 border border-gray-300 rounded text-sm">
                  <option value="" <%= !e.payment_type ? 'selected' : '' %>>—</option>
                  <option value="cash" <%= e.payment_type === 'cash' ? 'selected' : '' %>>Cash</option>
                  <option value="tfn"  <%= e.payment_type === 'tfn'  ? 'selected' : '' %>>TFN</option>
                  <option value="abn"  <%= e.payment_type === 'abn'  ? 'selected' : '' %>>ABN</option>
                </select>
              </td>
              <td class="px-2 py-1 text-right">
                <input type="number" step="0.01" min="0" name="rows[<%= e.id %>][rate_day]" value="<%= e.rate_day || 0 %>" class="w-20 px-2 py-1 border border-gray-300 rounded text-sm text-right tabular-nums">
              </td>
              <td class="px-2 py-1 text-right">
                <input type="number" step="0.01" min="0" name="rows[<%= e.id %>][rate_night]" value="<%= e.rate_night || 0 %>" class="w-20 px-2 py-1 border border-gray-300 rounded text-sm text-right tabular-nums">
              </td>
              <td class="px-2 py-1">
                <input type="text" name="rows[<%= e.id %>][payroll_bsb]" value="<%= e.payroll_bsb || '' %>" placeholder="000-000" class="w-24 px-2 py-1 border border-gray-300 rounded text-sm font-mono">
              </td>
              <td class="px-2 py-1">
                <input type="text" name="rows[<%= e.id %>][payroll_account]" value="<%= e.payroll_account || '' %>" placeholder="000000000" class="w-32 px-2 py-1 border border-gray-300 rounded text-sm font-mono">
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 flex items-center justify-between">
      <p class="text-xs text-gray-500"><%= employees.length %> active employee<%= employees.length !== 1 ? 's' : '' %></p>
      <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save all rates</button>
    </div>
  </form>
</div>

<script>
  const filterInput = document.getElementById('filter');
  const ptFilter = document.getElementById('ptFilter');
  function applyFilter() {
    const q = filterInput.value.trim().toLowerCase();
    const pt = ptFilter.value;
    document.querySelectorAll('#ratesTbody tr').forEach(tr => {
      const matchName = !q || tr.dataset.name.includes(q);
      const matchPt = pt === undefined || pt === null || pt === '' || tr.dataset.pt === pt;
      tr.style.display = (matchName && matchPt) ? '' : 'none';
    });
  }
  filterInput.addEventListener('input', applyFilter);
  ptFilter.addEventListener('change', applyFilter);
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
