<% locals.currentPage = 'pay-runs' %>
<%
  // Group employees by their current payment_type so each tab only renders
  // workers in that section. Unclassified workers go in their own tab.
  const groups = { cash: [], tfn: [], abn: [], unclassified: [] };
  employees.forEach(e => {
    const pt = (e.payment_type || '').toLowerCase();
    if (pt === 'cash')      groups.cash.push(e);
    else if (pt === 'tfn')  groups.tfn.push(e);
    else if (pt === 'abn')  groups.abn.push(e);
    else                    groups.unclassified.push(e);
  });

  // What columns each tab shows. Cash + ABN + TFN have different rate sets.
  const COLS = {
    cash: [
      { key: 'rate_day',           label: 'Day',     step: '0.01' },
      { key: 'rate_night',         label: 'Night',   step: '0.01' },
      { key: 'rate_meal',          label: 'Meal',    step: '0.01' },
      { key: 'rate_fares_daily',   label: 'Travel',  step: '0.01' },
    ],
    abn: [
      { key: 'rate_day',           label: 'Day',     step: '0.01' },
      { key: 'rate_ot',            label: 'Day OT',  step: '0.01' },
      { key: 'rate_night',         label: 'Night',   step: '0.01' },
      { key: 'rate_night_ot',      label: 'Night OT',step: '0.01' },
      { key: 'rate_weekend',       label: 'Weekend', step: '0.01' },
      { key: 'rate_meal',          label: 'Meal',    step: '0.01' },
      { key: 'rate_fares_daily',   label: 'Travel',  step: '0.01' },
    ],
    tfn: [
      { key: 'rate_day',           label: 'Day',     step: '0.01' },
      { key: 'rate_ot',            label: 'Day OT',  step: '0.01' },
      { key: 'rate_dt',            label: 'Day DT',  step: '0.01' },
      { key: 'rate_night',         label: 'Night',   step: '0.01' },
      { key: 'rate_night_ot',      label: 'Night OT',step: '0.01' },
      { key: 'rate_night_dt',      label: 'Night DT',step: '0.01' },
      { key: 'rate_weekend',       label: 'Weekend', step: '0.01' },
      { key: 'rate_public_holiday',label: 'PH',      step: '0.01' },
      { key: 'rate_meal',          label: 'Meal',    step: '0.01' },
      { key: 'rate_fares_daily',   label: 'Fares',   step: '0.01' },
    ],
    unclassified: [],
  };

  const TABS = [
    { key: 'cash', label: 'Cash', count: groups.cash.length, accent: 'amber' },
    { key: 'tfn',  label: 'TFN',  count: groups.tfn.length,  accent: 'emerald' },
    { key: 'abn',  label: 'ABN',  count: groups.abn.length,  accent: 'sky' },
    { key: 'unclassified', label: 'Unclassified', count: groups.unclassified.length, accent: 'gray' },
  ];
%>

<div class="space-y-5">
  <div class="flex items-center justify-between gap-3 flex-wrap">
    <div>
      <a href="/payroll/runs" class="text-sm text-brand-600 hover:underline">← Pay Runs</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">Worker Rates</h1>
      <p class="text-sm text-gray-500 mt-1">Set rates per section. Each pay run pulls these at import time. <a href="/payroll/award-rates" class="text-brand-600 hover:underline">Manage award classifications →</a></p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/payroll/holidays" class="px-3 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold rounded-lg">Public holidays</a>
    </div>
  </div>

  <!-- Tabs -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm">
    <div class="border-b border-gray-200 flex overflow-x-auto">
      <% TABS.forEach((t, i) => { %>
        <button type="button" onclick="showTab('<%= t.key %>')" id="tabBtn-<%= t.key %>"
          class="tab-btn px-5 py-3 text-sm font-semibold whitespace-nowrap border-b-2 transition <%= i === 0 ? 'border-brand-600 text-brand-700' : 'border-transparent text-gray-500 hover:text-gray-700' %>"
          data-tab="<%= t.key %>">
          <%= t.label %>
          <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-gray-100 text-gray-700"><%= t.count %></span>
        </button>
      <% }) %>
    </div>

    <form method="POST" action="/payroll/rates">
      <%- include('../partials/csrf') %>
      <% TABS.forEach((tab, i) => { %>
        <div id="tab-<%= tab.key %>" class="tab-pane <%= i === 0 ? '' : 'hidden' %>">
          <% const cols = COLS[tab.key]; const list = groups[tab.key]; %>
          <% if (list.length === 0) { %>
            <div class="p-10 text-center text-sm text-gray-500">
              <% if (tab.key === 'unclassified') { %>
                No unclassified employees — every worker has a section assigned. ✓
              <% } else { %>
                No <%= tab.label %> workers yet. Add by changing an employee's section in another tab.
              <% } %>
            </div>
          <% } else { %>
            <div class="overflow-x-auto">
              <table class="min-w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-200">
                  <tr>
                    <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest sticky left-0 bg-gray-50 z-10">Worker</th>
                    <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Section</th>
                    <% if (tab.key === 'tfn') { %>
                      <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Award class.</th>
                    <% } %>
                    <% cols.forEach(c => { %>
                      <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest"><%= c.label %></th>
                    <% }) %>
                    <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">BSB</th>
                    <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Account</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  <% list.forEach(e => { %>
                    <tr>
                      <td class="px-3 py-2 sticky left-0 bg-white z-[5]">
                        <p class="font-semibold text-gray-900 text-sm"><%= e.full_name %></p>
                        <% if (e.employee_code) { %><p class="text-[10px] text-gray-400 font-mono"><%= e.employee_code %></p><% } %>
                      </td>
                      <td class="px-2 py-1">
                        <select name="rows[emp_<%= e.id %>][payment_type]" class="px-2 py-1 border border-gray-300 rounded text-sm">
                          <option value="" <%= !e.payment_type ? 'selected' : '' %>>—</option>
                          <option value="cash" <%= e.payment_type === 'cash' ? 'selected' : '' %>>Cash</option>
                          <option value="tfn"  <%= e.payment_type === 'tfn'  ? 'selected' : '' %>>TFN</option>
                          <option value="abn"  <%= e.payment_type === 'abn'  ? 'selected' : '' %>>ABN</option>
                        </select>
                      </td>
                      <% if (tab.key === 'tfn') { %>
                        <td class="px-2 py-1">
                          <select name="rows[emp_<%= e.id %>][award_classification_id]" class="px-2 py-1 border border-gray-300 rounded text-sm">
                            <option value="">— None —</option>
                            <% classifications.forEach(c => { %>
                              <option value="<%= c.id %>" <%= e.award_classification_id == c.id ? 'selected' : '' %>><%= c.classification %></option>
                            <% }) %>
                          </select>
                        </td>
                      <% } %>
                      <% cols.forEach(c => { %>
                        <td class="px-1 py-1 text-right">
                          <input type="number" step="<%= c.step %>" min="0" name="rows[emp_<%= e.id %>][<%= c.key %>]" value="<%= e[c.key] || 0 %>" class="w-20 px-2 py-1 border border-gray-300 rounded text-sm text-right tabular-nums">
                        </td>
                      <% }) %>
                      <td class="px-2 py-1">
                        <input type="text" name="rows[emp_<%= e.id %>][payroll_bsb]" value="<%= e.payroll_bsb || '' %>" placeholder="000-000" class="w-24 px-2 py-1 border border-gray-300 rounded text-sm font-mono">
                      </td>
                      <td class="px-2 py-1">
                        <input type="text" name="rows[emp_<%= e.id %>][payroll_account]" value="<%= e.payroll_account || '' %>" placeholder="000000000" class="w-32 px-2 py-1 border border-gray-300 rounded text-sm font-mono">
                      </td>
                    </tr>

                    <!-- Hidden mirror inputs so columns NOT shown in this tab still post their current values -->
                    <% const allRateKeys = ['rate_day','rate_ot','rate_dt','rate_night','rate_night_ot','rate_night_dt','rate_weekend','rate_public_holiday','rate_meal','rate_fares_daily']; %>
                    <% allRateKeys.forEach(k => { if (!cols.find(c => c.key === k)) { %>
                      <input type="hidden" name="rows[emp_<%= e.id %>][<%= k %>]" value="<%= e[k] || 0 %>">
                    <% } }) %>
                    <% if (tab.key !== 'tfn') { %>
                      <input type="hidden" name="rows[emp_<%= e.id %>][award_classification_id]" value="<%= e.award_classification_id || '' %>">
                    <% } %>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      <% }) %>

      <div class="bg-gray-50 px-4 py-3 border-t border-gray-200 flex items-center justify-between rounded-b-xl">
        <p class="text-xs text-gray-500"><%= employees.length %> active employee<%= employees.length !== 1 ? 's' : '' %></p>
        <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save all rates</button>
      </div>
    </form>
  </div>
</div>

<script>
  // When a TFN worker's award classification changes, fetch the
  // classification's rates and auto-fill the row's rate inputs.
  document.querySelectorAll('select[name*="[award_classification_id]"]').forEach(sel => {
    sel.addEventListener('change', async (e) => {
      const id = e.target.value;
      if (!id) return;
      try {
        const r = await fetch('/payroll/award-classifications/' + id + '.json', { headers: { 'Accept': 'application/json' } });
        if (!r.ok) return;
        const data = await r.json();
        if (!data || !data.rates) return;
        // Find the parent row for this select and write each rate input
        const row = e.target.closest('tr');
        if (!row) return;
        const empMatch = e.target.name.match(/emp_(\d+)/);
        if (!empMatch) return;
        const empId = empMatch[1];
        Object.entries(data.rates).forEach(([k, v]) => {
          if (v == null) return;
          // Update visible input AND any hidden mirror inputs for the same key
          document.querySelectorAll('input[name="rows[emp_' + empId + '][' + k + ']"]').forEach(inp => {
            inp.value = (parseFloat(v) || 0).toFixed(2);
          });
        });
        // Tiny visual signal that the row was filled
        row.classList.add('bg-emerald-50');
        setTimeout(() => row.classList.remove('bg-emerald-50'), 900);
      } catch (err) {
        console.error('Award fetch failed:', err);
      }
    });
  });

  function showTab(key) {
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
    document.getElementById('tab-' + key).classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(b => {
      if (b.dataset.tab === key) {
        b.classList.add('border-brand-600', 'text-brand-700');
        b.classList.remove('border-transparent', 'text-gray-500');
      } else {
        b.classList.remove('border-brand-600', 'text-brand-700');
        b.classList.add('border-transparent', 'text-gray-500');
      }
    });
  }
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
