<% locals.currentPage = 'pay-runs' %>
<%
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Pay Runs</h1>
      <p class="text-sm text-gray-500 mt-1">
        Upload a Traffio Person Dockets CSV to generate a pay run split into Cash / TFN / ABN.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/payroll/rates" class="inline-flex items-center gap-1.5 px-3 py-2.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold rounded-lg transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Worker rates
      </a>
      <a href="/payroll/runs/new" class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Import CSV
      </a>
    </div>
  </div>

  <!-- List -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (!runs || runs.length === 0) { %>
      <div class="p-10 text-center">
        <svg class="w-12 h-12 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="mt-3 text-sm text-gray-500 font-semibold">No pay runs yet</p>
        <p class="text-xs text-gray-400 mt-1">Import a Traffio Person Dockets CSV to get started.</p>
        <a href="/payroll/runs/new" class="inline-block mt-3 text-sm font-semibold text-brand-600">Import your first pay run →</a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Period</th>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Workers</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden sm:table-cell">Cash</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden sm:table-cell">TFN</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden sm:table-cell">ABN</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Total</th>
              <th class="px-4 py-3 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden md:table-cell">Status</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% runs.forEach(r => { %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-4 py-3">
                  <a href="/payroll/runs/<%= r.id %>" class="block">
                    <p class="font-semibold text-gray-900 text-sm"><%= r.label || periodLabel(r.period_start, r.period_end) %></p>
                    <p class="text-[11px] text-gray-400 tabular-nums"><%= fmtDate(r.period_start) %> → <%= fmtDate(r.period_end) %></p>
                  </a>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 tabular-nums">
                  <%= r.line_count %>
                  <% if (r.unclassified_count > 0) { %>
                    <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-700"><%= r.unclassified_count %> unclassified</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right tabular-nums hidden sm:table-cell">$<%= fmtMoney(r.cash_total) %></td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right tabular-nums hidden sm:table-cell">$<%= fmtMoney(r.tfn_total) %></td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right tabular-nums hidden sm:table-cell">$<%= fmtMoney(r.abn_total) %></td>
                <td class="px-4 py-3 text-sm font-bold text-gray-900 text-right tabular-nums">$<%= fmtMoney(r.grand_total) %></td>
                <td class="px-4 py-3 text-center hidden md:table-cell">
                  <% if (r.status === 'finalized') { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Finalized</span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-gray-100 text-gray-600 ring-1 ring-gray-300">Draft</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <a href="/payroll/runs/<%= r.id %>" class="inline-flex items-center px-2.5 py-1.5 text-xs font-semibold text-brand-600 hover:bg-brand-50 rounded-lg">Open →</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
