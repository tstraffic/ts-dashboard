<% locals.currentPage = 'pay-runs' %>
<%
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <a href="/payroll/runs" class="text-sm text-brand-600 hover:underline">← Pay Runs</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1"><%= run.label || periodLabel(run.period_start, run.period_end) %></h1>
      <p class="text-sm text-gray-500 mt-0.5 tabular-nums"><%= fmtDate(run.period_start) %> → <%= fmtDate(run.period_end) %></p>
    </div>
    <div class="flex items-center gap-2">
      <form method="POST" action="/payroll/runs/<%= run.id %>/refresh" onsubmit="return confirm('Re-run categorization for ALL workers? Manual hour edits will be lost. Allowances + rates re-applied from current employee + classification.')">
        <%- include('../partials/csrf') %>
        <button type="submit" class="px-3 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-semibold rounded-lg transition" title="Re-run bucket categorization from shifts using current employee rates + classifications">
          ⟳ Refresh from rates
        </button>
      </form>
      <a href="/payroll/runs/<%= run.id %>/export.xlsx" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export xlsx
      </a>
      <form method="POST" action="/payroll/runs/<%= run.id %>/delete" onsubmit="return confirm('Delete pay run <%= run.label %>? This cannot be undone.')">
        <%- include('../partials/csrf') %>
        <button type="submit" class="px-3 py-2 bg-white border border-gray-300 hover:bg-red-50 hover:border-red-300 hover:text-red-600 text-gray-700 text-sm font-semibold rounded-lg">Delete</button>
      </form>
    </div>
  </div>

  <!-- Top totals strip -->
  <%
    const grandHours = (totals.cash.hours || 0) + (totals.tfn.hours || 0) + (totals.abn.hours || 0) + (totals.unclassified.hours || 0);
    function fmtHours(n) { return (Math.round((parseFloat(n) || 0) * 100) / 100).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  %>
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Workers</p>
      <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= grand.line_count %></p>
      <p class="text-[10px] text-gray-400 mt-0.5"><%= fmtHours(grandHours) %> hrs total</p>
    </div>
    <div class="bg-white border border-amber-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Cash</p>
      <p class="text-xl font-bold text-amber-700 mt-1 tabular-nums">$<%= fmtMoney(totals.cash.total) %></p>
      <p class="text-[10px] text-gray-400 mt-0.5"><%= buckets.cash.length %> · <%= fmtHours(totals.cash.hours) %> hrs · +GST $<%= fmtMoney(totals.cash.with_gst) %></p>
    </div>
    <div class="bg-white border border-emerald-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">TFN</p>
      <p class="text-xl font-bold text-emerald-700 mt-1 tabular-nums">$<%= fmtMoney(totals.tfn.total) %></p>
      <p class="text-[10px] text-gray-400 mt-0.5"><%= buckets.tfn.length %> · <%= fmtHours(totals.tfn.hours) %> hrs</p>
    </div>
    <div class="bg-white border border-sky-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-sky-500 uppercase tracking-widest">ABN</p>
      <p class="text-xl font-bold text-sky-700 mt-1 tabular-nums">$<%= fmtMoney(totals.abn.total) %></p>
      <p class="text-[10px] text-gray-400 mt-0.5"><%= buckets.abn.length %> · <%= fmtHours(totals.abn.hours) %> hrs</p>
    </div>
    <div class="bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-xl p-4">
      <p class="text-[10px] font-bold text-white/80 uppercase tracking-widest">Grand Total</p>
      <p class="text-xl font-bold mt-1 tabular-nums">$<%= fmtMoney(grand.total) %></p>
      <p class="text-[10px] text-white/80 mt-0.5"><%= grand.paid_count %>/<%= grand.line_count %> paid · <%= fmtHours(grandHours) %> hrs</p>
    </div>
  </div>

  <% if (buckets.unclassified.length > 0) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div class="flex-1">
        <p class="text-sm font-semibold text-amber-900"><%= buckets.unclassified.length %> worker<%= buckets.unclassified.length !== 1 ? 's' : '' %> need classification</p>
        <p class="text-xs text-amber-800 mt-0.5">Workers showing here either didn't match an employee, or the matched employee has no <span class="font-mono">payment_type</span> set. Classify each below — TFN/ABN/Cash applies different bucket rules.</p>
      </div>
    </div>
  <% } %>

  <% sections.forEach(section => {
    const lns = buckets[section.key];
    const sectTotals = totals[section.key];
    if (!lns || lns.length === 0) return;
  %>
    <%- include('partials/_section', { section, lines: lns, sectTotals, accent: section.accent, dowLabels, bucketLabels, fmtMoney }) %>
  <% }) %>

  <% if (buckets.unclassified.length > 0) { %>
    <%- include('partials/_section', {
      section: { key: 'unclassified', label: 'Unclassified', accent: 'gray', buckets: bucketKeys },
      lines: buckets.unclassified,
      sectTotals: totals.unclassified,
      accent: 'gray',
      dowLabels, bucketLabels, fmtMoney,
    }) %>
  <% } %>
</div>

<!-- Edit modal -->
<div id="editModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm overflow-y-auto" onclick="if(event.target===this)closeEditModal()">
  <div class="min-h-full flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-5xl">
      <form id="editForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="p-5 border-b border-gray-200 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-bold text-gray-900" id="editTitle">Edit worker</h2>
            <p class="text-xs text-gray-500 mt-0.5" id="editSubtitle"></p>
          </div>
          <button type="button" onclick="closeEditModal()" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="p-5 space-y-4 max-h-[70vh] overflow-y-auto">
          <!-- Section + identity -->
          <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Section</label>
              <select name="payment_type" id="ptSelect" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm">
                <option value="">Unclassified</option>
                <option value="cash">Cash</option>
                <option value="tfn">TFN</option>
                <option value="abn">ABN</option>
              </select>
              <p id="ptWarn" class="hidden text-[10px] text-amber-700 mt-1">⚠ Changing section re-runs categorization from shifts.</p>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">BSB</label>
              <input type="text" name="bsb" placeholder="000-000" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            </div>
            <div class="col-span-2">
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Account number</label>
              <input type="text" name="acc_number" placeholder="000000000" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            </div>
          </div>

          <!-- Buckets table -->
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Hours by bucket</label>
              <p class="text-[10px] text-gray-400">Mon..Sun. Edit cells to override; rate × hours = wages.</p>
            </div>
            <div class="overflow-x-auto rounded-lg border border-gray-200">
              <table class="min-w-full text-sm" id="bucketsTable">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Bucket</th>
                    <% dowLabels.forEach(d => { %>
                      <th class="px-1 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest"><%= d %></th>
                    <% }) %>
                    <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Hrs</th>
                    <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Rate</th>
                    <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Wages</th>
                  </tr>
                </thead>
                <tbody id="bucketsTbody"></tbody>
              </table>
            </div>
          </div>

          <!-- Travel & Meal as rate × quantity -->
          <div class="space-y-2 bg-gray-50 border border-gray-200 rounded-lg p-3">
            <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Travel & Meal allowances</p>
            <!-- Travel row -->
            <div class="grid grid-cols-12 gap-2 items-end">
              <div class="col-span-2">
                <label class="block text-[10px] font-semibold text-gray-500 mb-0.5">Travel</label>
                <p class="text-[10px] text-gray-400">days × fare</p>
              </div>
              <div class="col-span-3">
                <label class="block text-[10px] text-gray-500 mb-0.5">Rate ($)</label>
                <input type="number" step="0.01" min="0" name="travel_rate" id="travelRate" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums">
              </div>
              <div class="col-span-2">
                <label class="block text-[10px] text-gray-500 mb-0.5">Days</label>
                <input type="number" step="1" min="0" name="travel_count" id="travelCount" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums">
              </div>
              <div class="col-span-3">
                <label class="block text-[10px] text-gray-500 mb-0.5">Total ($)</label>
                <input type="number" step="0.01" min="0" name="travel_allowance" id="travelAllowance" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums" readonly>
              </div>
              <div class="col-span-2 flex items-center gap-1.5 pb-1.5">
                <input type="checkbox" id="travelOverride" name="travel_override" value="1" class="rounded border-gray-300">
                <label for="travelOverride" class="text-[10px] text-gray-600">Override</label>
              </div>
            </div>
            <!-- Meal row -->
            <div class="grid grid-cols-12 gap-2 items-end">
              <div class="col-span-2">
                <label class="block text-[10px] font-semibold text-gray-500 mb-0.5">Meal</label>
                <p class="text-[10px] text-gray-400">10h+ × meal</p>
              </div>
              <div class="col-span-3">
                <label class="block text-[10px] text-gray-500 mb-0.5">Rate ($)</label>
                <input type="number" step="0.01" min="0" name="meal_rate" id="mealRate" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums">
              </div>
              <div class="col-span-2">
                <label class="block text-[10px] text-gray-500 mb-0.5">Shifts</label>
                <input type="number" step="1" min="0" name="meal_count" id="mealCount" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums">
              </div>
              <div class="col-span-3">
                <label class="block text-[10px] text-gray-500 mb-0.5">Total ($)</label>
                <input type="number" step="0.01" min="0" name="meal_allowance" id="mealAllowance" class="w-full px-2 py-1.5 border border-gray-300 rounded text-sm tabular-nums" readonly>
              </div>
              <div class="col-span-2 flex items-center gap-1.5 pb-1.5">
                <input type="checkbox" id="mealOverride" name="meal_override" value="1" class="rounded border-gray-300">
                <label for="mealOverride" class="text-[10px] text-gray-600">Override</label>
              </div>
            </div>
          </div>

          <!-- Expenses & receipts -->
          <div class="bg-white border border-gray-200 rounded-lg p-3 space-y-2" id="expensesPanel">
            <div class="flex items-center justify-between">
              <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Expenses & receipts</p>
              <p class="text-[10px] text-gray-400">Other allowance: $<span id="otherAllowanceDisplay" class="tabular-nums">0.00</span></p>
            </div>
            <!-- Hidden mirror so the form still posts other_allowance -->
            <input type="hidden" name="other_allowance" id="otherAllowanceHidden">
            <!-- Existing expense rows -->
            <div id="expenseRows" class="space-y-1.5"></div>
            <!-- Drop zone + add buttons -->
            <div id="expenseDropZone" class="border-2 border-dashed border-gray-300 hover:border-brand-400 hover:bg-brand-50 transition rounded-lg p-3 text-center cursor-pointer">
              <p class="text-xs text-gray-600 font-semibold">Drag &amp; drop receipts here</p>
              <p class="text-[10px] text-gray-400 mt-0.5">JPG, PNG, PDF up to 10MB · or
                <button type="button" id="expenseFilePick" class="text-brand-600 font-semibold hover:underline">click to upload</button>
                ·
                <button type="button" id="expenseAddBlank" class="text-brand-600 font-semibold hover:underline">add expense without receipt</button>
              </p>
              <input type="file" id="expenseFileInput" multiple accept=".jpg,.jpeg,.png,.pdf,.webp,.heic,.heif" class="hidden">
            </div>
          </div>

          <!-- Paid -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Paid?</label>
              <select name="paid" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm">
                <option value="0">Not paid</option>
                <option value="1">Paid</option>
              </select>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Payment ref</label>
              <input type="text" name="paid_ref" placeholder="Inv-014" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm font-mono">
            </div>
          </div>

          <!-- Deductions -->
          <div class="bg-white border border-gray-200 rounded-lg p-3 space-y-2" id="deductionsPanel">
            <div class="flex items-center justify-between">
              <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Deductions</p>
              <p class="text-[10px] text-gray-400">Total: $<span id="deductionsTotalDisplay" class="tabular-nums">0.00</span></p>
            </div>
            <div id="deductionRows" class="space-y-1.5"></div>
            <button type="button" id="deductionAddBtn" class="w-full px-3 py-1.5 bg-gray-50 hover:bg-gray-100 border border-gray-300 text-gray-700 text-xs font-semibold rounded">
              + Add deduction
            </button>
          </div>

          <!-- Live grand-total preview + tax estimate (TFN only) -->
          <div class="bg-brand-50 border border-brand-200 rounded-lg p-2.5 space-y-1">
            <div class="flex items-center justify-between">
              <p class="text-[11px] font-semibold text-brand-900">Gross (wages + allowances − deductions)</p>
              <p class="text-base font-bold text-brand-900 tabular-nums">$<span id="grandTotalDisplay">0.00</span></p>
            </div>
            <div id="taxRow" class="hidden flex items-center justify-between text-[11px]">
              <span class="text-rose-700 font-semibold">PAYG tax (est., weekly TFT-claimed)</span>
              <span class="text-rose-700 font-semibold tabular-nums">−$<span id="taxDisplay">0.00</span></span>
            </div>
            <div id="netRow" class="hidden flex items-center justify-between text-[11px]">
              <span class="text-emerald-700 font-semibold">Net take-home</span>
              <span class="text-emerald-700 font-bold tabular-nums">$<span id="netDisplay">0.00</span></span>
            </div>
          </div>

          <div>
            <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">Notes</label>
            <textarea name="notes" rows="2" class="w-full px-2.5 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
          </div>

          <!-- Save back to employee -->
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 space-y-1.5">
            <p class="text-[11px] font-semibold text-blue-900">Also save to employee record?</p>
            <label class="flex items-center gap-2 text-xs text-blue-900"><input type="checkbox" class="save-back-cb" name="save_bsb_to_employee" value="1"> Save BSB / account as new defaults</label>
            <label class="flex items-center gap-2 text-xs text-blue-900"><input type="checkbox" class="save-back-cb" name="save_payment_type_to_employee" value="1"> Save section as new default</label>
          </div>
        </div>

        <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
          <button type="button" onclick="closeEditModal()" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
          <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Match modal -->
<div id="matchModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm overflow-y-auto" onclick="if(event.target===this)closeMatchModal()">
  <div class="min-h-full flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
      <form id="matchForm" method="POST">
        <%- include('../partials/csrf') %>
        <div class="p-5 border-b border-gray-200">
          <h2 class="text-lg font-bold text-gray-900">Link to employee</h2>
          <p class="text-xs text-gray-500 mt-0.5" id="matchSubtitle"></p>
        </div>
        <div class="p-5">
          <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Pick employee</label>
          <select name="employee_id" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm">
            <option value="">— Select —</option>
            <% employees.forEach(e => { %>
              <option value="<%= e.id %>"><%= e.full_name %><%= e.employee_code ? ' — ' + e.employee_code : '' %><%= e.payment_type ? ' (' + e.payment_type.toUpperCase() + ')' : '' %></option>
            <% }) %>
          </select>
          <p class="text-xs text-gray-500 mt-2">Employee's section + classification + rates pull onto this line. Hours re-categorize.</p>
        </div>
        <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
          <button type="button" onclick="closeMatchModal()" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
          <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Link</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const RUN_ID = <%= run.id %>;
  const BUCKET_KEYS = <%- JSON.stringify(bucketKeys) %>;
  const BUCKET_LABELS = <%- JSON.stringify(bucketLabels) %>;
  const SECTION_BUCKETS = {
    cash:         ['day_normal', 'night_normal'],
    tfn:          BUCKET_KEYS,
    abn:          ['day_normal', 'day_ot', 'night_normal', 'night_ot', 'weekend'],
    '':           BUCKET_KEYS, // unclassified shows all
  };

  const LINES = {};
  <% [...buckets.cash, ...buckets.tfn, ...buckets.abn, ...buckets.unclassified].forEach(l => { %>
    LINES[<%= l.id %>] = {
      id: <%= l.id %>,
      full_name: <%- JSON.stringify(l.full_name) %>,
      employee_code: <%- JSON.stringify(l.employee_code || '') %>,
      payment_type: <%- JSON.stringify(l.payment_type || '') %>,
      bsb: <%- JSON.stringify(l.bsb || '') %>,
      acc_number: <%- JSON.stringify(l.acc_number || '') %>,
      buckets: <%- JSON.stringify(l.buckets) %>,
      travel_rate: <%= l.travel_rate || 0 %>,
      travel_count: <%= l.travel_count || 0 %>,
      travel_allowance: <%= l.travel_allowance || 0 %>,
      meal_rate: <%= l.meal_rate || 0 %>,
      meal_count: <%= l.meal_count || 0 %>,
      meal_allowance: <%= l.meal_allowance || 0 %>,
      other_allowance: <%= l.other_allowance || 0 %>,
      total_deductions: <%= l.total_deductions || 0 %>,
      grand_total: <%= l.grand_total || 0 %>,
      expenses: <%- JSON.stringify(l.expenses || []) %>,
      deductions: <%- JSON.stringify(l.deductions || []) %>,
      paid: <%= l.paid ? 1 : 0 %>,
      paid_ref: <%- JSON.stringify(l.paid_ref || '') %>,
      notes: <%- JSON.stringify(l.notes || '') %>,
    };
  <% }) %>

  let originalPT = '';

  function renderBuckets(line) {
    const tbody = document.getElementById('bucketsTbody');
    const pt = document.getElementById('ptSelect').value;
    const sectionBuckets = SECTION_BUCKETS[pt] || BUCKET_KEYS;
    tbody.innerHTML = '';
    for (const k of sectionBuckets) {
      const b = (line.buckets && line.buckets[k]) || { hours: [0,0,0,0,0,0,0], total_hours: 0, rate: 0, total_wages: 0 };
      const tr = document.createElement('tr');
      tr.dataset.bucket = k;
      const cells = ['<td class="px-2 py-1.5 text-xs font-semibold text-gray-700">' + (BUCKET_LABELS[k] || k) + '</td>'];
      for (let i = 0; i < 7; i++) {
        const v = (b.hours && b.hours[i]) || 0;
        cells.push('<td class="px-1 py-1 text-center"><input type="number" step="0.25" min="0" name="buckets[' + k + '][hours][]" value="' + v + '" class="w-14 text-center px-1 py-0.5 border border-gray-300 rounded text-xs tabular-nums hours-cell"></td>');
      }
      cells.push('<td class="px-2 py-1.5 text-right text-xs font-semibold tabular-nums total-cell">' + (b.total_hours || 0).toFixed(2) + '</td>');
      cells.push('<td class="px-2 py-1 text-right"><input type="number" step="0.01" min="0" name="buckets[' + k + '][rate]" value="' + (b.rate || 0) + '" class="w-20 text-right px-1.5 py-0.5 border border-gray-300 rounded text-xs tabular-nums rate-cell"></td>');
      cells.push('<td class="px-2 py-1.5 text-right text-xs tabular-nums wages-cell">$' + (b.total_wages || 0).toFixed(2) + '</td>');
      tr.innerHTML = cells.join('');
      tbody.appendChild(tr);
    }
    // Wire live recompute
    tbody.querySelectorAll('.hours-cell, .rate-cell').forEach(inp => {
      inp.addEventListener('input', () => recomputeBucketRow(inp.closest('tr')));
    });
  }

  function recomputeBucketRow(tr) {
    const hours = Array.from(tr.querySelectorAll('.hours-cell')).map(i => parseFloat(i.value) || 0);
    const total = hours.reduce((a, b) => a + b, 0);
    const rate = parseFloat(tr.querySelector('.rate-cell').value) || 0;
    tr.querySelector('.total-cell').textContent = total.toFixed(2);
    tr.querySelector('.wages-cell').textContent = '$' + (total * rate).toFixed(2);
    if (typeof recomputeGrandTotalPreview === 'function') recomputeGrandTotalPreview();
  }

  let activeLineId = null;

  function openEdit(lineId) {
    const l = LINES[lineId];
    if (!l) return;
    activeLineId = lineId;
    const form = document.getElementById('editForm');
    form.action = '/payroll/runs/' + RUN_ID + '/lines/' + lineId;
    document.getElementById('editTitle').textContent = 'Edit ' + l.full_name;
    document.getElementById('editSubtitle').textContent = l.employee_code ? l.employee_code : 'Not linked to an employee';

    originalPT = l.payment_type;
    document.getElementById('ptSelect').value = l.payment_type;
    form.querySelector('input[name="bsb"]').value = l.bsb;
    form.querySelector('input[name="acc_number"]').value = l.acc_number;

    // Travel + Meal rate × count
    document.getElementById('travelRate').value = (parseFloat(l.travel_rate) || 0).toFixed(2);
    document.getElementById('travelCount').value = parseInt(l.travel_count, 10) || 0;
    document.getElementById('travelAllowance').value = (parseFloat(l.travel_allowance) || 0).toFixed(2);
    document.getElementById('travelOverride').checked = false;
    document.getElementById('travelAllowance').readOnly = true;
    document.getElementById('mealRate').value = (parseFloat(l.meal_rate) || 0).toFixed(2);
    document.getElementById('mealCount').value = parseInt(l.meal_count, 10) || 0;
    document.getElementById('mealAllowance').value = (parseFloat(l.meal_allowance) || 0).toFixed(2);
    document.getElementById('mealOverride').checked = false;
    document.getElementById('mealAllowance').readOnly = true;

    // Other allowance is now driven by the expenses list — keep hidden mirror in sync
    document.getElementById('otherAllowanceHidden').value = (parseFloat(l.other_allowance) || 0).toFixed(2);
    document.getElementById('otherAllowanceDisplay').textContent = (parseFloat(l.other_allowance) || 0).toFixed(2);

    form.querySelector('select[name="paid"]').value = l.paid;
    form.querySelector('input[name="paid_ref"]').value = l.paid_ref;
    form.querySelector('textarea[name="notes"]').value = l.notes;
    form.querySelectorAll('.save-back-cb').forEach(cb => cb.checked = false);

    renderBuckets(l);
    renderExpenses(l.expenses || []);
    renderDeductions(l.deductions || []);
    recomputeGrandTotalPreview();
    document.getElementById('ptWarn').classList.add('hidden');
    document.getElementById('editModal').classList.remove('hidden');
  }
  function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
    activeLineId = null;
  }

  // ---- Travel / meal recompute on input ----
  function wireTravelMeal() {
    function bind(rateId, countId, totalId, overrideId) {
      const r = document.getElementById(rateId);
      const c = document.getElementById(countId);
      const t = document.getElementById(totalId);
      const o = document.getElementById(overrideId);
      function update() {
        if (o.checked) return;
        const val = (parseFloat(r.value) || 0) * (parseInt(c.value, 10) || 0);
        t.value = val.toFixed(2);
        recomputeGrandTotalPreview();
      }
      r.addEventListener('input', update);
      c.addEventListener('input', update);
      o.addEventListener('change', () => {
        t.readOnly = !o.checked;
        if (!o.checked) update();
      });
      t.addEventListener('input', recomputeGrandTotalPreview);
    }
    bind('travelRate', 'travelCount', 'travelAllowance', 'travelOverride');
    bind('mealRate', 'mealCount', 'mealAllowance', 'mealOverride');
  }
  wireTravelMeal();

  // ---- PAYG weekly tax (TFT-claimed) — mirrors lib/payroll.js payAsYouGoWeekly ----
  function paygWeekly(grossWeekly) {
    const g = parseFloat(grossWeekly) || 0;
    if (g <= 0) return 0;
    const annual = g * 52;
    let tax = 0;
    if (annual > 190000) tax += (annual - 190000) * 0.45;
    if (annual > 135000) tax += (Math.min(annual, 190000) - 135000) * 0.37;
    if (annual > 45000)  tax += (Math.min(annual, 135000) -  45000) * 0.30;
    if (annual > 18200)  tax += (Math.min(annual,  45000) -  18200) * 0.16;
    if (annual >  26000) tax += annual * 0.02;
    return Math.round(tax / 52);
  }

  // ---- Grand total live preview ----
  function recomputeGrandTotalPreview() {
    let wages = 0;
    document.querySelectorAll('#bucketsTbody .wages-cell').forEach(c => {
      wages += parseFloat((c.textContent || '').replace(/[^0-9.\-]/g, '')) || 0;
    });
    const travel = parseFloat(document.getElementById('travelAllowance').value) || 0;
    const meal   = parseFloat(document.getElementById('mealAllowance').value) || 0;
    const other  = parseFloat(document.getElementById('otherAllowanceHidden').value) || 0;
    const ded    = parseFloat(document.getElementById('deductionsTotalDisplay').textContent.replace(/[^0-9.\-]/g, '')) || 0;
    const grand = wages + travel + meal + other - ded;
    document.getElementById('grandTotalDisplay').textContent = grand.toFixed(2);
    // Tax + net are TFN-only (Cash/ABN are taxed by the contractor themselves)
    const pt = document.getElementById('ptSelect').value;
    const taxRow = document.getElementById('taxRow');
    const netRow = document.getElementById('netRow');
    if (pt === 'tfn') {
      const tax = paygWeekly(grand);
      document.getElementById('taxDisplay').textContent = tax.toFixed(2);
      document.getElementById('netDisplay').textContent = (grand - tax).toFixed(2);
      taxRow.classList.remove('hidden');
      netRow.classList.remove('hidden');
    } else {
      taxRow.classList.add('hidden');
      netRow.classList.add('hidden');
    }
  }

  // ---- Expenses CRUD ----
  function renderExpenses(list) {
    const wrap = document.getElementById('expenseRows');
    wrap.innerHTML = '';
    let total = 0;
    list.forEach(e => {
      total += parseFloat(e.amount) || 0;
      wrap.appendChild(buildExpenseRow(e));
    });
    document.getElementById('otherAllowanceDisplay').textContent = total.toFixed(2);
    document.getElementById('otherAllowanceHidden').value = total.toFixed(2);
  }

  function buildExpenseRow(e) {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 bg-gray-50 border border-gray-200 rounded p-2';
    row.dataset.expenseId = e.id;
    const isOther = e.label === 'Other';
    row.innerHTML = `
      <select class="exp-label px-2 py-1 border border-gray-300 rounded text-xs">
        <option value="Fuel">Fuel</option>
        <option value="Tolls">Tolls</option>
        <option value="Parking">Parking</option>
        <option value="Other">Other</option>
      </select>
      <input type="text" class="exp-custom px-2 py-1 border border-gray-300 rounded text-xs flex-1 ${isOther ? '' : 'hidden'}" placeholder="Custom label" value="${(e.custom_label || '').replace(/"/g, '&quot;')}">
      <input type="number" step="0.01" min="0" class="exp-amount w-24 text-right px-2 py-1 border border-gray-300 rounded text-xs tabular-nums" value="${parseFloat(e.amount || 0).toFixed(2)}">
      ${e.receipt_path
        ? `<a href="/payroll/runs/${RUN_ID}/lines/${activeLineId}/expenses/${e.id}/receipt" target="_blank" class="text-xs text-brand-600 font-semibold hover:underline shrink-0" title="${(e.receipt_filename || '').replace(/"/g, '&quot;')}">📎 ${(e.receipt_filename || 'receipt').slice(0, 18)}</a>`
        : '<span class="text-[10px] text-gray-400 shrink-0">No receipt</span>'}
      <button type="button" class="exp-delete text-red-500 hover:text-red-700 text-xs font-semibold shrink-0">✕</button>
    `;
    row.querySelector('.exp-label').value = e.label;
    row.querySelector('.exp-label').addEventListener('change', ev => {
      const isOtherNow = ev.target.value === 'Other';
      row.querySelector('.exp-custom').classList.toggle('hidden', !isOtherNow);
      saveExpense(e.id, row);
    });
    row.querySelector('.exp-custom').addEventListener('blur', () => saveExpense(e.id, row));
    row.querySelector('.exp-amount').addEventListener('blur', () => saveExpense(e.id, row));
    row.querySelector('.exp-delete').addEventListener('click', () => deleteExpense(e.id, row));
    return row;
  }

  function saveExpense(expId, row) {
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('label', row.querySelector('.exp-label').value);
    params.set('custom_label', row.querySelector('.exp-custom').value);
    params.set('amount', row.querySelector('.exp-amount').value);
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/expenses/${expId}`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      if (data && data.line) {
        document.getElementById('otherAllowanceDisplay').textContent = (data.line.other_allowance || 0).toFixed(2);
        document.getElementById('otherAllowanceHidden').value = (data.line.other_allowance || 0).toFixed(2);
        if (LINES[activeLineId]) {
          LINES[activeLineId].other_allowance = data.line.other_allowance;
          LINES[activeLineId].grand_total = data.line.grand_total;
        }
        recomputeGrandTotalPreview();
      }
    }).catch(err => console.error('Save expense failed', err));
  }

  function deleteExpense(expId, row) {
    if (!confirm('Remove this expense?')) return;
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/expenses/${expId}/delete`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      row.remove();
      if (data && data.line) {
        document.getElementById('otherAllowanceDisplay').textContent = (data.line.other_allowance || 0).toFixed(2);
        document.getElementById('otherAllowanceHidden').value = (data.line.other_allowance || 0).toFixed(2);
        if (LINES[activeLineId]) LINES[activeLineId].other_allowance = data.line.other_allowance;
        recomputeGrandTotalPreview();
      }
    }).catch(err => alert('Delete failed: ' + err));
  }

  function uploadExpenseFiles(files) {
    if (!activeLineId || !files || !files.length) return;
    const csrf = document.querySelector('input[name="_csrf"]').value;
    Array.from(files).forEach(file => {
      const fd = new FormData();
      fd.append('label', 'Fuel'); // default — user can change after upload
      fd.append('amount', '0');
      fd.append('receipt', file);
      fd.append('_csrf', csrf);
      fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/expenses`, {
        method: 'POST', headers: { 'Accept': 'application/json' }, body: fd
      }).then(r => r.ok ? r.json() : r.json().then(j => Promise.reject(j.error || 'Upload failed')))
        .then(data => {
          if (data && data.expense) {
            document.getElementById('expenseRows').appendChild(buildExpenseRow(data.expense));
            document.getElementById('otherAllowanceDisplay').textContent = (data.line.other_allowance || 0).toFixed(2);
            document.getElementById('otherAllowanceHidden').value = (data.line.other_allowance || 0).toFixed(2);
            recomputeGrandTotalPreview();
          }
        }).catch(err => alert('Upload failed: ' + err));
    });
  }

  function addBlankExpense() {
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('label', 'Fuel');
    params.set('amount', '0');
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/expenses`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      if (data && data.expense) {
        document.getElementById('expenseRows').appendChild(buildExpenseRow(data.expense));
        if (data.line) {
          document.getElementById('otherAllowanceDisplay').textContent = (data.line.other_allowance || 0).toFixed(2);
          document.getElementById('otherAllowanceHidden').value = (data.line.other_allowance || 0).toFixed(2);
          recomputeGrandTotalPreview();
        }
      }
    }).catch(err => alert('Add expense failed: ' + err));
  }

  // Wire drop zone + buttons
  (function () {
    const dz = document.getElementById('expenseDropZone');
    if (!dz) return;
    const fi = document.getElementById('expenseFileInput');
    document.getElementById('expenseFilePick').addEventListener('click', () => fi.click());
    fi.addEventListener('change', () => uploadExpenseFiles(fi.files));
    document.getElementById('expenseAddBlank').addEventListener('click', addBlankExpense);
    ['dragenter', 'dragover'].forEach(ev => dz.addEventListener(ev, e => {
      e.preventDefault(); e.stopPropagation();
      dz.classList.add('border-brand-500', 'bg-brand-50');
    }));
    ['dragleave', 'drop'].forEach(ev => dz.addEventListener(ev, e => {
      e.preventDefault(); e.stopPropagation();
      dz.classList.remove('border-brand-500', 'bg-brand-50');
    }));
    dz.addEventListener('drop', e => uploadExpenseFiles(e.dataTransfer.files));
  })();

  // ---- Deductions CRUD ----
  function renderDeductions(list) {
    const wrap = document.getElementById('deductionRows');
    wrap.innerHTML = '';
    let total = 0;
    list.forEach(d => {
      total += parseFloat(d.amount) || 0;
      wrap.appendChild(buildDeductionRow(d));
    });
    document.getElementById('deductionsTotalDisplay').textContent = total.toFixed(2);
  }

  function buildDeductionRow(d) {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 bg-gray-50 border border-gray-200 rounded p-2';
    row.dataset.dedId = d.id;
    row.innerHTML = `
      <input type="text" class="ded-desc flex-1 px-2 py-1 border border-gray-300 rounded text-xs" placeholder="Description" value="${(d.description || '').replace(/"/g, '&quot;')}">
      <input type="number" step="0.01" min="0" class="ded-amount w-24 text-right px-2 py-1 border border-gray-300 rounded text-xs tabular-nums" value="${parseFloat(d.amount || 0).toFixed(2)}">
      <button type="button" class="ded-delete text-red-500 hover:text-red-700 text-xs font-semibold shrink-0">✕</button>
    `;
    row.querySelector('.ded-desc').addEventListener('blur', () => saveDeduction(d.id, row));
    row.querySelector('.ded-amount').addEventListener('blur', () => saveDeduction(d.id, row));
    row.querySelector('.ded-delete').addEventListener('click', () => deleteDeduction(d.id, row));
    return row;
  }

  function saveDeduction(dedId, row) {
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('description', row.querySelector('.ded-desc').value);
    params.set('amount', row.querySelector('.ded-amount').value);
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/deductions/${dedId}`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      if (data && data.line) {
        document.getElementById('deductionsTotalDisplay').textContent = (data.line.total_deductions || 0).toFixed(2);
        if (LINES[activeLineId]) LINES[activeLineId].total_deductions = data.line.total_deductions;
        recomputeGrandTotalPreview();
      }
    }).catch(err => console.error('Save deduction failed', err));
  }

  function deleteDeduction(dedId, row) {
    if (!confirm('Remove this deduction?')) return;
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/deductions/${dedId}/delete`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      row.remove();
      if (data && data.line) {
        document.getElementById('deductionsTotalDisplay').textContent = (data.line.total_deductions || 0).toFixed(2);
        if (LINES[activeLineId]) LINES[activeLineId].total_deductions = data.line.total_deductions;
        recomputeGrandTotalPreview();
      }
    }).catch(err => alert('Delete failed: ' + err));
  }

  function addBlankDeduction() {
    if (!activeLineId) return;
    const params = new URLSearchParams();
    params.set('description', 'New deduction');
    params.set('amount', '0');
    params.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch(`/payroll/runs/${RUN_ID}/lines/${activeLineId}/deductions`, {
      method: 'POST', headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(r => r.json()).then(data => {
      if (data && data.deduction) {
        document.getElementById('deductionRows').appendChild(buildDeductionRow(data.deduction));
      }
    }).catch(err => alert('Add failed: ' + err));
  }

  document.getElementById('deductionAddBtn').addEventListener('click', addBlankDeduction);

  document.getElementById('ptSelect').addEventListener('change', e => {
    const ptWarn = document.getElementById('ptWarn');
    if (e.target.value !== originalPT) ptWarn.classList.remove('hidden');
    else ptWarn.classList.add('hidden');
    // Re-render bucket rows with new section's bucket set (still using existing hour values)
    const titleEl = document.getElementById('editTitle');
    const lineId = parseInt(document.getElementById('editForm').action.split('/').pop(), 10);
    const l = LINES[lineId];
    if (l) renderBuckets(l);
  });

  function openMatch(lineId) {
    const l = LINES[lineId];
    if (!l) return;
    const form = document.getElementById('matchForm');
    form.action = '/payroll/runs/' + RUN_ID + '/lines/' + lineId + '/match';
    document.getElementById('matchSubtitle').textContent = 'CSV name: ' + l.full_name;
    form.querySelector('select[name="employee_id"]').value = '';
    document.getElementById('matchModal').classList.remove('hidden');
  }
  function closeMatchModal() { document.getElementById('matchModal').classList.add('hidden'); }

  function togglePaid(lineId, checked) {
    const fd = new FormData();
    fd.set('paid', checked ? '1' : '0');
    fd.set('_csrf', document.querySelector('input[name="_csrf"]').value);
    fetch('/payroll/runs/' + RUN_ID + '/lines/' + lineId, {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: fd,
    }).then(r => r.ok ? r.json() : Promise.reject(r.statusText))
      .then(() => { window.location.reload(); })
      .catch(err => alert('Save failed: ' + err));
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeEditModal(); closeMatchModal(); }
  });
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
