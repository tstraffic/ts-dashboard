<% locals.currentPage = 'equipment' %>

<%
  const statusColors = {
    open: 'bg-gray-100 text-gray-700 ring-1 ring-gray-600/20',
    picked_up: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    returned: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    closed: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
  };
%>

<div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
  <a href="/equipment" class="hover:text-gray-700">Equipment</a>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-600">Hire Dockets</span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Hire Dockets</h1>
    <p class="text-gray-500 text-sm mt-0.5">Pick-up &amp; drop-off inspections for hired equipment</p>
  </div>
  <a href="/equipment/hire-dockets/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    New Docket
  </a>
</div>

<div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.total %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Open</p>
    <p class="text-xl font-bold text-gray-700 mt-0.5"><%= stats.open %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-blue-500 uppercase tracking-widest">Picked Up</p>
    <p class="text-xl font-bold text-blue-600 mt-0.5"><%= stats.picked_up %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Returned</p>
    <p class="text-xl font-bold text-amber-600 mt-0.5"><%= stats.returned %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Closed</p>
    <p class="text-xl font-bold text-emerald-600 mt-0.5"><%= stats.closed %></p>
  </div>
</div>

<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/equipment/hire-dockets" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <div class="flex-1 min-w-0 sm:min-w-[220px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Docket #, job #, supplier, site..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="sm:min-w-[140px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
      <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All</option>
        <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
        <option value="picked_up" <%= filters.status === 'picked_up' ? 'selected' : '' %>>Picked Up</option>
        <option value="returned" <%= filters.status === 'returned' ? 'selected' : '' %>>Returned</option>
        <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
      </select>
    </div>
    <button type="submit" class="px-4 py-2 bg-gray-900 hover:bg-gray-800 text-white text-sm font-medium rounded-lg transition">Apply</button>
    <a href="/equipment/hire-dockets" class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition">Clear</a>
  </form>
</div>

<% if (dockets.length > 0) { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 bg-gray-50">
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Docket #</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Job / PO</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Supplier</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Site</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Items</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Status</th>
        <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-wide">Prepared</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% dockets.forEach(d => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium">
            <a href="/equipment/hire-dockets/<%= d.id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= d.docket_number %></a>
          </td>
          <td class="px-4 py-3 text-gray-700"><%= d.linked_job_number || d.job_number || '-' %></td>
          <td class="px-4 py-3 text-gray-700"><%= d.supplier_name || '-' %></td>
          <td class="px-4 py-3 text-gray-600 text-xs"><%= d.site_location || '-' %></td>
          <td class="px-4 py-3 text-gray-600"><%= d.item_count %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusColors[d.status] || 'bg-gray-100 text-gray-600' %>">
              <%= d.status.replace(/_/g, ' ') %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= d.date_prepared || '-' %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<p class="text-xs text-gray-400 mt-2"><%= dockets.length %> docket<%= dockets.length === 1 ? '' : 's' %> found</p>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
  <p class="text-gray-500 text-sm">No hire dockets yet.</p>
  <a href="/equipment/hire-dockets/new" class="inline-block mt-3 text-sm text-brand-600 hover:text-brand-700 font-medium">Create the first one →</a>
</div>
<% } %>
