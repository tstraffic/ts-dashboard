<% locals.currentPage = 'equipment' %>

<div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
  <a href="/equipment" class="hover:text-gray-700">Equipment</a>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <a href="/equipment/hire-dockets" class="hover:text-gray-700">Hire Dockets</a>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-600">New</span>
</div>

<h1 class="text-2xl font-bold text-gray-900 mb-1">New hire docket</h1>
<p class="text-gray-500 text-sm mb-5">Fill the essentials to spin up the docket — equipment items, photos, signatures and reconciliation all live on the next screen.</p>

<form method="POST" action="/equipment/hire-dockets" class="space-y-5">
  <%- include('../../partials/csrf') %>

  <!-- Job Details -->
  <section class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <header class="bg-gradient-to-r from-[#1f476b] to-[#2a5d8e] px-4 py-2.5 flex items-center justify-between">
      <h2 class="text-sm font-bold text-white tracking-wide">Job Details</h2>
      <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full bg-amber-400 text-amber-900">Required</span>
    </header>
    <div class="p-4 sm:p-5 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="hd-label">Job / PO # <span class="text-red-500">*</span></label>
        <input type="text" id="hd-job-number" name="job_number" placeholder="e.g. J-0423 or PO12345" class="hd-input" required>
      </div>
      <div>
        <label class="hd-label">Link to job</label>
        <select id="hd-job-link" name="job_id" class="hd-input">
          <option value="">— None —</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>" data-job-number="<%= j.job_number %>"><%= j.job_number %> — <%= [j.project_name, j.client].filter(Boolean).join(' · ') %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="hd-label">Date prepared</label>
        <input type="date" name="date_prepared" value="<%= today %>" class="hd-input">
      </div>
      <div class="sm:col-span-2 lg:col-span-3">
        <label class="hd-label">Site / Location <span class="text-red-500">*</span></label>
        <input type="text" name="site_location" placeholder="Site address or location" class="hd-input" required>
      </div>
      <div>
        <label class="hd-label">Prepared by <span class="text-red-500">*</span></label>
        <input type="text" name="prepared_by" value="<%= user.full_name %>" class="hd-input" required>
      </div>
      <div>
        <label class="hd-label">Contact #</label>
        <input type="text" name="prepared_by_contact" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Supervisor</label>
        <input type="text" name="supervisor" class="hd-input">
      </div>
      <div class="sm:col-span-2 lg:col-span-3">
        <label class="hd-label">Crew</label>
        <input type="text" name="crew" placeholder="Names on the crew..." class="hd-input">
      </div>
    </div>
  </section>

  <!-- Supplier -->
  <section class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <header class="bg-gradient-to-r from-[#1f476b] to-[#2a5d8e] px-4 py-2.5 flex items-center justify-between">
      <h2 class="text-sm font-bold text-white tracking-wide">Supplier</h2>
      <span class="text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded-full bg-amber-400 text-amber-900">Hire source</span>
    </header>
    <div class="p-4 sm:p-5 space-y-4">
      <% if (typeof suppliers !== 'undefined' && suppliers.length > 0) { %>
        <div class="flex flex-wrap items-end gap-3 bg-brand-50 border border-brand-200 rounded-lg p-3">
          <div class="flex-1 min-w-[200px]">
            <label class="hd-label">Load from saved supplier</label>
            <select id="hd-supplier-load" class="hd-input">
              <option value="">— pick a saved supplier to pre-fill —</option>
              <% suppliers.forEach(function(s) { %>
                <option value="<%= s.id %>"><%= s.name %><%= s.contact_person ? ' · ' + s.contact_person : '' %></option>
              <% }) %>
            </select>
          </div>
          <p class="text-[11px] text-brand-900/70 flex-1 min-w-[160px]">Pre-fills Supplier + Commercial Terms. Commercial terms become editable once the docket is created.</p>
        </div>
      <% } %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="hd-label">Supplier name <span class="text-red-500">*</span></label>
        <input type="text" name="supplier_name" class="hd-input" required>
      </div>
      <div>
        <label class="hd-label">Hire reference #</label>
        <input type="text" name="supplier_hire_ref" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Hire period</label>
        <input type="text" name="hire_period" placeholder="e.g. 22 Apr – 28 Apr" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Contact person</label>
        <input type="text" name="supplier_contact" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Phone</label>
        <input type="text" name="supplier_phone" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Agreed rate</label>
        <input type="text" name="agreed_rate" placeholder="e.g. $120/day" class="hd-input">
      </div>
      <div class="sm:col-span-2">
        <label class="hd-label">Pick-up address</label>
        <input type="text" name="pickup_address" class="hd-input">
      </div>
      <div>
        <label class="hd-label">Hire end date <span class="text-gray-400 font-normal normal-case tracking-normal text-[11px]">(drives off-hire reminder)</span></label>
        <input type="date" name="hire_end_date" class="hd-input">
      </div>
      </div><!-- /grid -->
    </div>
  </section>

  <div class="flex items-center gap-2">
    <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Create &amp; add items</button>
    <a href="/equipment/hire-dockets" class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition">Cancel</a>
  </div>
</form>

<link rel="stylesheet" href="/css/hire-docket.css?v=1">

<script>
  // When the user picks a job from the Link-to-job dropdown, auto-fill the
  // Job / PO # field with that job's number. Don't overwrite a value the
  // user has already typed themselves — we only fill when the field is
  // blank or still matches the previously-linked job's number.
  (function () {
    var link = document.getElementById('hd-job-link');
    var num = document.getElementById('hd-job-number');
    if (!link || !num) return;
    var lastLinked = '';
    link.addEventListener('change', function () {
      var opt = link.options[link.selectedIndex];
      var next = opt && opt.dataset ? (opt.dataset.jobNumber || '') : '';
      var current = num.value.trim();
      if (current === '' || current === lastLinked) {
        num.value = next;
      }
      lastLinked = next;
    });
  })();

  // Pre-fill the supplier section from a saved supplier profile.
  (function () {
    var sel = document.getElementById('hd-supplier-load');
    if (!sel) return;
    var fieldMap = {
      supplier_name: 'name',
      supplier_contact: 'contact_person',
      supplier_phone: 'phone',
      pickup_address: 'pickup_address',
    };
    sel.addEventListener('change', function () {
      var id = sel.value;
      if (!id) return;
      fetch('/equipment/hire-dockets/api/suppliers/' + encodeURIComponent(id), { credentials: 'same-origin' })
        .then(function (r) { if (!r.ok) throw new Error('fetch failed'); return r.json(); })
        .then(function (s) {
          Object.keys(fieldMap).forEach(function (formName) {
            var el = document.querySelector('[name="' + formName + '"]');
            if (el) el.value = s[fieldMap[formName]] || '';
          });
        })
        .catch(function () { alert('Could not load that supplier.'); });
    });
  })();
</script>
