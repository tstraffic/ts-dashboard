<% locals.currentPage = 'equipment' %>

<div class="flex items-center gap-2 text-sm text-gray-500 mb-3">
  <a href="/equipment" class="hover:text-gray-700">Equipment</a>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <a href="/equipment/hire-dockets" class="hover:text-gray-700">Hire Dockets</a>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-600">Deleted</span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Deleted hire dockets</h1>
    <p class="text-sm text-gray-500 mt-0.5">Recently deleted dockets can be restored here.</p>
  </div>
  <a href="/equipment/hire-dockets" class="inline-flex items-center px-4 py-2 bg-white text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition text-sm">
    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Back to Hire Dockets
  </a>
</div>

<% if (dockets.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
    <p class="text-gray-500 text-sm mb-1">No deleted dockets.</p>
    <p class="text-gray-400 text-sm">When dockets are deleted they'll show up here so you can restore them.</p>
  </div>
<% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50">
          <tr class="text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
            <th class="px-4 py-3">Docket</th>
            <th class="px-4 py-3">Supplier</th>
            <th class="px-4 py-3 hidden sm:table-cell">Items</th>
            <th class="px-4 py-3 hidden md:table-cell">Deleted by</th>
            <th class="px-4 py-3">Deleted</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% dockets.forEach(function(d) { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 align-top">
                <div class="font-semibold text-gray-900"><%= d.docket_number %></div>
                <div class="text-xs text-gray-500">
                  <%= d.job_number || d.linked_job_number || '—' %>
                  <%= d.site_location ? ' · ' + d.site_location : '' %>
                </div>
              </td>
              <td class="px-4 py-3 align-top text-sm text-gray-700">
                <%= d.supplier_name || '—' %>
              </td>
              <td class="px-4 py-3 align-top hidden sm:table-cell text-sm text-gray-600">
                <%= d.item_count %>
              </td>
              <td class="px-4 py-3 align-top hidden md:table-cell text-xs text-gray-600">
                <%= d.deleted_by_name || '—' %>
              </td>
              <td class="px-4 py-3 align-top text-xs text-gray-600 whitespace-nowrap">
                <%= d.deleted_at ? new Date(String(d.deleted_at).replace(' ','T') + 'Z').toLocaleString('en-AU', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '' %>
              </td>
              <td class="px-4 py-3 align-top text-right whitespace-nowrap">
                <form method="POST" action="/equipment/hire-dockets/<%= d.id %>/restore" class="inline">
                  <%- include('../../partials/csrf') %>
                  <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-emerald-600 text-white hover:bg-emerald-500 transition">Restore</button>
                </form>
                <form method="POST" action="/equipment/hire-dockets/<%= d.id %>/purge" class="inline ml-1" onsubmit="return confirm('Permanently delete docket <%= d.docket_number %>? This cannot be undone — photos, signatures and attachments will all be removed.');">
                  <%- include('../../partials/csrf') %>
                  <button type="submit" class="inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-lg bg-white text-red-600 border border-red-200 hover:bg-red-50 transition">Purge</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
