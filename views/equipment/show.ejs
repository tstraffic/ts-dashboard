<% locals.currentPage = 'equipment' %>
<%
  const today = new Date().toISOString().split('T')[0];
  const inspOverdue = item.next_inspection_date && item.next_inspection_date <= today;
  const activeAssignments = assignments.filter(a => !a.actual_return_date);
  const pastAssignments = assignments.filter(a => a.actual_return_date);
%>

<!-- Breadcrumb & Header -->
<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <a href="/equipment" class="hover:text-gray-700">Equipment Register</a>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-gray-600"><%= item.asset_number %></span>
  </div>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-bold text-gray-900"><%= item.asset_number %> - <%= item.name %></h1>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
        <% if (item.current_condition === 'new' || item.current_condition === 'good') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
        <% } else if (item.current_condition === 'fair') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
        <% } else if (item.current_condition === 'poor' || item.current_condition === 'damaged') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
        <% } else { %>bg-white text-gray-500<% } %>">
        <%= item.current_condition %>
      </span>
      <%
        const statusColors = { available: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', deployed: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20', maintenance: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20', inspection_due: 'bg-red-50 text-red-700 ring-1 ring-red-600/20', retired: 'bg-gray-100 text-gray-500' };
        const eqStatus = item.status || 'available';
      %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= statusColors[eqStatus] || 'bg-gray-100 text-gray-600' %>">
        <%= eqStatus.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
      </span>
      <% if (!item.active) { %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white text-gray-500">Inactive</span>
      <% } %>
    </div>
    <div class="flex items-center gap-2">
      <a href="/equipment/<%= item.id %>/edit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Edit</a>
      <form method="POST" action="/equipment/<%= item.id %>/delete" onsubmit="return confirm('Are you sure you want to delete <%= item.asset_number %>? This cannot be undone.')">
        <%- include('../partials/csrf') %>
        <button type="submit" class="inline-flex items-center px-4 py-2 bg-red-50 hover:bg-red-100 text-red-600 text-sm font-medium rounded-lg border border-red-200 transition">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        </button>
      </form>
    </div>
  </div>
</div>

<% if (item.ownership_type === 'hired') { %>
<!-- Hire Details Banner -->
<div class="bg-amber-50 border border-amber-200 rounded-xl shadow-sm p-4 mb-6">
  <div class="flex items-center gap-3 mb-3">
    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-amber-100 text-amber-800 ring-1 ring-amber-600/20">Hired Equipment</span>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 text-sm">
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Supplier</p>
      <p class="font-medium text-gray-900"><%= item.hire_supplier || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Reference / PO</p>
      <p class="font-medium text-gray-900"><%= item.hire_reference || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Daily Rate</p>
      <p class="font-medium text-gray-900"><%= item.hire_daily_rate ? '$' + Number(item.hire_daily_rate).toFixed(2) : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hire Start</p>
      <p class="font-medium text-gray-900"><%= item.hire_start_date ? new Date(item.hire_start_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hire End</p>
      <p class="font-medium text-gray-900"><%= item.hire_end_date ? new Date(item.hire_end_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></p>
    </div>
  </div>
</div>
<% } %>

<!-- Info Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Category</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.category.replace('_', ' ') %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Serial Number</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.serial_number || '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Registration</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.registration || '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Location</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.location || '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Storage Location</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.storage_location || '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Purchase Date</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.purchase_date || '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Purchase Cost</p>
    <p class="text-sm text-gray-900 font-medium"><%= item.purchase_cost ? '$' + parseFloat(item.purchase_cost).toFixed(2) : '-' %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Next Inspection</p>
    <p class="text-sm font-medium <%= inspOverdue ? 'text-red-600' : text-gray-900' %>">
      <% if (item.next_inspection_date) { %>
        <% if (inspOverdue) { %>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
            OVERDUE - <%= item.next_inspection_date %>
          </span>
        <% } else { %>
          <%= item.next_inspection_date %>
        <% } %>
      <% } else { %>
        -
      <% } %>
    </p>
    <% if (item.inspection_interval_days) { %>
      <p class="text-xs text-gray-400 mt-1">Every <%= item.inspection_interval_days %> days</p>
    <% } %>
  </div>
</div>

<% if (item.description) { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-8">
  <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Description</p>
  <p class="text-sm text-gray-600 whitespace-pre-line"><%= item.description %></p>
</div>
<% } %>

<% if (item.notes) { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-8">
  <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-2">Notes</p>
  <p class="text-sm text-gray-600 whitespace-pre-line"><%= item.notes %></p>
</div>
<% } %>

<!-- ============================================ -->
<!-- CURRENT ASSIGNMENTS -->
<!-- ============================================ -->
<div class="mb-8">
  <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    Current Assignments
    <% if (activeAssignments.length > 0) { %>
      <span class="text-xs font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20 px-2 py-0.5 rounded-full"><%= activeAssignments.length %> active</span>
    <% } %>
  </h2>

  <% if (activeAssignments.length > 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto mb-4">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job #</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Assigned Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Expected Return</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Qty</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Assigned By</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% activeAssignments.forEach(a => { %>
        <%
          const returnOverdue = a.expected_return_date && a.expected_return_date < today;
        %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><a href="/projects/<%= a.job_id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= a.job_number %></a></td>
          <td class="px-4 py-3 text-gray-600"><%= a.client %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= a.assigned_date %></td>
          <td class="px-4 py-3 text-xs <%= returnOverdue ? 'text-red-600 font-semibold' : 'text-gray-500' %>"><%= a.expected_return_date || '-' %></td>
          <td class="px-4 py-3 text-gray-600"><%= a.quantity %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= a.assigned_by_name %></td>
          <td class="px-4 py-3">
            <form method="POST" action="/equipment/<%= item.id %>/assignments/<%= a.id %>/return" class="inline">
              <%- include('../partials/csrf') %>
              <button type="submit" class="px-3 py-1 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-medium rounded-md transition-colors"
                onclick="return confirm('Mark this equipment as returned?')">Return</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-4">
    <p class="text-gray-400 text-sm text-center">No active assignments. This equipment is available.</p>
  </div>
  <% } %>

  <!-- Assign to Job Form -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Assign to Job</h3>
    <form method="POST" action="/equipment/<%= item.id %>/assign" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <%- include('../partials/csrf') %>
      <!-- Job -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Job <span class="text-red-600">*</span></label>
        <select name="job_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select job...</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>"><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
          <% }) %>
        </select>
      </div>
      <!-- Assigned Date -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Assigned Date <span class="text-red-600">*</span></label>
        <input type="date" name="assigned_date" required value="<%= today %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Expected Return -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Expected Return</label>
        <input type="date" name="expected_return_date"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Quantity -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Quantity</label>
        <input type="number" name="quantity" min="1" value="1"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Notes -->
      <div class="md:col-span-2">
        <label class="block text-xs font-medium text-gray-500 mb-1">Notes</label>
        <input type="text" name="notes" placeholder="Assignment notes..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Assign</button>
      </div>
    </form>
  </div>
</div>

<!-- ============================================ -->
<!-- ASSIGNMENT HISTORY -->
<!-- ============================================ -->
<% if (pastAssignments.length > 0) { %>
<div class="mb-8">
  <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    Assignment History
  </h2>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job #</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Assigned</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Returned</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Qty</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Assigned By</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Notes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% pastAssignments.forEach(a => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium"><a href="/projects/<%= a.job_id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= a.job_number %></a></td>
          <td class="px-4 py-3 text-gray-600"><%= a.client %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= a.assigned_date %></td>
          <td class="px-4 py-3 text-emerald-600 text-xs"><%= a.actual_return_date %></td>
          <td class="px-4 py-3 text-gray-600"><%= a.quantity %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= a.assigned_by_name %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= a.notes || '-' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- ============================================ -->
<!-- MAINTENANCE LOG -->
<!-- ============================================ -->
<div class="mb-8">
  <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    Maintenance Log
  </h2>

  <!-- Add Maintenance Form -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-4">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Add Maintenance Record</h3>
    <form method="POST" action="/equipment/<%= item.id %>/maintenance" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <%- include('../partials/csrf') %>
      <!-- Type -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Type <span class="text-red-600">*</span></label>
        <select name="maintenance_type" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select type...</option>
          <option value="inspection">Inspection</option>
          <option value="repair">Repair</option>
          <option value="service">Service</option>
          <option value="calibration">Calibration</option>
          <option value="replacement">Replacement</option>
        </select>
      </div>
      <!-- Description -->
      <div class="md:col-span-2">
        <label class="block text-xs font-medium text-gray-500 mb-1">Description <span class="text-red-600">*</span></label>
        <input type="text" name="description" required placeholder="What was done..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Date Performed -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Date Performed <span class="text-red-600">*</span></label>
        <input type="date" name="performed_date" required value="<%= today %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Performed By -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Performed By</label>
        <input type="text" name="performed_by" placeholder="Name or company"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Cost -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Cost ($)</label>
        <input type="number" name="cost" step="0.01" min="0" placeholder="0.00"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Next Due Date -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Next Due Date</label>
        <input type="date" name="next_due_date"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <p class="text-xs text-gray-400 mt-1">Will update the equipment's next inspection date</p>
      </div>
      <!-- Result -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Result</label>
        <select name="result" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="pass">Pass</option>
          <option value="fail">Fail</option>
          <option value="conditional">Conditional</option>
        </select>
      </div>
      <!-- Notes -->
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Notes</label>
        <input type="text" name="notes" placeholder="Additional notes..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div class="flex items-end">
        <button type="submit" class="w-full px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium rounded-lg transition-colors">Add Record</button>
      </div>
    </form>
  </div>

  <!-- Maintenance History -->
  <% if (maintenance.length > 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Type</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Description</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Performed By</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Result</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Cost</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Next Due</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% maintenance.forEach(m => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-gray-500 text-xs"><%= m.performed_date %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <% if (m.maintenance_type === 'inspection') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
              <% } else if (m.maintenance_type === 'repair') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
              <% } else if (m.maintenance_type === 'service') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else if (m.maintenance_type === 'calibration') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
              <% } else { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20<% } %>">
              <%= m.maintenance_type %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= m.description %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= m.performed_by || '-' %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <% if (m.result === 'pass') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
              <% } else if (m.result === 'fail') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
              <% } else { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20<% } %>">
              <%= m.result %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= m.cost ? '$' + parseFloat(m.cost).toFixed(2) : '-' %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= m.next_due_date || '-' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-gray-400 text-sm">No maintenance records yet.</p>
  </div>
  <% } %>
</div>

<% if (item.ownership_type === 'hired') { %>
<!-- Hire Checklist -->
<div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
  <div class="p-4 sm:p-5 border-b border-gray-200">
    <div class="flex items-center justify-between">
      <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider">Hire Checklist</h3>
      <button type="button" onclick="document.getElementById('hireCheckForm').classList.toggle('hidden')" class="text-xs font-medium text-brand-600 hover:text-brand-700">+ Add Checklist</button>
    </div>
  </div>

  <!-- Add Checklist Form (hidden by default) -->
  <div id="hireCheckForm" class="hidden p-4 sm:p-5 bg-gray-50 border-b border-gray-200">
    <form method="POST" action="/equipment/<%= item.id %>/hire-checklist">
      <%- include('../partials/csrf') %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Type</label>
          <select name="checklist_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="pickup">Pickup</option>
            <option value="return">Return</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Checked By</label>
          <input type="text" name="checked_by" value="<%= user.full_name %>" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Odometer</label>
          <input type="text" name="odometer_reading" placeholder="e.g. 45230" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Fuel Level</label>
          <select name="fuel_level" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="full">Full</option>
            <option value="3/4">3/4</option>
            <option value="1/2">1/2</option>
            <option value="1/4">1/4</option>
            <option value="empty">Empty</option>
          </select>
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Overall Condition</label>
        <div class="flex gap-3">
          <% ['good','fair','poor','damaged'].forEach(function(c) { %>
            <label class="flex items-center gap-1.5 text-sm text-gray-700 cursor-pointer">
              <input type="radio" name="general_condition" value="<%= c %>" <%= c === 'good' ? 'checked' : '' %> class="text-brand-600 focus:ring-brand-500">
              <span class="capitalize"><%= c %></span>
            </label>
          <% }); %>
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Inspection Items</label>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          <% ['body_exterior', 'lights_indicators', 'safety_features', 'tyres_wheels', 'fluid_levels', 'beacons_signals', 'cleanliness'].forEach(function(field) {
            var label = field.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
          %>
          <div class="flex items-center justify-between bg-white border border-gray-200 rounded-lg px-3 py-2">
            <span class="text-sm text-gray-700"><%= label %></span>
            <div class="flex gap-2">
              <% ['pass','fail','na'].forEach(function(v) { %>
                <label class="flex items-center gap-1 text-xs cursor-pointer">
                  <input type="radio" name="<%= field %>" value="<%= v %>" <%= v === 'pass' ? 'checked' : '' %> class="text-brand-600 focus:ring-brand-500">
                  <span class="<%= v === 'pass' ? 'text-emerald-600' : v === 'fail' ? 'text-red-600' : 'text-gray-400' %> font-medium uppercase"><%= v === 'na' ? 'N/A' : v.charAt(0).toUpperCase() + v.slice(1) %></span>
                </label>
              <% }); %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Defects Noted</label>
          <textarea name="defects_noted" rows="2" placeholder="List any defects or damage..." class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y"></textarea>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Notes</label>
          <textarea name="notes" rows="2" placeholder="Additional notes..." class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y"></textarea>
        </div>
      </div>
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Save Checklist</button>
    </form>
  </div>

  <!-- Checklist History -->
  <% if (locals.hireChecklists && hireChecklists.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Type</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Checked By</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Condition</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Odometer</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Fuel</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase hidden sm:table-cell">Items</th>
            <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-400 uppercase">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% hireChecklists.forEach(function(c) {
            var items = [c.body_exterior, c.lights_indicators, c.safety_features, c.tyres_wheels, c.fluid_levels, c.beacons_signals, c.cleanliness];
            var passCount = items.filter(i => i === 'pass').length;
            var failCount = items.filter(i => i === 'fail').length;
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium capitalize <%= c.checklist_type === 'pickup' ? 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' : 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20' %>"><%= c.checklist_type %></span>
            </td>
            <td class="px-4 py-3 text-gray-700"><%= c.checked_by %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium capitalize <%= c.general_condition === 'good' ? 'bg-emerald-50 text-emerald-700' : c.general_condition === 'fair' ? 'bg-amber-50 text-amber-700' : 'bg-red-50 text-red-700' %>"><%= c.general_condition %></span>
            </td>
            <td class="px-4 py-3 text-gray-600 tabular-nums"><%= c.odometer_reading || '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= c.fuel_level || '-' %></td>
            <td class="px-4 py-3 hidden sm:table-cell">
              <span class="text-emerald-600 font-medium"><%= passCount %>P</span>
              <% if (failCount > 0) { %> <span class="text-red-600 font-medium"><%= failCount %>F</span><% } %>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs tabular-nums"><%= c.checked_date ? new Date(c.checked_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="p-6 text-center text-gray-400 text-sm">No hire checklists yet</div>
  <% } %>
</div>
<% } %>

<!-- Activity History -->
<div class="mt-6">
  <div class="bg-white border border-gray-200 rounded-2xl p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider">Activity History</h3>
    </div>
    <%- include('../partials/activity-timeline', { activities: typeof activities !== 'undefined' ? activities : [], entityLink: '' }) %>
  </div>
</div>
