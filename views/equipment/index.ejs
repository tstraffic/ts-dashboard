<% locals.currentPage = 'equipment' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Equipment Register</h1>
    <p class="text-gray-500 text-sm mt-1">Track and manage all traffic management equipment and assets</p>
  </div>
  <a href="/equipment/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Add Equipment</a>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <!-- Total Items -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Items</p>
        <p class="text-2xl font-bold text-gray-900 mt-1"><%= stats.total %></p>
      </div>
      <div class="w-10 h-10 bg-blue-50 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
    </div>
  </div>
  <!-- Currently Deployed -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Currently Deployed</p>
        <p class="text-2xl font-bold text-brand-600 mt-1"><%= stats.totalDeployed %></p>
      </div>
      <div class="w-10 h-10 bg-amber-50 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
    </div>
  </div>
  <!-- Inspections Due -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Inspections Due</p>
        <p class="text-2xl font-bold <%= stats.inspectionsDue > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= stats.inspectionsDue %></p>
      </div>
      <div class="w-10 h-10 <%= stats.inspectionsDue > 0 ? 'bg-red-50' : 'bg-emerald-50' %> rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 <%= stats.inspectionsDue > 0 ? 'text-red-600' : 'text-emerald-600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" action="/equipment" class="flex flex-wrap items-end gap-4">
    <!-- Search -->
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Asset number, name, serial..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <!-- Category -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Category</label>
      <select name="category" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Categories</option>
        <% settingsOptions.equipment_category.forEach(opt => { %>
          <option value="<%= opt.key %>" <%= filters.category === opt.key ? 'selected' : '' %>><%= opt.label %></option>
        <% }) %>
      </select>
    </div>
    <!-- Condition -->
    <div class="min-w-[140px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Condition</label>
      <select name="condition" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Conditions</option>
        <option value="new" <%= filters.condition === 'new' ? 'selected' : '' %>>New</option>
        <option value="good" <%= filters.condition === 'good' ? 'selected' : '' %>>Good</option>
        <option value="fair" <%= filters.condition === 'fair' ? 'selected' : '' %>>Fair</option>
        <option value="poor" <%= filters.condition === 'poor' ? 'selected' : '' %>>Poor</option>
        <option value="damaged" <%= filters.condition === 'damaged' ? 'selected' : '' %>>Damaged</option>
        <option value="decommissioned" <%= filters.condition === 'decommissioned' ? 'selected' : '' %>>Decommissioned</option>
      </select>
    </div>
    <!-- Show Inactive -->
    <div class="flex items-center gap-2 pb-1">
      <input type="checkbox" id="show_inactive" name="active" value="0" <%= filters.active === '0' ? 'checked' : '' %>
        class="w-4 h-4 bg-white border-gray-300 rounded text-brand-500 focus:ring-brand-500 focus:ring-offset-white">
      <label for="show_inactive" class="text-sm text-gray-500">Show Inactive</label>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/equipment" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/equipment.csv?category=<%= filters.category || '' %>&condition=<%= filters.condition || '' %>&search=<%= encodeURIComponent(filters.search || '') %>&active=<%= filters.active || '' %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export CSV
      </a>
    </div>
  </form>
</div>

<!-- Equipment Table -->
<% if (equipment.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
    <p class="text-gray-400 text-sm">No equipment found matching your filters.</p>
    <a href="/equipment/new" class="inline-block mt-3 text-brand-600 hover:text-brand-700 text-sm font-medium">Add your first piece of equipment</a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Asset #</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Registration</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Category</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Condition</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Storage Location</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Deployed To</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Next Inspection</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% equipment.forEach(eq => { %>
      <%
        const today = new Date().toISOString().split('T')[0];
        const inspOverdue = eq.next_inspection_date && eq.next_inspection_date <= today;
      %>
      <tr class="hover:bg-gray-50 cursor-pointer <%= !eq.active ? 'opacity-50' : '' %>" onclick="window.location='/equipment/<%= eq.id %>'">
        <td class="px-4 py-3 font-medium">
          <a href="/equipment/<%= eq.id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= eq.asset_number %></a>
        </td>
        <td class="px-4 py-3 text-gray-600"><%= eq.name %></td>
        <td class="px-4 py-3 text-gray-600"><%= eq.registration || '-' %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white text-gray-600">
            <%= eq.category.replace('_', ' ') %>
          </span>
        </td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (eq.current_condition === 'new' || eq.current_condition === 'good') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
            <% } else if (eq.current_condition === 'fair') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (eq.current_condition === 'poor' || eq.current_condition === 'damaged') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
            <% } else { %>bg-white text-gray-500<% } %>">
            <%= eq.current_condition %>
          </span>
        </td>
        <td class="px-4 py-3 text-gray-500"><%= eq.storage_location || '-' %></td>
        <td class="px-4 py-3">
          <% if (eq.currently_deployed > 0 && eq.deployed_to_job) { %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 ring-1 ring-blue-600/20">
              <%= eq.deployed_to_job %>
            </span>
          <% } else { %>
            <span class="text-emerald-600 text-xs font-medium">Available</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-xs <%= inspOverdue ? 'text-red-600 font-semibold' : 'text-gray-500' %>">
          <% if (eq.next_inspection_date) { %>
            <% if (inspOverdue) { %>
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <%= eq.next_inspection_date %>
              </span>
            <% } else { %>
              <%= eq.next_inspection_date %>
            <% } %>
          <% } else { %>
            -
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-gray-400"><%= equipment.length %> item<%= equipment.length !== 1 ? 's' : '' %> found</div>
<% } %>
