<% locals.currentPage = 'ute-payments' %>
<%
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-center justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Ute Payments</h1>
      <p class="text-sm text-gray-500 mt-1">
        Per-shift ute payments. Imports a Traffio CSV, groups by plate × driver, multiplies by an editable rate per shift.
      </p>
    </div>
    <a href="/finance/ute-payments/new" class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      New ute sheet
    </a>
  </div>

  <%- include('../partials/csrf') %>

  <!-- List -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (!sheets || sheets.length === 0) { %>
      <div class="p-10 text-center">
        <svg class="w-12 h-12 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="mt-3 text-sm text-gray-500 font-semibold">No ute sheets yet</p>
        <p class="text-xs text-gray-400 mt-1">Import a Traffio CSV to get started.</p>
        <a href="/finance/ute-payments/new" class="inline-block mt-3 text-sm font-semibold text-brand-600">Import your first sheet →</a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Period</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden sm:table-cell">Plates</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden sm:table-cell">Lines</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Shifts</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Fee</th>
              <th class="px-4 py-3 text-center text-[10px] font-bold text-amber-700 uppercase tracking-widest">Ready</th>
              <th class="px-4 py-3 text-center text-[10px] font-bold text-emerald-700 uppercase tracking-widest">Paid</th>
              <th class="px-4 py-3 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% sheets.forEach(s => { %>
              <tr class="hover:bg-gray-50 transition <%= s.paid ? 'bg-emerald-50/40' : (s.ready_to_pay ? 'bg-amber-50/40' : '') %>">
                <td class="px-4 py-3">
                  <a href="/finance/ute-payments/<%= s.id %>" class="block">
                    <p class="font-semibold text-gray-900 text-sm"><%= s.label || periodLabel(s.period_start, s.period_end) %></p>
                    <p class="text-[11px] text-gray-400 tabular-nums"><%= fmtDate(s.period_start) %> → <%= fmtDate(s.period_end) %></p>
                  </a>
                </td>
                <td class="px-4 py-3 text-sm text-gray-700 text-right tabular-nums hidden sm:table-cell"><%= s.plate_count %></td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right tabular-nums hidden sm:table-cell"><%= s.line_count %></td>
                <td class="px-4 py-3 text-sm text-gray-600 text-right tabular-nums"><%= s.total_shifts %></td>
                <td class="px-4 py-3 text-sm font-bold text-gray-900 text-right tabular-nums">$<%= fmtMoney(s.total_fee) %></td>
                <td class="px-4 py-3 text-center">
                  <input type="checkbox" <%= s.ready_to_pay ? 'checked' : '' %> data-toggle="ready_to_pay" data-sheet-id="<%= s.id %>" class="sheet-toggle w-4 h-4 rounded border-gray-300 text-amber-600 focus:ring-amber-500" aria-label="Ready to pay">
                </td>
                <td class="px-4 py-3 text-center">
                  <input type="checkbox" <%= s.paid ? 'checked' : '' %> data-toggle="paid" data-sheet-id="<%= s.id %>" class="sheet-toggle w-4 h-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500" aria-label="Paid">
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <a href="/finance/ute-payments/<%= s.id %>" class="inline-flex items-center px-2.5 py-1.5 text-xs font-semibold text-brand-600 hover:bg-brand-50 rounded-lg">Open →</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
          <tfoot class="bg-gray-50 border-t-2 border-gray-300">
            <tr>
              <td colspan="4" class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-widest">Totals</td>
              <td class="px-4 py-3 text-right text-base font-bold tabular-nums text-gray-900">$<%= fmtMoney(totals.fee) %></td>
              <td class="px-4 py-3 text-center text-xs font-bold tabular-nums text-amber-700" title="Sum of fees for sheets marked Ready to Pay but not yet Paid">$<%= fmtMoney(totals.ready) %></td>
              <td class="px-4 py-3 text-center text-xs font-bold tabular-nums text-emerald-700" title="Sum of fees for sheets marked Paid">$<%= fmtMoney(totals.paid) %></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('input.sheet-toggle').forEach(cb => {
    cb.addEventListener('change', async (e) => {
      const t = e.currentTarget;
      const sheetId = t.dataset.sheetId;
      const which = t.dataset.toggle === 'paid' ? 'paid' : 'ready';
      const checked = t.checked;
      const fd = new URLSearchParams();
      fd.set('value', checked ? '1' : '0');
      fd.set('_csrf', document.querySelector('input[name="_csrf"]')?.value || '');
      try {
        const r = await fetch('/finance/ute-payments/' + sheetId + '/' + which, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: fd.toString(),
          credentials: 'same-origin',
        });
        if (!r.ok) throw new Error('Save failed');
        window.location.reload();
      } catch (err) {
        t.checked = !checked;
        alert('Save failed — refresh and try again.');
      }
    });
  });
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
