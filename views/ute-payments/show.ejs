<% locals.currentPage = 'ute-payments' %>
<%
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <a href="/finance/ute-payments" class="text-sm text-brand-600 hover:underline">← Ute Payments</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1"><%= sheet.label || periodLabel(sheet.period_start, sheet.period_end) %></h1>
      <p class="text-sm text-gray-500 mt-0.5 tabular-nums"><%= fmtDate(sheet.period_start) %> → <%= fmtDate(sheet.period_end) %></p>
      <% if (sheet.notes) { %><p class="text-xs text-gray-500 mt-1"><%= sheet.notes %></p><% } %>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" onclick="document.getElementById('editSheetModal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-gray-300 hover:bg-brand-50 hover:border-brand-300 hover:text-brand-700 text-gray-700 text-xs font-semibold rounded-lg transition">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </button>
      <a href="/finance/ute-payments/<%= sheet.id %>/export.xlsx" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold rounded-lg transition" title="Download as Excel">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export xlsx
      </a>
      <form method="POST" action="/finance/ute-payments/<%= sheet.id %>/delete" onsubmit="return confirm('Delete this ute sheet? This cannot be undone.')">
        <%- include('../partials/csrf') %>
        <button type="submit" class="px-3 py-2 text-xs font-semibold text-rose-700 bg-rose-50 hover:bg-rose-100 ring-1 ring-rose-200 rounded-lg">Delete</button>
      </form>
    </div>
  </div>

  <!-- Edit modal -->
  <div id="editSheetModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm overflow-y-auto" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="min-h-full flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
        <form method="POST" action="/finance/ute-payments/<%= sheet.id %>">
          <%- include('../partials/csrf') %>
          <div class="p-5 border-b border-gray-200">
            <h2 class="text-lg font-bold text-gray-900">Edit ute sheet</h2>
          </div>
          <div class="p-5 space-y-4">
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Label</label>
              <input type="text" name="label" value="<%= sheet.label || '' %>" maxlength="200" placeholder="e.g. April 2026" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period start <span class="text-rose-500">*</span></label>
                <input type="date" name="period_start" value="<%= sheet.period_start %>" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period end <span class="text-rose-500">*</span></label>
                <input type="date" name="period_end" value="<%= sheet.period_end %>" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Default rate per shift ($)</label>
              <input type="number" step="0.01" min="0" name="default_rate_per_shift" value="<%= (parseFloat(sheet.default_rate_per_shift) || 0).toFixed(2) %>" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
            </div>
            <label class="flex items-start gap-2 text-xs text-gray-700 cursor-pointer">
              <input type="checkbox" name="apply_default_to_all" value="1" class="mt-0.5 rounded border-gray-300 text-brand-600 focus:ring-brand-500">
              <span>Apply this rate to <strong>every line</strong> on save (overrides any per-line edits).</span>
            </label>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Notes <span class="text-gray-400 font-normal lowercase tracking-normal">(optional)</span></label>
              <textarea name="notes" rows="2" maxlength="1000" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm"><%= sheet.notes || '' %></textarea>
            </div>
          </div>
          <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
            <button type="button" onclick="document.getElementById('editSheetModal').classList.add('hidden')" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
            <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Top totals strip -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Plates</p>
      <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= grand.plate_count %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Lines</p>
      <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= grand.line_count %></p>
    </div>
    <div class="bg-white border border-emerald-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Shifts</p>
      <p class="text-2xl font-bold text-emerald-700 mt-1 tabular-nums"><%= grand.shifts %></p>
      <p class="text-[10px] text-gray-400 mt-0.5">@ $<%= fmtMoney(sheet.default_rate_per_shift) %>/shift default</p>
    </div>
    <div class="bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-xl p-4">
      <p class="text-[10px] font-bold text-white/80 uppercase tracking-widest">Sheet Fee</p>
      <p class="text-2xl font-bold mt-1 tabular-nums">$<%= fmtMoney(grand.fee) %></p>
    </div>
  </div>

  <%- include('../partials/csrf') %>

  <!-- Lines -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (lines.length === 0) { %>
      <div class="p-10 text-center"><p class="text-sm text-gray-500">No ute shifts in this sheet.</p></div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Plate</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Driver</th>
              <th class="px-3 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Shifts</th>
              <th class="px-3 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Rate / shift</th>
              <th class="px-3 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% lines.forEach(l => { %>
              <tr data-line-id="<%= l.id %>">
                <td class="px-3 py-2"><span class="font-mono font-semibold text-sm text-gray-900"><%= l.plate %></span></td>
                <td class="px-3 py-2 text-sm text-gray-700"><%= l.driver_name %></td>
                <td class="px-3 py-2 text-right">
                  <input type="number" step="1" min="0" value="<%= l.shift_count %>" data-line-id="<%= l.id %>" data-field="shift_count" class="line-input w-16 px-2 py-1 text-sm text-right tabular-nums border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-500">
                </td>
                <td class="px-3 py-2 text-right">
                  <div class="inline-flex items-center gap-1">
                    <span class="text-xs text-gray-400">$</span>
                    <input type="number" step="0.01" min="0" value="<%= (parseFloat(l.rate_per_shift) || 0).toFixed(2) %>" data-line-id="<%= l.id %>" data-field="rate_per_shift" class="line-input w-20 px-2 py-1 text-sm text-right tabular-nums border border-gray-300 rounded-md focus:ring-2 focus:ring-brand-500">
                  </div>
                </td>
                <td class="px-3 py-2 text-right text-sm font-semibold tabular-nums text-emerald-700" data-total>$<%= fmtMoney(l.total_fee) %></td>
              </tr>
            <% }) %>
          </tbody>
          <tfoot class="bg-gray-50 border-t-2 border-gray-300">
            <tr>
              <td colspan="2" class="px-3 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-widest">Sheet total</td>
              <td class="px-3 py-3 text-right text-sm font-bold tabular-nums text-gray-900" id="grandShifts"><%= grand.shifts %></td>
              <td></td>
              <td class="px-3 py-3 text-right text-sm font-bold tabular-nums text-emerald-700" id="grandFee">$<%= fmtMoney(grand.fee) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
  // Inline edit each line: change shift_count or rate_per_shift, blur fires
  // a save. Server returns the recomputed total_fee — write it into the row
  // and update the sheet grand totals on the fly.
  const SHEET_ID = <%= sheet.id %>;
  function fmtMoney(n) { return (parseFloat(n) || 0).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
  function recalcGrand() {
    let totalShifts = 0, totalFee = 0;
    document.querySelectorAll('tr[data-line-id]').forEach(row => {
      const sc = parseInt(row.querySelector('input[data-field="shift_count"]')?.value, 10) || 0;
      const rp = parseFloat(row.querySelector('input[data-field="rate_per_shift"]')?.value) || 0;
      totalShifts += sc;
      totalFee += sc * rp;
    });
    document.getElementById('grandShifts').textContent = totalShifts;
    document.getElementById('grandFee').textContent = '$' + fmtMoney(totalFee);
  }
  document.querySelectorAll('input.line-input').forEach(input => {
    let initialValue = input.value;
    input.addEventListener('focus', () => { initialValue = input.value; });
    input.addEventListener('blur', async () => {
      if (input.value === initialValue) return;
      const lineId = input.dataset.lineId;
      const field = input.dataset.field;
      const fd = new URLSearchParams();
      fd.set('_csrf', document.querySelector('input[name="_csrf"]').value);
      fd.set(field, input.value);
      try {
        const r = await fetch('/finance/ute-payments/' + SHEET_ID + '/lines/' + lineId, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: fd.toString(),
          credentials: 'same-origin',
        });
        if (!r.ok) throw new Error('Save failed');
        const data = await r.json();
        // Update the row total cell
        const row = input.closest('tr');
        const totalCell = row.querySelector('[data-total]');
        if (totalCell && data.line) totalCell.textContent = '$' + fmtMoney(data.line.total_fee);
        initialValue = input.value;
        recalcGrand();
      } catch (err) {
        input.value = initialValue;
        alert('Save failed — refresh and try again.');
      }
    });
  });
</script>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
