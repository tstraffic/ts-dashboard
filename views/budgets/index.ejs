<% locals.currentPage = 'budgets' %>

<%
  function fmtCurrency(val) {
    const n = Number(val) || 0;
    return '$' + n.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Budget & Cost Tracking</h1>
    <p class="text-slate-400 text-sm mt-1">Financial overview across all active jobs</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <!-- Total Contract Value -->
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
    <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Total Contract Value</p>
    <p class="text-2xl font-bold text-white mt-2"><%= fmtCurrency(totals.contract) %></p>
  </div>
  <!-- Total Budget -->
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
    <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Total Budget</p>
    <p class="text-2xl font-bold text-white mt-2"><%= fmtCurrency(totals.budget) %></p>
  </div>
  <!-- Total Spent -->
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
    <p class="text-xs font-medium text-slate-400 uppercase tracking-wide">Total Spent</p>
    <p class="text-2xl font-bold mt-2 <%= totals.spent > totals.budget ? 'text-red-400' : 'text-emerald-400' %>"><%= fmtCurrency(totals.spent) %></p>
    <% if (totals.budget > 0) { %>
      <p class="text-xs mt-1 <%= totals.spent > totals.budget ? 'text-red-500' : 'text-slate-500' %>">
        <%= ((totals.spent / totals.budget) * 100).toFixed(1) %>% of budget consumed
      </p>
    <% } %>
  </div>
</div>

<!-- Jobs Budget Table -->
<% if (budgets.length === 0) { %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-8 text-center">
    <svg class="w-12 h-12 mx-auto text-slate-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-slate-500 text-sm">No jobs with budgets found.</p>
  </div>
<% } else { %>
<div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700">
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Job #</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Client</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Status</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wide">Contract Value</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wide">Budget</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wide">Spent</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wide">Remaining</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase tracking-wide">Margin %</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700">
      <% budgets.forEach(b => {
        const contractVal = b.contract_value || 0;
        const budgetVal = b.total_budget || 0;
        const spentVal = b.total_spent || 0;
        const remaining = budgetVal - spentVal;
        const marginPct = contractVal > 0 ? ((contractVal - spentVal) / contractVal * 100) : 0;
      %>
      <tr class="hover:bg-slate-700/50 cursor-pointer" onclick="window.location='/budgets/job/<%= b.job_id %>'">
        <td class="px-4 py-3 font-medium">
          <a href="/budgets/job/<%= b.job_id %>" class="text-blue-400 hover:text-blue-300 hover:underline"><%= b.job_number %></a>
        </td>
        <td class="px-4 py-3 text-slate-300"><%= b.client %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (b.status === 'active') { %>bg-blue-900/60 text-blue-300
            <% } else if (b.status === 'on_hold') { %>bg-orange-900/60 text-brand-300
            <% } else if (b.status === 'completed') { %>bg-emerald-900/60 text-emerald-300
            <% } else if (b.status === 'won') { %>bg-teal-900/60 text-teal-300
            <% } else { %>bg-slate-700 text-slate-300<% } %>">
            <%= b.status ? b.status.replace('_', ' ') : '-' %>
          </span>
        </td>
        <td class="px-4 py-3 text-right text-slate-300 font-mono text-xs"><%= fmtCurrency(contractVal) %></td>
        <td class="px-4 py-3 text-right text-slate-300 font-mono text-xs"><%= fmtCurrency(budgetVal) %></td>
        <td class="px-4 py-3 text-right font-mono text-xs <%= spentVal > budgetVal ? 'text-red-400' : 'text-slate-300' %>"><%= fmtCurrency(spentVal) %></td>
        <td class="px-4 py-3 text-right font-mono text-xs <%= remaining < 0 ? 'text-red-400' : 'text-emerald-400' %>"><%= fmtCurrency(remaining) %></td>
        <td class="px-4 py-3 text-right">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (marginPct > 20) { %>bg-emerald-900/60 text-emerald-300
            <% } else if (marginPct >= 0) { %>bg-orange-900/60 text-brand-300
            <% } else { %>bg-red-900/60 text-red-300
            <% } %>">
            <%= marginPct.toFixed(1) %>%
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-slate-500"><%= budgets.length %> job<%= budgets.length !== 1 ? 's' : '' %> shown</div>
<% } %>
