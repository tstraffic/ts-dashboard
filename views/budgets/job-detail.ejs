<% locals.currentPage = 'budgets' %>

<%
  function fmtCurrency(val) {
    const n = Number(val) || 0;
    return '$' + n.toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  const remaining = totalBudget - totalSpent;
  const categories = [
    { key: 'labour', label: 'Labour' },
    { key: 'materials', label: 'Materials' },
    { key: 'subcontractors', label: 'Subcontractors' },
    { key: 'equipment', label: 'Equipment' },
    { key: 'other', label: 'Other' },
    { key: 'contingency', label: 'Contingency' }
  ];
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-3 flex-wrap">
    <a href="/budgets" class="text-gray-500 hover:text-gray-900 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-2xl font-bold text-gray-900"><%= job.job_number %></h1>
    <span class="text-lg text-gray-500">&mdash;</span>
    <span class="text-lg text-gray-600"><%= job.client %></span>
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
      <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
      <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
      <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
      <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
      <% } else { %>bg-white text-gray-600<% } %>">
      <%= job.status ? job.status.replace('_', ' ') : '-' %>
    </span>
  </div>
  <a href="/budgets" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Back to Budgets</a>
</div>

<!-- Summary Row -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Contract Value</p>
    <p class="text-xl font-bold text-gray-900 mt-2"><%= fmtCurrency(budget.contract_value) %></p>
    <% if (budget.variations_approved > 0) { %>
      <p class="text-xs text-brand-600 mt-1">+<%= fmtCurrency(budget.variations_approved) %> variations</p>
    <% } %>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Budget</p>
    <p class="text-xl font-bold text-gray-900 mt-2"><%= fmtCurrency(totalBudget) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Spent</p>
    <p class="text-xl font-bold mt-2 <%= totalSpent > totalBudget ? 'text-red-600' : 'text-brand-600' %>"><%= fmtCurrency(totalSpent) %></p>
    <% if (totalBudget > 0) { %>
      <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2">
        <div class="h-1.5 rounded-full <%= totalSpent > totalBudget ? 'bg-red-500' : 'bg-brand-600' %>" style="width: <%= Math.min((totalSpent / totalBudget) * 100, 100) %>%"></div>
      </div>
      <p class="text-xs text-gray-400 mt-1"><%= ((totalSpent / totalBudget) * 100).toFixed(1) %>% used</p>
    <% } %>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Remaining</p>
    <p class="text-xl font-bold mt-2 <%= remaining < 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= fmtCurrency(remaining) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center">
    <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Margin</p>
    <p class="text-xl font-bold mt-2
      <% if (parseFloat(margin) > 20) { %>text-emerald-600
      <% } else if (parseFloat(margin) >= 0) { %>text-brand-600
      <% } else { %>text-red-600
      <% } %>"><%= margin %>%</p>
  </div>
</div>

<!-- Budget Breakdown -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6" id="budget-breakdown">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Budget Breakdown</h2>
    <button type="button" onclick="document.getElementById('budget-breakdown').classList.toggle('editing'); this.textContent = this.textContent.trim() === 'Edit Budget' ? 'Cancel' : 'Edit Budget'"
      class="px-3 py-1.5 text-xs font-medium text-brand-600 hover:text-brand-700 border border-brand-200 hover:border-brand-300 rounded-lg transition-colors">Edit Budget</button>
  </div>

  <!-- Read-only view (default) -->
  <div class="budget-readonly">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Contract Value</p>
        <p class="text-sm font-semibold text-gray-900"><%= fmtCurrency(budget.contract_value || 0) %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Variations Approved</p>
        <p class="text-sm font-semibold text-gray-900"><%= fmtCurrency(budget.variations_approved || 0) %></p>
      </div>
    </div>
    <div class="overflow-x-auto mb-4">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Category</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Budget</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Spent</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Remaining</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">% Used</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% categories.forEach(cat => {
            const budgetAmt = budget['budget_' + cat.key] || 0;
            const spentAmt = spentByCategory[cat.key] || 0;
            const remainAmt = budgetAmt - spentAmt;
            const pctUsed = budgetAmt > 0 ? (spentAmt / budgetAmt * 100) : 0;
          %>
          <tr>
            <td class="px-4 py-3 text-gray-600 font-medium capitalize">
              <%= cat.label %>
              <% if (budgetAmt > 0 && spentAmt > budgetAmt) { %>
                <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-600/20">OVER</span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-right font-mono text-xs text-gray-900"><%= fmtCurrency(budgetAmt) %></td>
            <td class="px-4 py-3 text-right font-mono text-xs <%= spentAmt > budgetAmt && budgetAmt > 0 ? 'text-red-600' : 'text-gray-600' %>"><%= fmtCurrency(spentAmt) %></td>
            <td class="px-4 py-3 text-right font-mono text-xs <%= remainAmt < 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= fmtCurrency(remainAmt) %></td>
            <td class="px-4 py-3 text-right">
              <% if (budgetAmt > 0) { %>
                <div class="flex items-center justify-end gap-2">
                  <div class="w-16 bg-gray-200 rounded-full h-1.5">
                    <div class="h-1.5 rounded-full <%= pctUsed > 100 ? 'bg-red-500' : pctUsed > 80 ? 'bg-brand-600' : 'bg-emerald-500' %>" style="width: <%= Math.min(pctUsed, 100) %>%"></div>
                  </div>
                  <span class="text-xs text-gray-500 w-12 text-right"><%= pctUsed.toFixed(0) %>%</span>
                </div>
              <% } else { %>
                <span class="text-xs text-gray-400">-</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <tr class="border-t-2 border-gray-300 bg-white/30">
            <td class="px-4 py-3 text-gray-900 font-semibold">Total</td>
            <td class="px-4 py-3 text-right font-mono text-sm text-gray-900 font-semibold"><%= fmtCurrency(totalBudget) %></td>
            <td class="px-4 py-3 text-right font-mono text-sm text-gray-900 font-semibold"><%= fmtCurrency(totalSpent) %></td>
            <td class="px-4 py-3 text-right font-mono text-sm font-semibold <%= remaining < 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= fmtCurrency(remaining) %></td>
            <td class="px-4 py-3 text-right">
              <% if (totalBudget > 0) { %>
                <span class="text-xs font-semibold text-gray-600"><%= ((totalSpent / totalBudget) * 100).toFixed(0) %>%</span>
              <% } %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
    <% if (budget.notes) { %>
    <div class="mt-3 p-3 bg-gray-50 rounded-lg">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Notes</p>
      <p class="text-sm text-gray-600"><%= budget.notes %></p>
    </div>
    <% } %>
  </div>

  <!-- Edit form (hidden by default, shown when .editing class added) -->
  <form method="POST" action="/budgets/job/<%= job.id %>" class="budget-edit-form">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Contract Value ($)</label>
        <input type="number" step="0.01" name="contract_value" value="<%= budget.contract_value || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Variations Approved ($)</label>
        <input type="number" step="0.01" name="variations_approved" value="<%= budget.variations_approved || 0 %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
    <div class="overflow-x-auto mb-4">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Category</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Budget ($)</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Spent</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Remaining</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% categories.forEach(cat => {
            const budgetAmt = budget['budget_' + cat.key] || 0;
            const spentAmt = spentByCategory[cat.key] || 0;
            const remainAmt = budgetAmt - spentAmt;
          %>
          <tr>
            <td class="px-4 py-3 text-gray-600 font-medium capitalize"><%= cat.label %></td>
            <td class="px-4 py-3 text-right">
              <input type="number" step="0.01" name="budget_<%= cat.key %>" value="<%= budgetAmt %>"
                class="w-32 px-2 py-1 bg-white border border-gray-300 rounded text-gray-900 text-sm text-right focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            </td>
            <td class="px-4 py-3 text-right font-mono text-xs text-gray-600"><%= fmtCurrency(spentAmt) %></td>
            <td class="px-4 py-3 text-right font-mono text-xs <%= remainAmt < 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= fmtCurrency(remainAmt) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mb-4">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Notes</label>
      <textarea name="notes" rows="3" placeholder="Budget notes, assumptions, exclusions..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= budget.notes || '' %></textarea>
    </div>
    <div class="flex justify-end">
      <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Save Budget</button>
    </div>
  </form>
</div>
<style>
  #budget-breakdown .budget-edit-form { display: none; }
  #budget-breakdown.editing .budget-readonly { display: none; }
  #budget-breakdown.editing .budget-edit-form { display: block; }
</style>

<!-- P&L Summary -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Profit & Loss</h2>
  <%
    const contractIncVars = (budget.contract_value || 0) + (budget.variations_approved || 0);
    const grossProfit = contractIncVars - totalSpent;
    const grossMarginPct = contractIncVars > 0 ? (grossProfit / contractIncVars * 100) : 0;
  %>
  <div class="space-y-3">
    <div class="flex justify-between items-center py-2 border-b border-gray-200">
      <span class="text-gray-500 text-sm">Contract Value (incl. variations)</span>
      <span class="text-gray-900 font-mono text-sm font-medium"><%= fmtCurrency(contractIncVars) %></span>
    </div>
    <div class="flex justify-between items-center py-2 border-b border-gray-200">
      <span class="text-gray-500 text-sm">Less: Total Costs</span>
      <span class="text-red-600 font-mono text-sm font-medium">-<%= fmtCurrency(totalSpent) %></span>
    </div>
    <div class="flex justify-between items-center py-3 border-t-2 border-gray-300">
      <span class="text-gray-900 font-semibold">Gross Profit</span>
      <span class="font-mono text-lg font-bold <%= grossProfit >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= fmtCurrency(grossProfit) %></span>
    </div>
    <div class="flex justify-between items-center py-2">
      <span class="text-gray-500 text-sm">Gross Margin</span>
      <span class="font-mono text-sm font-semibold <% if (grossMarginPct > 20) { %>text-emerald-600<% } else if (grossMarginPct >= 0) { %>text-orange-600<% } else { %>text-red-600<% } %>"><%= grossMarginPct.toFixed(1) %>%</span>
    </div>
  </div>
  <% if (totalSpent > (budget.contract_value || 0) && (budget.contract_value || 0) > 0) { %>
    <div class="mt-4 p-3 bg-red-50 border border-red-300 rounded-lg">
      <p class="text-red-600 text-sm font-medium">⚠ This job has exceeded its contract value by <%= fmtCurrency(totalSpent - budget.contract_value) %></p>
    </div>
  <% } %>
</div>

<!-- Cost Entries Section -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Cost Entries</h2>

  <!-- Add Cost Entry Form -->
  <form method="POST" action="/budgets/job/<%= job.id %>/costs" class="mb-6">
    <div class="bg-white/30 border border-gray-300 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-600 mb-3">Add Cost Entry</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Category</label>
          <select name="category" required
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            <option value="">Select category...</option>
            <option value="labour">Labour</option>
            <option value="materials">Materials</option>
            <option value="subcontractors">Subcontractors</option>
            <option value="equipment">Equipment</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Description</label>
          <input type="text" name="description" required placeholder="What was this cost for?"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Amount ($)</label>
          <input type="number" step="0.01" name="amount" required placeholder="0.00"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Date</label>
          <input type="date" name="entry_date" required
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Invoice Ref</label>
          <input type="text" name="invoice_ref" placeholder="INV-XXXX"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Supplier</label>
          <input type="text" name="supplier" placeholder="Supplier name"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Receipt URL</label>
          <input type="url" name="receipt_url" placeholder="https://..."
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
      </div>
      <div class="flex justify-end mt-3">
        <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Add Entry</button>
      </div>
    </div>
  </form>

  <!-- Cost Entries Table -->
  <% if (costEntries.length === 0) { %>
    <div class="border border-gray-200 rounded-lg p-8 text-center">
      <svg class="w-12 h-12 mx-auto text-gray-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
      <p class="text-gray-400 text-sm">No cost entries recorded yet.</p>
      <p class="text-gray-400 text-xs mt-1">Use the form above to add the first cost entry for this job.</p>
    </div>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Category</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Description</th>
          <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Amount</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Invoice Ref</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Supplier</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Receipt</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Entered By</th>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% costEntries.forEach(entry => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap"><%= entry.entry_date %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (entry.category === 'labour') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
              <% } else if (entry.category === 'materials') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else if (entry.category === 'subcontractors') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
              <% } else if (entry.category === 'equipment') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
              <% } else { %>bg-white text-gray-600
              <% } %>">
              <%= entry.category %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-600 max-w-xs truncate"><%= entry.description %></td>
          <td class="px-4 py-3 text-right font-mono text-xs text-gray-900 font-medium"><%= fmtCurrency(entry.amount) %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= entry.invoice_ref || '-' %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= entry.supplier || '-' %></td>
          <td class="px-4 py-3 text-xs">
            <% if (entry.receipt_url) { %>
              <a href="<%= entry.receipt_url %>" target="_blank" class="text-brand-600 hover:text-brand-700 hover:underline">View</a>
            <% } else { %>
              <span class="text-gray-400">-</span>
            <% } %>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= entry.entered_by_name %></td>
          <td class="px-4 py-3 text-center">
            <form method="POST" action="/budgets/job/<%= job.id %>/costs/<%= entry.id %>/delete" class="inline" onsubmit="return confirm('Delete this cost entry?');">
              <button type="submit" class="text-red-600 hover:text-red-600 text-xs font-medium transition-colors">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
      <!-- Table Footer Totals -->
      <tfoot>
        <tr class="border-t-2 border-gray-300 bg-white/30">
          <td class="px-4 py-3 text-gray-900 font-semibold" colspan="3">Total (<%= costEntries.length %> entr<%= costEntries.length !== 1 ? 'ies' : 'y' %>)</td>
          <td class="px-4 py-3 text-right font-mono text-sm text-gray-900 font-semibold"><%= fmtCurrency(totalSpent) %></td>
          <td colspan="5"></td>
        </tr>
      </tfoot>
    </table>
  </div>
  <% } %>
</div>
