<% locals.currentPage = 'admin' %>

<%
  const roleColors = {
    management: 'bg-purple-600 text-purple-100',
    operations: 'bg-blue-600 text-blue-100',
    planning: 'bg-teal-600 text-teal-100',
    marketing: 'bg-pink-600 text-pink-100',
    accounts: 'bg-brand-700 text-brand-100'
  };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">User Management</h1>
    <a href="/admin/users/new" class="inline-flex items-center px-4 py-2 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add User
    </a>
  </div>

  <!-- Users Table -->
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <% if (users.length === 0) { %>
      <div class="p-8 text-center text-gray-500">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <p>No users found.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Full Name</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Username</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Active</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% users.forEach(function(user) { %>
              <tr class="hover:bg-gray-50 hover:bg-opacity-50">
                <td class="px-4 py-3 text-gray-900 font-medium"><%= user.full_name || '-' %></td>
                <td class="px-4 py-3 text-gray-600"><%= user.username %></td>
                <td class="px-4 py-3 text-gray-600"><%= user.email || '-' %></td>
                <td class="px-4 py-3">
                  <% if (user.role) { %>
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= roleColors[user.role] || 'bg-gray-100 text-gray-700' %>"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (user.password_hash === 'INVITE_PENDING') { %>
                    <span class="inline-flex items-center">
                      <span class="w-2.5 h-2.5 bg-amber-400 rounded-full mr-2"></span>
                      <span class="text-amber-600 text-sm">Invite Pending</span>
                    </span>
                  <% } else if (user.active) { %>
                    <span class="inline-flex items-center">
                      <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full mr-2"></span>
                      <span class="text-emerald-600 text-sm">Active</span>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center">
                      <span class="w-2.5 h-2.5 bg-red-400 rounded-full mr-2"></span>
                      <span class="text-red-600 text-sm">Inactive</span>
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-600 text-sm">
                  <%= user.created_at ? new Date(user.created_at).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <a href="/admin/users/<%= user.id %>/edit" class="text-gray-500 hover:text-brand-600 transition" title="Edit">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </a>
                    <% if (user.password_hash === 'INVITE_PENDING' && user.email) { %>
                      <form method="POST" action="/admin/users/<%= user.id %>/resend-invite" class="inline">
                        <button type="submit" class="text-xs text-amber-600 hover:text-amber-700 font-medium" title="Resend Invite">Resend</button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
