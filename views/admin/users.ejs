<% locals.currentPage = 'admin' %>

<%
  const roleColors = {
    management: 'bg-purple-600 text-purple-100',
    operations: 'bg-blue-600 text-blue-100',
    planning: 'bg-teal-600 text-teal-100',
    marketing: 'bg-pink-600 text-pink-100',
    accounts: 'bg-amber-600 text-amber-100'
  };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">User Management</h1>
    <a href="/admin/users/new" class="inline-flex items-center px-4 py-2 bg-amber-500 text-slate-900 font-semibold rounded-lg hover:bg-amber-400 transition">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add User
    </a>
  </div>

  <!-- Users Table -->
  <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
    <% if (users.length === 0) { %>
      <div class="p-8 text-center text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <p>No users found.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-700">
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Full Name</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Username</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Role</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Active</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Created</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700">
            <% users.forEach(function(user) { %>
              <tr class="hover:bg-slate-750 hover:bg-opacity-50">
                <td class="px-4 py-3 text-white font-medium"><%= user.full_name || '-' %></td>
                <td class="px-4 py-3 text-slate-300"><%= user.username %></td>
                <td class="px-4 py-3 text-slate-300"><%= user.email || '-' %></td>
                <td class="px-4 py-3">
                  <% if (user.role) { %>
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= roleColors[user.role] || 'bg-slate-600 text-slate-200' %>"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
                  <% } else { %>
                    <span class="text-slate-500">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <% if (user.active) { %>
                    <span class="inline-flex items-center">
                      <span class="w-2.5 h-2.5 bg-emerald-400 rounded-full mr-2"></span>
                      <span class="text-emerald-400 text-sm">Active</span>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center">
                      <span class="w-2.5 h-2.5 bg-red-400 rounded-full mr-2"></span>
                      <span class="text-red-400 text-sm">Inactive</span>
                    </span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-slate-300 text-sm">
                  <%= user.created_at ? new Date(user.created_at).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
                </td>
                <td class="px-4 py-3">
                  <a href="/admin/users/<%= user.id %>/edit" class="text-slate-400 hover:text-amber-400 transition" title="Edit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
