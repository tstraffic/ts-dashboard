<div class="max-w-2xl mx-auto space-y-6">

  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">My Profile</h1>
    <p class="text-sm text-gray-500 mt-1">Update your personal information and security settings</p>
  </div>

  <!-- Flash Messages -->
  <% if (flash_success && flash_success.length > 0) { %>
    <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg text-sm" data-auto-dismiss>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <%= flash_success[0] %>
      </div>
    </div>
  <% } %>
  <% if (flash_error && flash_error.length > 0) { %>
    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm" data-auto-dismiss>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <%= flash_error[0] %>
      </div>
    </div>
  <% } %>

  <!-- Profile Info Card -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-base font-semibold text-gray-900">Personal Information</h2>
    </div>
    <form method="POST" action="/profile" class="p-5 space-y-5">
      <!-- Avatar / initials -->
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xl font-bold flex-shrink-0">
          <%= profile.full_name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) %>
        </div>
        <div>
          <p class="text-lg font-semibold text-gray-900"><%= profile.full_name %></p>
          <p class="text-sm text-gray-500">@<%= profile.username %> &middot;
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (profile.role === 'admin') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else if (profile.role === 'operations') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
              <% } else if (profile.role === 'planning') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
              <% } else if (profile.role === 'finance') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
              <% } else { %>bg-gray-50 text-gray-700 ring-1 ring-gray-600/20
              <% } %>">
              <%= profile.role.charAt(0).toUpperCase() + profile.role.slice(1) %>
            </span>
          </p>
          <p class="text-xs text-gray-400 mt-0.5">Member since <%= new Date(profile.created_at).toLocaleDateString('en-AU', { month: 'long', year: 'numeric' }) %></p>
        </div>
      </div>

      <hr class="border-gray-200">

      <!-- Full Name -->
      <div>
        <label for="full_name" class="block text-sm font-medium text-gray-700 mb-1">Full Name <span class="text-red-500">*</span></label>
        <input type="text" id="full_name" name="full_name" value="<%= profile.full_name %>" required
          class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <input type="email" id="email" name="email" value="<%= profile.email || '' %>" placeholder="your@email.com"
          class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <p class="text-xs text-gray-400 mt-1">Used for notifications and password reset emails</p>
      </div>

      <!-- Username (read-only) -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input type="text" value="<%= profile.username %>" disabled
          class="w-full px-3 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-gray-500 text-sm cursor-not-allowed">
        <p class="text-xs text-gray-400 mt-1">Username cannot be changed. Contact an admin if needed.</p>
      </div>

      <!-- Notification Preferences -->
      <hr class="border-gray-200">
      <h3 class="text-sm font-semibold text-gray-900">Notification Preferences</h3>

      <div class="flex items-center gap-3">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" name="email_notifications_enabled" class="sr-only peer" <%= profile.email_notifications_enabled ? 'checked' : '' %>>
          <div class="w-10 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-brand-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-brand-600"></div>
        </label>
        <span class="text-sm text-gray-700">Email notifications</span>
      </div>

      <div>
        <label for="notification_frequency" class="block text-sm font-medium text-gray-700 mb-1">Notification Frequency</label>
        <select id="notification_frequency" name="notification_frequency"
          class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="immediate" <%= profile.notification_frequency === 'immediate' ? 'selected' : '' %>>Immediate</option>
          <option value="hourly" <%= profile.notification_frequency === 'hourly' ? 'selected' : '' %>>Hourly digest</option>
          <option value="daily" <%= profile.notification_frequency === 'daily' ? 'selected' : '' %>>Daily digest</option>
        </select>
      </div>

      <div class="pt-2">
        <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors">
          Save Changes
        </button>
      </div>
    </form>
  </div>

  <!-- Security Card -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-200 bg-gray-50">
      <h2 class="text-base font-semibold text-gray-900">Security</h2>
    </div>
    <div class="p-5 space-y-6">

      <!-- Change Password -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Change Password</h3>
        <form method="POST" action="/profile/change-password" class="space-y-4">
          <div>
            <label for="current_password" class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
            <input type="password" id="current_password" name="current_password" required autocomplete="current-password"
              class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="new_password" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
              <input type="password" id="new_password" name="new_password" required minlength="8" autocomplete="new-password"
                class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            </div>
            <div>
              <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
              <input type="password" id="confirm_password" name="confirm_password" required minlength="8" autocomplete="new-password"
                class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            </div>
          </div>
          <p class="text-xs text-gray-400">Minimum 8 characters</p>
          <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-gray-800 hover:bg-gray-700 text-white text-sm font-semibold rounded-lg transition-colors">
            Update Password
          </button>
        </form>
      </div>

      <% if (emailEnabled && profile.email) { %>
      <hr class="border-gray-200">

      <!-- Reset via Email -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-1">Forgot Your Password?</h3>
        <p class="text-sm text-gray-500 mb-3">We'll send a password reset link to <strong class="text-gray-700"><%= profile.email %></strong></p>
        <form method="POST" action="/profile/send-reset-email">
          <button type="submit" class="w-full sm:w-auto px-6 py-2.5 bg-white hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg border border-gray-300 transition-colors">
            <svg class="w-4 h-4 inline -mt-0.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Send Reset Link to Email
          </button>
        </form>
      </div>
      <% } else if (!profile.email) { %>
      <hr class="border-gray-200">
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-sm text-amber-800">
          <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          Add an email address above to enable password reset via email.
        </p>
      </div>
      <% } %>

    </div>
  </div>

</div>
