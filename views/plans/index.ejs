<% locals.currentPage = 'plans' %>

<%
  const planTypeLabels = { TGS: 'TGS', TCP: 'TCP', TMP: 'TMP' };
  const statusColors = {
    draft: 'bg-gray-100 text-gray-700',
    submitted: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    under_review: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    approved: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    rejected: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    expired: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20'
  };
  const statusLabels = {
    draft: 'DRAFT', submitted: 'SUBMITTED', under_review: 'REVIEW',
    approved: 'APPROVED', rejected: 'REJECTED', expired: 'EXPIRED'
  };

  function daysUntil(dateStr) {
    if (!dateStr) return null;
    return Math.ceil((new Date(dateStr) - new Date(today)) / (1000 * 60 * 60 * 24));
  }
  function formatShortDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }
%>

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Traffic Plans</h1>
    <p class="text-gray-500 text-sm mt-0.5">TGS, TCP &amp; TMP submissions &middot; approvals &middot; expiry tracking</p>
  </div>
  <a href="/plans/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Plan
  </a>
</div>

<!-- Filters -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/plans" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[110px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Plan Type</label>
        <select name="plan_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Types</option>
          <option value="TGS" <%= filters.plan_type === 'TGS' ? 'selected' : '' %>>TGS</option>
          <option value="TCP" <%= filters.plan_type === 'TCP' ? 'selected' : '' %>>TCP</option>
          <option value="TMP" <%= filters.plan_type === 'TMP' ? 'selected' : '' %>>TMP</option>
          <option value="ROL" <%= filters.plan_type === 'ROL' ? 'selected' : '' %>>ROL</option>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All</option>
          <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="submitted" <%= filters.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
          <option value="under_review" <%= filters.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
          <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="expired" <%= filters.status === 'expired' ? 'selected' : '' %>>Expired</option>
        </select>
      </div>
    </div>
    <div class="flex-1 min-w-0 sm:min-w-[180px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Jobs</option>
        <% jobs.forEach(function(job) { %>
          <option value="<%= job.id %>" <%= filters.job_id == job.id ? 'selected' : '' %>><%= job.job_number %> - <%= job.client %></option>
        <% }) %>
      </select>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Apply</button>
      <a href="/plans" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition">Clear</a>
    </div>
  </form>
</div>

<!-- Plans Table -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
  <% if (plans.length === 0) { %>
    <div class="p-6 text-center">
      <svg class="w-10 h-10 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      <p class="text-gray-500 text-sm font-medium">No traffic plans found</p>
      <p class="text-gray-400 text-xs mt-1">Traffic plans track TGS, TCP, and TMP submissions, approvals, and expiry dates for your jobs</p>
      <a href="/plans/new" class="inline-flex items-center mt-3 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Create First Plan
      </a>
    </div>
  <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Plan</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Job</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Designer</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">ROL</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Submitted</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Approved</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Expiry</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% plans.forEach(function(plan) {
            const isExpired = plan.expiry_date && plan.expiry_date < today;
            const expiryDays = daysUntil(plan.expiry_date);
            const expiringSoon = expiryDays !== null && expiryDays >= 0 && expiryDays <= 30;
          %>
          <tr class="hover:bg-gray-50 <%= isExpired ? 'border-l-4 border-l-red-400' : expiringSoon ? 'border-l-4 border-l-amber-400' : '' %>">
            <td class="px-3 py-2.5">
              <span class="text-brand-600 font-semibold"><%= plan.plan_number %></span>
              <span class="sm:hidden block text-[10px] text-gray-400"><%= plan.job_number || '' %></span>
            </td>
            <td class="px-3 py-2.5 hidden sm:table-cell">
              <% if (plan.job_id) { %>
                <a href="/projects/<%= plan.job_id %>" class="text-brand-600 hover:text-brand-700 text-xs"><%= plan.job_number %></a>
              <% } else { %>
                <span class="text-gray-300">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5">
              <div class="flex flex-wrap gap-1">
                <% const displayTypes = (plan.plan_types || plan.plan_type || '').split(',').filter(Boolean); %>
                <% displayTypes.forEach(function(t) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                    <% if (t === 'TGS') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                    <% } else if (t === 'TCP') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
                    <% } else if (t === 'ROL') { %>bg-orange-50 text-orange-700 ring-1 ring-orange-600/20
                    <% } else { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20<% } %>"><%= t %></span>
                <% }) %>
              </div>
            </td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden lg:table-cell"><%= plan.designer || '-' %></td>
            <td class="px-3 py-2.5 hidden lg:table-cell">
              <% if (plan.rol_required) { %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold
                  <%= plan.rol_approved ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' : plan.rol_submitted ? 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' : 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20' %>">
                  <%= plan.rol_approved ? 'APPROVED' : plan.rol_submitted ? 'SUBMITTED' : 'REQUIRED' %>
                </span>
              <% } else { %>
                <span class="text-gray-300 text-xs">N/A</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusColors[plan.status] || 'bg-gray-100 text-gray-700' %>"><%= statusLabels[plan.status] || plan.status || 'DRAFT' %></span>
            </td>
            <td class="px-3 py-2.5 text-gray-500 text-xs hidden md:table-cell"><%= plan.submitted_date ? formatShortDate(plan.submitted_date) : '-' %></td>
            <td class="px-3 py-2.5 text-gray-500 text-xs hidden xl:table-cell"><%= plan.approved_date ? formatShortDate(plan.approved_date) : '-' %></td>
            <td class="px-3 py-2.5 hidden sm:table-cell">
              <% if (plan.expiry_date) { %>
                <%
                  let expiryColor = 'text-gray-500';
                  let expiryLabel = formatShortDate(plan.expiry_date);
                  if (isExpired) { expiryColor = 'text-red-600 font-semibold'; expiryLabel = Math.abs(expiryDays) + 'd expired'; }
                  else if (expiryDays <= 14) { expiryColor = 'text-red-600'; }
                  else if (expiryDays <= 30) { expiryColor = 'text-amber-600'; }
                %>
                <span class="text-xs <%= expiryColor %>"><%= expiryLabel %></span>
                <% if (isExpired) { %><span class="block text-[10px] text-red-500">EXPIRED</span><% } %>
                <% if (!isExpired && expiryDays <= 30) { %><span class="block text-[10px] text-amber-500"><%= expiryDays %>d left</span><% } %>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-right">
              <div class="flex items-center justify-end gap-1">
                <a href="/plans/<%= plan.id %>/edit" class="px-2.5 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg">Edit</a>
                <form method="POST" action="/plans/<%= plan.id %>/delete" class="inline" onsubmit="return confirm('Delete this plan?')">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="px-3 py-2.5 border-t border-gray-200 text-xs text-gray-400"><%= plans.length %> plan<%= plans.length !== 1 ? 's' : '' %> found</div>
  <% } %>
</div>
