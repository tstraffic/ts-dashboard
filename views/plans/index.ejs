<% locals.currentPage = 'plans' %>

<%
  const planTypeLabels = {
    TGS: 'TGS',
    TCP: 'TCP',
    TMP: 'TMP'
  };
  const statusColors = {
    draft: 'bg-gray-100 text-gray-700',
    submitted: 'bg-blue-600 text-blue-100',
    under_review: 'bg-blue-600 text-blue-100',
    approved: 'bg-emerald-600 text-emerald-100',
    rejected: 'bg-red-600 text-red-100',
    expired: 'bg-orange-600 text-orange-100'
  };
  const statusLabels = {
    draft: 'Draft',
    submitted: 'Submitted',
    under_review: 'Under Review',
    approved: 'Approved',
    rejected: 'Rejected',
    expired: 'Expired'
  };
%>

<!-- Header -->
<div class="flex items-center justify-between mb-5">
    <h1 class="text-2xl font-bold text-gray-900">Traffic Plans</h1>
    <a href="/plans/new" class="inline-flex items-center px-4 py-2 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Plan
    </a>
  </div>

  <!-- Filters -->
  <form method="GET" action="/plans" class="bg-white border border-gray-200 rounded-lg shadow-sm p-4 mb-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
      <!-- Plan Type -->
      <div>
        <label class="block text-sm font-medium text-gray-500 mb-1">Plan Type</label>
        <select name="plan_type" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Types</option>
          <option value="TGS" <%= filters.plan_type === 'TGS' ? 'selected' : '' %>>TGS</option>
          <option value="TCP" <%= filters.plan_type === 'TCP' ? 'selected' : '' %>>TCP</option>
          <option value="TMP" <%= filters.plan_type === 'TMP' ? 'selected' : '' %>>TMP</option>
        </select>
      </div>

      <!-- Status -->
      <div>
        <label class="block text-sm font-medium text-gray-500 mb-1">Status</label>
        <select name="status" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Statuses</option>
          <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
          <option value="submitted" <%= filters.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
          <option value="under_review" <%= filters.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
          <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="expired" <%= filters.status === 'expired' ? 'selected' : '' %>>Expired</option>
        </select>
      </div>

      <!-- Job -->
      <div>
        <label class="block text-sm font-medium text-gray-500 mb-1">Job</label>
        <select name="job_id" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Jobs</option>
          <% jobs.forEach(function(job) { %>
            <option value="<%= job.id %>" <%= filters.job_id == job.id ? 'selected' : '' %>><%= job.job_number %> - <%= job.client %></option>
          <% }) %>
        </select>
      </div>

      <!-- Apply -->
      <div>
        <button type="submit" class="w-full px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-300 transition font-medium">Apply Filters</button>
      </div>
    </div>
  </form>

  <!-- Plans Table -->
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <% if (plans.length === 0) { %>
      <div class="p-10 text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-gray-500 text-sm font-medium">No traffic plans found</p>
        <p class="text-gray-400 text-xs mt-1">Traffic plans track TGS, TCP, and TMP submissions, approvals, and expiry dates for your jobs</p>
        <a href="/plans/new" class="inline-flex items-center mt-3 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Create First Plan
        </a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-gray-200">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Plan Number</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Job</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Designer</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">ROL</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Submitted</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Approved</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Expiry</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% plans.forEach(function(plan) { %>
              <tr class="hover:bg-gray-50 hover:bg-opacity-50">
                <td class="px-4 py-3 text-brand-600 font-medium"><%= plan.plan_number %></td>
                <td class="px-4 py-3">
                  <% if (plan.job_id) { %>
                    <a href="/projects/<%= plan.job_id %>" class="text-brand-600 hover:text-brand-700"><%= plan.job_number %></a>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                    <% if (plan.plan_type === 'TGS') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                    <% } else if (plan.plan_type === 'TCP') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
                    <% } else { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20<% } %>"><%= plan.plan_type %></span>
                </td>
                <td class="px-4 py-3 text-gray-600"><%= plan.designer || '-' %></td>
                <td class="px-4 py-3">
                  <% if (plan.rol_required) { %>
                    <span class="text-xs <%= plan.rol_approved ? 'text-emerald-600' : plan.rol_submitted ? 'text-brand-600' : 'text-orange-600' %>">
                      <%= plan.rol_approved ? 'Approved' : plan.rol_submitted ? 'Submitted' : 'Required' %>
                    </span>
                  <% } else { %>
                    <span class="text-xs text-gray-400">N/A</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= statusColors[plan.status] || 'bg-gray-100 text-gray-700' %>"><%= statusLabels[plan.status] || plan.status || 'Draft' %></span>
                </td>
                <td class="px-4 py-3 text-gray-600 text-xs">
                  <% if (plan.submitted_date) { %>
                    <%= new Date(plan.submitted_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td class="px-4 py-3 text-gray-600 text-xs">
                  <% if (plan.approved_date) { %>
                    <%= new Date(plan.approved_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                  <% } else { %>
                    -
                  <% } %>
                </td>
                <td class="px-4 py-3 text-xs">
                  <% if (plan.expiry_date) { %>
                    <%
                      const isExpired = new Date(plan.expiry_date) < new Date();
                    %>
                    <span class="<%= isExpired ? 'text-red-600 font-semibold' : 'text-gray-600' %>">
                      <%= new Date(plan.expiry_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                      <% if (isExpired) { %><span class="text-xs ml-1">EXPIRED</span><% } %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <a href="/plans/<%= plan.id %>/edit" class="text-gray-500 hover:text-brand-600 transition" title="Edit">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </a>
                    <form method="POST" action="/plans/<%= plan.id %>/delete" class="inline" onsubmit="return confirm('Delete this plan?')">
                      <button type="submit" class="text-gray-500 hover:text-red-600 transition" title="Delete">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
