<% locals.currentPage = 'plans' %>

<%
  const isEdit = !!plan;
  const formAction = isEdit ? '/plans/' + plan.id : '/plans';
  const selectedJobId = (isEdit && plan.job_id) ? plan.job_id : (preselectedJobId || '');
  const planTypeOptions = (settingsOptions.plan_type || []).map(opt => ({ value: opt.key, label: opt.label }));
  const statusOptions = (settingsOptions.plan_status || []).map(opt => ({ value: opt.key, label: opt.label }));
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/plans" class="hover:text-gray-900 transition">Traffic Plans</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? 'Edit Plan' : 'New Plan' %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Traffic Plan' : 'New Traffic Plan' %></h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update plan details' : 'Create a new TGS, TCP, or TMP submission' %></p>
  </div>
</div>

<form method="POST" action="<%= formAction %>" class="space-y-5" data-wizard>
  <input type="hidden" name="return_to" value="/plans">

  <!-- Step 1: Plan Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="0" data-wizard-title="Plan Details">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Plan Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="job_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Job</label>
        <select id="job_id" name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select a job...</option>
          <% jobs.forEach(function(job) { %>
            <option value="<%= job.id %>" <%= String(selectedJobId) === String(job.id) ? 'selected' : '' %>><%= job.job_number %> - <%= job.client %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="plan_type" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Plan Type</label>
        <select id="plan_type" name="plan_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select type...</option>
          <% planTypeOptions.forEach(function(opt) { %>
            <option value="<%= opt.value %>" <%= isEdit && plan.plan_type === opt.value ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="designer" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Designer</label>
        <input type="text" id="designer" name="designer" value="<%= isEdit && plan.designer ? plan.designer : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="Designer name...">
      </div>
      <div>
        <label for="status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</label>
        <select id="status" name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% statusOptions.forEach(function(opt) { %>
            <option value="<%= opt.value %>" <%= isEdit && plan.status === opt.value ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- Step 2: ROL -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="1" data-wizard-title="ROL">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">ROL</h2>
    <div class="flex flex-wrap items-center gap-6 mb-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="rol_required" value="1" <%= isEdit && plan.rol_required ? 'checked' : '' %>
          class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
        <span class="text-sm font-medium text-gray-600">ROL Required</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="rol_submitted" value="1" <%= isEdit && plan.rol_submitted ? 'checked' : '' %>
          class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
        <span class="text-sm font-medium text-gray-600">ROL Submitted</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="rol_approved" value="1" <%= isEdit && plan.rol_approved ? 'checked' : '' %>
          class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0">
        <span class="text-sm font-medium text-gray-600">ROL Approved</span>
      </label>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="council" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Council</label>
        <input type="text" id="council" name="council" value="<%= isEdit && plan.council ? plan.council : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="Council name...">
      </div>
      <div>
        <label for="tfnsw" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">TfNSW</label>
        <input type="text" id="tfnsw" name="tfnsw" value="<%= isEdit && plan.tfnsw ? plan.tfnsw : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="TfNSW reference...">
      </div>
    </div>
  </div>

  <!-- Step 3: Dates & Links -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="2" data-wizard-title="Dates">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Dates & File Link</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="submitted_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Submitted Date</label>
        <input type="date" id="submitted_date" name="submitted_date" value="<%= isEdit && plan.submitted_date ? new Date(plan.submitted_date).toISOString().split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="approval_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Approval Date</label>
        <input type="date" id="approval_date" name="approval_date" value="<%= isEdit && plan.approval_date ? new Date(plan.approval_date).toISOString().split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="approved_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Approved Date</label>
        <input type="date" id="approved_date" name="approved_date" value="<%= isEdit && plan.approved_date ? new Date(plan.approved_date).toISOString().split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="expiry_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Expiry Date</label>
        <input type="date" id="expiry_date" name="expiry_date" value="<%= isEdit && plan.expiry_date ? new Date(plan.expiry_date).toISOString().split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
    <div class="mt-4">
      <label for="file_link" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">File Link (URL)</label>
      <input type="url" id="file_link" name="file_link" value="<%= isEdit && plan.file_link ? plan.file_link : '' %>"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="https://...">
    </div>
    <div class="mt-4">
      <label for="notes" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Notes</label>
      <textarea id="notes" name="notes" rows="2"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y" placeholder="Additional notes..."><%= isEdit && plan.notes ? plan.notes : '' %></textarea>
    </div>
  </div>

  <noscript>
    <div class="flex items-center gap-3">
      <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition">
        <%= isEdit ? 'Update Plan' : 'Create Plan' %>
      </button>
      <a href="/plans" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition">Cancel</a>
    </div>
  </noscript>
</form>
