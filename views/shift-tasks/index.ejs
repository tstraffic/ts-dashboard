<% locals.currentPage = 'shift-tasks' %>

<%
  function rolePill(pr) {
    if (pr === 'supervisor')  return { label:'Supervisor',  cls:'bg-violet-50 text-violet-700' };
    if (pr === 'team_leader') return { label:'Team Leader', cls:'bg-amber-50 text-amber-700' };
    return                            { label:'TC',         cls:'bg-gray-100 text-gray-600' };
  }
  function priorityPill(p) {
    if (p === 'high') return 'bg-red-50 text-red-700 ring-red-600/10';
    if (p === 'low')  return 'bg-gray-100 text-gray-600 ring-gray-500/10';
    return            'bg-amber-50 text-amber-700 ring-amber-600/10';
  }
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-5">
  <div class="flex items-center justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Tasks Board</h1>
      <p class="text-sm text-gray-500 mt-0.5">Allocate tasks to TCs, Team Leaders, and Supervisors — bound to a specific shift or as standing work.</p>
    </div>
    <div class="text-xs text-gray-500 flex items-center gap-3">
      <span><span class="font-semibold text-amber-700"><%= counts.pending %></span> pending</span>
      <span><span class="font-semibold text-emerald-700"><%= counts.done %></span> done</span>
      <span><span class="font-semibold text-blue-700"><%= counts.general %></span> general</span>
    </div>
  </div>

  <!-- Filters + create form -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
    <h2 class="text-sm font-semibold text-gray-900 mb-3">Create task</h2>
    <form method="POST" action="/shift-tasks" class="space-y-3">
      <%- include('../partials/csrf') %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Assign to</label>
          <select name="crew_member_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm">
            <option value="">— Select crew member —</option>
            <% crew.forEach(function (c) { %>
              <option value="<%= c.id %>"><%= c.full_name %><% if (c.portal_role && c.portal_role !== 'traffic_controller') { %> · <%= c.portal_role.replace('_',' ') %><% } %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Priority</label>
          <select name="priority" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm">
            <option value="normal">Normal</option>
            <option value="high">High</option>
            <option value="low">Low</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <!-- Scope toggle -->
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Scope</label>
          <div class="grid grid-cols-2 gap-1 text-xs font-semibold rounded-lg p-0.5 bg-gray-100">
            <label class="cursor-pointer">
              <input type="radio" name="scope" value="shift" class="peer sr-only" checked
                onchange="document.getElementById('booking-row').style.display='block'">
              <span class="block text-center py-2 rounded-md text-gray-500 peer-checked:bg-white peer-checked:text-brand-700 peer-checked:shadow-sm">For a shift</span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="scope" value="general" class="peer sr-only"
                onchange="document.getElementById('booking-row').style.display='none'">
              <span class="block text-center py-2 rounded-md text-gray-500 peer-checked:bg-white peer-checked:text-blue-700 peer-checked:shadow-sm">General</span>
            </label>
          </div>
        </div>
        <div id="booking-row">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Shift / booking</label>
          <select name="booking_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm">
            <option value="">— Pick a booking —</option>
            <% bookings.forEach(function (b) { %>
              <option value="<%= b.id %>">
                <%= b.booking_number %> · <%= new Date(b.start_datetime).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                <% if (b.title) { %> · <%= b.title %><% } %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <input type="text" name="title" placeholder="Task title (e.g. Drop docket pack at office on the way back)" required maxlength="200"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm">
      <textarea name="description" rows="2" placeholder="Notes (optional)"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm resize-none"></textarea>
      <div class="flex items-center gap-2">
        <input type="datetime-local" name="due_at"
          class="flex-1 px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm">
        <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Add task
        </button>
      </div>
    </form>
  </div>

  <!-- Filters strip -->
  <form method="GET" class="flex flex-wrap items-center gap-2 text-xs">
    <div class="flex rounded-lg overflow-hidden ring-1 ring-gray-200">
      <% ['pending','done','all'].forEach(function (s) { %>
        <button type="submit" name="status" value="<%= s %>"
          class="px-3 py-1.5 font-semibold <%= status === s ? 'bg-brand-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50' %>"><%= s.charAt(0).toUpperCase() + s.slice(1) %></button>
      <% }) %>
    </div>
    <div class="flex rounded-lg overflow-hidden ring-1 ring-gray-200">
      <% [['all','All'],['shift','Shift-bound'],['general','General']].forEach(function (pair) { %>
        <button type="submit" name="scope" value="<%= pair[0] %>"
          class="px-3 py-1.5 font-semibold <%= scope === pair[0] ? 'bg-brand-50 text-brand-700' : 'bg-white text-gray-600 hover:bg-gray-50' %>"><%= pair[1] %></button>
      <% }) %>
      <input type="hidden" name="status" value="<%= status %>">
    </div>
    <select name="assignee" onchange="this.form.submit()" class="px-3 py-1.5 ring-1 ring-gray-200 rounded-lg bg-white text-gray-700 font-semibold">
      <option value="">All assignees</option>
      <% crew.forEach(function (c) { %>
        <option value="<%= c.id %>" <%= assignee === c.id ? 'selected' : '' %>><%= c.full_name %></option>
      <% }) %>
    </select>
    <% if (status !== 'pending' || scope !== 'all' || assignee) { %>
      <a href="/shift-tasks" class="text-gray-500 hover:text-gray-700 ml-1">Clear</a>
    <% } %>
  </form>

  <!-- Task list -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (rows.length === 0) { %>
      <div class="px-5 py-12 text-center text-sm text-gray-500">No tasks match these filters.</div>
    <% } else { %>
      <ul class="divide-y divide-gray-100">
        <% rows.forEach(function (t) { var rp = rolePill(t.assignee_portal_role); var done = t.status === 'done'; %>
          <li class="px-5 py-3 flex items-start gap-3 hover:bg-gray-50 <%= done ? 'opacity-70' : '' %>">
            <form method="POST" action="/shift-tasks/<%= t.id %>/status" class="shrink-0 mt-0.5">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="status" value="<%= done ? 'pending' : 'done' %>">
              <input type="hidden" name="return_status" value="<%= status %>">
              <button type="submit" aria-label="<%= done ? 'Reopen' : 'Mark done' %>"
                class="w-5 h-5 rounded flex items-center justify-center"
                style="border:1.5px solid <%= done ? '#10B981' : '#D1D5DB' %>;background:<%= done ? '#D1FAE5' : 'transparent' %>;">
                <% if (done) { %><svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><% } %>
              </button>
            </form>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium <%= done ? 'line-through text-gray-500' : 'text-gray-900' %>"><%= t.title %></p>
              <% if (t.description) { %><p class="text-xs text-gray-500 mt-0.5"><%= t.description %></p><% } %>
              <div class="flex items-center gap-1.5 flex-wrap mt-1.5">
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold <%= rp.cls %>"><%= t.assignee_name %></span>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold ring-1 <%= priorityPill(t.priority) %>"><%= (t.priority || 'normal').toUpperCase() %></span>
                <% if (t.booking_id) { %>
                  <a href="/bookings/<%= t.booking_id %>#tasks" class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 hover:underline">
                    <%= t.booking_number || '#' + t.booking_id %><% if (t.start_datetime) { %> · <%= new Date(t.start_datetime).toLocaleDateString('en-AU', { day:'numeric', month:'short' }) %><% } %>
                  </a>
                <% } else { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-blue-50 text-blue-700">GENERAL</span>
                <% } %>
                <% if (t.due_at) { %><span class="text-[10px] text-gray-500">Due <%= new Date(t.due_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></span><% } %>
                <% var by = t.created_by_name || t.created_by_crew_name; if (by) { %><span class="text-[10px] text-gray-400">· by <%= by %></span><% } %>
              </div>
            </div>
            <form method="POST" action="/shift-tasks/<%= t.id %>/delete" onsubmit="return confirm('Remove this task?')" class="shrink-0">
              <%- include('../partials/csrf') %>
              <input type="hidden" name="return_status" value="<%= status %>">
              <button type="submit" class="text-gray-300 hover:text-red-500 p-1" aria-label="Remove">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>
