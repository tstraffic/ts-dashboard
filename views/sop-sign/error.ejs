<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SOP Sign-Off — T&S Traffic Control</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col items-center justify-center p-6 text-center font-sans">
  <div class="w-16 h-16 rounded-full bg-amber-100 flex items-center justify-center mb-5">
    <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
  </div>
  <h1 class="text-xl font-bold text-gray-900 mb-2">Can't sign right now</h1>
  <p class="text-gray-600 max-w-sm"><%= message %></p>
</body>
</html>
