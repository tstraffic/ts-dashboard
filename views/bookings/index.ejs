function openBookingFormEdit(id) {
  const form = document.getElementById('booking-slide-form');
  const titleEl = document.getElementById('form-modal-title');
  const submitBtn = form.closest('.booking-modal').querySelector('.modal-footer-btn.primary');

  // CRITICAL: reset before populating. Without this the chip-based crew
  // picker carries stale `selectedCrew` from whichever booking was last
  // opened — when the user saves, those stale crew_ids[] hidden inputs
  // replace the actual booking's crew with someone unrelated.
  resetBookingForm();

  // Switch to edit mode
  titleEl.textContent = 'Edit Booking';
  form.action = '/bookings/' + id;
  submitBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Update Booking';

  // Surface a "Full edit page" link in the modal header so users can jump
  // to the detailed form when they need every field instead of the slim
  // slide-in. Inserted lazily so it survives form resets.
  if (titleEl && !document.getElementById('form-modal-fulledit')) {
    var fe = document.createElement('a');
    fe.id = 'form-modal-fulledit';
    fe.className = 'text-xs font-semibold text-brand-600 hover:underline ml-2';
    fe.textContent = 'Open full edit page →';
    titleEl.parentNode.appendChild(fe);
  }
  var feLink = document.getElementById('form-modal-fulledit');
  if (feLink) { feLink.href = '/bookings/' + id + '/edit'; feLink.style.display = 'inline'; }

  // Fetch booking data and pre-fill
  fetch('/bookings/' + id, { headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(b => {
      // Parse dates from start_datetime / end_datetime
      const sd = b.start_datetime ? b.start_datetime.split('T') : ['',''];
      const ed = b.end_datetime ? b.end_datetime.split('T') : ['',''];

      // Helper to set form values
      function setVal(name, val) {
        const el = form.querySelector('[name="' + name + '"]');
        if (!el || val === undefined || val === null) return;
        if (el.type === 'checkbox') { el.checked = !!val; }
        else if (el.type === 'radio') {
          const radio = form.querySelector('[name="' + name + '"][value="' + val + '"]');
          if (radio) radio.checked = true;
        } else { el.value = val; }
      }

      // Booking Depot
      setVal('depot', b.depot);
      setVal('supervisor_id', b.supervisor_id || '');
      setVal('status', b.status);

      // Client Information
      setVal('client_id', b.client_id || '');
      setVal('job_id', b.job_id || '');
      setVal('order_number', b.order_number || '');
      setVal('billing_code', b.billing_code || '');
      setVal('client_contact', b.client_contact || '');
      setVal('location_context', b.location_context || '');
      setVal('requester_id', b.requester_id || '');
      setVal('planner_id', b.planner_id || '');

      // Booking Information
      setVal('start_date', sd[0]);
      setVal('start_time', (sd[1] || '').substring(0, 5));
      setVal('end_date', ed[0]);
      setVal('end_time', (ed[1] || '').substring(0, 5));
      setVal('depot_meeting_time', b.depot_meeting_time || '');
      setVal('straight_to_site_time', b.straight_to_site_time || '');
      setVal('title', b.title || '');
      setVal('description', b.description || '');
      setVal('booking_tags', (b.tags_list || []).join(', '));
      setVal('is_emergency', b.is_emergency);
      setVal('is_callout', b.is_callout);
      setVal('billable', b.billable);

      // Location
      setVal('site_address', b.site_address || '');
      setVal('suburb', b.suburb || '');
      setVal('state', b.state || '');
      setVal('postcode', b.postcode || '');
      setVal('works_direction', b.works_direction || '');
      setVal('worksite_location', b.worksite_location || '');
      setVal('location_notes', b.location_notes || '');
      setVal('chainage_from', b.chainage_from || '');
      setVal('chainage_to', b.chainage_to || '');
      setVal('has_mobile_works', b.has_mobile_works);
      setVal('marker_is_accurate', b.marker_is_accurate);

      // Site Contacts
      const siteContactsBox = document.getElementById('panel-site-contacts');
      if (siteContactsBox) {
        siteContactsBox.querySelectorAll('input[name="site_contacts"]').forEach(cb => {
          cb.checked = (b.site_contact_ids || []).includes(parseInt(cb.value));
        });
      }

      // Booking Type
      setVal('booking_type', b.booking_type || 'regular');

      // Requirements
      const reqContainer = document.getElementById('panel-req-rows');
      reqContainer.innerHTML = '';
      if (b.requirements && b.requirements.length) {
        b.requirements.forEach(r => addPanelReqRow(r.resource_type, r.quantity_required));
      }

      // Crew assignment pre-fill — always run, even when b.crew is empty,
      // so the picker reflects exactly what's stored on this booking and
      // doesn't inherit chips from a previous edit. Falls back to the
      // existing `personnel` shape if `crew` isn't on the response.
      if (window._setFormCrew) {
        var crewSrc = b.crew || b.personnel || [];
        window._setFormCrew(crewSrc);
      }

      // Special Instructions & Pool
      setVal('requirements_text', b.requirements_text || '');
      setVal('is_booking_pool', b.is_booking_pool);
      setVal('notes', b.internal_notes || '');

      // Open the panel (skip reset since we just populated it)
      openBookingForm(true);
    })
    .catch(err => {
      console.error('Failed to load booking for edit:', err);
      // Fallback to full page edit
      window.location.href = '/bookings/' + id + '/edit';
    });
}

function resetBookingForm() {
  const form = document.getElementById('booking-slide-form');
  const titleEl = document.getElementById('form-modal-title');
  const submitBtn = form.closest('.booking-modal').querySelector('.modal-footer-btn.primary');
  titleEl.textContent = 'New Booking';
  form.action = '/bookings';
  form.reset();
  submitBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Create Booking';
  document.getElementById('panel-req-rows').innerHTML = '';
  // Clear crew selections
  if (window._clearFormCrew) window._clearFormCrew();
  // Reset default date values
  const startDate = form.querySelector('[name="start_date"]');
  const endDate = form.querySelector('[name="end_date"]');
  if (startDate) startDate.value = '<%= typeof currentDate !== "undefined" ? currentDate : "" %>';
  if (endDate) endDate.value = '<%= typeof currentDate !== "undefined" ? currentDate : "" %>';
  const startTime = form.querySelector('[name="start_time"]');
  const endTime = form.querySelector('[name="end_time"]');
  if (startTime) startTime.value = '06:00';
  if (endTime) endTime.value = '14:30';
}

function addPanelReqRow(type, qty) {
  const container = document.getElementById('panel-req-rows');
  const row = document.createElement('div');
  row.className = 'flex items-center gap-2 mb-2';
  let opts = '<option value="">-- Select --</option>';
  panelReqTypes.forEach(rt => { opts += '<option value="' + rt + '"' + (rt === type ? ' selected' : '') + '>' + rt + '</option>'; });
  row.innerHTML = '<select name="req_resource_type" class="modal-input flex-1">' + opts + '</select>'
    + '<input type="number" name="req_quantity" value="' + (qty || 1) + '" min="1" class="modal-input w-16 text-center">'
    + '<button type="button" onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 p-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>';
  container.appendChild(row);
}

// Escape closes form panel too
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeBookingForm();
});

// Click backdrop to close form
document.getElementById('booking-form-backdrop')?.addEventListener('click', function(e) {
  if (e.target === this) closeBookingForm();
});

// Auto-sync end date with start date in the panel form
const panelStartDate = document.querySelector('#booking-slide-form input[name="start_date"]');
const panelEndDate = document.querySelector('#booking-slide-form input[name="end_date"]');
if (panelStartDate && panelEndDate) {
  panelStartDate.addEventListener('change', function() { if (!panelEndDate.value || panelEndDate.value === panelStartDate.defaultValue) panelEndDate.value = this.value; });
}

// ===== Crew Search Multi-Select =====
(function() {
  var crewList = <%- JSON.stringify(formCrew.map(c => ({ id: c.id, name: c.full_name, role: c.role || '' }))) %>;
  var selectedCrew = {};
  var searchInput = document.getElementById('crew-search-input');
  var dropdown = document.getElementById('crew-dropdown');
  var dropdownList = document.getElementById('crew-dropdown-list');
  var chipsContainer = document.getElementById('crew-chips');
  var formEl = document.getElementById('booking-slide-form');

  if (!searchInput || !dropdown) return;

  var roleColors = {
    traffic_controller: '#2563eb', tc: '#2563eb', leading_hand: '#7c3aed',
    team_leader: '#7c3aed', supervisor: '#d97706', pilot_vehicle: '#059669',
    implementation_officer: '#dc2626'
  };

  function getRoleColor(role) {
    var key = (role || '').toLowerCase().replace(/\s+/g, '_');
    return roleColors[key] || '#6b7280';
  }

  function renderChips() {
    var html = '';
    Object.keys(selectedCrew).forEach(function(id) {
      var c = selectedCrew[id];
      var color = getRoleColor(c.role);
      html += '<div class="crew-chip" data-id="' + id + '" style="border-left-color:' + color + '">';
      html += '<span>' + c.name + '</span>';
      html += '<button type="button" class="crew-chip-x" onclick="window._removeCrewChip(' + id + ')">&times;</button>';
      html += '</div>';
    });
    chipsContainer.innerHTML = html;
    // Update hidden inputs
    formEl.querySelectorAll('input[name="crew_ids[]"]').forEach(function(el) { el.remove(); });
    Object.keys(selectedCrew).forEach(function(id) {
      var inp = document.createElement('input');
      inp.type = 'hidden';
      inp.name = 'crew_ids[]';
      inp.value = id;
      formEl.appendChild(inp);
    });
  }

  function renderDropdown(query) {
    var q = (query || '').toLowerCase().trim();
    var filtered = crewList.filter(function(c) {
      if (selectedCrew[c.id]) return false;
      if (!q) return true;
      return c.name.toLowerCase().indexOf(q) !== -1 || (c.role || '').toLowerCase().indexOf(q) !== -1;
    }).slice(0, 20);

    if (filtered.length === 0) {
      dropdownList.innerHTML = '<div class="crew-dropdown-empty">No matching crew</div>';
    } else {
      var html = '';
      filtered.forEach(function(c) {
        var color = getRoleColor(c.role);
        var roleLabel = (c.role || '').replace(/_/g, ' ');
        html += '<div class="crew-dropdown-item" onclick="window._selectCrew(' + c.id + ')">';
        html += '<div class="crew-dropdown-avatar" style="background:' + color + '">' + c.name.split(' ').map(function(n) { return n[0]; }).join('').substring(0, 2).toUpperCase() + '</div>';
        html += '<div class="crew-dropdown-info"><span class="crew-dropdown-name">' + c.name + '</span>';
        if (roleLabel) html += '<span class="crew-dropdown-role">' + roleLabel + '</span>';
        html += '</div></div>';
      });
      dropdownList.innerHTML = html;
    }
    dropdown.style.display = 'block';
  }

  searchInput.addEventListener('focus', function() { renderDropdown(this.value); });
  searchInput.addEventListener('input', function() { renderDropdown(this.value); });

  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('crew-select-wrap');
    if (wrap && !wrap.contains(e.target)) dropdown.style.display = 'none';
  });

  window._selectCrew = function(id) {
    var c = crewList.find(function(x) { return x.id === id; });
    if (c && !selectedCrew[id]) {
      selectedCrew[id] = c;
      renderChips();
      searchInput.value = '';
      renderDropdown('');
      searchInput.focus();
    }
  };

  window._removeCrewChip = function(id) {
    delete selectedCrew[id];
    renderChips();
  };

  // Expose for edit mode pre-fill
  window._setFormCrew = function(crewArray) {
    selectedCrew = {};
    (crewArray || []).forEach(function(c) {
      selectedCrew[c.id || c.crew_member_id] = { id: c.id || c.crew_member_id, name: c.full_name || c.name || 'Unknown', role: c.role_on_site || c.role || '' };
    });
    renderChips();
  };

  window._clearFormCrew = function() {
    selectedCrew = {};
    renderChips();
  };
})();

function exportBookingsCSV() {
  const data = <%- JSON.stringify(bookings.map(b => ({
    booking_number: b.bookingNumber,
    status: b.status,
    title: b.project.name,
    client: b.project.client,
    start: b.startDateTime,
    end: b.endDateTime,
    depot: b.depot,
    supervisor: b.supervisor,
    address: b.project.address,
    crew_count: b.personnel.length
  }))) %>;
  if (!data.length) { showToast('No bookings to export', 'error'); return; }
  const headers = ['Booking #','Status','Title','Client','Start','End','Depot','Supervisor','Address','Crew'];
  const rows = data.map(r => [r.booking_number, r.status, r.title, r.client, r.start, r.end, r.depot, r.supervisor, r.address, r.crew_count].map(v => '"' + String(v || '').replace(/"/g, '""') + '"').join(','));
  const csv = [headers.join(','), ...rows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'bookings-<%= currentDate %>.csv';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('Exported ' + data.length + ' bookings', 'success');
}

// ── Time Mask for HH:MM inputs (auto-inserts colon as you type) ──
function __bkNormaliseTime(raw) {
  if (!raw) return '';
  var d = String(raw).replace(/\D/g, '');
  if (!d) return '';
  if (d.length >= 6) d = d.slice(0, 4);
  if (d.length <= 2) return d;
  if (d.length === 3) return d.slice(0,2) + ':' + d.slice(2);
  return d.slice(0,2) + ':' + d.slice(2,4);
}
function __bkValidateTime(val) {
  if (!val) return '';
  var m = val.match(/^(\d{1,2}):?(\d{0,2})$/);
  if (!m) return val;
  var h = parseInt(m[1], 10), mm = m[2] === '' ? 0 : parseInt(m[2], 10);
  if (isNaN(h) || h > 23) h = 23;
  if (isNaN(mm) || mm > 59) mm = 59;
  return String(h).padStart(2,'0') + ':' + String(mm).padStart(2,'0');
}
function __bkBindTimeMask(inp) {
  if (inp.dataset.timeMaskBound) return;
  inp.dataset.timeMaskBound = '1';
  if (inp.value) inp.value = __bkValidateTime(inp.value.slice(0,5));
  inp.addEventListener('input', function() {
    var caret = inp.selectionStart;
    var before = inp.value;
    var next = __bkNormaliseTime(before);
    if (next !== before) {
      inp.value = next;
      var delta = next.length - before.length;
      try { inp.setSelectionRange(caret + delta, caret + delta); } catch (e) {}
    }
  });
  inp.addEventListener('blur', function() { if (inp.value) inp.value = __bkValidateTime(inp.value); });
  inp.addEventListener('paste', function(e) {
    e.preventDefault();
    var pasted = (e.clipboardData || window.clipboardData).getData('text');
    inp.value = __bkValidateTime(pasted);
  });
}
function __bkApplyTimeMasks() {
  document.querySelectorAll('input[data-time-mask]').forEach(__bkBindTimeMask);
}
__bkApplyTimeMasks();
// Re-apply when modal opens (observers will rebind new inputs)
document.addEventListener('DOMContentLoaded', __bkApplyTimeMasks);
var __bkMaskObserver = new MutationObserver(__bkApplyTimeMasks);
__bkMaskObserver.observe(document.body, { childList: true, subtree: true });
</script>
