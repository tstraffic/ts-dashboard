<% } else if (currentView === 'list') { %>
<!-- ============ LIST VIEW ============ -->
<div class="bookings-list-wrap">
  <div class="overflow-x-auto">
    <table class="bookings-table">
      <thead>
        <tr>
          <th class="w-8"></th>
          <th class="sortable">Job # <svg class="w-3 h-3 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></th>
          <th>Status</th>
          <th class="sortable">Start</th>
          <th>End</th>
          <th>Client</th>
          <th>Project</th>
          <th>Team Leader</th>
          <th>People</th>
          <th>Vehicles</th>
          <th>Address</th>
          <th>Order #</th>
        </tr>
      </thead>
      <tbody>
        <% bookings.forEach(booking => {
          const start = new Date(booking.startDateTime);
          const end = new Date(booking.endDateTime);
          const confirmedCount = booking.personnel.filter(p => p.confirmed).length;
        %>
        <tr class="booking-list-row" data-status="<%= booking.status %>" onclick="openBookingDetail(<%= booking.id %>)">
          <td>
            <div class="list-status-bar status-<%= booking.status %>"></div>
          </td>
          <td><span class="job-id-chip">#<%= booking.id %></span></td>
          <td>
            <span class="list-status-badge status-<%= booking.status %>">
              <%= booking.status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
            </span>
          </td>
          <td class="whitespace-nowrap"><%= start.toLocaleDateString('en-AU', {day:'2-digit',month:'short'}) %> <%= String(start.getHours()).padStart(2,'0') %>:<%= String(start.getMinutes()).padStart(2,'0') %></td>
          <td class="whitespace-nowrap"><%= String(end.getHours()).padStart(2,'0') %>:<%= String(end.getMinutes()).padStart(2,'0') %></td>
          <td><%= booking.project.client %></td>
          <td class="max-w-xs truncate"><%= booking.project.name %></td>
          <td><%= booking.supervisor %></td>
          <td>
            <span class="<%= confirmedCount < booking.personnel.length ? 'text-amber-600 font-medium' : 'text-emerald-600' %>">
              <%= confirmedCount %>/<%= booking.personnel.length %>
            </span>
          </td>
          <td><%= booking.vehicles.length %></td>
          <td class="max-w-xs truncate text-gray-500"><%= booking.project.address %></td>
          <td><%= booking.project.orderNumber %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="bookings-pagination">
    <div class="pagination-info">Showing 1-<%= bookings.length %> of <%= bookings.length %> bookings</div>
    <div class="pagination-controls">
      <button class="page-btn" disabled>First</button>
      <button class="page-btn" disabled>&lt; Prev</button>
      <button class="page-btn active">1</button>
      <button class="page-btn">Next &gt;</button>
      <button class="page-btn">Last</button>
    </div>
    <div class="pagination-size">
      <select class="filter-select filter-select-sm">
        <option>Show 25</option>
        <option>Show 50</option>
        <option selected>Show 100</option>
      </select>
    </div>
  </div>
</div>
<% } else if (currentView === 'calendar') { %>
<!-- ============ CALENDAR VIEW ============ -->
<%
  const calDate = new Date(currentDate + 'T00:00:00');
  const calYear = calDate.getFullYear();
  const calMonth = calDate.getMonth();
  const firstDay = new Date(calYear, calMonth, 1);
  const lastDay = new Date(calYear, calMonth + 1, 0);
  const startPad = firstDay.getDay(); // 0=Sun
  const totalDays = lastDay.getDate();
  const monthName = calDate.toLocaleDateString('en-AU', { month: 'long', year: 'numeric' });
  const prevMonth = new Date(calYear, calMonth - 1, 1).toISOString().split('T')[0];
  const nextMonth = new Date(calYear, calMonth + 1, 1).toISOString().split('T')[0];

  // Group bookings by date
  const bookingsByDate = {};
  bookings.forEach(bk => {
    const d = bk.startDateTime ? bk.startDateTime.split('T')[0] : '';
    if (d) { if (!bookingsByDate[d]) bookingsByDate[d] = []; bookingsByDate[d].push(bk); }
  });
%>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
  <!-- Calendar Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <a href="/bookings?view=calendar&date=<%= prevMonth %>" class="p-2 hover:bg-gray-100 rounded-lg transition">
      <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h2 class="text-lg font-bold text-gray-900"><%= monthName %></h2>
    <a href="/bookings?view=calendar&date=<%= nextMonth %>" class="p-2 hover:bg-gray-100 rounded-lg transition">
      <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Day Headers -->
  <div class="grid grid-cols-7 border-b border-gray-100">
    <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(d => { %>
      <div class="px-2 py-2 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= d %></div>
    <% }); %>
  </div>

  <!-- Calendar Grid -->
  <div class="grid grid-cols-7" id="calendar-grid">
    <% for (let i = 0; i < startPad; i++) { %>
      <div class="min-h-[100px] border-b border-r border-gray-50 bg-gray-50/50"></div>
    <% } %>
    <% for (let day = 1; day <= totalDays; day++) {
      const dateStr = calYear + '-' + String(calMonth + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
      const today = new Date().toISOString().split('T')[0];
      const isToday = dateStr === today;
      const dayBookings = bookingsByDate[dateStr] || [];
      const statusColors = { client_booking: 'bg-gray-400', unconfirmed: 'bg-purple-400', confirmed: 'bg-amber-400', locked: 'bg-gray-500', conflict: 'bg-red-500', green_to_go: 'bg-emerald-400', in_progress: 'bg-blue-400', complete: 'bg-gray-400', finalised: 'bg-indigo-400', cancelled: 'bg-gray-300', late_cancellation: 'bg-red-700', on_hold: 'bg-yellow-400' };
    %>
      <div class="min-h-[100px] border-b border-r border-gray-50 p-1 <%= isToday ? 'bg-brand-50/30' : '' %>"
        data-date="<%= dateStr %>"
        ondragover="event.preventDefault(); this.classList.add('bg-brand-50')"
        ondragleave="this.classList.remove('bg-brand-50')"
        ondrop="handleCalDrop(event, '<%= dateStr %>')">
        <div class="flex items-center justify-between mb-1">
          <a href="/bookings?view=board&date=<%= dateStr %>" class="text-xs font-semibold <%= isToday ? 'w-6 h-6 bg-brand-600 text-white rounded-full flex items-center justify-center' : 'text-gray-500 hover:text-brand-600' %>"><%= day %></a>
          <% if (dayBookings.length > 0) { %>
            <span class="text-[9px] font-bold text-gray-400"><%= dayBookings.length %></span>
          <% } %>
        </div>
        <div class="space-y-0.5">
          <% dayBookings.slice(0, 3).forEach(bk => {
            const t = new Date(bk.startDateTime);
            const timeStr = String(t.getHours()).padStart(2, '0') + ':' + String(t.getMinutes()).padStart(2, '0');
          %>
            <div class="text-[10px] leading-tight px-1 py-0.5 rounded cursor-pointer truncate hover:opacity-80 transition
              <%= statusColors[bk.status] || 'bg-gray-200' %> text-white font-medium"
              draggable="true"
              ondragstart="event.dataTransfer.setData('text/plain', '<%= bk.id %>')"
              onclick="window.location='/bookings/<%= bk.id %>'"
              title="<%= bk.project.name %> — <%= bk.supervisor || 'No supervisor' %>">
              <%= timeStr %> <%= bk.project.name ? bk.project.name.substring(0, 20) : 'BK-' + bk.id %>
            </div>
          <% }); %>
          <% if (dayBookings.length > 3) { %>
            <a href="/bookings?view=board&date=<%= dateStr %>" class="text-[9px] text-brand-600 font-medium pl-1">+<%= dayBookings.length - 3 %> more</a>
          <% } %>
        </div>
      </div>
    <% } %>
    <% const totalCells = startPad + totalDays; const remaining = 7 - (totalCells % 7); %>
    <% if (remaining < 7) { for (let i = 0; i < remaining; i++) { %>
      <div class="min-h-[100px] border-b border-r border-gray-50 bg-gray-50/50"></div>
    <% } } %>
  </div>
</div>

<script>
function handleCalDrop(event, targetDate) {
  event.preventDefault();
  event.currentTarget.classList.remove('bg-brand-50');
  const bookingId = event.dataTransfer.getData('text/plain');
  if (!bookingId) return;
  // Move booking to new date via API
  fetch('/bookings/' + bookingId + '/move', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'x-csrf-token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
    body: 'new_date=' + encodeURIComponent(targetDate)
  }).then(r => {
    if (r.ok) window.location.reload();
    else alert('Failed to move booking');
  });
}
</script>

<% } else if (currentView === 'map') { %>
<!-- ============ MAP VIEW ============ -->
<div class="space-y-4">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden" style="height: 500px; position: relative;">
    <div id="map-container" style="width:100%; height:100%; background: #e8ecf1;">
      <!-- Map rendered via Leaflet -->
    </div>
  </div>

  <% if (bookings.length === 0) { %>
    <div class="text-center py-6">
      <p class="text-sm text-gray-400">No bookings with location data for this date.</p>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Booking</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Title</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Address</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Time</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(bk => {
            const addr = [bk.project.address, bk.suburb, bk.state].filter(Boolean).join(', ') || '-';
            const t = new Date(bk.startDateTime);
            const timeStr = String(t.getHours()).padStart(2,'0') + ':' + String(t.getMinutes()).padStart(2,'0');
            const statusLabel = (bk.status || '').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            const statusColors = { client_booking: 'bg-gray-100 text-gray-600', unconfirmed: 'bg-purple-100 text-purple-700', confirmed: 'bg-amber-100 text-amber-700', locked: 'bg-gray-200 text-gray-700', conflict: 'bg-red-100 text-red-700', green_to_go: 'bg-emerald-100 text-emerald-700', in_progress: 'bg-blue-100 text-blue-700', complete: 'bg-gray-100 text-gray-500', finalised: 'bg-indigo-100 text-indigo-700', cancelled: 'bg-gray-100 text-gray-400 line-through', late_cancellation: 'bg-red-100 text-red-700', on_hold: 'bg-yellow-100 text-yellow-700' };
          %>
            <tr class="border-b border-gray-50 hover:bg-gray-50/50 cursor-pointer" onclick="openBookingDetail(<%= bk.id %>)">
              <td class="px-4 py-2.5 font-mono text-xs text-gray-500"><%= bk.bookingNumber %></td>
              <td class="px-4 py-2.5 font-medium text-gray-900"><%= bk.project.name || '-' %></td>
              <td class="px-4 py-2.5 text-gray-500 max-w-[250px] truncate"><%= addr %></td>
              <td class="px-4 py-2.5"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusColors[bk.status] || 'bg-gray-100 text-gray-600' %>"><%= statusLabel %></span></td>
              <td class="px-4 py-2.5 text-gray-500"><%= timeStr %></td>
