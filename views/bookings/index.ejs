<% locals.currentPage = 'bookings' %>

<!-- Sub-nav tab bar -->
<div class="bookings-subnav">
  <a href="/bookings?view=board" class="subnav-tab <%= currentView === 'board' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
    Board
  </a>
  <a href="/bookings?view=list" class="subnav-tab <%= currentView === 'list' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
    List
  </a>
  <a href="/bookings?view=calendar" class="subnav-tab <%= currentView === 'calendar' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    Calendar
  </a>
  <a href="/bookings?view=map" class="subnav-tab <%= currentView === 'map' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    Map
  </a>
  <a href="/bookings?view=timeline" class="subnav-tab <%= currentView === 'timeline' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
    Timeline
  </a>
  <a href="/bookings?view=archive" class="subnav-tab <%= currentView === 'archive' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
    Archive
  </a>
  <a href="/bookings?view=requests" class="subnav-tab <%= currentView === 'requests' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    Requests
  </a>
</div>

<!-- Page header -->
<div class="bookings-header">
  <div class="bookings-header-left">
    <h1 class="bookings-title">Bookings<br><span><%= currentView.charAt(0).toUpperCase() + currentView.slice(1) %></span></h1>
  </div>
  <div class="bookings-header-center">
    <div class="bookings-search-wrap">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="bookings-search" class="bookings-search-input" placeholder="Search bookings..." value="<%= currentSearch %>" data-shortcut="/">
      <kbd class="bookings-search-kbd">/</kbd>
    </div>
  </div>
  <div class="bookings-header-right">
    <button class="bookings-action-btn" title="Export" onclick="exportBookingsCSV()">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Export
    </button>
    <button onclick="openBookingForm()" class="bookings-new-btn">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Booking
    </button>
  </div>
</div>

<!-- Status summary pills — Traffio lifecycle -->
<div class="bookings-status-bar">
  <a href="/bookings" class="status-pill <%= !currentStatus ? 'active' : '' %>">
    <span class="status-dot" style="background:#6B7280"></span>
    All <strong><%= stats.total %></strong>
  </a>
  <a href="/bookings?status=green_to_go" class="status-pill <%= currentStatus === 'green_to_go' ? 'active' : '' %>">
    <span class="status-dot" style="background:#16A34A"></span>
    Green to Go <strong><%= stats.greenToGo %></strong>
  </a>
  <a href="/bookings?status=confirmed" class="status-pill <%= currentStatus === 'confirmed' ? 'active' : '' %>">
    <span class="status-dot" style="background:#D97706"></span>
    Confirmed <strong><%= stats.confirmed %></strong>
  </a>
  <a href="/bookings?status=in_progress" class="status-pill <%= currentStatus === 'in_progress' ? 'active' : '' %>">
    <span class="status-dot" style="background:#2563EB"></span>
    In Progress <strong><%= stats.inProgress %></strong>
  </a>
  <a href="/bookings?status=complete" class="status-pill <%= currentStatus === 'complete' ? 'active' : '' %>">
    <span class="status-dot" style="background:#6B7280"></span>
    Completed <strong><%= stats.complete %></strong>
  </a>
  <a href="/bookings?status=unconfirmed" class="status-pill <%= currentStatus === 'unconfirmed' ? 'active' : '' %>">
    <span class="status-dot" style="background:#7C3AED"></span>
    Unconfirmed <strong><%= stats.unconfirmed %></strong>
  </a>
  <a href="/bookings?status=finalised" class="status-pill <%= currentStatus === 'finalised' ? 'active' : '' %>">
    <span class="status-dot" style="background:#2563EB"></span>
    Finalised <strong><%= stats.finalised %></strong>
  </a>
  <a href="/bookings?status=cancelled" class="status-pill <%= currentStatus === 'cancelled' ? 'active' : '' %>">
    <span class="status-dot" style="background:#9CA3AF"></span>
    Cancelled <strong><%= stats.cancelled %></strong>
  </a>
</div>

<!-- Filter bar -->
<div class="bookings-filter-bar" id="bookings-filter-bar">
  <div class="filter-row-main">
    <!-- Date Navigator -->
    <div class="date-navigator">
      <button id="date-prev" class="date-nav-arrow" title="Previous day">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <div class="date-nav-label">
        <span class="date-nav-sub">Date, from 6 am</span>
        <input type="date" id="bookings-date" class="date-nav-input" value="<%= currentDate %>">
      </div>
      <button id="date-next" class="date-nav-arrow" title="Next day">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
      <button id="date-today" class="date-today-btn">Today</button>
    </div>

    <!-- Depot filter -->
    <div class="filter-dropdown-wrap">
      <label class="filter-label">Depot</label>
      <select id="filter-depot" class="filter-select">
        <option value="">All Depots</option>
        <% depots.forEach(d => { %>
        <option value="<%= d %>" <%= currentDepot === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
      </select>
    </div>

    <!-- More filters toggle -->
    <button id="toggle-more-filters" class="filter-toggle-btn">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
      More Filters
      <svg class="w-3 h-3 chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
    </button>

    <!-- Deleted items -->
    <select class="filter-select filter-select-sm" id="deleted-filter" onchange="applyDeletedFilter(this.value)">
      <option value="hide"<%= (typeof currentDeleted !== 'undefined' && currentDeleted === 'hide') || typeof currentDeleted === 'undefined' ? ' selected' : '' %>>Hide Deleted</option>
      <option value="show"<%= typeof currentDeleted !== 'undefined' && currentDeleted === 'show' ? ' selected' : '' %>>Show Deleted</option>
      <option value="only"<%= typeof currentDeleted !== 'undefined' && currentDeleted === 'only' ? ' selected' : '' %>>Only Deleted</option>
    </select>
  </div>

  <!-- Expandable filter rows -->
  <div class="filter-expanded-rows" id="filter-expanded" style="display:none;">
    <div class="filter-grid">
      <div class="filter-chip-group">
        <label>Client</label>
        <select class="filter-select"><option>All Clients</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Project</label>
        <select class="filter-select"><option>All Projects</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Supplier</label>
        <select class="filter-select"><option>All Suppliers</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Classification</label>
        <select class="filter-select"><option>All</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Planning</label>
        <select class="filter-select"><option>All</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Booking Status</label>
        <select class="filter-select"><option>All Statuses</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Location</label>
        <select class="filter-select"><option>All Locations</option></select>
      </div>
      <div class="filter-chip-group">
        <label>People</label>
        <select class="filter-select"><option>All People</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Billable</label>
        <select class="filter-select">
          <option>Billable & Non-billable</option>
          <option>Billable only</option>
          <option>Non-billable only</option>
        </select>
      </div>
      <div class="filter-chip-group">
        <label>Invoiced</label>
        <select class="filter-select">
          <option>Invoiced & Not Invoiced</option>
          <option>Invoiced only</option>
          <option>Not invoiced only</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Sort controls -->
  <div class="sort-controls">
    <button class="sort-btn active">
      <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Sort by time
    </button>
    <button class="sort-btn">
      <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      Sort by depot
    </button>
    <button class="sort-btn">
      <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Sort by client
    </button>
    <div class="sort-spacer"></div>
    <button class="sort-btn" id="toggle-resource-panel" title="Toggle resource panel">
      <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Resources
    </button>
  </div>
</div>

<% if (currentView === 'board') { %>
<!-- ============ BOARD VIEW ============ -->
<div class="bookings-board-wrap">
  <div class="bookings-board" id="bookings-board">
    <% if (bookings.length === 0) { %>
    <!-- Empty state -->
    <div class="bookings-empty">
      <div class="bookings-empty-icon">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-500 mt-4">No bookings found</h3>
      <p class="text-sm text-gray-400 mt-1 max-w-sm">There are no bookings matching your current filters. Try adjusting your filters or create a new booking.</p>
      <div class="flex gap-3 mt-5">
        <a href="/bookings" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition">Clear Filters</a>
        <button onclick="openBookingForm()" class="px-4 py-2 text-sm font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition">New Booking</button>
      </div>
    </div>
    <% } else { %>
    <% bookings.forEach((booking, idx) => {
      const start = new Date(booking.startDateTime);
      const end = new Date(booking.endDateTime);
      const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const dayName = days[start.getDay()];
      const startStr = `${dayName} ${start.getDate()}/${start.getMonth()+1} ${start.getHours()}:${String(start.getMinutes()).padStart(2,'0')}${start.getHours() < 12 ? 'am' : 'pm'}`;
      const endStr = `${end.getHours()}:${String(end.getMinutes()).padStart(2,'0')}${end.getHours() < 12 ? 'am' : 'pm'}`;
      const confirmedCount = booking.personnel.filter(p => p.confirmed).length;
      const totalPeople = booking.personnel.length;
    %>
    <div class="booking-card<%= booking.deletedAt ? ' booking-card-deleted' : '' %>" data-id="<%= booking.id %>" data-status="<%= booking.status %>" style="animation-delay: <%= idx * 40 %>ms"
      ondragover="event.preventDefault(); this.classList.add('drag-over')"
      ondragleave="this.classList.remove('drag-over')"
      ondrop="this.classList.remove('drag-over'); handleCrewDrop(event, <%= booking.id %>)"
      oncontextmenu="showCardContextMenu(event, <%= booking.id %>, '<%= booking.status %>')"
      <!-- Quick actions (hover) -->
      <div class="booking-card-actions">
        <button class="card-action-btn" title="Edit" onclick="event.stopPropagation(); openBookingFormEdit(<%= booking.id %>)">
          <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </button>
        <button class="card-action-btn" title="Duplicate" onclick="event.stopPropagation(); duplicateBooking(<%= booking.id %>)">
          <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
        <% if (!booking.deletedAt) { %>
        <button class="card-action-btn card-action-delete" title="Delete" onclick="event.stopPropagation(); deleteBooking(<%= booking.id %>, '<%= (booking.bookingNumber || '#' + booking.id).replace(/'/g, "\\'") %>')">
          <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
        <% } else { %>
        <button class="card-action-btn card-action-restore" title="Restore" onclick="event.stopPropagation(); undeleteBooking(<%= booking.id %>, '<%= (booking.bookingNumber || '#' + booking.id).replace(/'/g, "\\'") %>')">
          <svg class="w-3.5 h-3.5" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        </button>
        <% } %>
      </div>

      <%
        const statusLabels = { client_booking: 'Client Bk.', unconfirmed: 'Unconfirmed', confirmed: 'Confirmed', locked: 'Locked', conflict: 'Conflict', green_to_go: 'Green To Go', in_progress: 'In Progress', complete: 'Complete', finalised: 'Finalised', cancelled: 'Cancelled', late_cancellation: 'Late Cancel', on_hold: 'On Hold' };
      %>

      <!-- Card body -->
      <div class="booking-card-body" onclick="openBookingDetail(<%= booking.id %>)">
        <!-- Top row: status pill + booking ID -->
        <div class="bc-top-row">
          <span class="bc-status-pill status-<%= booking.status %>"><%= statusLabels[booking.status] || booking.status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></span>
          <span class="bc-id"><%= booking.bookingNumber || '#' + booking.id %></span>
        </div>

        <!-- Project title -->
        <div class="bc-title"><%= booking.project.name %></div>

        <!-- Time -->
        <div class="bc-meta">
          <svg class="bc-meta-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span><%= startStr %> &ndash; <%= endStr %></span>
        </div>

        <!-- Client -->
        <% if (booking.project.client) { %>
        <div class="bc-meta">
          <svg class="bc-meta-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          <span><%= booking.project.client %></span>
        </div>
        <% } %>

        <!-- Address -->
        <% if (booking.project.address) { %>
        <div class="bc-meta">
          <svg class="bc-meta-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span><%= booking.project.address %></span>
        </div>
        <% } %>

        <!-- Site contact -->
        <% if (booking.supervisor) { %>
        <div class="bc-meta">
          <svg class="bc-meta-icon" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span><%= booking.supervisor %></span>
        </div>
        <% } %>

        <!-- Vehicles -->
        <% if (booking.vehicles.length > 0) { %>
        <div class="bc-vehicles">
          <% booking.vehicles.forEach(function(v) { %>
          <span class="bc-vehicle-tag">
            <svg class="w-3 h-3" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
            <%= v.registration ? v.registration.toUpperCase() : v.name %>
          </span>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Crew avatars -->
      <% if (booking.personnel.length > 0) { %>
      <div class="bc-crew-avatars">
        <div class="bc-avatar-stack">
          <% const maxShow = 4; %>
          <% booking.personnel.slice(0, maxShow).forEach(function(p, i) { %>
          <%
            const initials = p.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
            const roleLabel = p.role === 'traffic_controller' ? 'TC' : (p.role === 'leading_hand' ? 'TL' : (p.role === 'pilot_vehicle' ? 'PV' : ''));
            const roleClass = roleLabel ? roleLabel.toLowerCase() : '';
          %>
          <div class="bc-avatar <%= roleClass %><%= p.confirmed ? ' confirmed' : '' %>" title="<%= p.name %><%= roleLabel ? ' (' + roleLabel + ')' : '' %><%= p.confirmed ? ' ✓' : '' %>"><%= initials %></div>
          <% }) %>
          <% if (booking.personnel.length > maxShow) { %>
          <div class="bc-avatar bc-avatar-more">+<%= booking.personnel.length - maxShow %></div>
          <% } %>
        </div>
        <span class="bc-crew-count <%= confirmedCount === totalPeople ? 'all-good' : '' %>"><%= confirmedCount %>/<%= totalPeople %></span>
      </div>
      <% } %>

      <!-- Alerts: still required + warnings -->
      <% if ((booking.stillRequired && booking.stillRequired.length > 0) || (booking.personnel.filter(p => p.warnings && p.warnings.length > 0).length > 0) || booking.scheduleWarning) { %>
      <div class="bc-alerts">
        <% if (booking.stillRequired && booking.stillRequired.length > 0) { %>
        <div class="bc-alert-row bc-alert-required">
          <svg class="w-3 h-3 flex-shrink-0" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          <span>Need: <% booking.stillRequired.forEach(function(req, i) { %><%= i > 0 ? ', ' : '' %><%= req %><% }) %></span>
        </div>
        <% } %>
        <% const allWarnings = booking.personnel.filter(p => p.warnings && p.warnings.length > 0); %>
        <% if (allWarnings.length > 0) { %>
        <% allWarnings.forEach(function(p) { p.warnings.forEach(function(w) { %>
        <div class="bc-alert-row bc-alert-warn">
          <svg class="w-3 h-3 flex-shrink-0" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          <span><%= w %></span>
        </div>
        <% }) }) %>
        <% } %>
        <% if (booking.scheduleWarning) { %>
        <div class="bc-alert-row bc-alert-warn">
          <svg class="w-3 h-3 flex-shrink-0" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01"/></svg>
          <span><%= booking.scheduleWarning %></span>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- Footer -->
      <div class="bc-footer">
        <div class="bc-footer-badges">
          <span class="bc-badge<%= booking.dockets > 0 ? ' active' : '' %>" title="Dockets">
            <svg class="w-3 h-3" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <%= booking.dockets %>
          </span>
          <span class="bc-badge<%= booking.notes > 0 ? ' active' : '' %>" title="Notes">
            <svg class="w-3 h-3" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
            <%= booking.notes %>
          </span>
          <span class="bc-badge<%= booking.tasks > 0 ? ' active' : '' %>" title="Tasks">
            <svg class="w-3 h-3" width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            <%= booking.tasks %>
          </span>
        </div>
        <span class="bc-depot"><%= booking.depot %></span>
      </div>
    </div>
    <% }) %>
    <% } %>
  </div>

  </div>

<!-- Card context menu -->
<div class="card-ctx-menu" id="card-ctx-menu" style="display:none;">
  <div class="card-ctx-title" id="card-ctx-title">Change Status</div>
  <button class="card-ctx-item" data-status="client_booking">Client Booking</button>
  <button class="card-ctx-item" data-status="unconfirmed">Unconfirmed</button>
