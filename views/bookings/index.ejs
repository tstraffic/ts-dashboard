            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Title</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Client</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Date</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Depot</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            <th class="text-left px-4 py-2.5 text-[10px] font-bold text-gray-400 uppercase tracking-widest">Crew</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(bk => {
            const d = new Date(bk.startDateTime);
            const dateStr2 = d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
            const statusLabel = (bk.status || '').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            const statusColors = { complete: 'bg-gray-100 text-gray-500', finalised: 'bg-indigo-100 text-indigo-700', cancelled: 'bg-gray-100 text-gray-400', late_cancellation: 'bg-red-100 text-red-700' };
          %>
            <tr class="border-b border-gray-50 hover:bg-gray-50/50 cursor-pointer" onclick="openBookingDetail(<%= bk.id %>)">
              <td class="px-4 py-2.5 font-mono text-xs text-gray-500"><%= bk.bookingNumber %></td>
              <td class="px-4 py-2.5 font-medium text-gray-900 max-w-[200px] truncate"><%= bk.project.name || '-' %></td>
              <td class="px-4 py-2.5 text-gray-500"><%= bk.project.client || '-' %></td>
              <td class="px-4 py-2.5 text-gray-500 text-xs"><%= dateStr2 %></td>
              <td class="px-4 py-2.5 text-gray-500"><%= bk.depot || '-' %></td>
              <td class="px-4 py-2.5"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusColors[bk.status] || 'bg-gray-100 text-gray-600' %>"><%= statusLabel %></span></td>
              <td class="px-4 py-2.5 text-gray-500"><%= bk.personnel.length %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<% } else if (currentView === 'requests') { %>
<!-- ============ REQUESTS VIEW ============ -->
<div class="space-y-4">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm px-5 py-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <h3 class="text-sm font-bold text-gray-900">Client Booking Requests</h3>
        <p class="text-xs text-gray-400">Bookings submitted by clients awaiting confirmation. Accept to move to Unconfirmed.</p>
      </div>
      <span class="ml-auto inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-amber-100 text-amber-700"><%= bookings.length %></span>
    </div>
  </div>

  <% if (bookings.length === 0) { %>
    <div class="text-center py-12">
      <svg class="w-10 h-10 text-gray-300 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="text-sm text-gray-400 mt-3">No pending requests. All caught up!</p>
    </div>
  <% } else { %>
    <div class="grid gap-3">
      <% bookings.forEach(bk => {
        const d = new Date(bk.startDateTime);
        const dateStr2 = d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
        const timeStr = String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
        const addr = [bk.project.address].filter(Boolean).join(', ') || 'No address';
      %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 hover:shadow-md transition">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-mono text-xs text-gray-400"><%= bk.bookingNumber %></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-amber-100 text-amber-700">Client Booking</span>
              </div>
              <h4 class="text-sm font-bold text-gray-900 truncate"><%= bk.project.name || 'Untitled' %></h4>
              <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <%= dateStr2 %> at <%= timeStr %>
                </span>
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= addr %>
                </span>
                <% if (bk.project.client) { %>
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
                    <%= bk.project.client %>
                  </span>
                <% } %>
                <% if (bk.depot) { %>
                  <span class="font-medium text-gray-400"><%= bk.depot %></span>
                <% } %>
              </div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <button onclick="event.stopPropagation(); changeBookingStatus(<%= bk.id %>, 'unconfirmed')" class="px-3 py-1.5 bg-emerald-600 text-white text-xs font-medium rounded-lg hover:bg-emerald-700 transition">
                <svg class="w-3.5 h-3.5 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Accept
              </button>
              <button onclick="event.stopPropagation(); changeBookingStatus(<%= bk.id %>, 'cancelled')" class="px-3 py-1.5 bg-white text-red-600 text-xs font-medium rounded-lg border border-red-200 hover:bg-red-50 transition">Decline</button>
              <button onclick="event.stopPropagation(); openBookingDetail(<%= bk.id %>)" class="px-3 py-1.5 bg-white text-gray-600 text-xs font-medium rounded-lg border border-gray-200 hover:bg-gray-50 transition">View</button>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<% } else { %>
<!-- Other views placeholder -->
<div class="bookings-empty">
  <div class="bookings-empty-icon">
    <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
  </div>
  <h3 class="text-lg font-semibold text-gray-500 mt-4"><%= currentView.charAt(0).toUpperCase() + currentView.slice(1) %> View</h3>
  <p class="text-sm text-gray-400 mt-1">This view is coming soon. Use the Board or List view for now.</p>
</div>
<% } %>

<!-- Booking Detail Modal -->
<div class="booking-modal-backdrop" id="booking-modal-backdrop" style="display:none;">
  <div class="booking-modal" id="booking-modal">
    <div class="booking-modal-header">
      <h2 id="modal-title">Booking Details</h2>
      <button onclick="closeBookingDetail()" class="modal-close-btn">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Modal tabs -->
    <div class="booking-modal-tabs">
      <button class="modal-tab active" data-tab="overview">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
        Overview
      </button>
      <button class="modal-tab" data-tab="resources">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Resources
      </button>
      <button class="modal-tab" data-tab="tasks">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        Tasks
      </button>
      <button class="modal-tab" data-tab="dockets">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Dockets
      </button>
      <button class="modal-tab" data-tab="notes">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Notes
      </button>
      <button class="modal-tab" data-tab="history">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        History
      </button>
      <button class="modal-tab" data-tab="documents">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        Documents
      </button>
    </div>

    <!-- Status workflow -->
    <div class="booking-modal-status-flow" id="modal-status-flow">
      <!-- Filled by JS -->
    </div>

    <!-- Modal body (scrollable) -->
    <div class="booking-modal-body" id="modal-body">
      <!-- Loading skeleton -->
      <div class="modal-skeleton" id="modal-skeleton">
        <div class="skeleton-line w-3/4 h-5"></div>
        <div class="skeleton-line w-1/2 h-4 mt-3"></div>
        <div class="skeleton-line w-full h-20 mt-4"></div>
        <div class="skeleton-line w-full h-20 mt-3"></div>
      </div>
      <div id="modal-content" style="display:none;"></div>
    </div>

    <!-- Modal footer -->
    <div class="booking-modal-footer">
      <button class="modal-footer-btn secondary" onclick="cloneFromModal()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Clone
      </button>
      <button class="modal-footer-btn secondary" onclick="printBooking()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
        Print
      </button>
      <div class="flex-1"></div>
      <button class="modal-footer-btn primary" id="modal-edit-btn" onclick="closeBookingDetail(); openBookingFormEdit(this.dataset.bookingId);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </button>
    </div>
  </div>
</div>

<!-- Booking Form Slide-in Panel -->
<%
  const formDepots = typeof depots !== 'undefined' ? depots : [];
  const formJobs = typeof jobs !== 'undefined' ? jobs : [];
  const formClients = typeof clients !== 'undefined' ? clients : [];
  const formSupervisors = typeof supervisors !== 'undefined' ? supervisors : [];
  const formContacts = typeof contacts !== 'undefined' ? contacts : [];
  const formCrew = typeof crewForSelect !== 'undefined' ? crewForSelect : [];
  const formStatuses = [
    { val: 'client_booking', label: 'Client Booking' },
    { val: 'unconfirmed', label: 'Unconfirmed' },
    { val: 'confirmed', label: 'Confirmed' },
    { val: 'locked', label: 'Locked' },
    { val: 'conflict', label: 'Conflict' },
    { val: 'green_to_go', label: 'Green to Go' },
    { val: 'in_progress', label: 'In Progress' },
    { val: 'complete', label: 'Complete' },
    { val: 'finalised', label: 'Finalised' },
    { val: 'cancelled', label: 'Cancelled' },
    { val: 'late_cancellation', label: 'Late Cancellation' },
    { val: 'on_hold', label: 'On Hold' },
  ];
  const formReqTypes = [
    '1x TC Crew','2x TC Crew','3x TC Crew','4x TC Crew','5x TC Crew',
    '6x TC Crew','7x TC Crew','8x TC Crew','9x TC Crew','10x TC Crew',
    'Arrow Board','Hoist Operator','IP','Pilot Vehicle','Pilot Vehicle Lead',
    'Portable Traffic Lights','Ute','TL 2x TC Crew','TL 3x TC Crew',
    'TL 4x TC Crew','TL 5x TC Crew','VMS Board','VMS Ute','Water Cart','Truck'
  ];
%>
<div class="booking-modal-backdrop" id="booking-form-backdrop" style="display:none;">
  <div class="booking-modal" id="booking-form-modal">
    <div class="booking-modal-header">
      <h2 id="form-modal-title">New Booking</h2>
      <button onclick="closeBookingForm()" class="modal-close-btn">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div class="booking-modal-body">
      <form method="POST" action="/bookings" id="booking-slide-form">
        <%- include('../partials/csrf') %>

        <!-- BOOKING DEPOT -->
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING DEPOT</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Depot <span class="text-red-500">*</span></label>
              <select name="depot" required class="modal-input">
                <option value="">-- Select --</option>
                <% formDepots.forEach(d => { %><option value="<%= d %>"><%= d %></option><% }); %>
              </select>
            </div>
            <div class="modal-field">
              <label>Supervisor</label>
              <select name="supervisor_id" class="modal-input">
                <option value="">-- Select --</option>
                <% formSupervisors.forEach(s => { %><option value="<%= s.id %>"><%= s.full_name %></option><% }); %>
              </select>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Status</label>
              <select name="status" class="modal-input">
                <% formStatuses.forEach(s => { %><option value="<%= s.val %>"><%= s.label %></option><% }); %>
              </select>
            </div>
          </div>
        </div>

        <!-- CLIENT INFORMATION -->
        <div class="modal-section highlight">
          <h4 class="modal-section-title">CLIENT INFORMATION</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Client <span class="text-red-500">*</span></label>
              <select name="client_id" required class="modal-input">
                <option value="">-- Select --</option>
                <% formClients.forEach(c => { %><option value="<%= c.id %>"><%= c.company_name %></option><% }); %>
              </select>
            </div>
            <div class="modal-field">
              <label>Job / Project</label>
              <select name="job_id" class="modal-input">
                <option value="">-- Select --</option>
                <% formJobs.forEach(j => { %><option value="<%= j.id %>"><%= j.job_number ? j.job_number + ' — ' : '' %><%= j.job_name %></option><% }); %>
              </select>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Order Number</label>
              <input type="text" name="order_number" class="modal-input" placeholder="PO or order number">
            </div>
            <div class="modal-field">
              <label>Billing Code</label>
              <input type="text" name="billing_code" class="modal-input" placeholder="Cost centre">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Client Contact</label>
              <input type="text" name="client_contact" class="modal-input" placeholder="Contact name or phone">
            </div>
            <div class="modal-field">
              <label>Location Context</label>
              <input type="text" name="location_context" class="modal-input" placeholder="e.g. Near intersection">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Requester</label>
              <select name="requester_id" class="modal-input">
                <option value="">-- Select --</option>
                <% formCrew.forEach(c => { %><option value="<%= c.id %>"><%= c.full_name %></option><% }); %>
              </select>
            </div>
            <div class="modal-field">
              <label>Planner</label>
              <select name="planner_id" class="modal-input">
                <option value="">-- Select --</option>
                <% formCrew.forEach(c => { %><option value="<%= c.id %>"><%= c.full_name %></option><% }); %>
              </select>
            </div>
          </div>
          <% if (formContacts.length > 0) { %>
          <div class="modal-field" style="margin-top:12px">
            <label>Site Contacts</label>
            <div class="grid grid-cols-2 gap-1 max-h-24 overflow-y-auto border border-gray-200 rounded-lg p-2" id="panel-site-contacts">
              <% formContacts.forEach(ct => { %>
                <label class="flex items-center gap-1.5 text-xs text-gray-700 cursor-pointer">
                  <input type="checkbox" name="site_contacts" value="<%= ct.id %>" class="rounded border-gray-300 text-brand-600">
                  <%= ct.full_name %>
                </label>
              <% }); %>
            </div>
          </div>
          <% } %>
        </div>

        <!-- BOOKING INFORMATION -->
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING INFORMATION</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Start Date <span class="text-red-500">*</span></label>
              <input type="date" name="start_date" required class="modal-input" value="<%= typeof currentDate !== 'undefined' ? currentDate : '' %>">
            </div>
            <div class="modal-field">
              <label>Start Time <span class="text-red-500">*</span></label>
              <input type="time" name="start_time" required class="modal-input" value="06:00">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>End Date <span class="text-red-500">*</span></label>
              <input type="date" name="end_date" required class="modal-input" value="<%= typeof currentDate !== 'undefined' ? currentDate : '' %>">
            </div>
            <div class="modal-field">
              <label>End Time <span class="text-red-500">*</span></label>
              <input type="time" name="end_time" required class="modal-input" value="14:30">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Depot Meeting Time <span class="text-red-500">*</span></label>
              <input type="time" name="depot_meeting_time" required class="modal-input">
            </div>
            <div class="modal-field">
              <label>Straight to Site Time</label>
              <input type="time" name="straight_to_site_time" class="modal-input">
            </div>
          </div>
          <div class="modal-field" style="grid-column: span 2">
            <label>Title <span class="text-red-500">*</span></label>
            <input type="text" name="title" required class="modal-input" placeholder="e.g. Lane closure — Main St resurfacing">
          </div>
          <div class="modal-field" style="margin-top:12px">
            <label>Description</label>
            <textarea name="description" rows="2" class="modal-input" placeholder="Brief description..."></textarea>
          </div>
          <div class="modal-field" style="margin-top:12px">
            <label>Tags</label>
            <input type="text" name="booking_tags" class="modal-input" placeholder="Comma-separated, e.g. night-work, RMS">
          </div>
          <div class="flex gap-6 mt-3">
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="is_emergency" value="1" class="rounded border-gray-300 text-red-600"> Emergency
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="is_callout" value="1" class="rounded border-gray-300 text-amber-600"> Callout
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="billable" value="1" checked class="rounded border-gray-300 text-brand-600"> Billable
            </label>
          </div>
        </div>

        <!-- LOCATION -->
        <div class="modal-section">
          <h4 class="modal-section-title">LOCATION</h4>
          <div class="modal-field" style="margin-bottom:12px">
            <label>Site Address</label>
            <input type="text" name="site_address" class="modal-input" placeholder="Street address">
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Suburb</label>
              <input type="text" name="suburb" class="modal-input" placeholder="e.g. Parramatta">
            </div>
            <div class="modal-field">
              <label>State</label>
              <input type="text" name="state" class="modal-input" placeholder="NSW" value="NSW">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Postcode</label>
              <input type="text" name="postcode" class="modal-input" placeholder="2000">
            </div>
            <div class="modal-field">
              <label>Works Direction</label>
              <input type="text" name="works_direction" class="modal-input" placeholder="e.g. Eastbound">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Worksite Location</label>
              <input type="text" name="worksite_location" class="modal-input" placeholder="e.g. Northbound lanes">
            </div>
            <div class="modal-field">
              <label>Location Notes</label>
              <input type="text" name="location_notes" class="modal-input" placeholder="Access instructions">
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Chainage From</label>
              <input type="text" name="chainage_from" class="modal-input" placeholder="12.500">
            </div>
            <div class="modal-field">
              <label>Chainage To</label>
              <input type="text" name="chainage_to" class="modal-input" placeholder="14.200">
            </div>
          </div>
          <div class="flex gap-6 mt-3">
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="has_mobile_works" value="1" class="rounded border-gray-300 text-brand-600"> Mobile Works
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="checkbox" name="marker_is_accurate" value="1" class="rounded border-gray-300 text-brand-600"> Marker Accurate
            </label>
          </div>
        </div>

        <!-- BOOKING TYPE -->
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING TYPE</h4>
          <div class="flex gap-6">
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="radio" name="booking_type" value="regular" checked class="text-brand-600"> Regular
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
              <input type="radio" name="booking_type" value="hire" class="text-brand-600"> Hire
            </label>
          </div>
        </div>

        <!-- BOOKING REQUIREMENTS -->
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING REQUIREMENTS</h4>
          <div id="panel-req-rows"></div>
          <button type="button" onclick="addPanelReqRow()" class="mt-2 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs text-orange-600 hover:text-orange-800 border border-orange-300 rounded-lg hover:bg-orange-50 transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Add Requirement
          </button>
          <div class="mt-3">
            <label class="block text-xs text-gray-400 mb-1">Special Instructions</label>
            <textarea name="requirements_text" rows="2" class="modal-input" placeholder="PPE requirements, site rules..."></textarea>
          </div>
        </div>

        <!-- NOTES -->
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING POOL & NOTES</h4>
          <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer mb-3">
            <input type="checkbox" name="is_booking_pool" value="1" class="rounded border-gray-300 text-brand-600"> Add to booking pool
          </label>
          <div class="modal-field">
            <label>Internal Notes</label>
            <textarea name="notes" rows="2" class="modal-input" placeholder="Internal notes..."></textarea>
          </div>
        </div>
      </form>
    </div>

    <div class="booking-modal-footer">
      <button type="button" onclick="closeBookingForm()" class="modal-footer-btn secondary">Cancel</button>
      <div class="flex-1"></div>
      <button type="submit" form="booking-slide-form" class="modal-footer-btn primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Create Booking
      </button>
    </div>
  </div>
</div>

<script>
// Bookings Board JS
(function() {
  // Search shortcut
  document.addEventListener('keydown', function(e) {
    if (e.key === '/' && !e.ctrlKey && !e.metaKey && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
      e.preventDefault();
      document.getElementById('bookings-search').focus();
    }
    if (e.key === 'Escape') {
      closeBookingDetail();
    }
  });

  // Search with debounce
  let searchTimeout;
  const searchInput = document.getElementById('bookings-search');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const params = new URLSearchParams(window.location.search);
        if (this.value) params.set('search', this.value);
        else params.delete('search');
        window.location.href = '/bookings?' + params.toString();
      }, 500);
    });
  }

  // Date navigation
  const dateInput = document.getElementById('bookings-date');
  if (dateInput) {
    dateInput.addEventListener('change', function() {
      const params = new URLSearchParams(window.location.search);
      params.set('date', this.value);
      window.location.href = '/bookings?' + params.toString();
    });

    document.getElementById('date-prev')?.addEventListener('click', function() {
      const d = new Date(dateInput.value);
      d.setDate(d.getDate() - 1);
      dateInput.value = d.toISOString().split('T')[0];
      dateInput.dispatchEvent(new Event('change'));
    });

    document.getElementById('date-next')?.addEventListener('click', function() {
      const d = new Date(dateInput.value);
      d.setDate(d.getDate() + 1);
      dateInput.value = d.toISOString().split('T')[0];
      dateInput.dispatchEvent(new Event('change'));
    });

    document.getElementById('date-today')?.addEventListener('click', function() {
      dateInput.value = new Date().toISOString().split('T')[0];
      dateInput.dispatchEvent(new Event('change'));
    });
  }

  // Depot filter
  const depotSelect = document.getElementById('filter-depot');
  if (depotSelect) {
    depotSelect.addEventListener('change', function() {
      const params = new URLSearchParams(window.location.search);
      if (this.value) params.set('depot', this.value);
      else params.delete('depot');
      window.location.href = '/bookings?' + params.toString();
    });
  }

  // More filters toggle
  const toggleBtn = document.getElementById('toggle-more-filters');
  const expanded = document.getElementById('filter-expanded');
  if (toggleBtn && expanded) {
    toggleBtn.addEventListener('click', function() {
      const isOpen = expanded.style.display !== 'none';
      expanded.style.display = isOpen ? 'none' : 'block';
      this.classList.toggle('active', !isOpen);
      if (!isOpen) {
        expanded.style.animation = 'slideDown 0.25s ease-out';
      }
    });
  }

  // Resource panel toggle
  const resBtn = document.getElementById('toggle-resource-panel');
  const resPanel = document.getElementById('resource-panel');
  const resClose = document.getElementById('close-resource-panel');
  let _resourceData = null; // cache for filtering
  function loadResources() {
    const list = document.getElementById('resource-list');
    const label = document.getElementById('resource-count-label');
    if (!list) return;
    fetch('/bookings/resources?date=<%= currentDate %>')
      .then(r => r.json())
      .then(data => {
        _resourceData = data;
        renderResourceList(data);
      })
      .catch(() => { list.innerHTML = '<div class="p-4 text-center text-red-400 text-sm">Failed to load</div>'; });
  }
  function renderResourceList(data) {
    const list = document.getElementById('resource-list');
    const label = document.getElementById('resource-count-label');
    if (!list) return;
    label.textContent = data.available.length + ' available, ' + data.assigned.length + ' assigned';
    if (data.available.length === 0 && data.assigned.length === 0) {
      list.innerHTML = '<div class="p-4 text-center text-gray-400 text-sm">No crew members found</div>';
      return;
    }
    list.innerHTML = '';
    function renderItem(c, statusClass, statusLabel) {
      const initials = c.full_name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
      const warningHtml = (c.warnings && c.warnings.length > 0)
        ? '<div class="resource-warnings">' + c.warnings.map(w => '<span class="resource-warning-badge">' + w + '</span>').join('') + '</div>'
        : '';
      const blockedClass = c.blocked ? ' resource-item-blocked' : '';
      const safeRole = (c.role||'').replace(/'/g, "\\'");
      const safeName = c.full_name.replace(/'/g, "\\'");
      list.innerHTML += '<div class="resource-item' + blockedClass + '" draggable="' + (!c.blocked) + '" '
        + 'data-crew-id="' + c.id + '" '
        + 'data-crew-name="' + c.full_name + '" '
        + 'data-crew-role="' + (c.role||'') + '" '
        + 'data-depot="' + (c.depot||'').toLowerCase() + '" '
        + 'data-employment="' + (c.employment_type||'').toLowerCase() + '" '
        + 'data-blocked="' + (c.blocked ? '1' : '0') + '" '
        + 'data-first-aid="' + (c.has_first_aid ? '1' : '0') + '" '
        + 'data-can-drive="' + (c.can_drive_truck ? '1' : '0') + '" '
        + 'data-assigned="' + (statusClass === 'busy' ? '1' : '0') + '" '
        + (c.blocked ? '' : 'style="cursor:grab" ondragstart="event.dataTransfer.setData(\'application/crew\', JSON.stringify({id:' + c.id + ',name:\'' + safeName + '\',role:\'' + safeRole + '\'}))"')
        + '>'
        + '<div class="resource-avatar">' + initials + '</div>'
        + '<div class="resource-info">'
        + '<span class="resource-name">' + c.full_name + '</span>'
        + '<span class="resource-role">' + (c.role || '').replace(/_/g, ' ') + (c.employee_id ? ' · ' + c.employee_id : '') + '</span>'
        + warningHtml
        + '</div>'
        + '<span class="resource-status ' + statusClass + '">' + (c.blocked ? 'Blocked' : statusLabel) + '</span>'
        + '</div>';
    }
    data.available.forEach(c => renderItem(c, c.blocked ? 'blocked' : 'available', 'Available'));
    data.assigned.forEach(c => renderItem(c, 'busy', 'On shift'));
  }
  if (resBtn && resPanel) {
    resBtn.addEventListener('click', function() {
      const isOpen = resPanel.style.display !== 'none';
      resPanel.style.display = isOpen ? 'none' : 'block';
      this.classList.toggle('active', !isOpen);
      if (!isOpen) loadResources();
    });
  }
  if (resClose && resPanel) {
    resClose.addEventListener('click', function() {
      resPanel.style.display = 'none';
      if (resBtn) resBtn.classList.remove('active');
    });
  }

  // Distance pill clicks
  document.querySelectorAll('.distance-pill').forEach(pill => {
    pill.addEventListener('click', function() {
      this.closest('.distance-pills').querySelectorAll('.distance-pill').forEach(p => p.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Unified resource filtering — applies search, toggles, and dropdowns together
  function applyResourceFilters() {
    const searchQ = (document.getElementById('resource-search')?.value || '').toLowerCase();
    const specFilter = (document.getElementById('res-filter-spec')?.value || '').toLowerCase();
    const depotFilter = (document.getElementById('res-filter-depot')?.value || '').toLowerCase();
    const empFilter = (document.getElementById('res-filter-employment')?.value || '').toLowerCase();

    // Read active toggle states
    const activeToggles = {};
    document.querySelectorAll('.res-toggle-btn.active').forEach(btn => {
      activeToggles[btn.getAttribute('data-filter')] = true;
    });

    document.querySelectorAll('#resource-list .resource-item').forEach(item => {
      const name = (item.getAttribute('data-crew-name') || '').toLowerCase();
      const role = (item.getAttribute('data-crew-role') || '').toLowerCase();
      const depot = (item.getAttribute('data-depot') || '');
      const emp = (item.getAttribute('data-employment') || '');
      const isBlocked = item.getAttribute('data-blocked') === '1';
      const isAssigned = item.getAttribute('data-assigned') === '1';
      const hasFirstAid = item.getAttribute('data-first-aid') === '1';
      const canDrive = item.getAttribute('data-can-drive') === '1';

      let show = true;

      // Text search
      if (searchQ && !name.includes(searchQ)) show = false;

      // Specialisation dropdown
      if (specFilter && role !== specFilter) show = false;

      // Depot dropdown
      if (depotFilter && depot !== depotFilter.toLowerCase()) show = false;

      // Employment dropdown
      if (empFilter && emp !== empFilter.toLowerCase()) show = false;

      // Toggle: Only TLs — show only leading_hand/supervisor
      if (activeToggles['tl-only'] && role !== 'leading_hand' && role !== 'supervisor') show = false;

      // Toggle: Assigned — show only assigned crew
      if (activeToggles['assigned'] && !isAssigned) show = false;

      // Toggle: Blocked — show only blocked crew
      if (activeToggles['blocked'] && !isBlocked) show = false;

      // Toggle: Can Drive
      if (activeToggles['can-drive'] && !canDrive) show = false;

      // Toggle: Only First Aid
      if (activeToggles['first-aid'] && !hasFirstAid) show = false;

      item.style.display = show ? '' : 'none';
    });

    // Update visible count
    const visible = document.querySelectorAll('#resource-list .resource-item:not([style*="display: none"])').length;
    const total = document.querySelectorAll('#resource-list .resource-item').length;
    const label = document.getElementById('resource-count-label');
    if (label && total > 0) {
      label.textContent = visible + ' of ' + total + ' shown';
    }
  }

  // Resource panel search
  const resSearch = document.getElementById('resource-search');
  if (resSearch) {
    resSearch.addEventListener('input', applyResourceFilters);
  }

  // Resource toggle buttons — toggle active + filter
  document.querySelectorAll('.res-toggle-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      this.classList.toggle('active');
      applyResourceFilters();
    });
  });

  // Dropdown filters
  ['res-filter-spec', 'res-filter-depot', 'res-filter-employment'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.addEventListener('change', applyResourceFilters);
  });

  // Sort buttons
  document.querySelectorAll('.sort-btn:not(#toggle-resource-panel)').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sort-btn:not(#toggle-resource-panel)').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });

  // Modal tabs — switch visible content
  document.querySelectorAll('.modal-tab').forEach(tab => {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      const tabName = this.getAttribute('data-tab');
      document.querySelectorAll('.modal-tab-content').forEach(c => c.style.display = 'none');
      const target = document.getElementById('tab-' + tabName);
      if (target) target.style.display = '';
    });
  });

  // Card entrance animation
  document.querySelectorAll('.booking-card').forEach(card => {
    card.style.opacity = '0';
    card.style.transform = 'translateY(12px)';
  });
  requestAnimationFrame(() => {
    document.querySelectorAll('.booking-card').forEach(card => {
      const delay = card.style.animationDelay || '0ms';
      setTimeout(() => {
        card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, parseInt(delay));
    });
  });
})();

// Drag-and-drop: assign crew from resource panel to booking card
function handleCrewDrop(event, bookingId) {
  event.preventDefault();
  event.currentTarget.style.outline = '';
  event.currentTarget.style.outlineOffset = '';

  const crewData = event.dataTransfer.getData('application/crew');
  if (!crewData) return;

  try {
    const crew = JSON.parse(crewData);
    fetch('/bookings/' + bookingId + '/crew', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'x-csrf-token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
      body: 'crew_member_id=' + crew.id + '&role_on_site=' + encodeURIComponent(crew.role.replace(/_/g, ' '))
    }).then(r => {
      if (r.redirected || r.ok) {
        // Show toast and reload
        const toast = document.createElement('div');
        toast.className = 'booking-toast show';
        toast.innerHTML = '<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> ' + crew.name + ' assigned';
        document.body.appendChild(toast);
        setTimeout(() => { toast.remove(); window.location.reload(); }, 1200);
      }
    });
  } catch(e) { console.error('Drop error:', e); }
}

function openBookingDetail(id) {
  const backdrop = document.getElementById('booking-modal-backdrop');
  const modal = document.getElementById('booking-modal');
  const skeleton = document.getElementById('modal-skeleton');
  const content = document.getElementById('modal-content');
  const titleEl = document.getElementById('modal-title');
  const statusFlow = document.getElementById('modal-status-flow');

  backdrop.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  skeleton.style.display = 'block';
  content.style.display = 'none';

  setTimeout(() => {
    backdrop.classList.add('open');
    modal.classList.add('open');
  }, 10);

  // Fetch booking data
  fetch('/bookings/' + id, { headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(booking => {
      titleEl.textContent = 'Job ' + booking.id + ': ' + booking.project.name;
      // Store booking ID for edit button
      const editBtn = document.getElementById('modal-edit-btn');
      if (editBtn) editBtn.dataset.bookingId = booking.id;

      // Status flow — Traffio lifecycle
      const statuses = ['Client Bk.', 'Unconf.', 'Confirmed', 'Locked', 'Conflict', 'G T G', 'Complete', 'Finalised'];
      const statusKeys = ['client_booking', 'unconfirmed', 'confirmed', 'locked', 'conflict', 'green_to_go', 'complete', 'finalised'];
      const statusMap = { client_booking: 0, unconfirmed: 1, confirmed: 2, locked: 3, conflict: 4, green_to_go: 5, in_progress: 5, complete: 6, finalised: 7, cancelled: -1, late_cancellation: -1, on_hold: -1 };
      const activeIdx = statusMap[booking.status] ?? 0;
      const statusColours = ['#6B7280','#7C3AED','#D97706','#475569','#DC2626','#16A34A','#6B7280','#4F46E5'];
      statusFlow.innerHTML = statuses.map((s, i) => {
        const isActive = i === activeIdx;
        const isDone = activeIdx >= 0 && i < activeIdx;
        return `<button class="status-flow-step ${isActive ? 'active' : ''} ${isDone ? 'done' : ''}" style="${isActive ? 'background:' + statusColours[i] + ';color:#fff;border-color:' + statusColours[i] : ''}" onclick="changeBookingStatus(${booking.id}, '${statusKeys[i]}', this)">${s}</button>`;
      }).join('');

      const start = new Date(booking.startDateTime);
      const end = new Date(booking.endDateTime);

      content.innerHTML = `
        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING DEPOT</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Booking depot</label>
              <p>${booking.depot}</p>
            </div>
            <div class="modal-field">
              <label>Supplier</label>
              <p>-</p>
            </div>
          </div>
        </div>

        <div class="modal-section highlight">
          <h4 class="modal-section-title">CLIENT INFORMATION</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Client</label>
              <p class="font-medium">${booking.project.client}</p>
            </div>
            <div class="modal-field">
              <label>Location Context</label>
              <p>${booking.location_context || '-'}</p>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Project</label>
              <p class="text-brand-600 font-medium">${booking.project.name}</p>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Purchase Order / Client Job Number</label>
              <p>${booking.project.orderNumber}</p>
            </div>
            <div class="modal-field">
              <label>Client Billing Code</label>
              <p>${booking.project.billingCode}</p>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Requester</label>
              <p>${booking.requester_name || '-'}</p>
            </div>
            <div class="modal-field">
              <label>Planner</label>
              <p>${booking.planner_name || '-'}</p>
            </div>
          </div>
          <div class="modal-field">
            <label>Site Contacts</label>
            ${(booking.site_contact_names && booking.site_contact_names.length > 0)
              ? booking.site_contact_names.map(n => '<div class="modal-contact-pill">' + n + '</div>').join('')
              : '<div class="modal-contact-pill">' + booking.supervisor + '</div>'}
          </div>
        </div>

        <div class="modal-section">
          <h4 class="modal-section-title">BOOKING INFORMATION</h4>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Start Time</label>
              <p>${start.toLocaleDateString('en-AU')} ${String(start.getHours()).padStart(2,'0')}:${String(start.getMinutes()).padStart(2,'0')}</p>
            </div>
            <div class="modal-field">
              <label>Approximate End Time</label>
              <p class="text-amber-600 font-medium">${end.toLocaleDateString('en-AU')} ${String(end.getHours()).padStart(2,'0')}:${String(end.getMinutes()).padStart(2,'0')}</p>
            </div>
          </div>
          <div class="modal-field-grid">
            <div class="modal-field">
              <label>Depot Meeting Time</label>
              <p>${booking.depot_meeting_time || '-'}</p>
            </div>
            <div class="modal-field">
              <label>Straight-to-Site Time</label>
              <p>${booking.straight_to_site_time || '-'}</p>
            </div>
          </div>
          <div class="modal-field">
            <label>Booking Title</label>
            <p class="font-medium">${booking.title}</p>
          </div>
          ${booking.description ? `
          <div class="modal-field">
            <label>Booking Description</label>
            <p class="whitespace-pre-line text-gray-600">${booking.description}</p>
          </div>` : ''}
          <div class="modal-field">
            <label>Booking Tags</label>
            ${(booking.tags_list && booking.tags_list.length > 0)
              ? '<div class="flex flex-wrap gap-1">' + booking.tags_list.map(t => '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-brand-50 text-brand-700 border border-brand-200">' + t + '</span>').join('') + '</div>'
              : '<p class="text-gray-400">No tags</p>'}
          </div>
          ${booking.booking_type === 'hire' ? '<div class="modal-field"><label>Booking Type</label><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-amber-50 text-amber-700 border border-amber-200">Hire</span></div>' : ''}
          ${booking.is_booking_pool ? '<div class="modal-field"><label>Booking Pool</label><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-purple-50 text-purple-700 border border-purple-200">In Pool</span></div>' : ''}
        </div>

        <div class="modal-section">
          <h4 class="modal-section-title">LOCATION</h4>
          <div class="modal-field">
            <label>Main Address</label>
            <p>${booking.project.address}${booking.suburb ? ', ' + booking.suburb : ''}${booking.state ? ' ' + booking.state : ''}${booking.postcode ? ' ' + booking.postcode : ''}</p>
          </div>
          ${booking.worksite_location || booking.works_direction ? '<div class="modal-field-grid">' +
            (booking.worksite_location ? '<div class="modal-field"><label>Worksite Location</label><p>' + booking.worksite_location + '</p></div>' : '') +
            (booking.works_direction ? '<div class="modal-field"><label>Works Direction</label><p>' + booking.works_direction + '</p></div>' : '') +
          '</div>' : ''}
          ${booking.chainage_from || booking.chainage_to ? '<div class="modal-field-grid">' +
            '<div class="modal-field"><label>Chainage From</label><p>' + (booking.chainage_from || '-') + '</p></div>' +
            '<div class="modal-field"><label>Chainage To</label><p>' + (booking.chainage_to || '-') + '</p></div>' +
          '</div>' : ''}
          ${booking.location_notes ? '<div class="modal-field"><label>Location Notes</label><p class="text-gray-600">' + booking.location_notes + '</p></div>' : ''}
          ${booking.has_mobile_works ? '<div class="modal-field"><span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-blue-50 text-blue-700 border border-blue-200">Mobile Works</span></div>' : ''}
        </div>

        <div class="modal-section">
          <h4 class="modal-section-title">PERSONNEL (${booking.personnel.length})</h4>
          <div class="modal-personnel-list">
            ${booking.personnel.map(p => `
              <div class="modal-personnel-row">
                <span class="modal-personnel-role">${p.role === 'Team Leader' ? 'TL' : 'TC'}</span>
                <span class="modal-personnel-name">${p.name}</span>
                ${p.confirmed
                  ? '<svg class="w-5 h-5 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z"/></svg>'
                  : '<svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'}
              </div>
              ${p.qualWarning ? '<div class="modal-personnel-warning">' + p.qualWarning + '</div>' : ''}
            `).join('')}
          </div>
        </div>
      `;

      // Add tab wrapper and other tab content
      const overviewHtml = content.innerHTML;
      const bkId = booking.id;

      // Build Resources tab
      const crewHtml = (booking.crew || []).map(c => `
        <div class="flex items-center gap-3 p-2 rounded-lg bg-gray-50 mb-1">
          <div class="w-7 h-7 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-[10px] font-bold">${(c.full_name||'?').split(' ').map(n=>n[0]).join('').substring(0,2)}</div>
          <div class="flex-1"><span class="text-sm font-medium">${c.full_name||'Unknown'}</span> <span class="text-xs text-gray-400">${c.role_on_site||c.crew_role||''}</span></div>
          <span class="text-[10px] font-medium ${c.status==='confirmed'?'text-emerald-600':'text-amber-600'}">${c.status||'assigned'}</span>
        </div>
      `).join('') || '<p class="text-sm text-gray-400">No crew assigned yet.</p>';

      // Build Notes tab
      const notesHtml = (booking.allNotes || []).map(n => `
        <div class="p-3 rounded-lg bg-gray-50 border border-gray-100 mb-2">
          <div class="flex justify-between mb-1"><span class="text-xs font-medium text-gray-600">${n.author_name||'System'}</span><span class="text-[10px] text-gray-400">${n.created_at ? new Date(n.created_at).toLocaleDateString('en-AU',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : ''}</span></div>
          <p class="text-sm text-gray-700">${(n.content||'').replace(/</g,'&lt;')}</p>
        </div>
      `).join('') || '<p class="text-sm text-gray-400">No notes.</p>';

      // Build Dockets tab
      const docketsHtml = (booking.dockets || []).length > 0
        ? booking.dockets.map(d => `<a href="/bookings/${bkId}/dockets/${d.id}" class="block p-3 rounded-lg bg-gray-50 hover:bg-gray-100 mb-2 transition"><span class="text-sm font-medium">${d.docket_number}</span> <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-gray-100 text-gray-600 ml-2">${(d.status||'draft').replace(/_/g,' ')}</span></a>`).join('')
        : '<p class="text-sm text-gray-400">No dockets yet. <a href="/bookings/' + bkId + '" class="text-brand-600 hover:underline">Go to booking</a> to create one.</p>';

      // Build Documents tab
      const docsHtml = (booking.documents || []).length > 0
        ? booking.documents.map(d => `<div class="flex items-center gap-2 p-2 rounded-lg bg-gray-50 mb-1"><svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg><a href="/bookings/${bkId}/documents/${d.id}/download" class="text-sm font-medium text-brand-600 hover:text-brand-700">${d.title||d.original_name}</a></div>`).join('')
        : '<p class="text-sm text-gray-400">No documents.</p>';

      // Build History tab
      const historyHtml = (booking.activity || []).length > 0
        ? booking.activity.map(a => `<div class="flex items-start gap-3 mb-3"><div class="w-5 h-5 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5"><svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><div><p class="text-sm text-gray-700">${a.details||a.action}</p><p class="text-[10px] text-gray-400">${a.user_name||'System'} · ${a.created_at ? new Date(a.created_at).toLocaleDateString('en-AU',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}) : ''}</p></div></div>`).join('')
        : '<p class="text-sm text-gray-400">No activity recorded.</p>';

      content.innerHTML = `
        <div class="modal-tab-content" id="tab-overview">${overviewHtml}</div>
        <div class="modal-tab-content" id="tab-resources" style="display:none"><div class="modal-section"><h4 class="modal-section-title">CREW (${(booking.crew||[]).length})</h4>${crewHtml}</div></div>
        <div class="modal-tab-content" id="tab-tasks" style="display:none"><div class="modal-section"><p class="text-sm text-gray-400">Tasks linked to this booking will appear here.</p></div></div>
        <div class="modal-tab-content" id="tab-dockets" style="display:none"><div class="modal-section"><h4 class="modal-section-title">DOCKETS</h4>${docketsHtml}</div></div>
        <div class="modal-tab-content" id="tab-notes" style="display:none"><div class="modal-section"><h4 class="modal-section-title">NOTES</h4>
          <div class="flex gap-2 mb-3">
            <input type="text" id="modal-note-input" class="modal-input flex-1" placeholder="Add a note..." onkeydown="if(event.key==='Enter'){addNoteFromModal(${bkId});event.preventDefault();}">
            <button onclick="addNoteFromModal(${bkId})" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-700 transition">Add</button>
          </div>
          <div id="modal-notes-list">${notesHtml}</div>
        </div></div>
        <div class="modal-tab-content" id="tab-history" style="display:none"><div class="modal-section"><h4 class="modal-section-title">ACTIVITY LOG</h4>${historyHtml}</div></div>
        <div class="modal-tab-content" id="tab-documents" style="display:none"><div class="modal-section"><h4 class="modal-section-title">DOCUMENTS</h4>${docsHtml}</div></div>
      `;

      // Reset to overview tab
      document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
      document.querySelector('.modal-tab[data-tab="overview"]').classList.add('active');

      skeleton.style.display = 'none';
      content.style.display = 'block';
    })
    .catch(err => {
      console.error('Failed to load booking:', err);
      skeleton.innerHTML = '<p class="text-red-500 text-sm">Failed to load booking details.</p>';
    });
}

function closeBookingDetail() {
  const backdrop = document.getElementById('booking-modal-backdrop');
  const modal = document.getElementById('booking-modal');
  if (!backdrop || backdrop.style.display === 'none') return;
  backdrop.classList.remove('open');
  modal.classList.remove('open');
  setTimeout(() => {
    backdrop.style.display = 'none';
    document.body.style.overflow = '';
  }, 250);
}

function duplicateBooking(id) {
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
  fetch('/bookings/' + id + '/clone', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: ''
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      showToast('Cloned as ' + data.booking_number, 'success');
      setTimeout(() => window.location.reload(), 800);
    } else { showToast(data.error || 'Clone failed', 'error'); }
  }).catch(() => showToast('Clone failed', 'error'));
}

function changeBookingStatus(id, newStatus, btn) {
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
  fetch('/bookings/' + id + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: 'status=' + encodeURIComponent(newStatus)
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      showToast('Status → ' + newStatus.replace(/_/g, ' '), 'success');
      // Re-render status flow
      const statusFlow = document.getElementById('modal-status-flow');
      if (statusFlow) {
        const statuses = ['Client Bk.', 'Unconf.', 'Confirmed', 'Locked', 'Conflict', 'G T G', 'Complete', 'Finalised'];
        const statusKeys = ['client_booking', 'unconfirmed', 'confirmed', 'locked', 'conflict', 'green_to_go', 'complete', 'finalised'];
        const statusMap = { client_booking: 0, unconfirmed: 1, confirmed: 2, locked: 3, conflict: 4, green_to_go: 5, complete: 6, finalised: 7 };
        const activeIdx = statusMap[data.status] ?? 0;
        const statusColours = ['#6B7280','#7C3AED','#D97706','#475569','#DC2626','#16A34A','#6B7280','#4F46E5'];
        statusFlow.innerHTML = statuses.map((s, i) => {
          const isActive = i === activeIdx;
          const isDone = activeIdx >= 0 && i < activeIdx;
          return '<button class="status-flow-step ' + (isActive ? 'active' : '') + ' ' + (isDone ? 'done' : '') + '" style="' + (isActive ? 'background:' + statusColours[i] + ';color:#fff;border-color:' + statusColours[i] : '') + '" onclick="changeBookingStatus(' + id + ', \'' + statusKeys[i] + '\', this)">' + s + '</button>';
        }).join('');
      }
      // Reload page after brief delay so card status updates
      setTimeout(() => window.location.reload(), 1200);
    } else { showToast(data.error || 'Update failed', 'error'); }
  }).catch(() => showToast('Status update failed', 'error'));
}

function cloneFromModal() {
  const editBtn = document.getElementById('modal-edit-btn');
  if (!editBtn || !editBtn.dataset.bookingId) return;
  duplicateBooking(editBtn.dataset.bookingId);
  closeBookingDetail();
}

function printBooking() {
  const editBtn = document.getElementById('modal-edit-btn');
  if (!editBtn || !editBtn.dataset.bookingId) return;
  window.open('/bookings/' + editBtn.dataset.bookingId, '_blank');
}

function addNoteFromModal(bookingId) {
  const input = document.getElementById('modal-note-input');
  if (!input || !input.value.trim()) return;
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
  const content = input.value.trim();
  input.disabled = true;
  fetch('/bookings/' + bookingId + '/notes', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: 'content=' + encodeURIComponent(content)
  }).then(r => r.json()).then(data => {
    input.disabled = false;
    if (data.ok) {
      input.value = '';
      // Prepend the new note to the notes list
      const notesList = document.getElementById('modal-notes-list');
      if (notesList) {
        const noNotes = notesList.querySelector('.text-gray-400');
        if (noNotes) noNotes.remove();
        const noteEl = document.createElement('div');
        noteEl.className = 'p-3 rounded-lg bg-gray-50 border border-gray-100 mb-2';
        noteEl.innerHTML = '<div class="flex justify-between mb-1"><span class="text-xs font-medium text-gray-600">' + (data.author_name || 'You') + '</span><span class="text-[10px] text-gray-400">Just now</span></div><p class="text-sm text-gray-700">' + content.replace(/</g, '&lt;') + '</p>';
        notesList.insertBefore(noteEl, notesList.firstChild);
      }
      showToast('Note added', 'success');
    } else { showToast(data.error || 'Failed to add note', 'error'); }
  }).catch(() => { input.disabled = false; showToast('Failed to add note', 'error'); });
}

function showToast(message, type) {
  const toast = document.createElement('div');
  toast.className = 'booking-toast';
  const icon = type === 'error'
    ? '<svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
    : '<svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
  toast.innerHTML = icon + ' ' + message;
  document.body.appendChild(toast);
  requestAnimationFrame(() => toast.classList.add('show'));
  setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 300); }, 2000);
}

// Click backdrop to close
