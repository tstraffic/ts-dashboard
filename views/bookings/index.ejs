function changeBookingStatus(id, newStatus, btn) {
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
  const card = document.querySelector('.booking-card[data-id="' + id + '"]');
  const oldStatus = card ? card.getAttribute('data-status') : null;
  const statusLabels = { client_booking: 'Client Bk.', unconfirmed: 'Unconfirmed', confirmed: 'Confirmed', locked: 'Locked', conflict: 'Conflict', green_to_go: 'Green To Go', in_progress: 'In Progress', complete: 'Complete', finalised: 'Finalised', cancelled: 'Cancelled', late_cancellation: 'Late Cancel', on_hold: 'On Hold' };

  // Optimistic update: instantly update card status
  if (card) {
    card.setAttribute('data-status', newStatus);
    var pill = card.querySelector('.bc-status-pill');
    if (pill) {
      pill.className = 'bc-status-pill status-' + newStatus;
      pill.textContent = statusLabels[newStatus] || newStatus.replace(/_/g, ' ');
    }
    card.style.transition = 'transform 0.2s, opacity 0.2s';
    card.style.transform = 'scale(0.97)';
    card.style.opacity = '0.7';
    setTimeout(function() { card.style.transform = ''; card.style.opacity = ''; }, 300);
  }

  fetch('/bookings/' + id + '/status', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'x-csrf-token': csrf },
    body: 'status=' + encodeURIComponent(newStatus)
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      showToast('Status → ' + newStatus.replace(/_/g, ' '), 'success');
      // Re-render status flow in modal if open
      var statusFlow = document.getElementById('modal-status-flow');
      if (statusFlow) {
        var statuses = ['Client Bk.', 'Unconf.', 'Confirmed', 'Locked', 'Conflict', 'G T G', 'Complete', 'Finalised'];
        var statusKeys = ['client_booking', 'unconfirmed', 'confirmed', 'locked', 'conflict', 'green_to_go', 'complete', 'finalised'];
        var statusMap = { client_booking: 0, unconfirmed: 1, confirmed: 2, locked: 3, conflict: 4, green_to_go: 5, complete: 6, finalised: 7 };
        var activeIdx = statusMap[data.status] ?? 0;
        var statusColours = ['#6B7280','#7C3AED','#D97706','#475569','#DC2626','#16A34A','#6B7280','#4F46E5'];
        statusFlow.innerHTML = statuses.map(function(s, i) {
          var isActive = i === activeIdx;
          var isDone = activeIdx >= 0 && i < activeIdx;
          return '<button class="status-flow-step ' + (isActive ? 'active' : '') + ' ' + (isDone ? 'done' : '') + '" style="' + (isActive ? 'background:' + statusColours[i] + ';color:#fff;border-color:' + statusColours[i] : '') + '" onclick="changeBookingStatus(' + id + ', \'' + statusKeys[i] + '\', this)">' + s + '</button>';
        }).join('');
      }
    } else {
      // Revert optimistic update
      if (card && oldStatus) {
        card.setAttribute('data-status', oldStatus);
        var pill = card.querySelector('.bc-status-pill');
        if (pill) { pill.className = 'bc-status-pill status-' + oldStatus; pill.textContent = statusLabels[oldStatus] || oldStatus; }
      }
      showToast(data.error || 'Update failed', 'error');
    }
  }).catch(function() {
    // Revert on network error
    if (card && oldStatus) {
      card.setAttribute('data-status', oldStatus);
      var pill = card.querySelector('.bc-status-pill');
      if (pill) { pill.className = 'bc-status-pill status-' + oldStatus; pill.textContent = statusLabels[oldStatus] || oldStatus; }
    }
    showToast('Status update failed', 'error');
  });
}

