<% locals.currentPage = 'bookings' %>

<!-- Sub-nav tab bar -->
<div class="bookings-subnav">
  <a href="/bookings?view=board" class="subnav-tab <%= currentView === 'board' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
    Board
  </a>
  <a href="/bookings?view=list" class="subnav-tab <%= currentView === 'list' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
    List
  </a>
  <a href="/bookings?view=calendar" class="subnav-tab <%= currentView === 'calendar' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
    Calendar
  </a>
  <a href="/bookings?view=map" class="subnav-tab <%= currentView === 'map' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    Map
  </a>
  <a href="/bookings?view=archive" class="subnav-tab <%= currentView === 'archive' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
    Archive
  </a>
  <a href="/bookings?view=requests" class="subnav-tab <%= currentView === 'requests' ? 'active' : '' %>">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
    Requests
  </a>
</div>

<!-- Page header -->
<div class="bookings-header">
  <div class="bookings-header-left">
    <h1 class="bookings-title">Bookings<br><span>Board</span></h1>
  </div>
  <div class="bookings-header-center">
    <div class="bookings-search-wrap">
      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text" id="bookings-search" class="bookings-search-input" placeholder="Search bookings..." value="<%= currentSearch %>" data-shortcut="/">
      <kbd class="bookings-search-kbd">/</kbd>
    </div>
  </div>
  <div class="bookings-header-right">
    <button class="bookings-action-btn" title="Export">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Export
    </button>
    <a href="/bookings/new" class="bookings-new-btn">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Booking
    </a>
  </div>
</div>

<!-- Status summary pills -->
<div class="bookings-status-bar">
  <a href="/bookings" class="status-pill <%= !currentStatus ? 'active' : '' %>">
    <span class="status-dot" style="background:#6B7280"></span>
    All <strong><%= stats.total %></strong>
  </a>
  <a href="/bookings?status=green_to_go" class="status-pill <%= currentStatus === 'green_to_go' ? 'active' : '' %>">
    <span class="status-dot" style="background:#22C55E"></span>
    Green to Go <strong><%= stats.greenToGo %></strong>
  </a>
  <a href="/bookings?status=confirmed" class="status-pill <%= currentStatus === 'confirmed' ? 'active' : '' %>">
    <span class="status-dot" style="background:#3B82F6"></span>
    Confirmed <strong><%= stats.confirmed %></strong>
  </a>
  <a href="/bookings?status=in_progress" class="status-pill <%= currentStatus === 'in_progress' ? 'active' : '' %>">
    <span class="status-dot" style="background:#F59E0B"></span>
    In Progress <strong><%= stats.inProgress %></strong>
  </a>
  <a href="/bookings?status=completed" class="status-pill <%= currentStatus === 'completed' ? 'active' : '' %>">
    <span class="status-dot" style="background:#8B5CF6"></span>
    Completed <strong><%= stats.completed %></strong>
  </a>
  <a href="/bookings?status=unconfirmed" class="status-pill <%= currentStatus === 'unconfirmed' ? 'active' : '' %>">
    <span class="status-dot" style="background:#EF4444"></span>
    Unconfirmed <strong><%= stats.unconfirmed %></strong>
  </a>
  <a href="/bookings?status=cancelled" class="status-pill <%= currentStatus === 'cancelled' ? 'active' : '' %>">
    <span class="status-dot" style="background:#9CA3AF"></span>
    Cancelled <strong><%= stats.cancelled %></strong>
  </a>
</div>

<!-- Filter bar -->
<div class="bookings-filter-bar" id="bookings-filter-bar">
  <div class="filter-row-main">
    <!-- Date Navigator -->
    <div class="date-navigator">
      <button id="date-prev" class="date-nav-arrow" title="Previous day">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <div class="date-nav-label">
        <span class="date-nav-sub">Date, from 6 am</span>
        <input type="date" id="bookings-date" class="date-nav-input" value="<%= currentDate %>">
      </div>
      <button id="date-next" class="date-nav-arrow" title="Next day">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
      <button id="date-today" class="date-today-btn">Today</button>
    </div>

    <!-- Depot filter -->
    <div class="filter-dropdown-wrap">
      <label class="filter-label">Depot</label>
      <select id="filter-depot" class="filter-select">
        <option value="">All Depots</option>
        <% depots.forEach(d => { %>
        <option value="<%= d %>" <%= currentDepot === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
      </select>
    </div>

    <!-- More filters toggle -->
    <button id="toggle-more-filters" class="filter-toggle-btn">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
      More Filters
      <svg class="w-3 h-3 chevron-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
    </button>

    <!-- Deleted items -->
    <select class="filter-select filter-select-sm">
      <option>Hide Deleted</option>
      <option>Show Deleted</option>
      <option>Only Deleted</option>
    </select>
  </div>

  <!-- Expandable filter rows -->
  <div class="filter-expanded-rows" id="filter-expanded" style="display:none;">
    <div class="filter-grid">
      <div class="filter-chip-group">
        <label>Client</label>
        <select class="filter-select"><option>All Clients</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Project</label>
        <select class="filter-select"><option>All Projects</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Supplier</label>
        <select class="filter-select"><option>All Suppliers</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Classification</label>
        <select class="filter-select"><option>All</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Planning</label>
        <select class="filter-select"><option>All</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Booking Status</label>
        <select class="filter-select"><option>All Statuses</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Location</label>
        <select class="filter-select"><option>All Locations</option></select>
      </div>
      <div class="filter-chip-group">
        <label>People</label>
        <select class="filter-select"><option>All People</option></select>
      </div>
      <div class="filter-chip-group">
        <label>Billable</label>
        <select class="filter-select">
          <option>Billable & Non-billable</option>
          <option>Billable only</option>
          <option>Non-billable only</option>
        </select>
      </div>
      <div class="filter-chip-group">
        <label>Invoiced</label>
        <select class="filter-select">
          <option>Invoiced & Not Invoiced</option>
          <option>Invoiced only</option>
          <option>Not invoiced only</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Sort controls -->
  <div class="sort-controls">
    <button class="sort-btn active">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Sort by time
    </button>
    <button class="sort-btn">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      Sort by depot
    </button>
    <button class="sort-btn">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Sort by client
    </button>
    <div class="sort-spacer"></div>
    <button class="sort-btn" id="toggle-resource-panel" title="Toggle resource panel">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Resources
    </button>
  </div>
</div>

<% if (currentView === 'board') { %>
<!-- ============ BOARD VIEW ============ -->
<div class="bookings-board-wrap">
  <div class="bookings-board" id="bookings-board">
    <% if (bookings.length === 0) { %>
    <!-- Empty state -->
    <div class="bookings-empty">
      <div class="bookings-empty-icon">
        <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-gray-500 mt-4">No bookings found</h3>
      <p class="text-sm text-gray-400 mt-1 max-w-sm">There are no bookings matching your current filters. Try adjusting your filters or create a new booking.</p>
      <div class="flex gap-3 mt-5">
        <a href="/bookings" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition">Clear Filters</a>
        <a href="/bookings/new" class="px-4 py-2 text-sm font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition">New Booking</a>
      </div>
    </div>
    <% } else { %>
    <% bookings.forEach((booking, idx) => {
      const start = new Date(booking.startDateTime);
      const end = new Date(booking.endDateTime);
      const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      const dayName = days[start.getDay()];
      const startStr = `${dayName} ${start.getDate()}/${start.getMonth()+1} ${start.getHours()}:${String(start.getMinutes()).padStart(2,'0')}${start.getHours() < 12 ? 'am' : 'pm'}`;
      const endStr = `${end.getHours()}:${String(end.getMinutes()).padStart(2,'0')}${end.getHours() < 12 ? 'am' : 'pm'}`;
      const confirmedCount = booking.personnel.filter(p => p.confirmed).length;
      const totalPeople = booking.personnel.length;
    %>
    <div class="booking-card" data-id="<%= booking.id %>" data-status="<%= booking.status %>" style="animation-delay: <%= idx * 40 %>ms">
      <!-- Quick actions (hover) -->
      <div class="booking-card-actions">
        <button class="card-action-btn" title="Edit" onclick="event.stopPropagation(); openBookingDetail(<%= booking.id %>)">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </button>
        <button class="card-action-btn" title="Duplicate" onclick="event.stopPropagation(); duplicateBooking(<%= booking.id %>)">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </button>
      </div>

      <!-- Compact header: status + ID + time -->
      <div class="booking-card-header status-<%= booking.status %>">
        <span class="booking-status-label"><%= booking.status.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></span>
        <span class="booking-id">#<%= booking.id %></span>
      </div>

      <!-- Card body — clean and scannable -->
      <div class="booking-card-body" onclick="openBookingDetail(<%= booking.id %>)">
        <div class="booking-title-row">
          <span class="booking-project-title"><%= booking.project.name %></span>
        </div>

        <div class="booking-info-grid">
          <div class="booking-info-item">
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span><%= startStr %> &ndash; <%= endStr %></span>
          </div>
          <div class="booking-info-item">
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span><%= booking.project.client %></span>
          </div>
          <div class="booking-info-item">
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span><%= booking.project.address %></span>
          </div>
        </div>

        <!-- Compact crew summary row -->
        <div class="booking-crew-summary">
          <div class="crew-summary-left">
            <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="font-medium text-gray-700"><%= booking.supervisor %></span>
            <span class="crew-count-badge <%= confirmedCount === totalPeople ? 'all-confirmed' : 'partial' %>">
              <%= confirmedCount %>/<%= totalPeople %>
            </span>
          </div>
          <% if (booking.vehicles.length > 0) { %>
          <div class="vehicle-badge">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
            <%= booking.vehicles.length %>
          </div>
          <% } %>
        </div>

        <% if (booking.scheduleWarning) { %>
        <div class="booking-schedule-warning-inline">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01"/></svg>
          <%= booking.scheduleWarning %>
        </div>
        <% } %>
      </div>

      <!-- Compact footer — single row with counts -->
      <div class="booking-card-footer-compact">
        <span class="footer-badge<%= booking.dockets > 0 ? ' has-count' : '' %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <%= booking.dockets %>
        </span>
        <span class="footer-badge<%= booking.notes > 0 ? ' has-count' : '' %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <%= booking.notes %>
        </span>
        <span class="footer-badge<%= booking.tasks > 0 ? ' has-count' : '' %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          <%= booking.tasks %>
        </span>
        <span class="footer-badge<%= booking.docs > 0 ? ' has-count' : '' %>">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
          <%= booking.docs %>
        </span>
        <span class="depot-tag"><%= booking.depot %></span>
      </div>
    </div>
    <% }) %>
    <% } %>
  </div>

  <!-- Right resource panel (togglable) -->
  <div class="resource-panel" id="resource-panel" style="display:none;">
    <div class="resource-panel-header">
      <h3>Resources</h3>
      <button id="close-resource-panel" class="resource-close-btn">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="resource-panel-body">
      <div class="resource-filter-group">
        <label>Specialisation</label>
        <select class="filter-select"><option>All</option><option>Traffic Controller</option><option>Team Leader</option><option>Pilot Vehicle</option></select>
      </div>
      <div class="resource-filter-group">
        <label>Depot</label>
        <select class="filter-select">
          <option>All Depots</option>
          <% depots.forEach(d => { %>
          <option><%= d %></option>
          <% }) %>
        </select>
      </div>
      <div class="resource-filter-group">
        <label>Employment Type</label>
