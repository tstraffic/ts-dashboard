function exportBookingsCSV() {
  const data = <%- JSON.stringify(bookings.map(b => ({
    booking_number: b.bookingNumber,
    status: b.status,
    title: b.project.name,
    client: b.project.client,
    start: b.startDateTime,
    end: b.endDateTime,
    depot: b.depot,
    supervisor: b.supervisor,
    address: b.project.address,
    crew_count: b.personnel.length
  }))) %>;
  if (!data.length) { showToast('No bookings to export', 'error'); return; }
  const headers = ['Booking #','Status','Title','Client','Start','End','Depot','Supervisor','Address','Crew'];
  const rows = data.map(r => [r.booking_number, r.status, r.title, r.client, r.start, r.end, r.depot, r.supervisor, r.address, r.crew_count].map(v => '"' + String(v || '').replace(/"/g, '""') + '"').join(','));
  const csv = [headers.join(','), ...rows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'bookings-<%= currentDate %>.csv';
  a.click();
  URL.revokeObjectURL(a.href);
  showToast('Exported ' + data.length + ' bookings', 'success');
}
</script>
