<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function() {
  const mapEl = document.getElementById('map-container');
  if (!mapEl) return;
  const map = L.map(mapEl).setView([-33.87, 151.0], 10); // Sydney default
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors', maxZoom: 18
  }).addTo(map);

  const statusColors = { client_booking: '#6B7280', unconfirmed: '#7C3AED', confirmed: '#D97706', locked: '#475569', conflict: '#DC2626', green_to_go: '#16A34A', in_progress: '#3B82F6', complete: '#6B7280', finalised: '#4F46E5', cancelled: '#9CA3AF', late_cancellation: '#B91C1C', on_hold: '#CA8A04' };
  const bookings = <%- JSON.stringify(bookings.map(b => ({ id: b.id, name: b.project.name, address: b.project.address, status: b.status, lat: b.latitude || null, lng: b.longitude || null, bookingNumber: b.bookingNumber, supervisor: b.supervisor, startDateTime: b.startDateTime }))) %>;
  const markers = [];
  bookings.forEach(bk => {
    if (bk.lat && bk.lng) {
      const color = statusColors[bk.status] || '#6B7280';
      const marker = L.circleMarker([bk.lat, bk.lng], { radius: 8, fillColor: color, color: '#fff', weight: 2, fillOpacity: 0.9 }).addTo(map);
      marker.bindPopup('<strong>' + (bk.name || bk.bookingNumber) + '</strong><br>' + (bk.address || '') + '<br><a href="/bookings/' + bk.id + '">View booking</a>');
      markers.push(marker);
    }
  });
  if (markers.length > 0) {
    const group = L.featureGroup(markers);
    map.fitBounds(group.getBounds().pad(0.1));
  }
})();
</script>

