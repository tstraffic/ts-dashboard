<% locals.currentPage = 'bookings' %>
<%
  const isEdit = typeof booking !== 'undefined' && booking;

  function val(field) {
    if (!isEdit || booking[field] == null) return '';
    return booking[field];
  }

  function selected(field, value) {
    if (!isEdit) return '';
    return String(booking[field]) === String(value) ? 'selected' : '';
  }

  function checked(field) {
    if (!isEdit) return '';
    return booking[field] ? 'checked' : '';
  }

  // Site contacts (JSON array of IDs)
  const siteContactIds = isEdit && booking.site_contacts_arr ? booking.site_contacts_arr : [];

  // Requirements grid prepopulation
  const existingReqs = isEdit && booking.requirements ? booking.requirements : [];

  const statusOptions = [
    { val: 'client_booking', label: 'Client Booking' },
    { val: 'unconfirmed', label: 'Unconfirmed' },
    { val: 'confirmed', label: 'Confirmed' },
    { val: 'locked', label: 'Locked' },
    { val: 'conflict', label: 'Conflict' },
    { val: 'green_to_go', label: 'Green to Go' },
    { val: 'in_progress', label: 'In Progress' },
    { val: 'complete', label: 'Complete' },
    { val: 'finalised', label: 'Finalised' },
    { val: 'cancelled', label: 'Cancelled' },
    { val: 'late_cancellation', label: 'Late Cancellation' },
    { val: 'on_hold', label: 'On Hold' },
  ];

  // Resource picker options. "Nx TC Crew" ships N traffic controllers + 1
  // ute automatically (see peopleCounts and the auto-totals JS below).
  // Standalone "TMP" and "Traffic Guidance Scheme" entries dropped at the
  // office's request — TMP is captured via "TMP with Traffic Management"
  // and the TGS document lives on Site Documents now.
  const requirementTypes = [
    '1x TC Crew', '2x TC Crew', '3x TC Crew', '4x TC Crew', '5x TC Crew',
    'Arrow Board', 'Hoist Operator', 'Labour', 'Light Tower', 'Permit',
    'Pod Truck', 'Portaboom', 'Security', 'Speed Advisory Sign', 'Spotter',
    'TMA (dry hire)', 'TMA (wet hire)', 'TMP with Traffic Management',
    'Traffic Controller', 'Trainee', 'VMS Board', 'VMS Ute', 'Vehicle',
  ];
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/bookings" class="hover:text-gray-900 transition">Bookings</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? 'Edit: ' + booking.booking_number : 'New Booking' %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Booking' : 'New Booking' %></h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update booking details and schedule' : 'Create a new booking for scheduling' %></p>
  </div>
  <% if (isEdit) { %>
    <a href="/bookings/<%= booking.id %>" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
      View booking
    </a>
  <% } %>
</div>

<!-- Quick nav — anchor links to every section so the form is navigable
     without endless scrolling. Sticks to the top on scroll. -->
<nav class="sticky top-0 z-20 bg-gray-50/95 backdrop-blur-sm border-b border-gray-200 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 py-2 mb-5 overflow-x-auto">
  <div class="flex items-center gap-1.5 text-xs font-semibold whitespace-nowrap">
    <a href="#sec-depot"     class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Depot</a>
    <a href="#sec-client"    class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Client</a>
    <a href="#sec-schedule"  class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Schedule</a>
    <a href="#sec-location"  class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Location</a>
    <a href="#sec-docs"      class="px-2.5 py-1 rounded text-brand-700 bg-brand-50">Site Docs</a>
    <a href="#sec-type"      class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Type</a>
    <a href="#sec-req"       class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Requirements</a>
    <a href="#sec-pool"      class="px-2.5 py-1 rounded text-gray-600 hover:bg-white hover:text-brand-700">Pool / Notes</a>
  </div>
</nav>

<form method="POST" action="<%= isEdit ? '/bookings/' + booking.id : '/bookings' %>" class="space-y-5">
  <%- include('../partials/csrf') %>

  <!-- Section 1: BOOKING DEPOT -->
  <div id="sec-depot"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">BOOKING DEPOT</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Depot <span class="text-red-500">*</span></label>
        <select name="depot" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Depot --</option>
          <% depots.forEach(d => { %>
            <option value="<%= d %>" <%= val('depot') === d ? 'selected' : '' %>><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Supervisor</label>
        <select name="supervisor_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Supervisor --</option>
          <% supervisors.forEach(s => { %>
            <option value="<%= s.id %>" <%= isEdit && booking.supervisor_id == s.id ? 'selected' : '' %>><%= s.full_name %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% statusOptions.forEach(s => { %>
            <option value="<%= s.val %>" <%= selected('status', s.val) %>><%= s.label %></option>
          <% }); %>
        </select>
      </div>
    </div>
  </div>

  <!-- Section 2: CLIENT INFORMATION -->
  <div id="sec-client"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">CLIENT INFORMATION</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Client <span class="text-red-500">*</span></label>
        <select name="client_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Client --</option>
          <% if (typeof clients !== 'undefined' && clients.length) { clients.forEach(c => { %>
            <option value="<%= c.id %>" <%= isEdit && booking.client_id == c.id ? 'selected' : '' %>><%= c.company_name %></option>
          <% }); } %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Job / Project <span class="text-red-500">*</span></label>
        <select name="job_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Job --</option>
          <% if (typeof jobs !== 'undefined' && jobs.length) { jobs.forEach(j => { %>
            <option value="<%= j.id %>" <%= isEdit && booking.job_id == j.id ? 'selected' : '' %>><%= j.job_number ? j.job_number + ' — ' : '' %><%= j.job_name %></option>
          <% }); } %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Location Context</label>
        <input type="text" name="location_context" value="<%= val('location_context') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Near intersection of Main & George">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Order Number</label>
        <input type="text" name="order_number" value="<%= val('order_number') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="PO or order number">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Billing Code</label>
        <input type="text" name="billing_code" value="<%= val('billing_code') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Cost centre or billing code">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Client Contact</label>
        <input type="text" name="client_contact" value="<%= val('client_contact') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Contact name or phone">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Requester</label>
        <select name="requester_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Requester --</option>
          <% if (typeof crewForSelect !== 'undefined') { crewForSelect.forEach(c => { %>
            <option value="<%= c.id %>" <%= isEdit && booking.requester_id == c.id ? 'selected' : '' %>><%= c.full_name %></option>
          <% }); } %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Planner</label>
        <select name="planner_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Planner --</option>
          <% if (typeof crewForSelect !== 'undefined') { crewForSelect.forEach(c => { %>
            <option value="<%= c.id %>" <%= isEdit && booking.planner_id == c.id ? 'selected' : '' %>><%= c.full_name %></option>
          <% }); } %>
        </select>
      </div>
    </div>
    <!-- Site Contacts -->
    <% if (typeof contacts !== 'undefined' && contacts.length > 0) { %>
    <div class="mt-4">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Site Contacts</label>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 max-h-32 overflow-y-auto border border-gray-200 rounded-lg p-3">
        <% contacts.forEach(ct => { %>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="site_contacts" value="<%= ct.id %>"
              <%= siteContactIds.includes(String(ct.id)) ? 'checked' : '' %>
              class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
            <%= ct.full_name %>
          </label>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Section 3: BOOKING INFORMATION -->
  <div id="sec-schedule"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">BOOKING INFORMATION</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Start Date <span class="text-red-500">*</span></label>
        <input type="date" name="start_date" value="<%= isEdit ? (val('start_date') || '') : '' %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Start Time <span class="text-red-500">*</span></label>
        <input type="time" name="start_time" value="<%= isEdit ? (val('start_time') || '') : '06:00' %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">End Date <span class="text-red-500">*</span></label>
        <input type="date" name="end_date" value="<%= isEdit ? (val('end_date') || '') : '' %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">End Time <span class="text-red-500">*</span></label>
        <input type="time" name="end_time" value="<%= isEdit ? (val('end_time') || '') : '14:30' %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Depot Meeting Time <span class="text-red-500">*</span></label>
        <input type="text" name="depot_meeting_time" value="<%= val('depot_meeting_time') %>" required
          inputmode="numeric" maxlength="5" placeholder="HH:MM" autocomplete="off"
          pattern="^([01][0-9]|2[0-3]):[0-5][0-9]$"
          title="Enter time in 24-hour HH:MM format, e.g. 07:30 or 14:45"
          data-time-mask
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent font-mono tabular-nums">
        <p class="text-[10px] text-gray-400 mt-1">24-hour format, e.g. 07:30 or 14:45</p>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Straight to Site Time</label>
        <input type="text" name="straight_to_site_time" value="<%= val('straight_to_site_time') %>"
          inputmode="numeric" maxlength="5" placeholder="HH:MM" autocomplete="off"
          pattern="^([01][0-9]|2[0-3]):[0-5][0-9]$"
          title="Enter time in 24-hour HH:MM format, e.g. 07:30 or 14:45"
          data-time-mask
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent font-mono tabular-nums">
        <p class="text-[10px] text-gray-400 mt-1">Leave blank if meeting at depot first</p>
      </div>
      <div class="lg:col-span-2 flex items-end gap-6">
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_emergency" id="is_emergency" value="1" <%= checked('is_emergency') %>
            class="rounded border-gray-300 text-red-600 focus:ring-red-500">
          <label for="is_emergency" class="text-sm text-gray-700">Emergency</label>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="is_callout" id="is_callout" value="1" <%= checked('is_callout') %>
            class="rounded border-gray-300 text-amber-600 focus:ring-amber-500">
          <label for="is_callout" class="text-sm text-gray-700">Callout</label>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="billable" id="billable" value="1" <%= isEdit ? checked('billable') : 'checked' %>
            class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
          <label for="billable" class="text-sm text-gray-700">Billable</label>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
      <div class="sm:col-span-2">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Title <span class="text-red-500">*</span></label>
        <input type="text" name="title" value="<%= val('title') %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Lane closure — Main St resurfacing">
      </div>
      <div class="sm:col-span-2">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Description</label>
        <textarea name="description" rows="2"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Brief description of the booking..."><%= val('description') %></textarea>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Tags</label>
        <input type="text" name="booking_tags" value="<%= isEdit && booking.booking_tags_str ? booking.booking_tags_str : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Comma-separated tags, e.g. night-work, road-closure, RMS">
      </div>
    </div>
  </div>

  <!-- Section 4: LOCATION -->
  <div id="sec-location"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">LOCATION</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="sm:col-span-2">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Site Address</label>
        <input type="text" name="site_address" value="<%= val('site_address') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Street address">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Suburb</label>
        <input type="text" name="suburb" value="<%= val('suburb') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Parramatta">
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">State</label>
          <input type="text" name="state" value="<%= val('state') %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
            placeholder="NSW">
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Postcode</label>
          <input type="text" name="postcode" value="<%= val('postcode') %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
            placeholder="2000">
        </div>
      </div>
    </div>
    <!-- Map placeholder -->
    <div class="mt-4 bg-gray-100 border border-gray-200 rounded-lg h-40 flex items-center justify-center text-gray-400 text-sm">
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Map integration coming soon
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Latitude</label>
        <input type="number" step="any" name="latitude" value="<%= val('latitude') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="-33.8688">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Longitude</label>
        <input type="number" step="any" name="longitude" value="<%= val('longitude') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="151.2093">
      </div>
      <div class="flex items-end">
        <div class="flex items-center gap-2">
          <input type="checkbox" name="marker_is_accurate" id="marker_is_accurate" value="1" <%= checked('marker_is_accurate') %>
            class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
          <label for="marker_is_accurate" class="text-sm text-gray-700">Marker is accurate</label>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Location Notes</label>
        <textarea name="location_notes" rows="2"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="Access instructions, landmarks, parking info..."><%= val('location_notes') %></textarea>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Worksite Location</label>
        <input type="text" name="worksite_location" value="<%= val('worksite_location') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Northbound lanes">
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Works Direction</label>
        <input type="text" name="works_direction" value="<%= val('works_direction') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. Eastbound">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Chainage From</label>
        <input type="text" name="chainage_from" value="<%= val('chainage_from') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. 12.500">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Chainage To</label>
        <input type="text" name="chainage_to" value="<%= val('chainage_to') %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. 14.200">
      </div>
      <div class="flex items-end">
        <div class="flex items-center gap-2">
          <input type="checkbox" name="has_mobile_works" id="has_mobile_works" value="1" <%= checked('has_mobile_works') %>
            class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
          <label for="has_mobile_works" class="text-sm text-gray-700">Mobile works</label>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 5: SITE DOCUMENTS — placeholder. The actual upload UI lives
       OUTSIDE the main form (below) because nested <form> tags aren't
       valid HTML. The anchor + summary card here is the in-flow marker;
       the upload card sits at the bottom of the page so the file inputs
       can post multipart without hijacking the main edit submission. -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <div class="flex items-center justify-between gap-2 flex-wrap">
      <div>
        <h2 class="booking-form-section-header" style="margin-bottom:0;">SITE DOCUMENTS</h2>
        <p class="text-xs text-gray-500 mt-0.5">TGS / TMP / ROL / Stage Plans · visible to crew on the worker portal under DOCS.</p>
      </div>
      <% if (isEdit) { %>
        <a href="#sec-docs" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-brand-50 text-brand-700 text-xs font-semibold hover:bg-brand-100">
          <%= (typeof bookingDocuments !== 'undefined' ? bookingDocuments.length : 0) %> attached · Manage below ↓
        </a>
      <% } else { %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-amber-100 text-amber-800">
          Save booking first
        </span>
      <% } %>
    </div>
  </div>

  <!-- Section 6: BOOKING TYPE -->
  <div id="sec-type"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">BOOKING TYPE</h2>
    <div class="flex gap-6">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="radio" name="booking_type" value="regular" <%= !isEdit || val('booking_type') === 'regular' || !val('booking_type') ? 'checked' : '' %>
          class="text-brand-600 focus:ring-brand-500">
        <span class="text-sm text-gray-700 font-medium">Regular</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="radio" name="booking_type" value="hire" <%= isEdit && val('booking_type') === 'hire' ? 'checked' : '' %>
          class="text-brand-600 focus:ring-brand-500">
        <span class="text-sm text-gray-700 font-medium">Hire</span>
      </label>
    </div>
  </div>

  <!-- Section 7: BOOKING REQUIREMENTS -->
  <div id="sec-req"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">BOOKING REQUIREMENTS</h2>
    <div id="requirements-grid">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">
            <th class="text-left pb-2 pr-2">Item Classification</th>
            <th class="text-left pb-2 pr-2 w-24">Qty</th>
            <th class="w-10 pb-2"></th>
          </tr>
        </thead>
        <tbody id="req-rows">
          <% if (existingReqs.length > 0) { existingReqs.forEach(r => { %>
          <tr class="req-row">
            <td class="pr-2 pb-2">
              <select name="req_resource_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
                <option value="">-- Select --</option>
                <% requirementTypes.forEach(rt => { %>
                  <option value="<%= rt %>" <%= r.resource_type === rt ? 'selected' : '' %>><%= rt %></option>
                <% }); %>
              </select>
            </td>
            <td class="pr-2 pb-2">
              <input type="number" name="req_quantity" value="<%= r.quantity_required %>" min="1"
                class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            </td>
            <td class="pb-2 text-center">
              <button type="button" onclick="this.closest('tr').remove(); updateReqTotals();"
                class="text-red-400 hover:text-red-600 transition p-1" title="Remove">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </td>
          </tr>
          <% }); } %>
        </tbody>
      </table>
      <button type="button" id="add-req-row"
        class="mt-2 inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-orange-600 hover:text-orange-800 border border-orange-300 rounded-lg hover:bg-orange-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add Requirement
      </button>
    </div>
    <!-- Totals summary -->
    <div id="req-totals" class="mt-4 flex gap-6 text-sm font-medium text-gray-500 border-t border-gray-100 pt-3">
      <span>People: <strong id="total-people" class="text-gray-900">0</strong></span>
      <span>Vehicles: <strong id="total-vehicles" class="text-gray-900">0</strong></span>
      <span>Equipment: <strong id="total-equipment" class="text-gray-900">0</strong></span>
    </div>

    <!-- Existing requirements_text field for free-text instructions -->
    <div class="mt-4">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Requirements / Special Instructions</label>
      <textarea name="requirements_text" rows="2"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        placeholder="PPE requirements, site-specific rules, equipment needed..."><%= val('requirements_text') %></textarea>
    </div>
  </div>

  <!-- Section 8: BOOKING POOL + NOTES -->
  <div id="sec-pool"></div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="booking-form-section-header">BOOKING POOL & NOTES</h2>
    <div class="flex items-center gap-2 mb-4">
      <input type="checkbox" name="is_booking_pool" id="is_booking_pool" value="1" <%= checked('is_booking_pool') %>
        class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
      <label for="is_booking_pool" class="text-sm text-gray-700 font-medium">Add to booking pool</label>
      <span class="text-xs text-gray-400 ml-1">(Available for other planners to claim)</span>
    </div>
    <div>
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Internal Notes</label>
      <textarea name="notes" rows="3"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        placeholder="Internal notes about this booking..."><%= val('notes') %></textarea>
    </div>
  </div>

  <!-- Submit -->
  <div class="flex items-center gap-3">
    <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <%= isEdit ? 'Update Booking' : 'Create Booking' %>
    </button>
    <a href="<%= isEdit ? '/bookings/' + booking.id : '/bookings' %>" class="px-5 py-2.5 text-sm text-gray-500 hover:text-gray-700">Cancel</a>
  </div>

</form>

<!-- Site Documents — rendered OUTSIDE the main edit form so the upload +
     delete forms post multipart without hijacking the main save action. -->
<% if (isEdit) { %>
  <%
    var DOC_LABEL = { tgs:'TGS', tmp:'TMP', ctmp:'CTMP', rol:'ROL', rol_day:'ROL — Day', rol_night:'ROL — Night', stage_plan:'Stage Plan', swms:'SWMS', permit:'Permit', invoice:'Invoice', photo:'Photo', other:'Other' };
    function fmtSize(n) { if (!n) return ''; if (n < 1024) return n + ' B'; if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB'; return (n/1048576).toFixed(1) + ' MB'; }
  %>
  <div id="sec-docs" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 mt-5">
    <div class="flex items-center justify-between gap-2 mb-3 flex-wrap">
      <div>
        <h2 class="booking-form-section-header" style="margin-bottom:0;">SITE DOCUMENTS</h2>
        <p class="text-xs text-gray-500 mt-0.5">TGS / TMP / ROL / Stage Plans · visible to crew under each shift's DOCS tab.</p>
      </div>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-gray-100 text-gray-600">
        <%= (typeof bookingDocuments !== 'undefined' ? bookingDocuments.length : 0) %> attached
      </span>
    </div>

    <% if (bookingDocuments && bookingDocuments.length) { %>
      <ul class="divide-y divide-gray-100 mb-4 border border-gray-200 rounded-lg overflow-hidden">
        <% bookingDocuments.forEach(function (d) { %>
          <li class="flex items-center gap-3 px-3 py-2.5 hover:bg-gray-50">
            <div class="w-9 h-9 rounded-lg bg-red-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/><path d="M14 2v6h6M9 14h6M9 18h6M9 10h2"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <a href="/bookings/<%= booking.id %>/documents/<%= d.id %>/download" target="_blank" class="text-sm font-semibold text-brand-700 hover:underline truncate block">
                <%= d.title || d.original_name %>
              </a>
              <p class="text-[11px] text-gray-500">
                <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold bg-brand-50 text-brand-700"><%= DOC_LABEL[d.document_type] || d.document_type %></span>
                <% if (d.file_size) { %>· <%= fmtSize(d.file_size) %><% } %>
                <% if (d.uploader_name) { %>· <%= d.uploader_name %><% } %>
                · <%= new Date(d.created_at).toLocaleDateString('en-AU', { day:'numeric', month:'short' }) %>
              </p>
            </div>
            <form method="POST" action="/bookings/<%= booking.id %>/documents/<%= d.id %>/delete" onsubmit="return confirm('Delete this document? Workers will stop seeing it immediately.');">
              <%- include('../partials/csrf') %>
              <button type="submit" class="text-gray-400 hover:text-red-600 p-1" title="Delete">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V3a1 1 0 011-1h4a1 1 0 011 1v4"/></svg>
              </button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <div class="rounded-lg border border-dashed border-gray-300 px-3 py-5 mb-4 text-center text-xs text-gray-500">
        No documents yet — upload the TGS / TMP / ROL / stage plans below.
      </div>
    <% } %>

    <form method="POST" action="/bookings/<%= booking.id %>/documents" enctype="multipart/form-data" class="space-y-2">
      <%- include('../partials/csrf') %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Type</label>
          <select name="document_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="tgs">TGS</option>
            <option value="tmp">TMP</option>
            <option value="ctmp">CTMP</option>
            <option value="rol">ROL</option>
            <option value="rol_day">ROL — Day</option>
            <option value="rol_night">ROL — Night</option>
            <option value="stage_plan">Stage Plan</option>
            <option value="swms">SWMS</option>
            <option value="permit">Permit</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Title (optional)</label>
          <input type="text" name="title" placeholder="e.g. TGS Stage 2.1 — Naremburn"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
      </div>
      <div class="flex items-end gap-2 flex-wrap">
        <input type="file" name="file" required accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.tiff"
          class="block flex-1 min-w-[180px] text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
        <button type="submit" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-brand-600 text-white text-sm font-semibold hover:bg-brand-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
          Upload
        </button>
      </div>
      <p class="text-[11px] text-gray-400">Up to 25 MB · PDF preferred · also accepts doc / docx / png / jpg / tiff.</p>
    </form>
  </div>
<% } %>

<script>
  // Auto-sync end date with start date if end date is empty
  const startDate = document.querySelector('input[name="start_date"]');
  const endDate = document.querySelector('input[name="end_date"]');
  if (startDate && endDate) {
    startDate.addEventListener('change', function() {
      if (!endDate.value) endDate.value = this.value;
    });
  }

  // Requirements grid — add/remove rows
  const reqTypes = <%- JSON.stringify(requirementTypes) %>;

  // Categorize requirement types for totals.
  //   - "Nx TC Crew" packages = N traffic controllers + 1 ute (auto-vehicle)
  //   - Other people types: Hoist Operator / Labour / Security / Spotter
  //     / Traffic Controller (single) / Trainee — count as 1 person each
  //   - VMS Ute, Vehicle, Pod Truck, TMA (dry/wet hire) = vehicle counters
  const peopleTypes = ['1x TC Crew','2x TC Crew','3x TC Crew','4x TC Crew','5x TC Crew',
    'Hoist Operator','Labour','Security','Spotter','Traffic Controller','Trainee'];
  const vehicleTypes = ['Pod Truck','TMA (dry hire)','TMA (wet hire)','VMS Ute','Vehicle'];
  const equipmentTypes = ['Arrow Board','Light Tower','Portaboom','Speed Advisory Sign','VMS Board'];

  // Per-row people / auto-vehicle counts. "Nx TC Crew" ships N TCs + 1 ute.
  const peopleCounts  = { '1x TC Crew':1,'2x TC Crew':2,'3x TC Crew':3,'4x TC Crew':4,'5x TC Crew':5,
    'Hoist Operator':1,'Labour':1,'Security':1,'Spotter':1,'Traffic Controller':1,'Trainee':1 };
  // Items that AUTO-include a vehicle (one ute) when added. Displayed in
  // the totals as part of the vehicles count, so the office sees the
  // resulting head count + vehicle count without manually adding a Ute row.
  const autoVehicleCounts = { '1x TC Crew':1,'2x TC Crew':1,'3x TC Crew':1,'4x TC Crew':1,'5x TC Crew':1 };

  function createReqRow(type, qty) {
    const tr = document.createElement('tr');
    tr.className = 'req-row';
    let opts = '<option value="">-- Select --</option>';
    reqTypes.forEach(rt => { opts += '<option value="' + rt + '"' + (rt === type ? ' selected' : '') + '>' + rt + '</option>'; });
    tr.innerHTML = '<td class="pr-2 pb-2"><select name="req_resource_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" onchange="updateReqTotals()">' + opts + '</select></td>'
      + '<td class="pr-2 pb-2"><input type="number" name="req_quantity" value="' + (qty||1) + '" min="1" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" oninput="updateReqTotals()"></td>'
      + '<td class="pb-2 text-center"><button type="button" onclick="this.closest(\'tr\').remove(); updateReqTotals();" class="text-red-400 hover:text-red-600 transition p-1" title="Remove"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button></td>';
    return tr;
  }

  document.getElementById('add-req-row').addEventListener('click', function() {
    document.getElementById('req-rows').appendChild(createReqRow('', 1));
    updateReqTotals();
  });

  // Attach onchange/oninput to existing rows
  document.querySelectorAll('#req-rows select[name="req_resource_type"]').forEach(s => s.addEventListener('change', updateReqTotals));
  document.querySelectorAll('#req-rows input[name="req_quantity"]').forEach(s => s.addEventListener('input', updateReqTotals));

  function updateReqTotals() {
    let people = 0, vehicles = 0, equipment = 0;
    document.querySelectorAll('.req-row').forEach(row => {
      const type = row.querySelector('select[name="req_resource_type"]').value;
      const qty = parseInt(row.querySelector('input[name="req_quantity"]').value) || 0;
      if (peopleTypes.includes(type)) people += (peopleCounts[type] || 1) * qty;
      if (autoVehicleCounts[type]) vehicles += autoVehicleCounts[type] * qty;
      if (vehicleTypes.includes(type)) vehicles += qty;
      if (equipmentTypes.includes(type)) equipment += qty;
    });
    document.getElementById('total-people').textContent = people;
    document.getElementById('total-vehicles').textContent = vehicles;
    document.getElementById('total-equipment').textContent = equipment;
  }
  updateReqTotals();

  // ── Time Mask for HH:MM inputs ──
  // Users type digits; colon is auto-inserted after 2 digits.
  // Accepts paste of "14:30", "1430", or "1430:00" etc and normalises.
  function normaliseTime(raw) {
    if (!raw) return '';
    // Strip everything but digits
    var d = String(raw).replace(/\D/g, '');
    if (!d) return '';
    // Trim seconds if user pasted HH:MM:SS
    if (d.length >= 6) d = d.slice(0, 4);
    if (d.length === 1) return d;              // "1"
    if (d.length === 2) return d;              // "14" (colon added on blur)
    if (d.length === 3) return d.slice(0,2) + ':' + d.slice(2); // "14:3"
    return d.slice(0,2) + ':' + d.slice(2,4); // "14:30"
  }
  function validateTime(val) {
    if (!val) return '';
    var m = val.match(/^(\d{1,2}):?(\d{0,2})$/);
    if (!m) return val;
    var h = parseInt(m[1], 10);
    var mm = m[2] === '' ? 0 : parseInt(m[2], 10);
    if (isNaN(h) || h > 23) h = 23;
    if (isNaN(mm) || mm > 59) mm = 59;
    return String(h).padStart(2,'0') + ':' + String(mm).padStart(2,'0');
  }
  document.querySelectorAll('input[data-time-mask]').forEach(function(inp) {
    // Normalise prefilled value that might be HH:MM:SS from DB
    if (inp.value) inp.value = validateTime(inp.value.slice(0,5));

    inp.addEventListener('input', function(e) {
      var caret = inp.selectionStart;
      var before = inp.value;
      var next = normaliseTime(before);
      if (next !== before) {
        inp.value = next;
        // Keep caret at a sensible spot
        var delta = next.length - before.length;
        try { inp.setSelectionRange(caret + delta, caret + delta); } catch (err) {}
      }
    });
    inp.addEventListener('blur', function() {
      if (!inp.value) return;
      inp.value = validateTime(inp.value);
    });
    inp.addEventListener('paste', function(e) {
      e.preventDefault();
      var pasted = (e.clipboardData || window.clipboardData).getData('text');
      inp.value = validateTime(pasted);
    });
  });

  // ── Auto end-time = start + 8 hours ──
  // When the user picks a start time we default end_time to 8h later
  // (and roll end_date forward if it crosses midnight). The end fields
  // remain editable — once the user touches end_time/end_date manually
  // we stop auto-overwriting them.
  (function () {
    var sd = document.querySelector('[name="start_date"]');
    var st = document.querySelector('[name="start_time"]');
    var ed = document.querySelector('[name="end_date"]');
    var et = document.querySelector('[name="end_time"]');
    if (!st || !et) return;
    var endUserEdited = false;
    function markEdited() { endUserEdited = true; }
    et.addEventListener('input', markEdited);
    if (ed) ed.addEventListener('input', markEdited);

    function applyAutoEnd() {
      if (endUserEdited) return;
      if (!st.value) return;
      var parts = st.value.split(':');
      var h = parseInt(parts[0], 10), m = parseInt(parts[1] || '0', 10);
      if (isNaN(h) || isNaN(m)) return;
      var startDate = (sd && sd.value) ? sd.value : null;
      var d = startDate ? new Date(startDate + 'T00:00:00') : new Date();
      d.setHours(h, m, 0, 0);
      d.setHours(d.getHours() + 8);
      var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
      et.value = pad(d.getHours()) + ':' + pad(d.getMinutes());
      if (ed && startDate) {
        ed.value = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
      }
    }
    st.addEventListener('change', applyAutoEnd);
    if (sd) sd.addEventListener('change', applyAutoEnd);
  })();
</script>
