<% locals.currentPage = 'bookings' %>
<%
  const b = booking;
  const start = new Date(b.startDateTime);
  const end = new Date(b.endDateTime);
  const timeOpts = { hour: '2-digit', minute: '2-digit', hour12: true };
  const dateOpts = { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' };
  const statusColors = {
    unconfirmed: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    confirmed: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    green_to_go: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    in_progress: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    completed: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    cancelled: 'bg-gray-100 text-gray-500',
    on_hold: 'bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20',
  };
  const confirmedCount = b.personnel ? b.personnel.filter(p => p.confirmed).length : 0;
%>

<!-- Breadcrumb + Actions -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div class="flex items-center gap-2 text-sm text-gray-400">
    <a href="/bookings" class="hover:text-gray-900 transition">Bookings</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-gray-900"><%= b.booking_number %></span>
  </div>
  <div class="flex items-center gap-2">
    <a href="/bookings/<%= b.id %>/edit" class="inline-flex items-center px-3 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Edit
    </a>
    <form method="POST" action="/bookings/<%= b.id %>/clone" class="inline">
      <%- include('../partials/csrf') %>
      <button type="submit" class="inline-flex items-center px-3 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Clone
      </button>
    </form>
  </div>
</div>

<!-- Header Card -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-5">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div>
      <div class="flex items-center gap-3 mb-2">
        <h1 class="text-2xl font-bold text-gray-900"><%= b.project.name || b.booking_number %></h1>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= statusColors[b.status] || statusColors.unconfirmed %>">
          <%= (b.status || '').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
        </span>
      </div>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-500">
        <span class="font-mono text-xs"><%= b.booking_number %></span>
        <% if (b.project.client) { %><span>&middot; <%= b.project.client %></span><% } %>
        <% if (b.depot) { %><span>&middot; <%= b.depot %></span><% } %>
      </div>
    </div>
    <!-- Quick Status Change -->
    <form method="POST" action="/bookings/<%= b.id %>/status" class="flex-shrink-0">
      <%- include('../partials/csrf') %>
      <select name="status" onchange="this.form.submit()" class="text-sm font-medium rounded-lg px-3 py-2 border border-gray-300 bg-white text-gray-700 focus:ring-2 focus:ring-brand-500 cursor-pointer">
        <% ['unconfirmed','confirmed','green_to_go','in_progress','completed','cancelled','on_hold'].forEach(s => { %>
          <option value="<%= s %>" <%= b.status === s ? 'selected' : '' %>><%= s.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></option>
        <% }); %>
      </select>
    </form>
  </div>

  <!-- Status Flow Bar -->
  <%
    const flowSteps = [
      { key: 'unconfirmed', label: 'Unconfirmed' },
      { key: 'confirmed', label: 'Confirmed' },
      { key: 'green_to_go', label: 'GTG' },
      { key: 'in_progress', label: 'In Progress' },
      { key: 'completed', label: 'Complete' },
    ];
    const currentIdx = flowSteps.findIndex(s => s.key === b.status);
    const isCancelled = b.status === 'cancelled' || b.status === 'on_hold';
  %>
  <div class="flex gap-1.5 mt-4 overflow-x-auto pb-1">
    <% flowSteps.forEach((step, i) => { %>
      <form method="POST" action="/bookings/<%= b.id %>/status" class="inline">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="status" value="<%= step.key %>">
        <button type="submit" class="px-3 py-1.5 text-xs font-semibold rounded-lg border whitespace-nowrap transition-all
          <%= i === currentIdx ? 'bg-brand-600 text-white border-brand-600 shadow-sm' : i < currentIdx && !isCancelled ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-white text-gray-400 border-gray-200 hover:border-gray-300 hover:text-gray-600' %>">
          <% if (i < currentIdx && !isCancelled) { %>
            <svg class="w-3 h-3 inline mr-0.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          <% } %>
          <%= step.label %>
        </button>
      </form>
    <% }); %>
    <% if (isCancelled) { %>
      <span class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-red-50 text-red-600 border border-red-200">
        <%= b.status === 'cancelled' ? 'Cancelled' : 'On Hold' %>
      </span>
    <% } %>
  </div>

  <!-- Schedule + Location -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-5 pt-5 border-t border-gray-100">
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Start</p>
      <p class="text-sm font-medium text-gray-900 mt-0.5"><%= start.toLocaleDateString('en-AU', dateOpts) %></p>
      <p class="text-xs text-gray-500"><%= start.toLocaleTimeString('en-AU', timeOpts) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">End</p>
      <p class="text-sm font-medium text-gray-900 mt-0.5"><%= end.toLocaleDateString('en-AU', dateOpts) %></p>
      <p class="text-xs text-gray-500"><%= end.toLocaleTimeString('en-AU', timeOpts) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Location</p>
      <p class="text-sm font-medium text-gray-900 mt-0.5"><%= b.project.address || '-' %></p>
      <% if (b.suburb) { %><p class="text-xs text-gray-500"><%= b.suburb %><%= b.state ? ', ' + b.state : '' %> <%= b.postcode || '' %></p><% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Supervisor</p>
      <p class="text-sm font-medium text-gray-900 mt-0.5"><%= b.supervisor || '-' %></p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

  <!-- Left column: Crew + Notes -->
  <div class="lg:col-span-2 space-y-5">

    <!-- Crew / Personnel -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Crew (<%= confirmedCount %>/<%= b.personnel ? b.personnel.length : 0 %> confirmed)</h2>
      </div>

      <% if (b.personnel && b.personnel.length > 0) { %>
        <div class="space-y-2 mb-4">
          <% b.personnel.forEach(p => { %>
            <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-50">
              <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xs font-bold">
                <%= p.name ? p.name.split(' ').map(n => n[0]).join('').substring(0,2) : '?' %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= p.name %></p>
                <p class="text-xs text-gray-400"><%= p.role || 'Crew' %></p>
              </div>
              <% if (p.confirmed) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-emerald-50 text-emerald-700">Confirmed</span>
              <% } else { %>
                <form method="POST" action="/bookings/<%= b.id %>/crew/<%= p.id %>/confirm" class="inline">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium bg-amber-50 text-amber-700 hover:bg-amber-100 transition cursor-pointer">Confirm</button>
                </form>
              <% } %>
              <form method="POST" action="/bookings/<%= b.id %>/crew/<%= p.id %>/remove" class="inline">
                <%- include('../partials/csrf') %>
                <button type="submit" class="text-gray-300 hover:text-red-500 transition" title="Remove">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </form>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400 mb-4">No crew assigned yet.</p>
      <% } %>

      <!-- Add crew form -->
      <form method="POST" action="/bookings/<%= b.id %>/crew" class="flex items-end gap-2">
        <%- include('../partials/csrf') %>
        <div class="flex-1">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Add Crew Member</label>
          <select name="crew_member_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">-- Select --</option>
            <% if (typeof allCrew !== 'undefined') { allCrew.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.full_name %> (<%= c.role %>)</option>
            <% }); } %>
          </select>
        </div>
        <div>
          <input type="text" name="role_on_site" placeholder="Role" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm w-24 focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <button type="submit" class="px-3 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Add</button>
      </form>
    </div>

    <!-- Dockets -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Dockets (<%= b.dockets ? b.dockets.length : 0 %>)</h2>
        <form method="POST" action="/bookings/<%= b.id %>/dockets" class="inline">
          <%- include('../partials/csrf') %>
          <button type="submit" class="inline-flex items-center px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">
            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            New Docket
          </button>
        </form>
      </div>

      <% if (b.dockets && b.dockets.length > 0) { %>
        <div class="space-y-2">
          <% b.dockets.forEach(dk => {
            const statusColors = { draft: 'bg-gray-100 text-gray-600', pending_signoff: 'bg-amber-50 text-amber-700', signed: 'bg-emerald-50 text-emerald-700', finalised: 'bg-purple-50 text-purple-700' };
          %>
            <a href="/bookings/<%= b.id %>/dockets/<%= dk.id %>" class="flex items-center justify-between p-3 rounded-lg bg-gray-50 hover:bg-gray-100 transition group">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-gray-400 group-hover:text-brand-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <div>
                  <span class="text-sm font-medium text-gray-900"><%= dk.docket_number %></span>
                  <% if (dk.physical_docket_number) { %><span class="text-xs text-gray-400 ml-2">(#<%= dk.physical_docket_number %>)</span><% } %>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <% if (dk.worker_signature) { %>
                  <span class="text-[10px] text-emerald-500 font-medium">Worker signed</span>
                <% } %>
                <% if (dk.client_signature) { %>
                  <span class="text-[10px] text-blue-500 font-medium">Client signed</span>
                <% } %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusColors[dk.status] || statusColors.draft %>">
                  <%= (dk.status || 'draft').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
                </span>
              </div>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400">No dockets yet. Create one to track crew time and get signatures.</p>
      <% } %>
    </div>

    <!-- Notes -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Notes</h2>

      <% if (b.notes && b.notes.length > 0) { %>
        <div class="space-y-3 mb-4">
          <% b.notes.forEach(n => { %>
            <div class="p-3 rounded-lg bg-gray-50 border border-gray-100">
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-medium text-gray-600"><%= n.author_name || 'System' %></span>
                <div class="flex items-center gap-2">
                  <% if (n.is_private) { %><span class="text-[10px] text-amber-500 font-medium">Private</span><% } %>
                  <span class="text-[10px] text-gray-400"><%= new Date(n.created_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
                  <form method="POST" action="/bookings/<%= b.id %>/notes/<%= n.id %>/delete" class="inline">
                    <%- include('../partials/csrf') %>
                    <button type="submit" class="text-gray-300 hover:text-red-500 transition"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  </form>
                </div>
              </div>
              <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= n.content %></p>
            </div>
          <% }); %>
        </div>
      <% } %>

      <form method="POST" action="/bookings/<%= b.id %>/notes" class="space-y-2">
        <%- include('../partials/csrf') %>
        <textarea name="content" rows="2" required placeholder="Add a note..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
        <div class="flex items-center gap-3">
          <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">Add Note</button>
          <label class="flex items-center gap-1.5 text-xs text-gray-500">
            <input type="checkbox" name="is_private" value="1" class="rounded border-gray-300 text-amber-600 focus:ring-amber-500">
            Private
          </label>
        </div>
      </form>
    </div>
  </div>

  <!-- Right column: Details + Vehicles -->
  <div class="space-y-5">

    <!-- Resource Requirements -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Requirements</h2>
      <% if (b.requirements && b.requirements.length > 0) { %>
        <div class="space-y-2 mb-3">
          <% b.requirements.forEach(r => {
            const tagColor = r.status === 'fulfilled' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : r.status === 'partial' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-red-50 text-red-700 border-red-200';
            const tagLabel = r.status === 'fulfilled' ? 'Filled' : r.quantity_assigned > r.quantity_required ? 'Over-allocated' : r.status === 'partial' ? 'Partial' : 'Unfulfilled';
          %>
            <div class="flex items-center justify-between p-2 rounded-lg bg-gray-50">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-900"><%= r.resource_type.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></span>
                <span class="text-xs text-gray-400"><%= r.quantity_assigned %>/<%= r.quantity_required %></span>
              </div>
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium border <%= tagColor %>"><%= tagLabel %></span>
                <form method="POST" action="/bookings/<%= b.id %>/requirements/<%= r.id %>/delete" class="inline">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="text-gray-300 hover:text-red-500 transition"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
      <form method="POST" action="/bookings/<%= b.id %>/requirements" class="flex items-end gap-2">
        <%- include('../partials/csrf') %>
        <div class="flex-1">
          <select name="resource_type" required class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">-- Type --</option>
            <option value="traffic_controller">Traffic Controller</option>
            <option value="leading_hand">Leading Hand</option>
            <option value="supervisor">Supervisor</option>
            <option value="pilot_vehicle">Pilot Vehicle</option>
            <option value="spotter">Spotter</option>
            <option value="labourer">Labourer</option>
            <option value="arrow_board">Arrow Board</option>
            <option value="vehicle">Vehicle</option>
            <option value="vms">VMS Board</option>
          </select>
        </div>
        <input type="number" name="quantity_required" min="1" value="1" class="w-14 px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs text-center focus:outline-none focus:ring-2 focus:ring-brand-500">
        <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">Add</button>
      </form>
    </div>

    <!-- Equipment -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Equipment</h2>
      <% if (b.equipment && b.equipment.length > 0) { %>
        <div class="space-y-2 mb-3">
          <% b.equipment.forEach(eq => { %>
            <div class="flex items-center justify-between p-2 rounded-lg bg-gray-50">
              <div>
                <span class="text-sm font-medium text-gray-900"><%= eq.equipment_name || eq.asset_name || 'Unknown' %></span>
                <% if (eq.equipment_type || eq.eq_category) { %><span class="text-xs text-gray-400 ml-1">(<%= eq.equipment_type || eq.eq_category %>)</span><% } %>
                <% if (eq.quantity > 1) { %><span class="text-xs font-bold text-gray-500 ml-1">x<%= eq.quantity %></span><% } %>
              </div>
              <form method="POST" action="/bookings/<%= b.id %>/equipment/<%= eq.id %>/remove" class="inline">
                <%- include('../partials/csrf') %>
                <button type="submit" class="text-gray-300 hover:text-red-500 transition"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
              </form>
            </div>
          <% }); %>
        </div>
      <% } %>
      <form method="POST" action="/bookings/<%= b.id %>/equipment" class="flex items-end gap-2">
        <%- include('../partials/csrf') %>
        <div class="flex-1">
          <select name="equipment_id" class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">-- From register --</option>
            <% if (typeof allEquipment !== 'undefined') { allEquipment.forEach(eq => { %>
              <option value="<%= eq.id %>"><%= eq.asset_name %> (<%= eq.category %>)</option>
            <% }); } %>
          </select>
        </div>
        <input type="number" name="quantity" min="1" value="1" class="w-14 px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs text-center focus:outline-none focus:ring-2 focus:ring-brand-500">
        <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">Add</button>
      </form>
    </div>

    <!-- Booking Info -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Details</h2>
      <div class="space-y-3 text-sm">
        <% if (b.project.orderNumber) { %><div><span class="text-gray-400">Order #:</span> <span class="font-medium text-gray-700"><%= b.project.orderNumber %></span></div><% } %>
        <% if (b.project.billingCode) { %><div><span class="text-gray-400">Billing:</span> <span class="font-medium text-gray-700"><%= b.project.billingCode %></span></div><% } %>
        <% if (b.client_contact) { %><div><span class="text-gray-400">Contact:</span> <span class="font-medium text-gray-700"><%= b.client_contact %></span></div><% } %>
        <% if (b.is_emergency) { %><div class="text-red-500 font-medium">Emergency Booking</div><% } %>
        <% if (b.is_callout) { %><div class="text-amber-500 font-medium">Callout</div><% } %>
        <div><span class="text-gray-400">Billable:</span> <span class="font-medium"><%= b.billable ? 'Yes' : 'No' %></span></div>
        <% if (b.requirements_text) { %>
          <div class="pt-2 border-t border-gray-100">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Requirements</p>
            <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= b.requirements_text %></p>
          </div>
        <% } %>
        <% if (b.description) { %>
          <div class="pt-2 border-t border-gray-100">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Description</p>
            <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= b.description %></p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Vehicles -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Vehicles</h2>
      <% if (b.allVehicles && b.allVehicles.length > 0) { %>
        <div class="space-y-2 mb-3">
          <% b.allVehicles.forEach(v => { %>
            <div class="flex items-center justify-between p-2 rounded-lg bg-gray-50">
              <div>
                <span class="text-sm font-medium text-gray-900"><%= v.vehicle_name || v.registration %></span>
                <% if (v.vehicle_name && v.registration) { %><span class="text-xs text-gray-400 ml-2"><%= v.registration %></span><% } %>
              </div>
              <form method="POST" action="/bookings/<%= b.id %>/vehicles/<%= v.id %>/remove" class="inline">
                <%- include('../partials/csrf') %>
                <button type="submit" class="text-gray-300 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
              </form>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-400 mb-3">No vehicles assigned.</p>
      <% } %>

      <form method="POST" action="/bookings/<%= b.id %>/vehicles" class="space-y-2">
        <%- include('../partials/csrf') %>
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">From Register</label>
            <select name="from_register" id="vehicle-select" onchange="if(this.value){var o=this.options[this.selectedIndex];document.getElementById('vn').value=o.text.split(' (')[0];document.getElementById('vr').value=o.getAttribute('data-rego')||''}"
              class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="">-- Select vehicle --</option>
              <% if (typeof allEquipment !== 'undefined') { allEquipment.filter(eq => ['vehicle','vms','lighting'].includes(eq.category) || (eq.asset_name||'').toLowerCase().includes('ute') || (eq.asset_name||'').toLowerCase().includes('truck')).forEach(eq => { %>
                <option value="<%= eq.id %>" data-rego=""><%= eq.asset_name %> (<%= eq.category %>)</option>
              <% }); } %>
            </select>
          </div>
        </div>
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <input type="text" name="vehicle_name" id="vn" placeholder="Vehicle name" class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <input type="text" name="registration" id="vr" placeholder="Rego" class="w-20 px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">Add</button>
        </div>
      </form>
    </div>

    <!-- Documents -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Documents (<%= b.documents ? b.documents.length : 0 %>)</h2>

      <% if (b.documents && b.documents.length > 0) { %>
        <div class="space-y-2 mb-3">
          <% b.documents.forEach(doc => {
            const sizeKb = doc.file_size ? (doc.file_size / 1024).toFixed(0) + ' KB' : '';
          %>
            <div class="flex items-center justify-between p-2 rounded-lg bg-gray-50">
              <div class="flex items-center gap-2 min-w-0">
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                <div class="min-w-0">
                  <a href="/bookings/<%= b.id %>/documents/<%= doc.id %>/download" class="text-sm font-medium text-brand-600 hover:text-brand-700 truncate block"><%= doc.title || doc.original_name %></a>
                  <p class="text-[10px] text-gray-400"><%= sizeKb %><%= doc.uploader_name ? ' · ' + doc.uploader_name : '' %></p>
                </div>
              </div>
              <form method="POST" action="/bookings/<%= b.id %>/documents/<%= doc.id %>/delete" class="inline">
                <%- include('../partials/csrf') %>
                <button type="submit" class="text-gray-300 hover:text-red-500 transition"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
              </form>
            </div>
          <% }); %>
        </div>
      <% } %>

      <form method="POST" action="/bookings/<%= b.id %>/documents" enctype="multipart/form-data" class="space-y-2">
        <%- include('../partials/csrf') %>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Upload Document</label>
          <input type="file" name="file" required class="w-full text-sm text-gray-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
        </div>
        <div class="flex items-end gap-2">
          <div class="flex-1">
            <input type="text" name="title" placeholder="Document title (optional)" class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <select name="document_type" class="px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="other">Other</option>
            <option value="tgs">TGS</option>
            <option value="ctmp">CTMP</option>
            <option value="rol">ROL</option>
            <option value="permit">Permit</option>
            <option value="invoice">Invoice</option>
            <option value="photo">Photo</option>
          </select>
          <button type="submit" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition">Upload</button>
        </div>
      </form>
    </div>

    <!-- Activity History -->
    <% if (b.activity && b.activity.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">History</h2>
      <div class="space-y-3">
        <% b.activity.forEach(a => { %>
          <div class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-gray-700"><%= a.details || a.action %></p>
              <p class="text-[10px] text-gray-400"><%= a.user_name || 'System' %> &middot; <%= a.created_at ? new Date(a.created_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) : '' %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>
</div>
