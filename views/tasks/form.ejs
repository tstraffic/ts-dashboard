<%
  const isEdit = !!task;
  const formAction = isEdit ? '/tasks/' + task.id : '/tasks';
  const pageTitle = isEdit ? 'Edit Task' : 'New Task';
  const selectedJobId = (isEdit && task.job_id) ? task.job_id : (prefillJobId || '');
  const returnTo = (typeof locals.req !== 'undefined' && locals.req && locals.req.headers && locals.req.headers.referer) ? locals.req.headers.referer : '/tasks';
  // editable is passed from route for edit mode; always true for new tasks
  const canEdit = isEdit ? (typeof editable !== 'undefined' ? editable : true) : true;
  const disabled = canEdit ? '' : 'disabled';
%>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= pageTitle %></h1>
    <% if (isEdit && !canEdit) { %>
      <p class="mt-1 text-sm text-amber-600">
        <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        Read-only — this task is assigned to someone else. Only the task owner or an admin can edit it.
      </p>
    <% } %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <form method="POST" action="<%= formAction %>">
      <input type="hidden" name="return_to" value="<%= returnTo %>">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Job -->
        <div>
          <label for="job_id" class="block text-sm font-medium text-gray-600 mb-1">Project <span class="text-gray-400 font-normal text-xs">(optional)</span></label>
          <select id="job_id" name="job_id" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <option value="">No project</option>
            <% jobs.forEach(function(job) { %>
              <option value="<%= job.id %>" <%= String(selectedJobId) === String(job.id) ? 'selected' : '' %>><%= job.job_number %> - <%= job.client %></option>
            <% }) %>
          </select>
        </div>

        <!-- Division -->
        <div>
          <label for="division" class="block text-sm font-medium text-gray-600 mb-1">Division <span class="text-red-600">*</span></label>
          <select id="division" name="division" required <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <option value="">Select division...</option>
            <option value="ops" <%= isEdit && task.division === 'ops' ? 'selected' : (!isEdit ? 'selected' : '') %>>Operations</option>
            <option value="planning" <%= isEdit && task.division === 'planning' ? 'selected' : '' %>>Planning</option>
            <option value="finance" <%= isEdit && task.division === 'finance' ? 'selected' : '' %>>Finance</option>
            <option value="admin" <%= isEdit && task.division === 'admin' ? 'selected' : '' %>>Admin</option>
          </select>
        </div>

        <!-- Task Type -->
        <div>
          <label for="task_type" class="block text-sm font-medium text-gray-600 mb-1">Task Type</label>
          <select id="task_type" name="task_type" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <option value="one_off" <%= isEdit && task.task_type === 'one_off' ? 'selected' : (!isEdit ? 'selected' : '') %>>One-off</option>
            <option value="daily" <%= isEdit && task.task_type === 'daily' ? 'selected' : '' %>>Daily</option>
            <option value="weekly" <%= isEdit && task.task_type === 'weekly' ? 'selected' : '' %>>Weekly</option>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">

        <!-- Title -->
        <div class="md:col-span-2">
          <label for="title" class="block text-sm font-medium text-gray-600 mb-1">Title <span class="text-red-600">*</span></label>
          <input type="text" id="title" name="title" required <%= disabled %> value="<%= isEdit ? task.title : '' %>" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>" placeholder="Task title...">
        </div>

        <!-- Description -->
        <div class="md:col-span-2">
          <label for="description" class="block text-sm font-medium text-gray-600 mb-1">Description</label>
          <textarea id="description" name="description" rows="3" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>" placeholder="Task description..."><%= isEdit && task.description ? task.description : '' %></textarea>
        </div>

        <!-- Owner -->
        <div>
          <label for="owner_id" class="block text-sm font-medium text-gray-600 mb-1">Owner <span class="text-red-600">*</span></label>
          <select id="owner_id" name="owner_id" required <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <option value="">Select owner...</option>
            <% users.forEach(function(u) { %>
              <option value="<%= u.id %>" <%= isEdit && task.owner_id == u.id ? 'selected' : '' %>><%= u.full_name || u.username %></option>
            <% }) %>
          </select>
        </div>

        <!-- Due Date -->
        <div>
          <label for="due_date" class="block text-sm font-medium text-gray-600 mb-1">Due Date <span class="text-red-600">*</span></label>
          <input type="date" id="due_date" name="due_date" required <%= disabled %> value="<%= isEdit && task.due_date ? new Date(task.due_date).toISOString().split('T')[0] : '' %>" class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
        </div>

        <!-- Status -->
        <div>
          <label for="status" class="block text-sm font-medium text-gray-600 mb-1">Status</label>
          <select id="status" name="status" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <% (settingsOptions.task_status || []).forEach(opt => { %>
              <option value="<%= opt.key %>" <%= isEdit && task.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>

        <!-- Priority -->
        <div>
          <label for="priority" class="block text-sm font-medium text-gray-600 mb-1">Priority</label>
          <select id="priority" name="priority" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>">
            <% (settingsOptions.task_priority || []).forEach(opt => { %>
              <option value="<%= opt.key %>" <%= isEdit && task.priority === opt.key ? 'selected' : '' %>><%= opt.label %></option>
            <% }) %>
          </select>
        </div>

        <!-- Notes -->
        <div class="md:col-span-2">
          <label for="notes" class="block text-sm font-medium text-gray-600 mb-1">Notes</label>
          <textarea id="notes" name="notes" rows="3" <%= disabled %> class="w-full bg-white border border-gray-300 text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500 <%= disabled ? 'opacity-60 cursor-not-allowed' : '' %>" placeholder="Additional notes..."><%= isEdit && task.notes ? task.notes : '' %></textarea>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3 mt-6 pt-6 border-t border-gray-200">
        <div>
          <% if (isEdit && canEdit) { %>
            <button type="button" onclick="document.getElementById('delete-modal').classList.remove('hidden')" class="px-4 py-2.5 text-red-600 hover:bg-red-50 rounded-lg transition font-medium text-sm">
              <svg class="w-4 h-4 inline mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              Delete Task
            </button>
          <% } %>
        </div>
        <div class="flex flex-col-reverse sm:flex-row gap-3">
          <a href="/tasks" class="px-4 py-2.5 bg-white text-gray-600 rounded-lg hover:bg-gray-100 transition font-medium text-center">
            <%= canEdit ? 'Cancel' : 'Back' %>
          </a>
          <% if (canEdit) { %>
            <button type="submit" class="px-6 py-2.5 bg-brand-600 text-white rounded-lg hover:bg-brand-500 transition font-semibold">
              <%= isEdit ? 'Update Task' : 'Create Task' %>
            </button>
          <% } %>
        </div>
      </div>
    </form>
  </div>

  <% if (isEdit) { %>
  <!-- Subtasks -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-5">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-bold text-gray-900">Subtasks</h3>
      <% if (typeof subtasks !== 'undefined' && subtasks.length > 0) { %>
        <span class="text-xs text-gray-400"><%= subtasks.filter(s => s.completed).length %>/<%= subtasks.length %> done</span>
      <% } %>
    </div>
    <% if (typeof subtasks !== 'undefined' && subtasks.length > 0) { %>
      <!-- Progress bar -->
      <div class="w-full bg-gray-100 rounded-full h-1.5 mb-3">
        <div class="bg-brand-600 h-1.5 rounded-full transition-all" style="width: <%= Math.round((subtasks.filter(s => s.completed).length / subtasks.length) * 100) %>%"></div>
      </div>
      <div class="space-y-1.5 mb-3">
        <% subtasks.forEach(s => { %>
          <div class="flex items-center gap-2 group">
            <form method="POST" action="/tasks/<%= task.id %>/subtasks/<%= s.id %>/toggle" class="flex items-center">
              <button type="submit" class="w-5 h-5 rounded border flex items-center justify-center transition-colors <%= s.completed ? 'bg-brand-600 border-brand-600 text-white' : 'border-gray-300 hover:border-brand-400' %>">
                <% if (s.completed) { %><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg><% } %>
              </button>
            </form>
            <span class="text-sm flex-1 <%= s.completed ? 'text-gray-400 line-through' : 'text-gray-700' %>"><%= s.title %></span>
            <form method="POST" action="/tasks/<%= task.id %>/subtasks/<%= s.id %>/delete" class="opacity-0 group-hover:opacity-100 transition-opacity">
              <button type="submit" class="text-gray-300 hover:text-red-500 transition-colors" title="Delete subtask"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
    <form method="POST" action="/tasks/<%= task.id %>/subtasks" class="flex gap-2">
      <input type="text" name="title" placeholder="Add a subtask..." class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none" required>
      <button type="submit" class="px-3 py-1.5 text-sm font-medium text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">Add</button>
    </form>
  </div>

  <!-- Dependencies -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-5">
    <h3 class="text-sm font-bold text-gray-900 mb-3">Dependencies</h3>

    <% if (typeof dependencies !== 'undefined' && dependencies.length > 0) { %>
      <div class="mb-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">This task depends on</p>
        <div class="space-y-1.5">
          <% dependencies.forEach(d => { %>
            <div class="flex items-center gap-2 group">
              <% const depStatusColor = d.status === 'complete' ? 'bg-green-100 text-green-700' : d.status === 'blocked' ? 'bg-red-100 text-red-700' : d.status === 'in_progress' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'; %>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= depStatusColor %>">
                <%= d.status === 'not_started' ? 'Not Started' : d.status === 'in_progress' ? 'In Progress' : d.status === 'blocked' ? 'Blocked' : 'Complete' %>
              </span>
              <a href="/tasks/<%= d.depends_on_id %>/edit" class="text-sm text-brand-600 hover:text-brand-700 hover:underline flex-1 truncate"><%= d.title %></a>
              <% if (d.due_date) { %>
                <span class="text-xs text-gray-400"><%= new Date(d.due_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) %></span>
              <% } %>
              <form method="POST" action="/tasks/<%= task.id %>/dependencies/<%= d.dep_id %>/delete" class="opacity-0 group-hover:opacity-100 transition-opacity">
                <button type="submit" class="text-gray-300 hover:text-red-500 transition-colors" title="Remove dependency"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
              </form>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (typeof dependents !== 'undefined' && dependents.length > 0) { %>
      <div class="mb-3">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Tasks that depend on this</p>
        <div class="space-y-1.5">
          <% dependents.forEach(d => { %>
            <div class="flex items-center gap-2">
              <% const dntStatusColor = d.status === 'complete' ? 'bg-green-100 text-green-700' : d.status === 'blocked' ? 'bg-red-100 text-red-700' : d.status === 'in_progress' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600'; %>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium <%= dntStatusColor %>">
                <%= d.status === 'not_started' ? 'Not Started' : d.status === 'in_progress' ? 'In Progress' : d.status === 'blocked' ? 'Blocked' : 'Complete' %>
              </span>
              <a href="/tasks/<%= d.task_id %>/edit" class="text-sm text-brand-600 hover:text-brand-700 hover:underline flex-1 truncate"><%= d.title %></a>
              <% if (d.due_date) { %>
                <span class="text-xs text-gray-400"><%= new Date(d.due_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) %></span>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <form method="POST" action="/tasks/<%= task.id %>/dependencies" class="flex gap-2">
      <select name="depends_on_id" required class="flex-1 text-sm border border-gray-200 rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none bg-white">
        <option value="">Select a task...</option>
        <% if (typeof allTasks !== 'undefined') { allTasks.forEach(t => { %>
          <% const alreadyDep = typeof dependencies !== 'undefined' && dependencies.some(d => d.depends_on_id === t.id); %>
          <% if (!alreadyDep) { %>
            <option value="<%= t.id %>"><%= t.title %> (<%= t.status === 'not_started' ? 'Not Started' : t.status === 'in_progress' ? 'In Progress' : t.status === 'blocked' ? 'Blocked' : 'Complete' %>)</option>
          <% } %>
        <% }) } %>
      </select>
      <button type="submit" class="px-3 py-1.5 text-sm font-medium text-brand-600 hover:bg-brand-50 rounded-lg transition-colors">Add</button>
    </form>
  </div>

  <!-- Comments -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-5">
    <h3 class="text-sm font-bold text-gray-900 mb-3">Activity & Comments</h3>
    <form method="POST" action="/tasks/<%= task.id %>/comments" class="mb-4">
      <textarea name="comment" rows="2" placeholder="Add a comment..." class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none resize-none" required></textarea>
      <div class="flex justify-end mt-2">
        <button type="submit" class="px-4 py-1.5 text-sm font-medium bg-brand-600 hover:bg-brand-500 text-white rounded-lg transition-colors">Post Comment</button>
      </div>
    </form>
    <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
      <div class="space-y-3 border-t border-gray-100 pt-3">
        <% comments.forEach(c => { %>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center text-xs font-bold flex-shrink-0">
              <%= c.user_name ? c.user_name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U' %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-semibold text-gray-900"><%= c.user_name %></span>
                <span class="text-xs text-gray-400"><%= new Date(c.created_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              <p class="text-sm text-gray-600 mt-0.5 whitespace-pre-wrap"><%= c.comment %></p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-400 text-center py-3">No comments yet</p>
    <% } %>
  </div>
  <% } %>

  <% if (typeof activityLog !== 'undefined' && activityLog.length > 0) { %>
  <!-- Activity Timeline -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-5">
    <h3 class="text-sm font-bold text-gray-900 mb-3">Activity</h3>
    <%- include('../partials/activity-timeline', { activities: activityLog }) %>
  </div>
  <% } %>

</div>

<% if (isEdit && canEdit) { %>
<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm" onclick="document.getElementById('delete-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6">
    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Delete Task?</h3>
    <p class="text-sm text-gray-500 text-center mb-6">This will permanently delete "<%= task.title %>". This action cannot be undone.</p>
    <div class="flex gap-3">
      <button onclick="document.getElementById('delete-modal').classList.add('hidden')" class="flex-1 px-4 py-2.5 bg-gray-100 text-gray-700 rounded-xl hover:bg-gray-200 transition font-medium">Cancel</button>
      <form method="POST" action="/tasks/<%= task.id %>/delete" class="flex-1">
        <input type="hidden" name="return_to" value="/tasks">
        <button type="submit" class="w-full px-4 py-2.5 bg-red-600 text-white rounded-xl hover:bg-red-700 transition font-semibold">Delete</button>
      </form>
    </div>
  </div>
</div>
<% } %>
