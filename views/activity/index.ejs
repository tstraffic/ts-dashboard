<% locals.currentPage = 'activity' %>

<%
  const actionColors = {
    create: 'bg-emerald-500', update: 'bg-blue-500', delete: 'bg-red-500',
    login: 'bg-purple-500', logout: 'bg-gray-400', upload: 'bg-teal-500',
    download: 'bg-cyan-500', complete: 'bg-emerald-500', approve: 'bg-green-500', reject: 'bg-red-500'
  };
  const actionLabels = {
    create: 'Created', update: 'Updated', delete: 'Deleted', login: 'Login', logout: 'Logout',
    upload: 'Upload', download: 'Download', complete: 'Completed', approve: 'Approved', reject: 'Rejected'
  };
  const entityIcons = {
    job: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    task: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
    incident: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z',
    user: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    equipment: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z'
  };
  const entityTypeLabels = {
    job: 'Job', task: 'Task', update: 'Update', compliance: 'Compliance', document: 'Document',
    user: 'User', incident: 'Incident', timesheet: 'Timesheet', equipment: 'Equipment',
    defect: 'Defect', budget: 'Budget', cost_entry: 'Cost', contact: 'Contact',
    communication: 'Comms', corrective_action: 'Action'
  };
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Activity Log</h1>
    <p class="text-gray-500 text-xs mt-0.5">System audit trail &middot; all user actions tracked</p>
  </div>
  <div class="text-xs text-gray-400">
    <% if (pagination.total > 0) { %>
      <%= pagination.total.toLocaleString() %> entries
    <% } %>
  </div>
</div>

<!-- Compact Filters -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-4">
  <form method="GET" action="/activity" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex gap-2 flex-1 min-w-0">
      <div class="flex-1 min-w-[100px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">User</label>
        <select name="user_id" class="w-full px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% users.forEach(function(u) { %>
            <option value="<%= u.id %>" <%= filters.user_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 min-w-[90px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Action</label>
        <select name="action" class="w-full px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% Object.keys(actionLabels).forEach(function(key) { %>
            <option value="<%= key %>" <%= filters.action === key ? 'selected' : '' %>><%= actionLabels[key] %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 min-w-[90px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Type</label>
        <select name="entity_type" class="w-full px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% Object.keys(entityTypeLabels).forEach(function(key) { %>
            <option value="<%= key %>" <%= filters.entity_type === key ? 'selected' : '' %>><%= entityTypeLabels[key] %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <div class="min-w-[110px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">From</label>
        <input type="date" name="from_date" value="<%= filters.from_date || '' %>" class="w-full px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div class="min-w-[110px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">To</label>
        <input type="date" name="to_date" value="<%= filters.to_date || '' %>" class="w-full px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
    </div>
    <div class="flex gap-2">
      <a href="/activity" class="px-4 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Activity Feed — Timeline Style -->
<% if (logs.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <svg class="w-10 h-10 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-gray-500 text-sm font-medium">No activity found</p>
    <p class="text-gray-400 text-xs mt-1">Actions will appear here as users interact with the system — creating jobs, updating tasks, approving timesheets, and more.</p>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm divide-y divide-gray-100">
  <% let lastDate = ''; logs.forEach(function(log) {
    const displayName = log.user_display_name || log.user_name || 'System';
    const initials = displayName.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
    const actionLabel = actionLabels[log.action] || log.action;
    const actionColor = actionColors[log.action] || 'bg-gray-400';
    const entityLabel = entityTypeLabels[log.entity_type] || log.entity_type;
    let dateStr = '', timeStr = '';
    if (log.created_at) {
      const d = new Date(log.created_at);
      dateStr = d.toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric' });
      timeStr = d.toLocaleTimeString('en-AU', { timeZone: 'Australia/Sydney', hour: '2-digit', minute: '2-digit', hour12: false });
    }
    const showDateHeader = dateStr !== lastDate;
    lastDate = dateStr;
  %>
    <% if (showDateHeader) { %>
    <div class="px-4 py-1.5 bg-gray-50 text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= dateStr %></div>
    <% } %>
    <div class="px-4 py-2.5 flex items-start gap-3 hover:bg-gray-50 transition-colors">
      <!-- User Avatar -->
      <div class="w-7 h-7 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0 text-[10px] font-bold text-gray-500"><%= initials %></div>
      <!-- Content -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-1.5 flex-wrap">
          <span class="text-sm font-medium text-gray-900"><%= displayName %></span>
          <span class="inline-flex items-center gap-1">
            <span class="w-1.5 h-1.5 rounded-full <%= actionColor %>"></span>
            <span class="text-xs text-gray-500"><%= actionLabel.toLowerCase() %></span>
          </span>
          <span class="text-xs font-medium text-gray-700"><%= entityLabel %></span>
          <% if (log.entity_label) { %>
            <span class="text-xs text-brand-600 truncate max-w-[200px]"><%= log.entity_label %></span>
          <% } %>
          <% if (log.job_number) { %>
            <a href="/projects/<%= log.job_id %>" class="text-[10px] text-gray-400 hover:text-brand-600"><%= log.job_number %></a>
          <% } %>
        </div>
        <% if (log.details) { %>
          <p class="text-xs text-gray-400 mt-0.5 truncate"><%= log.details %></p>
        <% } %>
      </div>
      <!-- Time -->
      <span class="text-[11px] text-gray-400 tabular-nums whitespace-nowrap flex-shrink-0"><%= timeStr %></span>
    </div>
  <% }) %>
</div>

<!-- Pagination -->
<% if (pagination.totalPages > 1) { %>
  <div class="flex items-center justify-between mt-3">
    <p class="text-xs text-gray-400">Page <%= pagination.page %> of <%= pagination.totalPages %></p>
    <div class="flex items-center gap-1">
      <% if (pagination.page > 1) { %>
        <% const prevP = new URLSearchParams(filters); prevP.set('page', pagination.page - 1); %>
        <a href="/activity?<%= prevP.toString() %>" class="px-2.5 py-1 bg-white border border-gray-200 text-gray-600 rounded-lg hover:bg-gray-50 text-xs font-medium">Prev</a>
      <% } %>
      <%
        const maxV = 5;
        let startP = Math.max(1, pagination.page - Math.floor(maxV / 2));
        let endP = Math.min(pagination.totalPages, startP + maxV - 1);
        if (endP - startP + 1 < maxV) startP = Math.max(1, endP - maxV + 1);
      %>
      <% for (let i = startP; i <= endP; i++) { %>
        <% const pp = new URLSearchParams(filters); pp.set('page', i); %>
        <% if (i === pagination.page) { %>
          <span class="px-2.5 py-1 bg-brand-600 text-white rounded-lg text-xs font-bold"><%= i %></span>
        <% } else { %>
          <a href="/activity?<%= pp.toString() %>" class="px-2.5 py-1 bg-white border border-gray-200 text-gray-600 rounded-lg hover:bg-gray-50 text-xs font-medium"><%= i %></a>
        <% } %>
      <% } %>
      <% if (pagination.page < pagination.totalPages) { %>
        <% const nextP = new URLSearchParams(filters); nextP.set('page', pagination.page + 1); %>
        <a href="/activity?<%= nextP.toString() %>" class="px-2.5 py-1 bg-white border border-gray-200 text-gray-600 rounded-lg hover:bg-gray-50 text-xs font-medium">Next</a>
      <% } %>
    </div>
  </div>
<% } %>
<% } %>
