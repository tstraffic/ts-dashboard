<% locals.currentPage = 'activity' %>

<%
  const actionColors = {
    create: 'bg-emerald-600 text-emerald-100',
    update: 'bg-blue-600 text-blue-100',
    delete: 'bg-red-600 text-red-100',
    login: 'bg-purple-600 text-purple-100',
    logout: 'bg-slate-600 text-slate-200',
    upload: 'bg-teal-600 text-teal-100',
    download: 'bg-cyan-600 text-cyan-100',
    complete: 'bg-emerald-600 text-emerald-100',
    approve: 'bg-green-600 text-green-100',
    reject: 'bg-red-600 text-red-100'
  };
  const actionLabels = {
    create: 'Create',
    update: 'Update',
    delete: 'Delete',
    login: 'Login',
    logout: 'Logout',
    upload: 'Upload',
    download: 'Download',
    complete: 'Complete',
    approve: 'Approve',
    reject: 'Reject'
  };
  const entityTypeLabels = {
    job: 'Job',
    task: 'Task',
    update: 'Update',
    compliance: 'Compliance',
    document: 'Document',
    user: 'User',
    incident: 'Incident',
    timesheet: 'Timesheet',
    equipment: 'Equipment',
    defect: 'Defect',
    budget: 'Budget',
    cost_entry: 'Cost Entry',
    contact: 'Contact',
    communication: 'Communication',
    corrective_action: 'Corrective Action'
  };
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-white">Activity Log</h1>
      <p class="text-sm text-slate-400 mt-1">Audit trail of all system actions</p>
    </div>
  </div>

  <!-- Filters -->
  <form method="GET" action="/activity" class="bg-slate-800 border border-slate-700 rounded-lg p-4 mb-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 items-end">
      <!-- User -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">User</label>
        <select name="user_id" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Users</option>
          <% users.forEach(function(u) { %>
            <option value="<%= u.id %>" <%= filters.user_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Action -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Action</label>
        <select name="action" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Actions</option>
          <% Object.keys(actionLabels).forEach(function(key) { %>
            <option value="<%= key %>" <%= filters.action === key ? 'selected' : '' %>><%= actionLabels[key] %></option>
          <% }) %>
        </select>
      </div>

      <!-- Entity Type -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Entity Type</label>
        <select name="entity_type" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Types</option>
          <% Object.keys(entityTypeLabels).forEach(function(key) { %>
            <option value="<%= key %>" <%= filters.entity_type === key ? 'selected' : '' %>><%= entityTypeLabels[key] %></option>
          <% }) %>
        </select>
      </div>

      <!-- Job -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Job</label>
        <select name="job_id" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">All Jobs</option>
          <% jobs.forEach(function(job) { %>
            <option value="<%= job.id %>" <%= filters.job_id == job.id ? 'selected' : '' %>><%= job.job_number %></option>
          <% }) %>
        </select>
      </div>

      <!-- Date From -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">From Date</label>
        <input type="date" name="from_date" value="<%= filters.from_date || '' %>" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>

      <!-- Date To -->
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">To Date</label>
        <input type="date" name="to_date" value="<%= filters.to_date || '' %>" class="w-full bg-slate-700 border border-slate-600 text-white rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
    </div>

    <div class="flex items-center gap-3 mt-4">
      <button type="submit" class="px-4 py-2 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition">
        Apply Filters
      </button>
      <a href="/activity" class="px-4 py-2 bg-slate-600 text-white rounded-lg hover:bg-slate-500 transition font-medium">
        Clear
      </a>
    </div>
  </form>

  <!-- Results Count -->
  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-slate-400">
      <% if (pagination.total > 0) { %>
        Showing <%= ((pagination.page - 1) * 50) + 1 %> - <%= Math.min(pagination.page * 50, pagination.total) %> of <%= pagination.total %> entries
      <% } else { %>
        No entries found
      <% } %>
    </p>
  </div>

  <!-- Activity Table -->
  <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
    <% if (logs.length === 0) { %>
      <div class="p-8 text-center text-slate-400">
        <svg class="w-12 h-12 mx-auto mb-3 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p>No activity log entries found.</p>
        <p class="text-sm mt-1">Activity will appear here as users interact with the system.</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-700">
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Timestamp</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">User</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Action</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Entity Type</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Entity</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Job</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-400 uppercase tracking-wider">Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700">
            <% logs.forEach(function(log) { %>
              <%
                const displayName = log.user_display_name || log.user_name || 'System';
                const actionColor = actionColors[log.action] || 'bg-slate-600 text-slate-200';
                const actionLabel = actionLabels[log.action] || log.action;
                const entityLabel = entityTypeLabels[log.entity_type] || log.entity_type;
                let formattedTime = '';
                if (log.created_at) {
                  const d = new Date(log.created_at);
                  formattedTime = d.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) + ' ' + d.toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit', hour12: false });
                }
              %>
              <tr class="hover:bg-slate-750 hover:bg-opacity-50">
                <td class="px-4 py-3 text-sm text-slate-300 whitespace-nowrap"><%= formattedTime %></td>
                <td class="px-4 py-3 text-sm text-white font-medium whitespace-nowrap"><%= displayName %></td>
                <td class="px-4 py-3">
                  <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full <%= actionColor %>"><%= actionLabel %></span>
                </td>
                <td class="px-4 py-3 text-sm text-slate-300"><%= entityLabel %></td>
                <td class="px-4 py-3 text-sm text-slate-300">
                  <% if (log.entity_label) { %>
                    <%= log.entity_label %>
                  <% } else { %>
                    <span class="text-slate-500">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-sm">
                  <% if (log.job_number) { %>
                    <a href="/jobs/<%= log.job_id %>" class="text-brand-400 hover:text-brand-300"><%= log.job_number %></a>
                  <% } else { %>
                    <span class="text-slate-500">-</span>
                  <% } %>
                </td>
                <td class="px-4 py-3 text-sm text-slate-400 max-w-xs truncate" title="<%= log.details || '' %>">
                  <%= log.details || '-' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (pagination.totalPages > 1) { %>
    <div class="flex items-center justify-between mt-6">
      <p class="text-sm text-slate-400">
        Page <%= pagination.page %> of <%= pagination.totalPages %>
      </p>
      <div class="flex items-center gap-2">
        <% if (pagination.page > 1) { %>
          <%
            const prevParams = new URLSearchParams(filters);
            prevParams.set('page', pagination.page - 1);
          %>
          <a href="/activity?<%= prevParams.toString() %>" class="px-3 py-1.5 bg-slate-700 text-slate-300 rounded-lg hover:bg-slate-600 hover:text-white transition text-sm font-medium">
            Previous
          </a>
        <% } else { %>
          <span class="px-3 py-1.5 bg-slate-800 text-slate-600 rounded-lg text-sm font-medium cursor-not-allowed">
            Previous
          </span>
        <% } %>

        <%
          const maxVisible = 5;
          let startPage = Math.max(1, pagination.page - Math.floor(maxVisible / 2));
          let endPage = Math.min(pagination.totalPages, startPage + maxVisible - 1);
          if (endPage - startPage + 1 < maxVisible) {
            startPage = Math.max(1, endPage - maxVisible + 1);
          }
        %>

        <% if (startPage > 1) { %>
          <%
            const firstParams = new URLSearchParams(filters);
            firstParams.set('page', 1);
          %>
          <a href="/activity?<%= firstParams.toString() %>" class="px-3 py-1.5 bg-slate-700 text-slate-300 rounded-lg hover:bg-slate-600 hover:text-white transition text-sm font-medium">1</a>
          <% if (startPage > 2) { %>
            <span class="px-2 text-slate-500">...</span>
          <% } %>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
          <%
            const pageParams = new URLSearchParams(filters);
            pageParams.set('page', i);
          %>
          <% if (i === pagination.page) { %>
            <span class="px-3 py-1.5 bg-brand-600 text-white rounded-lg text-sm font-bold"><%= i %></span>
          <% } else { %>
            <a href="/activity?<%= pageParams.toString() %>" class="px-3 py-1.5 bg-slate-700 text-slate-300 rounded-lg hover:bg-slate-600 hover:text-white transition text-sm font-medium"><%= i %></a>
          <% } %>
        <% } %>

        <% if (endPage < pagination.totalPages) { %>
          <% if (endPage < pagination.totalPages - 1) { %>
            <span class="px-2 text-slate-500">...</span>
          <% } %>
          <%
            const lastParams = new URLSearchParams(filters);
            lastParams.set('page', pagination.totalPages);
          %>
          <a href="/activity?<%= lastParams.toString() %>" class="px-3 py-1.5 bg-slate-700 text-slate-300 rounded-lg hover:bg-slate-600 hover:text-white transition text-sm font-medium"><%= pagination.totalPages %></a>
        <% } %>

        <% if (pagination.page < pagination.totalPages) { %>
          <%
            const nextParams = new URLSearchParams(filters);
            nextParams.set('page', pagination.page + 1);
          %>
          <a href="/activity?<%= nextParams.toString() %>" class="px-3 py-1.5 bg-slate-700 text-slate-300 rounded-lg hover:bg-slate-600 hover:text-white transition text-sm font-medium">
            Next
          </a>
        <% } else { %>
          <span class="px-3 py-1.5 bg-slate-800 text-slate-600 rounded-lg text-sm font-medium cursor-not-allowed">
            Next
          </span>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
