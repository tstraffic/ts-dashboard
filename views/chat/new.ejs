<% locals.currentPage = 'chat' %>

<div class="max-w-2xl mx-auto">
  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <a href="/chat" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">New Conversation</h1>
      <p class="text-gray-500 text-sm mt-0.5">Start a DM, group chat, or channel</p>
    </div>
  </div>

  <!-- Type selector tabs -->
  <div class="flex gap-1 mb-5 bg-gray-100 p-1 rounded-xl">
    <button type="button" onclick="showSection('dm')" id="tab-dm" class="flex-1 text-center px-3 py-2 text-sm font-medium rounded-lg transition-colors bg-white text-gray-900 shadow-sm">Direct Message</button>
    <button type="button" onclick="showSection('group')" id="tab-group" class="flex-1 text-center px-3 py-2 text-sm font-medium rounded-lg transition-colors text-gray-500 hover:text-gray-700">Group Chat</button>
    <button type="button" onclick="showSection('channel')" id="tab-channel" class="flex-1 text-center px-3 py-2 text-sm font-medium rounded-lg transition-colors text-gray-500 hover:text-gray-700">Channel</button>
    <% if (['admin','operations'].includes(user.role)) { %>
    <button type="button" onclick="showSection('ops')" id="tab-ops" class="flex-1 text-center px-3 py-2 text-sm font-medium rounded-lg transition-colors text-gray-500 hover:text-gray-700">Ops Thread</button>
    <% } %>
  </div>

  <!-- ═══════════════ DM Section ═══════════════ -->
  <div id="section-dm" class="chat-section">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-blue-50 text-blue-700">DM</span>
        Direct Message
      </h2>
      <form method="POST" action="/chat/new">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="thread_type" value="dm">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Send to</label>
          <select name="dm_user_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" required>
            <option value="">Select person...</option>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>"><%= u.full_name %> (<%= u.role %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Write your first message..."></textarea>
        </div>
        <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Start Conversation
        </button>
      </form>
    </div>
  </div>

  <!-- ═══════════════ Group Chat Section ═══════════════ -->
  <div id="section-group" class="chat-section hidden">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-purple-50 text-purple-700">GROUP</span>
        Group Chat
      </h2>
      <form method="POST" action="/chat/new">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="thread_type" value="group">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Group Name</label>
          <input type="text" name="group_name" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="e.g. Project Discussion, Quick Sync..." required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Members</label>
          <div id="group-member-chips" class="flex flex-wrap gap-2 mb-2"></div>
          <select id="group-member-select" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" onchange="addGroupMember(this)">
            <option value="">+ Add member...</option>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>" data-name="<%= u.full_name %>"><%= u.full_name %> (<%= u.role %>)</option>
            <% }) %>
          </select>
          <div id="group-hidden-inputs"></div>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Write your first message..."></textarea>
        </div>
        <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Create Group
        </button>
      </form>
    </div>
  </div>

  <!-- ═══════════════ Channel Section ═══════════════ -->
  <div id="section-channel" class="chat-section hidden">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700">CHANNEL</span>
        New Channel
      </h2>
      <form method="POST" action="/chat/new">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="thread_type" value="channel">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Channel Name</label>
          <input type="text" name="channel_name" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" placeholder="e.g. Site Updates, Safety Alerts..." required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Members</label>
          <div id="channel-member-chips" class="flex flex-wrap gap-2 mb-2"></div>
          <select id="channel-member-select" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" onchange="addChannelMember(this)">
            <option value="">+ Add member...</option>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>" data-name="<%= u.full_name %>"><%= u.full_name %> (<%= u.role %>)</option>
            <% }) %>
          </select>
          <div id="channel-hidden-inputs"></div>
          <p class="text-xs text-gray-400 mt-1">You'll be added automatically as the channel admin.</p>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">First Message <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Welcome message or topic..."></textarea>
        </div>
        <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Create Channel
        </button>
      </form>
    </div>
  </div>

  <% if (['admin','operations'].includes(user.role)) { %>
  <!-- ═══════════════ Ops Thread Section ═══════════════ -->
  <div id="section-ops" class="chat-section hidden">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-amber-50 text-amber-700">OPS</span>
        Operational Thread
      </h2>
      <form method="POST" action="/chat/new">
        <%- include('../partials/csrf') %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Thread Type</label>
          <select name="thread_type" id="thread_type" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" required onchange="toggleEntitySelect()">
            <option value="">Select type...</option>
            <option value="job">Job Thread</option>
            <option value="incident">Incident Thread</option>
          </select>
        </div>
        <div id="job_select_group" class="mb-4 hidden">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Job</label>
          <select name="entity_id" id="job_entity_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" disabled>
            <option value="">Select job...</option>
            <% jobs.forEach(j => { %>
              <option value="<%= j.id %>"><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
            <% }) %>
          </select>
        </div>
        <div id="incident_select_group" class="mb-4 hidden">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Incident</label>
          <select name="entity_id" id="incident_entity_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" disabled>
            <option value="">Select incident...</option>
            <% incidents.forEach(i => { %>
              <option value="<%= i.id %>"><%= i.incident_number %> — <%= i.title %> (<%= i.job_number %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Initial Message <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Add a message to start the conversation..."></textarea>
        </div>
        <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Create Thread
        </button>
      </form>
    </div>
  </div>
  <% } %>
</div>

<script>
  // Tab switching
  function showSection(type) {
    document.querySelectorAll('.chat-section').forEach(s => s.classList.add('hidden'));
    document.querySelectorAll('[id^="tab-"]').forEach(t => {
      t.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
      t.classList.add('text-gray-500');
    });
    document.getElementById('section-' + type).classList.remove('hidden');
    const tab = document.getElementById('tab-' + type);
    tab.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
    tab.classList.remove('text-gray-500');
  }

  // Ops thread entity toggle
  function toggleEntitySelect() {
    const type = document.getElementById('thread_type');
    if (!type) return;
    const val = type.value;
    const jobGroup = document.getElementById('job_select_group');
    const incidentGroup = document.getElementById('incident_select_group');
    const jobSelect = document.getElementById('job_entity_id');
    const incidentSelect = document.getElementById('incident_entity_id');
    jobGroup.classList.add('hidden'); incidentGroup.classList.add('hidden');
    jobSelect.disabled = true; incidentSelect.disabled = true;
    if (val === 'job') { jobGroup.classList.remove('hidden'); jobSelect.disabled = false; }
    else if (val === 'incident') { incidentGroup.classList.remove('hidden'); incidentSelect.disabled = false; }
  }

  // Multi-select member chips for Group Chat
  const groupSelected = new Set();
  function addGroupMember(select) {
    const id = select.value;
    if (!id || groupSelected.has(id)) { select.value = ''; return; }
    const name = select.options[select.selectedIndex].dataset.name;
    groupSelected.add(id);
    renderChips('group');
    select.value = '';
  }
  function removeGroupMember(id) {
    groupSelected.delete(id);
    renderChips('group');
  }

  // Multi-select member chips for Channel
  const channelSelected = new Set();
  function addChannelMember(select) {
    const id = select.value;
    if (!id || channelSelected.has(id)) { select.value = ''; return; }
    const name = select.options[select.selectedIndex].dataset.name;
    channelSelected.add(id);
    renderChips('channel');
    select.value = '';
  }
  function removeChannelMember(id) {
    channelSelected.delete(id);
    renderChips('channel');
  }

  // User name lookup
  const userNames = {<% users.forEach(u => { %>'<%= u.id %>':'<%= u.full_name.replace(/'/g, "\\'") %>',<% }) %>};

  function renderChips(type) {
    const selected = type === 'group' ? groupSelected : channelSelected;
    const chipsEl = document.getElementById(type + '-member-chips');
    const hiddenEl = document.getElementById(type + '-hidden-inputs');
    const selectEl = document.getElementById(type + '-member-select');

    chipsEl.innerHTML = '';
    hiddenEl.innerHTML = '';
    selected.forEach(id => {
      const name = userNames[id] || 'User ' + id;
      chipsEl.innerHTML += `<span class="inline-flex items-center gap-1 px-2.5 py-1 bg-brand-50 text-brand-700 text-xs font-medium rounded-full border border-brand-200">
        ${name}
        <button type="button" onclick="remove${type === 'group' ? 'Group' : 'Channel'}Member('${id}')" class="ml-0.5 text-brand-400 hover:text-brand-700">&times;</button>
      </span>`;
      hiddenEl.innerHTML += `<input type="hidden" name="${type}_members" value="${id}">`;
    });

    // Disable already-selected options
    Array.from(selectEl.options).forEach(opt => {
      if (opt.value) opt.disabled = selected.has(opt.value);
    });
  }
</script>
