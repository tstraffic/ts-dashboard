<% locals.currentPage = 'chat' %>

<div class="max-w-2xl mx-auto">
  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <a href="/chat" class="p-2 text-gray-400 hover:text-gray-600 rounded-lg hover:bg-gray-100 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">New Message</h1>
      <p class="text-gray-500 text-sm mt-0.5">Start a direct message or operational thread</p>
    </div>
  </div>

  <!-- Direct Message Section -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-4">
    <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-blue-50 text-blue-700">DM</span>
      Direct Message
    </h2>
    <form method="POST" action="/chat/new">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="thread_type" value="dm">

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Send to</label>
        <select name="dm_user_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" required>
          <option value="">Select person...</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.full_name %> (<%= u.role %>)</option>
          <% }) %>
        </select>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Message <span class="text-gray-400 font-normal">(optional)</span></label>
        <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Write your first message..."></textarea>
      </div>

      <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
        Start Conversation
      </button>
    </form>
  </div>

  <% if (canCreateOpsThread) { %>
  <!-- Operational Thread Section -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-emerald-50 text-emerald-700">OPS</span>
      Operational Thread
    </h2>
    <form method="POST" action="/chat/new">
      <%- include('../partials/csrf') %>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Thread Type</label>
        <select name="thread_type" id="thread_type" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" required onchange="toggleEntitySelect()">
          <option value="">Select type...</option>
          <option value="job">Job Thread</option>
          <option value="incident">Incident Thread</option>
        </select>
      </div>

      <div id="job_select_group" class="mb-4 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Job</label>
        <select name="entity_id" id="job_entity_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" disabled>
          <option value="">Select job...</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>"><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
          <% }) %>
        </select>
      </div>

      <div id="incident_select_group" class="mb-4 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Incident</label>
        <select name="entity_id" id="incident_entity_id" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent" disabled>
          <option value="">Select incident...</option>
          <% incidents.forEach(i => { %>
            <option value="<%= i.id %>"><%= i.incident_number %> — <%= i.title %> (<%= i.job_number %>)</option>
          <% }) %>
        </select>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Initial Message <span class="text-gray-400 font-normal">(optional)</span></label>
        <textarea name="initial_message" rows="2" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-none" placeholder="Add a message to start the conversation..."></textarea>
      </div>

      <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
        Create Thread
      </button>
    </form>
  </div>
  <% } %>
</div>

<script>
  function toggleEntitySelect() {
    const type = document.getElementById('thread_type').value;
    const jobGroup = document.getElementById('job_select_group');
    const incidentGroup = document.getElementById('incident_select_group');
    const jobSelect = document.getElementById('job_entity_id');
    const incidentSelect = document.getElementById('incident_entity_id');
    jobGroup.classList.add('hidden'); incidentGroup.classList.add('hidden');
    jobSelect.disabled = true; incidentSelect.disabled = true;
    if (type === 'job') { jobGroup.classList.remove('hidden'); jobSelect.disabled = false; }
    else if (type === 'incident') { incidentGroup.classList.remove('hidden'); incidentSelect.disabled = false; }
  }
  toggleEntitySelect();
</script>
