<% locals.currentPage = 'reports' %>

<!-- Page Header + Date Range Filter -->
<div class="mb-4 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Reports & Analytics</h1>
    <p class="text-gray-500 text-xs mt-0.5">Operational insights for <%= fromDate %> to <%= toDate %></p>
  </div>
  <form method="GET" action="/reports" class="flex items-end gap-2 flex-shrink-0">
    <input type="hidden" name="tab" id="activeTabInput" value="<%= activeTab %>">
    <div>
      <label class="block text-[10px] text-gray-400 mb-0.5">From</label>
      <input type="date" name="from" value="<%= fromDate %>" class="px-2.5 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div>
      <label class="block text-[10px] text-gray-400 mb-0.5">To</label>
      <input type="date" name="to" value="<%= toDate %>" class="px-2.5 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <button type="submit" class="px-4 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Apply</button>
  </form>
</div>

<!-- Tab Bar -->
<div class="border-b border-gray-200 mb-4">
  <nav class="flex gap-6 -mb-px overflow-x-auto" id="reportTabs">
    <button data-tab="crew" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Crew Utilisation</button>
    <button data-tab="jobs" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Job Health</button>
    <% if (canViewFinance) { %>
    <button data-tab="finance" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Financial</button>
    <% } %>
    <button data-tab="safety" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Safety & Compliance</button>
    <button data-tab="timesheets" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Timesheets</button>
    <button data-tab="exports" class="tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors">Quick Exports</button>
  </nav>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- TAB 1: Crew Utilisation                            -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="tab-crew" class="tab-panel hidden">
  <!-- KPI Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= activeCrew %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Active Crew</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= avgDaysAllocated %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Avg Days Allocated</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= Math.round(totalCrewHours * 10) / 10 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Total Hours</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= fatigueCount > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= fatigueCount %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Fatigue Alerts</p>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Hours by Crew Member</h3>
      <% if (crewData.filter(c => c.total_hours > 0).length > 0) { %>
      <div style="height: 300px"><canvas id="crewHoursBar"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No timesheet data for this period</p>
      <% } %>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Daily Allocations</h3>
      <% if (dailyAllocations.length > 0) { %>
      <div style="height: 300px"><canvas id="dailyAllocLine"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No allocations for this period</p>
      <% } %>
    </div>
  </div>

  <!-- Crew Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Crew Breakdown</h3>
    </div>
    <% if (crewData.filter(c => c.days_allocated > 0 || c.total_hours > 0).length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Name</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Role</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Days</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Overtime</th>
            <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% crewData.filter(c => c.days_allocated > 0 || c.total_hours > 0).forEach(c => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5 font-medium text-gray-900"><%= c.full_name %></td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= (c.role || '').replace(/_/g, ' ') %></td>
            <td class="px-3 py-2.5 text-right text-gray-700"><%= c.days_allocated %></td>
            <td class="px-3 py-2.5 text-right text-gray-700"><%= Math.round(c.total_hours * 10) / 10 %></td>
            <td class="px-3 py-2.5 text-right text-gray-700 hidden sm:table-cell"><%= Math.round(c.overtime_hours * 10) / 10 %></td>
            <td class="px-3 py-2.5 text-center">
              <% if (c.fatigue) { %>
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-red-50 text-red-700">Fatigue Risk</span>
              <% } else { %>
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-emerald-50 text-emerald-700">OK</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-sm text-gray-400 py-8 text-center">No crew activity for this period</p>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- TAB 2: Job Health                                  -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="tab-jobs" class="tab-panel hidden">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= activeJobCount %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Active Jobs</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= redHealth > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= redHealth %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Red Health</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= overdueJobs.length > 0 ? 'text-amber-600' : 'text-gray-900' %>"><%= overdueJobs.length %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Overdue</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= staleJobs.length %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Stale (7d+)</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Active Jobs by Health</h3>
      <% if (jobsByHealth.length > 0) { %>
      <div style="height: 250px" class="flex items-center justify-center"><canvas id="jobHealthDoughnut"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No active jobs</p>
      <% } %>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Jobs by Status</h3>
      <% if (jobsByStatus.length > 0) { %>
      <div style="height: 250px"><canvas id="jobStatusBar"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No jobs</p>
      <% } %>
    </div>
  </div>

  <!-- Needs Attention Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Needs Attention</h3>
    </div>
    <% var attentionItems = [];
       overdueJobs.forEach(j => attentionItems.push({ job_number: j.job_number, client: j.client, reason: 'Overdue (end: ' + j.end_date + ')', severity: 'red', id: j.id }));
       overBudgetJobs.forEach(j => attentionItems.push({ job_number: j.job_number, client: j.client, reason: 'Over budget ($' + Math.round(j.total_spent - j.contract_value).toLocaleString() + ')', severity: 'amber', id: j.id }));
       staleJobs.forEach(j => attentionItems.push({ job_number: j.job_number, client: j.client, reason: 'No update since ' + (j.last_update_date || 'never'), severity: 'gray', id: j.id }));
    %>
    <% if (attentionItems.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Client</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Issue</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% attentionItems.forEach(item => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5"><a href="/jobs/<%= item.id %>" class="font-medium text-brand-600 hover:underline"><%= item.job_number %></a></td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= item.client %></td>
            <td class="px-3 py-2.5">
              <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-<%= item.severity %>-50 text-<%= item.severity %>-700"><%= item.reason %></span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-sm text-gray-400 py-8 text-center">All jobs healthy</p>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- TAB 3: Financial (admin/finance only)              -->
<!-- ═══════════════════════════════════════════════════ -->
<% if (canViewFinance) { %>
<div id="tab-finance" class="tab-panel hidden">
  <% var fd = financeData; var margin = fd.portfolio.total_contract > 0 ? Math.round((1 - fd.portfolio.total_spent / fd.portfolio.total_contract) * 1000) / 10 : 0; %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900">$<%= Math.round(fd.portfolio.total_contract).toLocaleString() %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Contract Value</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900">$<%= Math.round(fd.portfolio.total_spent).toLocaleString() %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Total Spend</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= margin < 10 ? 'text-red-600' : margin < 25 ? 'text-amber-600' : 'text-emerald-600' %>"><%= margin %>%</p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Portfolio Margin</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= fd.overBudgetCount > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= fd.overBudgetCount %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Over Budget</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Monthly Spend Trend</h3>
      <% if (fd.monthlySpend.length > 0) { %>
      <div style="height: 280px"><canvas id="monthlySpendChart"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No cost entries recorded</p>
      <% } %>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Spend by Category</h3>
      <% if (fd.spendByCategory.length > 0) { %>
      <div style="height: 280px" class="flex items-center justify-center"><canvas id="spendCatChart"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No cost entries for this period</p>
      <% } %>
    </div>
  </div>

  <!-- Job Financials Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job Financial Summary</h3>
    </div>
    <% if (fd.jobFinancials.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Client</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Contract</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Spent</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Margin</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest w-32 hidden md:table-cell">Usage</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% fd.jobFinancials.forEach(j => {
            var total = j.contract_value + j.variations;
            var pct = total > 0 ? Math.round(j.total_spent / total * 100) : 0;
            var marginPct = total > 0 ? Math.round((1 - j.total_spent / total) * 100) : 0;
            var barColor = pct > 90 ? 'bg-red-500' : pct > 70 ? 'bg-amber-500' : 'bg-emerald-500';
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5"><a href="/jobs/<%= j.id %>" class="font-medium text-brand-600 hover:underline"><%= j.job_number %></a></td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= j.client %></td>
            <td class="px-3 py-2.5 text-right text-gray-700">$<%= Math.round(total).toLocaleString() %></td>
            <td class="px-3 py-2.5 text-right text-gray-700">$<%= Math.round(j.total_spent).toLocaleString() %></td>
            <td class="px-3 py-2.5 text-right hidden sm:table-cell">
              <span class="<%= marginPct < 10 ? 'text-red-600' : marginPct < 25 ? 'text-amber-600' : 'text-emerald-600' %> font-medium"><%= marginPct %>%</span>
            </td>
            <td class="px-3 py-2.5 hidden md:table-cell">
              <div class="w-full bg-gray-100 rounded-full h-2">
                <div class="<%= barColor %> h-2 rounded-full" style="width: <%= Math.min(pct, 100) %>%"></div>
              </div>
              <span class="text-[10px] text-gray-400"><%= pct %>%</span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-sm text-gray-400 py-8 text-center">No budgets configured</p>
    <% } %>
  </div>
</div>
<% } %>

<!-- ═══════════════════════════════════════════════════ -->
<!-- TAB 4: Safety & Compliance                         -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="tab-safety" class="tab-panel hidden">
  <% var caRate = correctiveStats.total > 0 ? Math.round(correctiveStats.completed / correctiveStats.total * 100) : 100; %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= openIncidents.length > 0 ? 'text-amber-600' : 'text-gray-900' %>"><%= openIncidents.length %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Open Incidents</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= correctiveStats.overdue > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= correctiveStats.overdue %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Overdue Actions</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= caRate < 70 ? 'text-red-600' : caRate < 90 ? 'text-amber-600' : 'text-emerald-600' %>"><%= caRate %>%</p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Action Completion</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= notifiableCount > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= notifiableCount %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Notifiable</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Incidents by Month</h3>
      <% if (incidentsByMonth.length > 0) { %>
      <div style="height: 280px"><canvas id="incidentMonthChart"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No incidents for this period</p>
      <% } %>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Incidents by Type</h3>
      <% if (incidentsByType.length > 0) { %>
      <div style="height: 280px" class="flex items-center justify-center"><canvas id="incidentTypeChart"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No incidents for this period</p>
      <% } %>
    </div>
  </div>

  <!-- Open Incidents Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden mb-4">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Open Incidents</h3>
    </div>
    <% if (openIncidents.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Incident</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Job</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Severity</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Date</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% openIncidents.forEach(i => {
            var sevColor = { low: 'emerald', medium: 'amber', high: 'red', critical: 'red' }[i.severity] || 'gray';
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5">
              <a href="/incidents/<%= i.id %>" class="font-medium text-brand-600 hover:underline"><%= i.incident_number %></a>
              <p class="text-xs text-gray-400 truncate max-w-xs"><%= i.title %></p>
            </td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= i.job_number %></td>
            <td class="px-3 py-2.5"><span class="px-2 py-0.5 text-xs font-medium rounded-full bg-<%= sevColor %>-50 text-<%= sevColor %>-700"><%= i.severity %></span></td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= i.incident_date %></td>
            <td class="px-3 py-2.5"><span class="px-2 py-0.5 text-xs font-medium rounded-full bg-blue-50 text-blue-700"><%= (i.investigation_status || '').replace(/_/g, ' ') %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-sm text-gray-400 py-8 text-center">No open incidents</p>
    <% } %>
  </div>

  <!-- Overdue Compliance -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Overdue Compliance Items</h3>
    </div>
    <% if (overdueCompliance.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Item</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Job</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Due</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% overdueCompliance.forEach(c => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2.5 font-medium text-gray-900"><%= c.title %></td>
            <td class="px-3 py-2.5 text-gray-500 hidden sm:table-cell"><%= c.job_number %></td>
            <td class="px-3 py-2.5"><span class="px-2 py-0.5 text-xs font-medium rounded-full bg-purple-50 text-purple-700"><%= (c.item_type || '').replace(/_/g, ' ') %></span></td>
            <td class="px-3 py-2.5 text-red-600 font-medium"><%= c.due_date %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <p class="text-sm text-gray-400 py-8 text-center">No overdue compliance items</p>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ -->
<!-- TAB 5: Timesheets                                  -->
<!-- ═══════════════════════════════════════════════════ -->
<div id="tab-timesheets" class="tab-panel hidden">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= Math.round(tsOverall.total_hours * 10) / 10 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Total Hours</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold <%= tsOverall.pending_hours > 0 ? 'text-amber-600' : 'text-gray-900' %>"><%= Math.round(tsOverall.pending_hours * 10) / 10 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Pending Approval</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= Math.round(tsOverall.overtime_hours * 10) / 10 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Overtime Hours</p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-2xl font-extrabold text-gray-900"><%= tsOverall.unique_crew %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Unique Crew</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Weekly Hours</h3>
      <% if (tsWeekly.length > 0) { %>
      <div style="height: 280px"><canvas id="weeklyHoursChart"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No timesheet data for this period</p>
      <% } %>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Approval Status</h3>
      <% if (tsOverall.total_hours > 0) { %>
      <div style="height: 280px" class="flex items-center justify-center"><canvas id="approvalPie"></canvas></div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-12 text-center">No timesheet data</p>
      <% } %>
    </div>
  </div>

  <!-- Hours by Job -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100">
        <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours by Job</h3>
      </div>
      <% if (tsByJob.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50">
              <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">OT</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Crew</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% tsByJob.forEach(j => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2.5">
                <a href="/jobs/<%= j.id %>" class="font-medium text-brand-600 hover:underline"><%= j.job_number %></a>
                <p class="text-xs text-gray-400 truncate max-w-[150px]"><%= j.client %></p>
              </td>
              <td class="px-3 py-2.5 text-right font-medium text-gray-700"><%= Math.round(j.total_hours * 10) / 10 %></td>
              <td class="px-3 py-2.5 text-right text-gray-500 hidden sm:table-cell"><%= Math.round(j.overtime * 10) / 10 %></td>
              <td class="px-3 py-2.5 text-right text-gray-500 hidden sm:table-cell"><%= j.crew_count %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-8 text-center">No timesheet data</p>
      <% } %>
    </div>

    <!-- Hours by Crew -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100">
        <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours by Crew Member</h3>
      </div>
      <% if (tsByCrew.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50/50">
              <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Name</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Hours</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">OT</th>
              <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Days</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% tsByCrew.forEach(c => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2.5">
                <p class="font-medium text-gray-900"><%= c.full_name %></p>
                <p class="text-xs text-gray-400"><%= (c.role || '').replace(/_/g, ' ') %></p>
              </td>
              <td class="px-3 py-2.5 text-right font-medium text-gray-700"><%= Math.round(c.total_hours * 10) / 10 %></td>
              <td class="px-3 py-2.5 text-right text-gray-500 hidden sm:table-cell"><%= Math.round(c.overtime * 10) / 10 %></td>
              <td class="px-3 py-2.5 text-right text-gray-500 hidden sm:table-cell"><%= c.days_worked %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-sm text-gray-400 py-8 text-center">No timesheet data</p>
      <% } %>
    </div>
  </div>
</div>

