<!-- Chart.js + Tab Switching Script                     -->
<!-- ═══════════════════════════════════════════════════ -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
  // Tab switching
  var tabs = document.querySelectorAll('.tab-btn');
  var panels = document.querySelectorAll('.tab-panel');
  var tabInput = document.getElementById('activeTabInput');

  function activateTab(name) {
    tabs.forEach(function(t) {
      var active = t.getAttribute('data-tab') === name;
      t.className = 'tab-btn whitespace-nowrap pb-2.5 px-1 text-sm font-medium border-b-2 transition-colors ' +
        (active ? 'border-brand-500 text-brand-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300');
    });
    panels.forEach(function(p) {
      p.classList.toggle('hidden', p.id !== 'tab-' + name);
    });
    tabInput.value = name;
  }

  tabs.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activateTab(this.getAttribute('data-tab'));
    });
  });

  activateTab('<%= activeTab %>');

  // ── Chart Helpers ──
  var brandBlue = '#2B7FFF';
  var chartDefaults = { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } };

  // ── Crew Utilisation Charts ──
  <% var crewChartData = crewData.filter(c => c.total_hours > 0).slice(0, 15); %>
  <% if (crewChartData.length > 0) { %>
  var crewBarData = <%- JSON.stringify(crewChartData) %>;
  new Chart(document.getElementById('crewHoursBar'), {
    type: 'bar',
    data: {
      labels: crewBarData.map(function(d) { return d.full_name; }),
      datasets: [{
        data: crewBarData.map(function(d) { return Math.round(d.total_hours * 10) / 10; }),
        backgroundColor: crewBarData.map(function(d) { return d.fatigue ? '#f87171' : brandBlue; }),
        borderRadius: 4, barThickness: 16
      }]
    },
    options: Object.assign({}, chartDefaults, { indexAxis: 'y', scales: { x: { grid: { display: false }, beginAtZero: true }, y: { grid: { display: false } } } })
  });
  <% } %>

  <% if (dailyAllocations.length > 0) { %>
  var allocData = <%- JSON.stringify(dailyAllocations) %>;
  new Chart(document.getElementById('dailyAllocLine'), {
    type: 'line',
    data: {
      labels: allocData.map(function(d) { return new Date(d.date + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }); }),
      datasets: [{ data: allocData.map(function(d) { return d.count; }), borderColor: brandBlue, backgroundColor: 'rgba(43,127,255,0.08)', fill: true, tension: 0.4, pointRadius: 2, borderWidth: 2 }]
    },
    options: Object.assign({}, chartDefaults, { scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' }, beginAtZero: true, ticks: { stepSize: 1 } } } })
  });
  <% } %>

  // ── Job Health Charts ──
  <% if (jobsByHealth.length > 0) { %>
  var healthData = <%- JSON.stringify(jobsByHealth) %>;
  var hColors = { green: '#34d399', amber: '#fb923c', red: '#f87171' };
  new Chart(document.getElementById('jobHealthDoughnut'), {
    type: 'doughnut',
    data: {
      labels: healthData.map(function(d) { return d.health.charAt(0).toUpperCase() + d.health.slice(1); }),
      datasets: [{ data: healthData.map(function(d) { return d.count; }), backgroundColor: healthData.map(function(d) { return hColors[d.health] || '#94a3b8'; }), borderWidth: 0, cutout: '70%' }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 16 } } } }
  });
  <% } %>

  <% if (jobsByStatus.length > 0) { %>
  var statusData = <%- JSON.stringify(jobsByStatus) %>;
  var sLabels = { lead: 'Lead', won: 'Won', active: 'Active', on_hold: 'On Hold', completed: 'Completed', lost: 'Lost' };
  var sColors = { lead: '#94a3b8', won: '#34d399', active: '#2B7FFF', on_hold: '#fb923c', completed: '#6ee7b7', lost: '#fca5a5' };
  new Chart(document.getElementById('jobStatusBar'), {
    type: 'bar',
    data: {
      labels: statusData.map(function(d) { return sLabels[d.status] || d.status; }),
      datasets: [{ data: statusData.map(function(d) { return d.count; }), backgroundColor: statusData.map(function(d) { return sColors[d.status] || '#94a3b8'; }), borderRadius: 6, barThickness: 24 }]
    },
    options: Object.assign({}, chartDefaults, { indexAxis: 'y', scales: { x: { grid: { display: false }, ticks: { stepSize: 1 } }, y: { grid: { display: false } } } })
  });
  <% } %>

  // ── Financial Charts ──
  <% if (canViewFinance && financeData.monthlySpend && financeData.monthlySpend.length > 0) { %>
  var spendData = <%- JSON.stringify(financeData.monthlySpend) %>;
  new Chart(document.getElementById('monthlySpendChart'), {
    type: 'bar',
    data: {
      labels: spendData.map(function(d) { var p = d.month.split('-'); return new Date(p[0], p[1]-1).toLocaleDateString('en-AU', { month: 'short', year: '2-digit' }); }),
      datasets: [{ data: spendData.map(function(d) { return Math.round(d.total); }), backgroundColor: brandBlue, borderRadius: 6, barThickness: 32 }]
    },
    options: Object.assign({}, chartDefaults, { scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' }, beginAtZero: true, ticks: { callback: function(v) { return '$' + v.toLocaleString(); } } } } })
  });
  <% } %>

  <% if (canViewFinance && financeData.spendByCategory && financeData.spendByCategory.length > 0) { %>
  var catData = <%- JSON.stringify(financeData.spendByCategory) %>;
  var catColors = { labour: '#2B7FFF', materials: '#34d399', subcontractors: '#fb923c', equipment: '#a78bfa', other: '#94a3b8' };
  new Chart(document.getElementById('spendCatChart'), {
    type: 'doughnut',
    data: {
      labels: catData.map(function(d) { return d.category.charAt(0).toUpperCase() + d.category.slice(1); }),
      datasets: [{ data: catData.map(function(d) { return Math.round(d.total); }), backgroundColor: catData.map(function(d) { return catColors[d.category] || '#94a3b8'; }), borderWidth: 0, cutout: '65%' }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 16 } }, tooltip: { callbacks: { label: function(ctx) { return ctx.label + ': $' + ctx.parsed.toLocaleString(); } } } } }
  });
  <% } %>

  // ── Safety Charts ──
  <% if (incidentsByMonth.length > 0) { %>
  var incMonthRaw = <%- JSON.stringify(incidentsByMonth) %>;
  // Group by month, stack by severity
  var months = []; var sevSets = {};
  incMonthRaw.forEach(function(d) {
    if (months.indexOf(d.month) === -1) months.push(d.month);
    if (!sevSets[d.severity]) sevSets[d.severity] = {};
    sevSets[d.severity][d.month] = d.count;
  });
  var sevColors = { low: '#94a3b8', medium: '#fbbf24', high: '#fb923c', critical: '#f87171' };
  var sevDatasets = Object.keys(sevSets).map(function(sev) {
    return { label: sev.charAt(0).toUpperCase() + sev.slice(1), data: months.map(function(m) { return sevSets[sev][m] || 0; }), backgroundColor: sevColors[sev] || '#94a3b8', borderRadius: 4 };
  });
  new Chart(document.getElementById('incidentMonthChart'), {
    type: 'bar',
    data: { labels: months.map(function(m) { var p = m.split('-'); return new Date(p[0], p[1]-1).toLocaleDateString('en-AU', { month: 'short' }); }), datasets: sevDatasets },
    options: Object.assign({}, chartDefaults, { plugins: { legend: { display: true, position: 'bottom' } }, scales: { x: { stacked: true, grid: { display: false } }, y: { stacked: true, grid: { color: '#f3f4f6' }, beginAtZero: true, ticks: { stepSize: 1 } } } })
  });
  <% } %>

  <% if (incidentsByType.length > 0) { %>
  var typeData = <%- JSON.stringify(incidentsByType) %>;
  var typeColors = ['#2B7FFF','#34d399','#fb923c','#f87171','#a78bfa','#fbbf24','#94a3b8','#ec4899','#14b8a6','#6366f1','#78716c'];
  new Chart(document.getElementById('incidentTypeChart'), {
    type: 'doughnut',
    data: {
      labels: typeData.map(function(d) { return d.incident_type.replace(/_/g, ' '); }),
      datasets: [{ data: typeData.map(function(d) { return d.count; }), backgroundColor: typeColors.slice(0, typeData.length), borderWidth: 0, cutout: '65%' }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 12, boxWidth: 12 } } } }
  });
  <% } %>

  // ── Timesheet Charts ──
  <% if (tsWeekly.length > 0) { %>
  var weekData = <%- JSON.stringify(tsWeekly) %>;
  new Chart(document.getElementById('weeklyHoursChart'), {
    type: 'bar',
    data: {
      labels: weekData.map(function(d) { return d.week; }),
      datasets: [
        { label: 'Ordinary', data: weekData.map(function(d) { return Math.round((d.ordinary || d.total_hours - d.overtime) * 10) / 10; }), backgroundColor: brandBlue, borderRadius: 4 },
        { label: 'Overtime', data: weekData.map(function(d) { return Math.round(d.overtime * 10) / 10; }), backgroundColor: '#fb923c', borderRadius: 4 }
      ]
    },
    options: Object.assign({}, chartDefaults, { plugins: { legend: { display: true, position: 'bottom' } }, scales: { x: { stacked: true, grid: { display: false } }, y: { stacked: true, grid: { color: '#f3f4f6' }, beginAtZero: true } } })
  });
  <% } %>

  <% if (tsOverall.total_hours > 0) { %>
  new Chart(document.getElementById('approvalPie'), {
    type: 'doughnut',
    data: {
      labels: ['Approved', 'Pending'],
      datasets: [{ data: [<%= tsOverall.approved_hours %>, <%= tsOverall.pending_hours %>], backgroundColor: ['#34d399', '#fbbf24'], borderWidth: 0, cutout: '65%' }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 16 } } } }
  });
  <% } %>
})();
</script>
