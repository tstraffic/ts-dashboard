              <input type="date" name="from_date" value="<%= new Date().toISOString().split('T')[0] %>" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
            <div>
              <label class="block text-[10px] text-gray-400 mb-0.5">To</label>
              <input type="date" name="to_date" value="<%= (() => { const d = new Date(); d.setDate(d.getDate() + 6); return d.toISOString().split('T')[0]; })() %>" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            </div>
          </div>
          <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Export CSV</button>
        </form>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Job Report (PDF)</h3>
        <p class="text-xs text-gray-500 mb-3">Full job summary including budget, timesheets & compliance</p>
        <form method="GET" action="/exports/job-report.pdf" class="space-y-2">
          <%- include('../partials/csrf') %>
          <select name="job_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">Choose a job...</option>
            <% jobs.forEach(j => { %>
              <option value="<%= j.id %>"><%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %></option>
            <% }) %>
          </select>
          <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Generate PDF</button>
        </form>
      </div>
    </div>
  </div>
</div>

