<% locals.currentPage = 'reports' %>

<!-- Page Header -->
<div class="mb-4">
  <h1 class="text-2xl font-bold text-gray-900">Reports & Exports</h1>
  <p class="text-gray-500 text-xs mt-0.5">Download data extracts and generate reports</p>
</div>

<!-- Two-column layout: Quick Exports left, Tools right -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

  <!-- Quick Exports — compact list, not cards -->
  <div class="lg:col-span-2">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm">
      <div class="px-4 py-3 border-b border-gray-100">
        <h2 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Quick Exports</h2>
      </div>
      <div class="divide-y divide-gray-50">
        <a href="/exports/jobs.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Jobs Register</p>
            <p class="text-xs text-gray-400">All jobs with status, dates & budget</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <a href="/exports/timesheets.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-emerald-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Timesheets</p>
            <p class="text-xs text-gray-400">All entries with hours, crew & approval status</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <a href="/exports/incidents.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-red-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Incidents</p>
            <p class="text-xs text-gray-400">Safety incidents, severity & actions</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <a href="/exports/compliance.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-purple-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Compliance</p>
            <p class="text-xs text-gray-400">Permits, approvals & certifications</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <a href="/exports/equipment.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-amber-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Equipment</p>
            <p class="text-xs text-gray-400">Assets, conditions & assignments</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <a href="/exports/allocations.csv?from_date=<%= new Date().toISOString().split('T')[0] %>&to_date=<%= (() => { const d = new Date(); d.setDate(d.getDate() + 6); return d.toISOString().split('T')[0]; })() %>" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-teal-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Allocations</p>
            <p class="text-xs text-gray-400">This week's crew bookings</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>

        <% if (user && (user.role === 'admin' || user.role === 'finance')) { %>
        <a href="/exports/budgets.csv" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
          <div class="w-8 h-8 bg-yellow-50 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 group-hover:text-brand-600 transition-colors">Budgets</p>
            <p class="text-xs text-gray-400">Budget & cost summary per job</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3"/></svg>
        </a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right column: Report tools -->
  <div class="space-y-4">
    <!-- Timesheet Summary -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Timesheet Weekly Summary</h3>
      <p class="text-xs text-gray-500 mb-3">Hours per crew member for a selected week</p>
      <form method="GET" action="/exports/timesheet-summary.csv" class="space-y-2">
        <%- include('../partials/csrf') %>
        <input type="date" name="week_of" value="<%= new Date().toISOString().split('T')[0] %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Export CSV</button>
      </form>
    </div>

    <!-- Allocations Date Range -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Allocations by Date Range</h3>
      <p class="text-xs text-gray-500 mb-3">Crew allocations for a specific period</p>
      <form method="GET" action="/exports/allocations.csv" class="space-y-2">
        <%- include('../partials/csrf') %>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-[10px] text-gray-400 mb-0.5">From</label>
            <input type="date" name="from_date" value="<%= new Date().toISOString().split('T')[0] %>"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <label class="block text-[10px] text-gray-400 mb-0.5">To</label>
            <input type="date" name="to_date" value="<%= (() => { const d = new Date(); d.setDate(d.getDate() + 6); return d.toISOString().split('T')[0]; })() %>"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
        </div>
        <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Export CSV</button>
      </form>
    </div>

    <!-- Job PDF Report -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Job Report (PDF)</h3>
      <p class="text-xs text-gray-500 mb-3">Full job summary including budget, timesheets & compliance</p>
      <form method="GET" action="/exports/job-report.pdf" class="space-y-2">
        <%- include('../partials/csrf') %>
        <select name="job_id" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <option value="">Choose a job...</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>"><%= j.job_number %> - <%= j.client %></option>
          <% }) %>
        </select>
        <button type="submit" class="w-full px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Generate PDF</button>
      </form>
    </div>
  </div>
</div>
