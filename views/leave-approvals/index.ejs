<% locals.currentPage = 'leave-approvals' %>
<meta name="color-scheme" content="light only">

<%
  function fmtDate(iso) {
    if (!iso) return '';
    const d = new Date(iso + 'T00:00:00');
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  function fmtRange(s, e) {
    return s === e ? fmtDate(s) : (fmtDate(s) + ' – ' + fmtDate(e));
  }
  function daysAgo(iso) {
    if (!iso) return '';
    const d = new Date(iso); const diff = Math.max(0, Math.floor((Date.now() - d.getTime()) / 86400000));
    if (diff === 0) return 'today';
    if (diff === 1) return 'yesterday';
    if (diff < 7) return diff + 'd ago';
    return d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short' });
  }
  function leaveTypePill(t) {
    const map = {
      annual:   'bg-blue-50 text-blue-700 ring-blue-600/20',
      sick:     'bg-rose-50 text-rose-700 ring-rose-600/20',
      personal: 'bg-violet-50 text-violet-700 ring-violet-600/20',
      unpaid:   'bg-amber-50 text-amber-700 ring-amber-600/20',
      other:    'bg-gray-100 text-gray-600 ring-gray-600/15',
    };
    return map[t] || map.other;
  }
  function rolePill(pr) {
    if (pr === 'supervisor')  return 'bg-violet-50 text-violet-700';
    if (pr === 'team_leader') return 'bg-amber-50 text-amber-700';
    return                            'bg-gray-100 text-gray-600';
  }
  function urgencyClass(start) {
    if (!start) return 'bg-gray-50 text-gray-600 ring-gray-600/15';
    if (start <= todayIso) return 'bg-red-50 text-red-700 ring-red-600/20';
    return 'bg-amber-50 text-amber-700 ring-amber-600/20';
  }
%>

<style>
  .la-card    { background:#fff; border:1px solid #E5E7EB; border-radius:14px; }
  .la-row     { display:flex; align-items:flex-start; gap:14px; padding:14px 16px; border-top:1px solid #F3F4F6; }
  .la-row:first-child { border-top:none; }
  .la-row:hover { background:#F9FAFB; }
  .la-avatar  { width:38px; height:38px; flex-shrink:0; border-radius:999px; background:#EFF6FF; color:#1D4ED8; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:0.78rem; }
  .la-meta    { flex:1; min-width:0; }
  .la-name    { font-size:0.92rem; font-weight:700; color:#0F172A; line-height:1.2; }
  .la-emp     { font-size:0.7rem; color:#6B7280; margin-top:1px; font-family:ui-monospace,SFMono-Regular,monospace; letter-spacing:0.02em; }
  .la-when    { font-size:0.85rem; color:#1F2937; font-weight:600; margin-top:6px; }
  .la-reason  { font-size:0.8rem; color:#4B5563; margin-top:4px; line-height:1.35; }
  .la-pills   { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
  .la-pill    { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:999px; font-size:0.65rem; font-weight:700; ring-width:1px; text-transform:uppercase; letter-spacing:0.04em; }
  .la-actions { display:flex; align-items:center; gap:6px; flex-shrink:0; }
  .la-btn     { display:inline-flex; align-items:center; gap:5px; padding:7px 12px; font-size:0.78rem; font-weight:700; border-radius:8px; transition:background 0.12s, color 0.12s; cursor:pointer; }
  .la-approve { background:#10B981; color:#fff; }
  .la-approve:hover { background:#059669; }
  .la-reject  { background:#FEE2E2; color:#B91C1C; }
  .la-reject:hover { background:#FECACA; }

  .la-section-head { display:flex; align-items:center; justify-content:space-between; margin: 18px 4px 8px; }
  .la-section-title { display:flex; align-items:center; gap:8px; font-size:0.78rem; font-weight:800; letter-spacing:0.02em; color:#111827; }
  .la-section-title .icon { width:24px; height:24px; border-radius:8px; display:flex; align-items:center; justify-content:center; }
  .la-section-title .icon.now   { background:#FEE2E2; color:#DC2626; }
  .la-section-title .icon.month { background:#FEF3C7; color:#B45309; }
  .la-section-title .icon.later { background:#DBEAFE; color:#1D4ED8; }
  .la-section-title .icon.done  { background:#F3F4F6; color:#6B7280; }
  .la-section-count { font-size:0.65rem; font-weight:800; color:#6B7280; background:#F3F4F6; padding:2px 8px; border-radius:999px; }
  .la-section-empty { padding:18px 16px; font-size:0.8rem; color:#9CA3AF; font-style:italic; background:#fff; border:1px dashed #E5E7EB; border-radius:12px; text-align:center; }

  .la-status-chip {
    display:inline-flex; align-items:center; gap:6px;
    padding:7px 12px; border-radius:999px;
    font-size:0.72rem; font-weight:700;
    background:#fff; color:#4B5563;
    border:1px solid #E5E7EB;
    text-decoration:none; transition: all 0.12s;
  }
  .la-status-chip:hover { background:#F9FAFB; }
  .la-status-chip.active { background:#0F172A; color:#fff; border-color:#0F172A; }
  .la-status-chip .n {
    background:rgba(0,0,0,0.06); color:inherit;
    font-size:0.6rem; font-weight:800; padding:1px 6px; border-radius:999px;
  }
  .la-status-chip.active .n { background:rgba(255,255,255,0.18); }
  .la-status-chip .dot {
    width:6px; height:6px; border-radius:999px;
  }

  .la-search-input {
    width:100%;
    background:#fff; color:#0F172A;
    border:1px solid #D1D5DB; border-radius:10px;
    padding:9px 12px 9px 34px;
    font-size:0.85rem;
    color-scheme:light;
  }
  .la-search-input:focus { outline:none; border-color:#2B7FFF; box-shadow:0 0 0 3px rgba(43,127,255,0.18); }
</style>

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-5">

  <!-- ── Header ── -->
  <div class="flex items-end justify-between flex-wrap gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Leave Approvals</h1>
      <p class="text-sm text-gray-500 mt-0.5">Approve or decline worker leave requests. Action-now first, organised by urgency.</p>
    </div>
    <% if (counts.actionNow > 0) { %>
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-red-50 text-red-700 ring-1 ring-red-600/20 text-xs font-semibold">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <%= counts.actionNow %> request<%= counts.actionNow === 1 ? '' : 's' %> need attention this week
      </div>
    <% } %>
  </div>

  <!-- ── Status chips + search + crew filter ── -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 flex flex-col lg:flex-row lg:items-center gap-3">
    <form method="GET" class="flex flex-wrap items-center gap-2 flex-1 min-w-0">
      <% [
        ['pending',  'Pending',  counts.pending,  '#F59E0B'],
        ['approved', 'Approved', counts.approved, '#10B981'],
        ['rejected', 'Rejected', counts.rejected, '#EF4444'],
        ['all',      'All',      counts.pending + counts.approved + counts.rejected, '#6B7280'],
      ].forEach(function (p) { %>
        <button type="submit" name="status" value="<%= p[0] %>"
          class="la-status-chip <%= status === p[0] ? 'active' : '' %>">
          <span class="dot" style="background:<%= p[3] %>;"></span>
          <%= p[1] %>
          <span class="n"><%= p[2] %></span>
        </button>
      <% }) %>
      <% if (search) { %><input type="hidden" name="q" value="<%= search %>"><% } %>
      <% if (crewId) { %><input type="hidden" name="crew_member_id" value="<%= crewId %>"><% } %>
    </form>

    <form method="GET" class="flex items-center gap-2 lg:ml-auto" role="search">
      <input type="hidden" name="status" value="<%= status %>">
      <% if (crewId) { %><input type="hidden" name="crew_member_id" value="<%= crewId %>"><% } %>
      <label class="relative block">
        <span class="sr-only">Search reason or employee</span>
        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
        <input type="text" name="q" value="<%= search %>" placeholder="Search name, code, reason…" class="la-search-input" style="min-width:240px;">
      </label>
    </form>

    <% if (search || crewId || status !== 'pending') { %>
      <a href="/leave-approvals" class="text-xs text-gray-500 hover:text-gray-700">Clear filters</a>
    <% } %>
  </div>

  <!-- ── PENDING buckets, organised by urgency ── -->
  <% if (status === 'pending' || status === 'all') { %>

    <!-- Action now — overdue or this week -->
    <div class="la-section-head">
      <div class="la-section-title">
        <span class="icon now"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></span>
        Action now <span class="text-gray-400 font-normal">— starting in the next 7 days or already in progress</span>
      </div>
      <span class="la-section-count"><%= buckets.actionNow.length %></span>
    </div>
    <% if (buckets.actionNow.length === 0) { %>
      <div class="la-section-empty">Nothing urgent — caught up here.</div>
    <% } else { %>
      <%- include('_pending_card', { rows: buckets.actionNow, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '' }) %>
    <% } %>

    <!-- This month -->
    <% if (buckets.thisMonth.length > 0) { %>
      <div class="la-section-head">
        <div class="la-section-title">
          <span class="icon month"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></span>
          This month
        </div>
        <span class="la-section-count"><%= buckets.thisMonth.length %></span>
      </div>
      <%- include('_pending_card', { rows: buckets.thisMonth, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '' }) %>
    <% } %>

    <!-- Later -->
    <% if (buckets.later.length > 0) { %>
      <div class="la-section-head">
        <div class="la-section-title">
          <span class="icon later"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></span>
          Later
        </div>
        <span class="la-section-count"><%= buckets.later.length %></span>
      </div>
      <%- include('_pending_card', { rows: buckets.later, csrfToken: typeof csrfToken !== 'undefined' ? csrfToken : '' }) %>
    <% } %>

    <% if (buckets.actionNow.length === 0 && buckets.thisMonth.length === 0 && buckets.later.length === 0) { %>
      <div class="la-card p-10 text-center">
        <div class="w-14 h-14 rounded-full bg-emerald-50 text-emerald-500 flex items-center justify-center mx-auto mb-3">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <p class="text-base font-semibold text-gray-700">All clear — no pending leave requests.</p>
        <p class="text-sm text-gray-500 mt-1">When workers submit leave from the portal, it'll show up here for approval.</p>
      </div>
    <% } %>
  <% } %>

  <!-- ── DECIDED list (approved + rejected, when filtered to those) ── -->
  <% if (status === 'approved' || status === 'rejected' || status === 'all') { %>
    <div class="la-section-head">
      <div class="la-section-title">
        <span class="icon done"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg></span>
        <%= status === 'approved' ? 'Approved' : status === 'rejected' ? 'Rejected' : 'Decided' %>
      </div>
      <span class="la-section-count"><%= buckets.decided.length %></span>
    </div>
    <% if (buckets.decided.length === 0) { %>
      <div class="la-section-empty">Nothing here yet.</div>
    <% } else { %>
      <div class="la-card">
        <% buckets.decided.forEach(function (l) { %>
          <div class="la-row">
            <div class="la-avatar"><%= (l.crew_name || '?').split(' ').map(function (p) { return p[0] || ''; }).join('').slice(0, 2).toUpperCase() %></div>
            <div class="la-meta">
              <p class="la-name"><%= l.crew_name %></p>
              <p class="la-emp"><%= l.crew_emp_id || '—' %></p>
              <p class="la-when"><%= fmtRange(l.start_date, l.end_date) %><% if (l.total_days) { %> <span class="text-gray-400 font-normal">· <%= l.total_days %> day<%= l.total_days === 1 ? '' : 's' %></span><% } %></p>
              <% if (l.reason) { %><p class="la-reason"><%= l.reason %></p><% } %>
              <div class="la-pills">
                <span class="la-pill ring-1 <%= leaveTypePill(l.leave_type) %>"><%= (l.leave_type || 'leave').replace('_',' ') %></span>
                <% if (l.status === 'approved') { %>
                  <span class="la-pill ring-1 bg-emerald-50 text-emerald-700 ring-emerald-600/20">Approved</span>
                <% } else if (l.status === 'rejected') { %>
                  <span class="la-pill ring-1 bg-red-50 text-red-700 ring-red-600/20">Rejected</span>
                <% } %>
                <% if (l.approver_name) { %>
                  <span class="text-[11px] text-gray-400">by <%= l.approver_name %> · <%= daysAgo(l.approved_at) %></span>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  <% } %>

</div>
