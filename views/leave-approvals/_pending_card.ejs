<%
  function fmtDateP(iso) {
    if (!iso) return '';
    const d = new Date(iso + 'T00:00:00');
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  function fmtRangeP(s, e) { return s === e ? fmtDateP(s) : (fmtDateP(s) + ' – ' + fmtDateP(e)); }
  function leaveTypePillP(t) {
    const map = {
      annual:   'bg-blue-50 text-blue-700 ring-blue-600/20',
      sick:     'bg-rose-50 text-rose-700 ring-rose-600/20',
      personal: 'bg-violet-50 text-violet-700 ring-violet-600/20',
      unpaid:   'bg-amber-50 text-amber-700 ring-amber-600/20',
      other:    'bg-gray-100 text-gray-600 ring-gray-600/15',
    };
    return map[t] || map.other;
  }
  function rolePillP(pr) {
    if (pr === 'supervisor')  return 'bg-violet-50 text-violet-700';
    if (pr === 'team_leader') return 'bg-amber-50 text-amber-700';
    return                            'bg-gray-100 text-gray-600';
  }
  function roleLabelP(pr) {
    if (pr === 'supervisor')  return 'Supervisor';
    if (pr === 'team_leader') return 'Team Leader';
    return                            'TC';
  }
%>

<div class="la-card">
  <% rows.forEach(function (l) { %>
    <div class="la-row">
      <div class="la-avatar"><%= (l.crew_name || '?').split(' ').map(function (p) { return p[0] || ''; }).join('').slice(0, 2).toUpperCase() %></div>

      <div class="la-meta">
        <div class="flex items-center gap-2 flex-wrap">
          <p class="la-name"><%= l.crew_name %></p>
          <% if (l.portal_role) { %>
            <span class="la-pill ring-1 ring-inset <%= rolePillP(l.portal_role) %>" style="--tw-ring-color:transparent;"><%= roleLabelP(l.portal_role) %></span>
          <% } %>
        </div>
        <p class="la-emp"><%= l.crew_emp_id || '—' %><% if (l.crew_phone) { %> · <%= l.crew_phone %><% } %></p>

        <p class="la-when"><%= fmtRangeP(l.start_date, l.end_date) %><% if (l.total_days) { %> <span class="text-gray-400 font-normal">· <%= l.total_days %> day<%= l.total_days === 1 ? '' : 's' %></span><% } %></p>
        <% if (l.reason) { %><p class="la-reason"><%= l.reason %></p><% } %>

        <div class="la-pills">
          <span class="la-pill ring-1 <%= leaveTypePillP(l.leave_type) %>"><%= (l.leave_type || 'leave').replace('_',' ') %></span>
          <% if (l.shift_period && l.shift_period !== 'full_day') { %>
            <span class="la-pill ring-1 bg-gray-100 text-gray-600 ring-gray-600/15"><%= l.shift_period.replace('_',' ') %></span>
          <% } %>
          <span class="text-[11px] text-gray-400">submitted <%= new Date(l.created_at).toLocaleDateString('en-AU', { day:'numeric', month:'short' }) %></span>
        </div>
      </div>

      <div class="la-actions">
        <form method="POST" action="/leave-approvals/<%= l.id %>/approve" class="inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="la-btn la-approve" aria-label="Approve <%= l.crew_name %>'s leave">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Approve
          </button>
        </form>
        <form method="POST" action="/leave-approvals/<%= l.id %>/reject" class="inline" onsubmit="return confirm('Reject this leave request?');">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="la-btn la-reject" aria-label="Reject <%= l.crew_name %>'s leave">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            Reject
          </button>
        </form>
      </div>
    </div>
  <% }) %>
</div>
