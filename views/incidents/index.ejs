<% locals.currentPage = 'incidents' %>

<%
  function daysAgo(dateStr) {
    if (!dateStr) return null;
    return Math.floor((new Date(today) - new Date(dateStr)) / (1000 * 60 * 60 * 24));
  }
  function formatShortDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' });
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Incidents</h1>
    <p class="text-gray-500 text-sm mt-0.5">Safety register &middot; investigations &middot; corrective actions</p>
  </div>
  <a href="/incidents/new" class="inline-flex items-center justify-center px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    Report Incident
  </a>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.total %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Open</p>
    <p class="text-xl font-bold <%= stats.open > 0 ? 'text-amber-600' : 'text-gray-300' %> mt-0.5"><%= stats.open %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Critical / High</p>
    <p class="text-xl font-bold <%= stats.critical > 0 ? 'text-red-600' : 'text-gray-300' %> mt-0.5"><%= stats.critical %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-orange-400 uppercase tracking-widest">Open Actions</p>
    <p class="text-xl font-bold <%= stats.openActions > 0 ? 'text-orange-600' : 'text-gray-300' %> mt-0.5"><%= stats.openActions %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-brand-500 uppercase tracking-widest">This Month</p>
    <p class="text-xl font-bold text-brand-600 mt-0.5"><%= stats.thisMonth %></p>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/incidents" data-module="incidents" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1 min-w-0 sm:min-w-[180px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
        <% }) %>
      </select>
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Type</label>
        <select name="incident_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Types</option>
          <% (settingsOptions.incident_type || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.incident_type === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Severity</label>
        <select name="severity" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <% (settingsOptions.incident_severity || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.severity === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All</option>
          <option value="reported" <%= filters.status === 'reported' ? 'selected' : '' %>>Reported</option>
          <option value="investigating" <%= filters.status === 'investigating' ? 'selected' : '' %>>Investigating</option>
          <option value="resolved" <%= filters.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
          <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <a href="/incidents" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/incidents.csv?job_id=<%= filters.job_id || '' %>&incident_type=<%= filters.incident_type || '' %>&severity=<%= filters.severity || '' %>&status=<%= filters.status || '' %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="hidden sm:inline">CSV</span>
      </a>
    </div>
  </form>
</div>

<!-- Incidents Table -->
<% if (incidents.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <div class="w-10 h-10 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No incidents recorded</h3>
    <p class="text-gray-500 text-sm mb-1">Track injuries, near misses, hazards, and property damage across all job sites.</p>
    <p class="text-gray-400 text-xs mb-4">Report incidents to trigger investigations, corrective actions, and compliance reporting.</p>
    <a href="/incidents/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-red-600 hover:bg-red-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Report Incident
    </a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <% const incSortParams = '&job_id=' + encodeURIComponent(filters.job_id || '') + '&incident_type=' + encodeURIComponent(filters.incident_type || '') + '&severity=' + encodeURIComponent(filters.severity || '') + '&status=' + encodeURIComponent(filters.status || ''); %>
      <tr class="border-b border-gray-200">
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Incident', field: 'title', currentSort: sort, currentOrder: order, baseUrl: '/incidents', extraParams: incSortParams }) %></th>
        <th class="px-3 py-2.5 text-left hidden sm:table-cell"><%- include('../partials/sort-header', { label: 'Date', field: 'incident_date', currentSort: sort, currentOrder: order, baseUrl: '/incidents', extraParams: incSortParams }) %></th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Type</th>
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Severity', field: 'severity', currentSort: sort, currentOrder: order, baseUrl: '/incidents', extraParams: incSortParams }) %></th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Job</th>
        <th class="px-3 py-2.5 text-left"><%- include('../partials/sort-header', { label: 'Status', field: 'investigation_status', currentSort: sort, currentOrder: order, baseUrl: '/incidents', extraParams: incSortParams }) %></th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Age</th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Actions</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Reported By</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% incidents.forEach(incident => {
        const isCritical = incident.severity === 'critical';
        const isHigh = incident.severity === 'high';
        const isOpen = ['reported','investigating'].includes(incident.investigation_status);
        const age = daysAgo(incident.incident_date);
      %>
      <tr class="hover:bg-gray-50 <%= isCritical && isOpen ? 'border-l-4 border-l-red-500' : isHigh && isOpen ? 'border-l-4 border-l-amber-400' : '' %>">
        <td class="px-3 py-2.5">
          <a href="/incidents/<%= incident.id %>" class="text-brand-600 hover:text-brand-700 font-semibold text-sm hover:underline"><%= incident.incident_number %></a>
          <p class="text-gray-400 text-xs truncate max-w-[180px]"><%= incident.title %></p>
          <p class="text-gray-400 text-[10px] lg:hidden"><%= incident.job_number %></p>
        </td>
        <td class="px-3 py-2.5 text-gray-500 text-xs hidden sm:table-cell"><%= formatShortDate(incident.incident_date) %></td>
        <td class="px-3 py-2.5 hidden md:table-cell">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
            <% if (['injury','worker_injury','traffic_incident'].includes(incident.incident_type)) { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
            <% } else if (['near_miss','property_damage'].includes(incident.incident_type)) { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (['hazard'].includes(incident.incident_type)) { %>bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20
            <% } else if (['vehicle','vehicle_damage'].includes(incident.incident_type)) { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else { %>bg-gray-100 text-gray-600<% } %>">
            <%= incident.incident_type ? incident.incident_type.replace(/_/g, ' ').toUpperCase() : '-' %>
          </span>
        </td>
        <td class="px-3 py-2.5">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
            <% if (incident.severity === 'critical') { %>bg-red-100 text-red-800
            <% } else if (incident.severity === 'high') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (incident.severity === 'medium') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else { %>bg-gray-100 text-gray-600<% } %>">
            <%= (incident.severity || 'low').toUpperCase() %>
          </span>
        </td>
        <td class="px-3 py-2.5 text-gray-600 text-xs hidden lg:table-cell"><%= incident.job_number %></td>
        <td class="px-3 py-2.5">
          <form method="POST" action="/incidents/<%= incident.id %>/status" class="inline">
            <%- include('../partials/csrf') %>
            <select name="status" onchange="this.form.submit()" class="text-[10px] font-bold px-2 py-1 rounded-full border-0 cursor-pointer appearance-none
              <% if (incident.investigation_status === 'reported') { %>bg-gray-100 text-gray-600
              <% } else if (incident.investigation_status === 'investigating') { %>bg-blue-50 text-blue-700
              <% } else if (incident.investigation_status === 'resolved') { %>bg-emerald-50 text-emerald-700
              <% } else if (incident.investigation_status === 'closed') { %>bg-purple-50 text-purple-700
              <% } else { %>bg-gray-50 text-gray-600<% } %> focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="reported" <%= incident.investigation_status === 'reported' ? 'selected' : '' %>>Reported</option>
              <option value="investigating" <%= incident.investigation_status === 'investigating' ? 'selected' : '' %>>Investigating</option>
              <option value="resolved" <%= incident.investigation_status === 'resolved' ? 'selected' : '' %>>Resolved</option>
              <option value="closed" <%= incident.investigation_status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </form>
        </td>
        <!-- Days Open -->
        <td class="px-3 py-2.5 text-center hidden sm:table-cell">
          <% if (age !== null && isOpen) { %>
            <span class="inline-flex items-center justify-center min-w-[2rem] px-1.5 py-0.5 rounded-full text-[10px] font-bold
              <%= age > 14 ? 'bg-red-50 text-red-700 ring-1 ring-red-600/20' : age > 7 ? 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' : 'bg-gray-100 text-gray-600' %>"><%= age %>d</span>
          <% } else if (!isOpen) { %>
            <span class="text-gray-300 text-[10px]">Closed</span>
          <% } else { %>
            <span class="text-gray-300">-</span>
          <% } %>
        </td>
        <!-- Corrective Actions -->
        <td class="px-3 py-2.5 text-center hidden lg:table-cell">
          <% if (incident.corrective_action_count > 0) { %>
            <span class="inline-flex items-center justify-center min-w-[2rem] px-1.5 py-0.5 rounded-full text-[10px] font-bold
              <%= incident.open_actions > 0 ? 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' : 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' %>">
              <% if (incident.open_actions > 0) { %><%= incident.open_actions %>/<%= incident.corrective_action_count %><% } else { %><%= incident.corrective_action_count %>✓<% } %>
            </span>
          <% } else { %>
            <span class="text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-gray-500 text-xs hidden xl:table-cell"><%= incident.reported_by_name %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-2 text-xs text-gray-400"><%= incidents.length %> incident<%= incidents.length !== 1 ? 's' : '' %> found</div>
<% } %>
