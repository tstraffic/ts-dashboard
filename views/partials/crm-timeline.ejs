<%
  // Expects: timelineEvents (array)
  // Each event: { type, date, icon_type, title, description, user_name, meta }
  const events = typeof timelineEvents !== 'undefined' ? timelineEvents : [];

  // Icon SVG paths by type
  const iconPaths = {
    call: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    email: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    meeting: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    site_visit: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
    stage_change: 'M13 7l5 5m0 0l-5 5m5-5H6',
    proposal_sent: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    follow_up: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    note: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z'
  };

  // Dot / icon background colors by type
  const dotColors = {
    call: 'bg-green-100 text-green-600',
    email: 'bg-blue-100 text-blue-600',
    meeting: 'bg-purple-100 text-purple-600',
    site_visit: 'bg-emerald-100 text-emerald-600',
    stage_change: 'bg-amber-100 text-amber-600',
    proposal_sent: 'bg-orange-100 text-orange-600',
    follow_up: 'bg-red-100 text-red-600',
    note: 'bg-gray-100 text-gray-500'
  };

  // Connecting line dot (solid circle) colors
  const lineDotColors = {
    call: 'bg-green-500',
    email: 'bg-blue-500',
    meeting: 'bg-purple-500',
    site_visit: 'bg-emerald-500',
    stage_change: 'bg-amber-500',
    proposal_sent: 'bg-orange-500',
    follow_up: 'bg-red-500',
    note: 'bg-gray-400'
  };

  function relativeTime(dateStr) {
    if (!dateStr) return '';
    var now = new Date();
    var date = new Date(dateStr);
    var diffMs = now - date;
    var diffMins = Math.floor(diffMs / 60000);
    var diffHours = Math.floor(diffMs / 3600000);
    var diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return diffMins + 'm ago';
    if (diffHours < 24) return diffHours + 'h ago';
    if (diffDays < 7) return diffDays + 'd ago';
    if (diffDays < 30) return Math.floor(diffDays / 7) + 'w ago';
    return date.toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric' });
  }
%>

<% if (events.length === 0) { %>
<div class="text-center py-10">
  <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
    <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
  </div>
  <h3 class="text-gray-500 text-sm font-medium mb-1">No activity yet</h3>
  <p class="text-gray-400 text-xs">Activities, stage changes, and notes will appear here.</p>
</div>
<% } else { %>
<div class="relative">
  <% events.forEach(function(evt, idx) {
    var iconType = evt.icon_type || evt.type || 'note';
    var path = iconPaths[iconType] || iconPaths.note;
    var colorClass = dotColors[iconType] || dotColors.note;
    var dotColor = lineDotColors[iconType] || lineDotColors.note;
    var isLast = idx === events.length - 1;
  %>
  <div class="relative flex gap-4 pb-6 last:pb-0">
    <!-- Vertical connecting line -->
    <% if (!isLast) { %>
    <div class="absolute left-[17px] top-9 bottom-0 w-0.5 bg-gray-200"></div>
    <% } %>

    <!-- Icon circle -->
    <div class="relative flex-shrink-0">
      <div class="w-[34px] h-[34px] rounded-full flex items-center justify-center <%= colorClass %> ring-4 ring-white">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/></svg>
      </div>
    </div>

    <!-- Content -->
    <div class="flex-1 min-w-0 pt-0.5">
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-gray-900 leading-tight"><%= evt.title %></p>
          <% if (evt.description) { %>
          <p class="text-xs text-gray-500 mt-0.5 line-clamp-2"><%= evt.description %></p>
          <% } %>
          <% if (evt.meta && evt.meta.stage_from && evt.meta.stage_to) { %>
          <div class="flex items-center gap-1.5 mt-1">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600"><%= evt.meta.stage_from.replace(/_/g, ' ') %></span>
            <svg class="w-3 h-3 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 ring-1 ring-amber-600/20"><%= evt.meta.stage_to.replace(/_/g, ' ') %></span>
          </div>
          <% } %>
        </div>
        <span class="text-[10px] text-gray-400 whitespace-nowrap flex-shrink-0 pt-0.5"><%= relativeTime(evt.date) %></span>
      </div>
      <p class="text-[10px] text-gray-400 mt-1">
        <% if (evt.user_name) { %>
        <span class="font-medium text-gray-500"><%= evt.user_name %></span>
        <% } %>
        <% if (evt.date) { %>
        <span class="<%= evt.user_name ? 'ml-1' : '' %>"><%= new Date(evt.date).toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric' }) %> at <%= new Date(evt.date).toLocaleTimeString('en-AU', { timeZone: 'Australia/Sydney', hour: '2-digit', minute: '2-digit' }) %></span>
        <% } %>
      </p>
    </div>
  </div>
  <% }); %>
</div>
<% } %>