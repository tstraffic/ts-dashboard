<nav class="bg-white/70 backdrop-blur-xl border-b border-gray-200/60 sticky top-0 z-30">
  <div class="px-3 sm:px-6">
    <div class="flex items-center justify-between h-14 sm:h-16">
      <div class="flex items-center gap-2 sm:gap-3">
        <% if (user) { %>
        <button id="sidebar-toggle" class="lg:hidden p-2.5 -ml-1 text-gray-500 hover:text-brand-600 hover:bg-brand-50 rounded-xl focus:outline-none active:scale-95 transition-all" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
        </button>
        <% } %>
        <a href="/dashboard" class="header-logo-wrap flex items-center gap-2.5 sm:gap-3 group">
          <img src="/images/logo-colour.jpg" alt="T&S" class="h-8 sm:h-9 w-auto rounded-lg shadow-sm ring-1 ring-black/5 group-hover:shadow-md transition-shadow">
          <div class="hidden sm:block">
            <span class="text-gray-900 font-bold text-[15px] leading-tight block tracking-tight"><%= typeof title !== 'undefined' && title ? title : 'T&S Dashboard' %></span>
            <span class="text-[10px] text-gray-400 font-medium tracking-wide uppercase">Traffic Control</span>
          </div>
        </a>
      </div>
      <div class="flex items-center gap-1.5 sm:gap-3">
        <% if (user) { %>
          <!-- Dark / Light Mode Toggle -->
          <button id="theme-toggle" onclick="toggleTheme()" class="p-2.5 text-gray-400 hover:text-brand-600 transition-all focus:outline-none rounded-xl hover:bg-brand-50 active:scale-95 w-10 h-10 flex items-center justify-center" title="Toggle dark/light mode" aria-label="Toggle theme">
            <!-- Moon icon: visible in light mode → click to go dark -->
            <svg id="icon-moon" class="theme-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
            </svg>
            <!-- Sun icon: visible in dark mode → click to go light -->
            <svg id="icon-sun" class="theme-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
            </svg>
          </button>

          <!-- Notification Bell + Popup -->
          <div class="relative" id="notif-container">
            <button onclick="toggleNotifDropdown()" class="relative p-2.5 text-gray-400 hover:text-brand-600 transition-all focus:outline-none rounded-xl hover:bg-brand-50 active:scale-95" title="Notifications" id="notif-bell">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              <% if (typeof unreadNotifications !== 'undefined' && unreadNotifications > 0) { %>
                <span id="notif-badge" class="absolute top-1.5 right-1.5 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center animate-pulse"><%= unreadNotifications > 9 ? '9+' : unreadNotifications %></span>
              <% } else { %>
                <span id="notif-badge" class="absolute top-1.5 right-1.5 w-4 h-4 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center hidden">0</span>
              <% } %>
            </button>

            <!-- Dropdown Popup -->
            <div id="notif-dropdown" class="notif-panel hidden absolute right-0 mt-2 w-[calc(100vw-2rem)] sm:w-96 max-w-md bg-white border border-gray-200 rounded-2xl shadow-2xl z-50 overflow-hidden" style="min-height:120px">
              <div class="notif-panel-header flex items-center justify-between px-4 py-3 border-b border-gray-100 bg-gray-50/50">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                  <span class="font-bold text-sm text-gray-900">Notifications</span>
                </div>
                <span id="notif-unread-label" class="text-xs font-medium text-gray-400"></span>
              </div>
              <div id="notif-list" class="notif-panel-list max-h-96 overflow-y-auto">
                <div class="p-6 text-center text-gray-400 text-sm" id="notif-loading">
                  <div class="notif-spinner mx-auto mb-2"></div>
                  Loading...
                </div>
              </div>
              <div class="notif-panel-footer flex items-center justify-between px-4 py-2.5 border-t border-gray-100 bg-gray-50/50">
                <button onclick="markAllReadFromPopup()" class="text-xs font-medium text-gray-500 hover:text-brand-600 transition flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  Mark All Read
                </button>
                <a href="/notifications" class="text-xs font-bold text-brand-600 hover:text-brand-700 transition">View All &rarr;</a>
              </div>
            </div>
          </div>

          <!-- Quick Add Menu -->
          <div class="relative" id="quickadd-container">
            <button onclick="toggleQuickAdd()" class="p-2.5 text-gray-400 hover:text-brand-600 transition-all focus:outline-none rounded-xl hover:bg-brand-50 active:scale-95" title="Quick Create" id="quickadd-btn">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            </button>
            <div id="quickadd-dropdown" class="hidden pointer-events-none absolute right-0 mt-2 w-56 bg-white border border-gray-200 rounded-2xl shadow-2xl z-50 overflow-hidden">
              <div class="px-4 py-2.5 border-b border-gray-100 bg-gray-50/50">
                <span class="font-bold text-sm text-gray-900">Quick Create</span>
              </div>
              <div class="py-1.5">
                <a href="/jobs/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                  New Job
                </a>
                <a href="/tasks/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                  New Task
                </a>
                <a href="/crew/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                  Add Crew Member
                </a>
                <a href="/clients/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                  New Company
                </a>
                <% if (canAccess(user, 'crm')) { %>
                <a href="/opportunities/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                  New Opportunity
                </a>
                <a href="/crm/activities/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  Log Activity
                </a>
                <% } %>
                <a href="/timesheets/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-brand-50 hover:text-brand-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Log Timesheet
                </a>
                <div class="border-t border-gray-100 my-1"></div>
                <a href="/incidents/new" class="flex items-center gap-3 px-4 py-2 text-sm text-gray-700 hover:bg-red-50 hover:text-red-700 transition-colors">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                  Report Incident
                </a>
              </div>
            </div>
          </div>

          <!-- Divider -->
          <div class="hidden lg:block w-px h-6 bg-gray-200/80 mx-1"></div>

          <!-- Profile avatar (clickable) -->
          <a href="/profile" class="flex items-center gap-2.5 hover:opacity-90 transition-all active:scale-[0.97] group" title="My Profile">
            <div class="hidden lg:block text-right">
              <span class="text-gray-800 text-sm font-semibold block leading-tight"><%= user.full_name %></span>
              <span class="text-[10px] font-medium leading-tight
                <% if (user.role === 'admin') { %>text-purple-500
                <% } else if (user.role === 'operations') { %>text-blue-500
                <% } else if (user.role === 'planning') { %>text-teal-500
                <% } else if (user.role === 'finance') { %>text-amber-500
                <% } else { %>text-gray-400<% } %>"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
            </div>
            <div class="w-9 h-9 sm:w-8 sm:h-8 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center text-xs font-bold shadow-sm ring-2 ring-white group-hover:ring-brand-100 transition-all">
              <%= user.full_name ? user.full_name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U' %>
            </div>
          </a>

          <a href="/logout" class="hidden lg:inline-flex items-center gap-1.5 text-gray-400 hover:text-red-500 text-sm transition-colors p-2 rounded-xl hover:bg-red-50" title="Sign out">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          </a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<% if (user) { %>
<script>
(function() {
  let notifOpen = false;
  const dropdown = document.getElementById('notif-dropdown');
  const container = document.getElementById('notif-container');

  window.toggleNotifDropdown = function() {
    if (notifOpen) {
      dropdown.classList.add('hidden');
      notifOpen = false;
    } else {
      dropdown.classList.remove('hidden');
      notifOpen = true;
      loadNotifications();
    }
  };

  // Close on click outside
  document.addEventListener('click', function(e) {
    if (notifOpen && !container.contains(e.target)) {
      dropdown.classList.add('hidden');
      notifOpen = false;
    }
  });

  function timeAgo(dateStr) {
    const now = new Date();
    const d = new Date(dateStr);
    const diffMs = now - d;
    const mins = Math.floor(diffMs / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return mins + 'm ago';
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    const days = Math.floor(hrs / 24);
    if (days < 7) return days + 'd ago';
    return d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short' });
  }

  function typeIcon(type) {
    var icons = {
      overdue_task: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      new_incident: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
      critical_defect: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      ticket_expiry: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>',
      expiring_compliance: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
      equipment_overdue: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>',
      corrective_action_due: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>',
      over_budget: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      follow_up_due: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>',
      missing_update: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>'
    };
    return icons[type] || '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
  }

  function typeColorClass(type) {
    if (['overdue_task','new_incident','critical_defect'].includes(type)) return 'notif-icon-red';
    if (['expiring_compliance','equipment_overdue','ticket_expiry'].includes(type)) return 'notif-icon-amber';
    if (type === 'missing_update') return 'notif-icon-yellow';
    if (['corrective_action_due'].includes(type)) return 'notif-icon-rose';
    if (type === 'follow_up_due') return 'notif-icon-purple';
    if (type === 'over_budget') return 'notif-icon-orange';
    return 'notif-icon-blue';
  }

  function loadNotifications() {
    var list = document.getElementById('notif-list');
    list.innerHTML = '<div class="p-6 text-center text-gray-400 text-sm"><div class="notif-spinner mx-auto mb-2"></div>Loading...</div>';

    fetch('/notifications/recent')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var badge = document.getElementById('notif-badge');
        var label = document.getElementById('notif-unread-label');
        if (data.unreadCount > 0) {
          badge.textContent = data.unreadCount > 9 ? '9+' : data.unreadCount;
          badge.classList.remove('hidden');
          label.textContent = data.unreadCount + ' unread';
        } else {
          badge.classList.add('hidden');
          label.textContent = 'All caught up';
        }

        if (data.notifications.length === 0) {
          list.innerHTML = '<div class="notif-empty"><svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg><p class="text-gray-400 text-sm font-medium">All caught up!</p><p class="text-gray-300 text-xs mt-1">No unread notifications</p></div>';
          return;
        }

        var html = '';
        data.notifications.forEach(function(n) {
          var iconClass = typeColorClass(n.type);
          var icon = typeIcon(n.type);
          var link = n.link || '/notifications';
          var escapedTitle = (n.title || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          var escapedMsg = (n.message || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
          var ago = timeAgo(n.created_at);

          var readClass = n.is_read ? ' notif-item-read' : '';
          html += '<a href="' + link + '" class="notif-item' + readClass + '" data-id="' + n.id + '" onclick="markNotifRead(event, ' + n.id + ')">';
          html += '<div class="notif-item-icon ' + iconClass + '">' + icon + '</div>';
          html += '<div class="notif-item-body">';
          html += '<p class="notif-item-title">' + escapedTitle + '</p>';
          html += '<p class="notif-item-msg">' + escapedMsg + '</p>';
          html += '<div class="notif-item-meta">';
          html += '<span class="notif-item-time">' + ago + '</span>';
          if (n.job_number) html += '<span class="notif-item-tag">' + n.job_number + '</span>';
          html += '</div>';
          html += '</div>';
          html += '<div class="notif-item-action"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></div>';
          html += '</a>';
        });
        list.innerHTML = html;
      })
      .catch(function() {
        list.innerHTML = '<div class="notif-empty"><svg class="w-8 h-8 text-red-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><p class="text-red-400 text-sm">Failed to load notifications</p></div>';
      });
  }

  window.markNotifRead = function(event, id) {
    // Mark as read in background, let the link navigate
    fetch('/notifications/' + id + '/read', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'x-csrf-token': document.querySelector('meta[name="csrf-token"]').content }
    }).catch(function() {});
  };

  window.markAllReadFromPopup = function() {
    fetch('/notifications/mark-all-read', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'x-csrf-token': document.querySelector('meta[name="csrf-token"]').content } })
      .then(function() {
        loadNotifications();
        var badge = document.getElementById('notif-badge');
        badge.classList.add('hidden');
      })
      .catch(function() {});
  };

  // Quick Add dropdown
  var qaOpen = false;
  var qaDropdown = document.getElementById('quickadd-dropdown');
  var qaContainer = document.getElementById('quickadd-container');
  window.toggleQuickAdd = function() {
    if (qaOpen) { qaDropdown.classList.add('hidden'); qaDropdown.classList.add('pointer-events-none'); qaDropdown.classList.remove('pointer-events-auto'); qaOpen = false; }
    else { qaDropdown.classList.remove('hidden'); qaDropdown.classList.remove('pointer-events-none'); qaDropdown.classList.add('pointer-events-auto'); qaOpen = true; if (notifOpen) { dropdown.classList.add('hidden'); notifOpen = false; } }
  };
  document.addEventListener('click', function(e) {
    if (qaOpen && !qaContainer.contains(e.target)) { qaDropdown.classList.add('hidden'); qaDropdown.classList.add('pointer-events-none'); qaDropdown.classList.remove('pointer-events-auto'); qaOpen = false; }
  });

  // ===== Theme Toggle =====
  var iconMoon = document.getElementById('icon-moon');
  var iconSun  = document.getElementById('icon-sun');

  function applyThemeIcons() {
    var isDark = document.body.classList.contains('dark-glass');
    // Dark mode: show sun (to switch to light), hide moon
    // Light mode: show moon (to switch to dark), hide sun
    if (isDark) {
      iconSun.classList.remove('theme-icon-hidden'); iconSun.classList.add('theme-icon-visible');
      iconMoon.classList.remove('theme-icon-visible'); iconMoon.classList.add('theme-icon-hidden');
    } else {
      iconMoon.classList.remove('theme-icon-hidden'); iconMoon.classList.add('theme-icon-visible');
      iconSun.classList.remove('theme-icon-visible'); iconSun.classList.add('theme-icon-hidden');
    }
  }

  window.toggleTheme = function() {
    var nowDark = document.body.classList.toggle('dark-glass');
    try { localStorage.setItem('ts-theme-2', nowDark ? 'dark' : 'light'); } catch(e) {}
    applyThemeIcons();
  };

  // Set initial icon state
  applyThemeIcons();
})();
</script>
<% } %>
