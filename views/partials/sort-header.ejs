<a href="<%= baseUrl %>?sort=<%= field %>&order=<%= currentSort === field && currentOrder === 'asc' ? 'desc' : 'asc' %><%= typeof extraParams !== 'undefined' ? extraParams : '' %>"
   class="inline-flex items-center gap-1 text-xs font-semibold text-gray-500 uppercase tracking-wider hover:text-gray-700 transition-colors group">
  <%= label %>
  <% if (currentSort === field) { %>
    <svg class="w-3.5 h-3.5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <% if (currentOrder === 'asc') { %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      <% } else { %>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      <% } %>
    </svg>
  <% } else { %>
    <svg class="w-3.5 h-3.5 text-gray-300 group-hover:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
    </svg>
  <% } %>
</a>
