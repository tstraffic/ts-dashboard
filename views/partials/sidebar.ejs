      </button>
    </div>
    <% if (user) { %>
    <div class="flex items-center gap-3 p-3 bg-white/10 rounded-xl backdrop-blur-sm">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-400 to-brand-600 text-white flex items-center justify-center text-sm font-bold shadow-lg">
        <%= user.full_name ? user.full_name.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2) : 'U' %>
