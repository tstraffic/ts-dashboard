<!-- Mobile sidebar backdrop -->
<div id="sidebar-backdrop" class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-40 hidden lg:hidden" aria-hidden="true"></div>

<!-- Sidebar -->
<aside id="sidebar" class="w-[280px] lg:w-64 bg-brand-900 flex-shrink-0 hidden lg:flex lg:flex-col fixed lg:sticky z-50 inset-y-0 left-0 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out lg:top-0" style="min-height: calc(100vh - 56px); max-height: 100vh;">

  <!-- Mobile sidebar header -->
