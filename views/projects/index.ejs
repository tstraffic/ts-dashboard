<% locals.currentPage = 'projects' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Jobs</h1>
    <p class="text-gray-500 text-sm mt-1">Job register</p>
  </div>
  <div class="flex items-center gap-2">
    <a href="/projects/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Job</a>
  </div>
</div>

<!-- Project Register -->
<div>

  <!-- Filter Bar -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-4">
    <form method="GET" action="/projects" class="flex flex-wrap items-end gap-4">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="_tab" value="register">
      <!-- Search -->
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Search</label>
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Job number, client, address..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Status -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Statuses</option>
          <% settingsOptions.job_status.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <!-- Suburb -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Suburb</label>
        <select name="suburb" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Suburbs</option>
          <% suburbs.forEach(s => { %>
            <option value="<%= s %>" <%= filters.suburb === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <!-- Buttons -->
      <div class="flex gap-2">
        <a href="/projects" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
        <a href="/exports/projects.csv?status=<%= filters.status || '' %>&search=<%= encodeURIComponent(filters.search || '') %>&suburb=<%= encodeURIComponent(filters.suburb || '') %>"
          class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Export CSV
        </a>
      </div>
    </form>
  </div>

  <!-- Jobs Table -->
  <% if (jobs.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No jobs yet</h3>
      <p class="text-gray-500 text-sm mb-1">Jobs track your traffic management work from tender through to closeout.</p>
      <p class="text-gray-400 text-xs mb-4">Create your first job to start tracking crew allocations and compliance.</p>
      <a href="/jobs/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Create First Job
      </a>
    </div>
  <% } else { %>
  <!-- Client Grouped Accordion -->
  <div class="space-y-3">
    <% clientGroups.forEach(function(group, gi) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
      <!-- Client Header (accordion toggle) -->
      <button type="button" onclick="var el=document.getElementById('cg-<%= gi %>');el.classList.toggle('hidden');this.querySelector('.chevron').classList.toggle('rotate-90')" class="w-full flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition-colors text-left">
        <div class="flex items-center gap-3">
          <svg class="w-4 h-4 text-gray-400 chevron transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-sm font-semibold text-gray-900"><%= group.name %></span>
          <% if (group.hasHighPriority) { %><span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" title="Contains high priority job"></span><% } %>
          <span class="text-xs text-gray-400"><%= group.totalCount %> job<%= group.totalCount !== 1 ? 's' : '' %></span>
        </div>
        <div class="flex items-center gap-2">
          <% if (group.hasHighPriority) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700 ring-1 ring-red-600/20">Priority</span>
          <% } %>
          <% if (group.overdueTasks > 0) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-100 text-red-700 ring-1 ring-red-600/20"><%= group.overdueTasks %> overdue</span>
          <% } %>
          <% if (group.pendingTasks > 0) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-blue-100 text-blue-700 ring-1 ring-blue-600/20"><%= group.pendingTasks %> task<%= group.pendingTasks !== 1 ? 's' : '' %></span>
          <% } %>
          <% if (group.pendingPlans > 0) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-100 text-amber-700 ring-1 ring-amber-600/20"><%= group.pendingPlans %> plan<%= group.pendingPlans !== 1 ? 's' : '' %></span>
          <% } %>
          <% if (group.activeCount > 0) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600 ring-1 ring-gray-400/20"><%= group.activeCount %> active</span>
          <% } %>
        </div>
      </button>
      <!-- Jobs Table (expanded by default) -->
      <div id="cg-<%= gi %>" class="">
        <div class="border-t border-gray-100 overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50/50">
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job Number</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Suburb</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Stage</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden sm:table-cell">Health</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">% Complete</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Start Date</th>
                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">PM</th>
                <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
                <th class="px-3 py-2 text-center text-xs font-medium text-gray-500 uppercase tracking-wide hidden xl:table-cell">Budget</th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% group.jobs.forEach(function(job) {
                const isClosed = job.status === 'closed';
                const healthColor = job.health === 'green' ? '#10b981' : job.health === 'amber' ? '#f59e0b' : job.health === 'red' ? '#ef4444' : '#e5e7eb';
                const pct = job.percent_complete || 0;
                const barColor = isClosed ? 'bg-gray-400' : pct >= 100 ? 'bg-emerald-500' : pct >= 60 ? 'bg-blue-500' : pct >= 30 ? 'bg-amber-400' : 'bg-red-400';
                const rowBorder = isClosed ? '#9ca3af' : (job.priority === 'high' ? '#ef4444' : healthColor);
                const rowBg = isClosed ? 'bg-gray-50' : (job.priority === 'high' ? 'bg-red-50/30' : '');
              %>
              <tr class="hover:bg-gray-50 <%= rowBg %> <%= isClosed ? 'text-gray-400' : '' %>" style="border-left: 3px solid <%= rowBorder %>">
                <td class="px-3 py-2 font-medium">
                  <div class="flex items-center gap-1">
                    <a href="/projects/<%= job.id %>" class="<%= isClosed ? 'text-gray-500 line-through hover:text-gray-700' : 'text-brand-600 hover:text-brand-700' %> hover:underline"><%= job.job_number %></a>
                    <% if (job.priority === 'high' && !isClosed) { %>
                      <span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" title="High Priority"></span>
                    <% } %>
                  </div>
                  <% if (job.pending_tasks > 0 || job.pending_plans > 0 || job.overdue_tasks > 0 || job.overdue_compliance > 0) { %>
                    <div class="flex flex-wrap gap-1 mt-0.5">
                      <% if (job.overdue_tasks > 0) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20"><%= job.overdue_tasks %> overdue</span>
                      <% } %>
                      <% if (job.pending_tasks > 0) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-blue-50 text-blue-700 ring-1 ring-blue-600/20"><%= job.pending_tasks %> task<%= job.pending_tasks !== 1 ? 's' : '' %></span>
                      <% } %>
                      <% if (job.overdue_compliance > 0) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20"><%= job.overdue_compliance %> plan<%= job.overdue_compliance !== 1 ? 's' : '' %> overdue</span>
                      <% } else if (job.pending_plans > 0) { %>
                        <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20"><%= job.pending_plans %> plan<%= job.pending_plans !== 1 ? 's' : '' %></span>
                      <% } %>
                    </div>
                  <% } %>
                </td>
                <td class="px-3 py-2 text-gray-600"><%= job.suburb || '-' %></td>
                <td class="px-3 py-2">
                  <% if (isClosed) { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-widest bg-gray-800 text-white">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                      Closed
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <% if (job.status === 'active') { %>bg-blue-100 text-blue-800 ring-1 ring-blue-600/30
                      <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                      <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                      <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
                      <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
                      <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
                      <% } else { %>bg-white text-gray-600<% } %>">
                      <%= job.status ? job.status.replace('_', ' ') : '-' %>
                    </span>
                  <% } %>
                </td>
                <td class="px-3 py-2 <%= isClosed ? 'text-gray-400' : 'text-gray-600' %> hidden md:table-cell"><%= job.stage || '-' %></td>
                <td class="px-3 py-2 hidden sm:table-cell">
                  <% if (isClosed) { %>
                    <span class="text-xs text-gray-400">—</span>
                  <% } else if (job.health) { %>
                    <span class="inline-flex items-center gap-1.5 text-xs font-medium
                      <% if (job.health === 'green') { %>text-emerald-600
                      <% } else if (job.health === 'amber') { %>text-amber-600
                      <% } else if (job.health === 'red') { %>text-red-600
                      <% } else { %>text-gray-400<% } %>">
                      <span class="inline-block w-2.5 h-2.5 rounded-full
                        <% if (job.health === 'green') { %>bg-emerald-500
                        <% } else if (job.health === 'amber') { %>bg-amber-500
                        <% } else if (job.health === 'red') { %>bg-red-500
                        <% } else { %>bg-gray-300<% } %>"></span>
                      <%= job.health.charAt(0).toUpperCase() + job.health.slice(1) %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-400">-</span>
                  <% } %>
                </td>
                <td class="px-3 py-2 hidden lg:table-cell">
                  <div class="flex items-center gap-2">
                    <div class="w-16 bg-gray-200 rounded-full h-2 overflow-hidden">
                      <div class="h-2 rounded-full <%= barColor %> transition-all" style="width: <%= Math.min(pct, 100) %>%"></div>
                    </div>
                    <span class="text-xs text-gray-500 tabular-nums"><%= pct %>%</span>
                  </div>
                </td>
                <td class="px-3 py-2 text-gray-500 text-xs hidden md:table-cell"><%= job.start_date ? new Date(job.start_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></td>
                <td class="px-3 py-2 text-gray-600 hidden lg:table-cell"><%= job.pm_name || '-' %></td>
                <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
                <td class="px-3 py-2 text-center hidden xl:table-cell">
                  <% if (!job.budget_contract) { %>
                    <span class="text-gray-400">—</span>
                  <% } else {
                    const budgetMargin = (job.budget_contract - (job.budget_spent || 0)) / job.budget_contract * 100;
                  %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium <% if (budgetMargin > 20) { %>text-emerald-700 bg-emerald-50<% } else if (budgetMargin >= 0) { %>text-orange-700 bg-orange-50<% } else { %>text-red-700 bg-red-50<% } %>" title="Margin: <%= budgetMargin.toFixed(1) %>%">
                      <span class="inline-block w-1.5 h-1.5 rounded-full <% if (budgetMargin > 20) { %>bg-emerald-500<% } else if (budgetMargin >= 0) { %>bg-orange-500<% } else { %>bg-red-500<% } %>"></span>
                      <%= budgetMargin > 20 ? 'On track' : budgetMargin >= 0 ? 'Tight' : 'Over' %>
                    </span>
                  <% } %>
                </td>
                <% } %>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <div class="mt-3 text-xs text-gray-400"><%= jobs.length %> job<%= jobs.length !== 1 ? 's' : '' %> across <%= clientGroups.length %> client<%= clientGroups.length !== 1 ? 's' : '' %></div>
  <% } %>

</div>
