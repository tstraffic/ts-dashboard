<% locals.currentPage = 'projects' %>

<style>
  .tab-content { display: none; }
  .tab-content:target { display: block; }
  .tab-content:first-of-type:not(:target) { display: block; }
  .tab-group:has(.tab-content:target) > .tab-content:first-of-type:not(:target) { display: none; }
</style>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Projects</h1>
    <p class="text-gray-500 text-sm mt-1">Project register and weekly updates</p>
  </div>
  <div class="flex items-center gap-2">
    <a href="/updates/new?return_to=/projects%23updates" class="px-4 py-2 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-sm font-medium rounded-lg transition-colors">+ Submit Update</a>
    <a href="/projects/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Project</a>
  </div>
</div>

<!-- Tabs -->
<div class="border-b border-gray-200 mb-6">
  <nav class="flex gap-0 -mb-px">
    <a href="#register" class="px-5 py-3 text-sm font-medium border-b-2 transition-colors text-gray-500 hover:text-gray-700 border-transparent hover:border-gray-300">
      Register
    </a>
    <a href="#updates" class="px-5 py-3 text-sm font-medium border-b-2 transition-colors text-gray-500 hover:text-gray-700 border-transparent hover:border-gray-300">
      Updates
      <% if (recentUpdates.length > 0) { %><span class="ml-1.5 px-1.5 py-0.5 text-xs bg-gray-100 text-gray-500 rounded-full"><%= recentUpdates.length %></span><% } %>
    </a>
  </nav>
</div>

<div class="tab-group">

<!-- ── TAB 1: PROJECT REGISTER ── -->
<div id="register" class="tab-content">

  <!-- Filter Bar -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
    <form method="GET" action="/projects" class="flex flex-wrap items-end gap-4">
      <input type="hidden" name="_tab" value="register">
      <!-- Search -->
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Search</label>
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Job number, client, address..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Status -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Statuses</option>
          <% settingsOptions.job_status.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <!-- Suburb -->
      <div class="min-w-[160px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Suburb</label>
        <select name="suburb" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Suburbs</option>
          <% suburbs.forEach(s => { %>
            <option value="<%= s %>" <%= filters.suburb === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <!-- Buttons -->
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
        <a href="/projects" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
        <a href="/exports/projects.csv?status=<%= filters.status || '' %>&search=<%= encodeURIComponent(filters.search || '') %>&suburb=<%= encodeURIComponent(filters.suburb || '') %>"
          class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Export CSV
        </a>
      </div>
    </form>
  </div>

  <!-- Projects Table -->
  <% if (jobs.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No projects yet</h3>
      <p class="text-gray-500 text-sm mb-1">Projects track your traffic management jobs from tender through to closeout.</p>
      <p class="text-gray-400 text-xs mb-4">Create your first project to start tracking jobs, crew allocations, and compliance.</p>
      <a href="/jobs/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Create First Project
      </a>
    </div>
  <% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job Number</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Suburb</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Stage</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Health</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">% Complete</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Start Date</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">PM</th>
          <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
          <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Budget</th>
          <% } %>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% jobs.forEach(job => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 font-medium">
            <a href="/projects/<%= job.id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= job.job_number %></a>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= job.client %></td>
          <td class="px-4 py-3 text-gray-600"><%= job.suburb || '-' %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
              <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
              <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
              <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
              <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
              <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
              <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
              <% } else if (job.status === 'closed') { %>bg-gray-100/60 text-gray-600
              <% } else { %>bg-white text-gray-600<% } %>">
              <%= job.status ? job.status.replace('_', ' ') : '-' %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= job.stage || '-' %></td>
          <td class="px-4 py-3">
            <% if (job.health) { %>
              <span class="inline-block w-3 h-3 rounded-full
                <% if (job.health === 'green') { %>bg-emerald-500
                <% } else if (job.health === 'amber') { %>bg-brand-600
                <% } else if (job.health === 'red') { %>bg-red-500
                <% } else { %>bg-gray-100<% } %>" title="<%= job.health %>"></span>
            <% } else { %>
              <span class="text-gray-400">-</span>
            <% } %>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <div class="w-16 bg-gray-200 rounded-full h-2">
                <div class="h-2 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-blue-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
              </div>
              <span class="text-xs text-gray-500"><%= job.percent_complete || 0 %>%</span>
            </div>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= job.start_date || '-' %></td>
          <td class="px-4 py-3 text-gray-600"><%= job.pm_name || '-' %></td>
          <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
          <td class="px-4 py-3 text-center">
            <% if (!job.budget_contract) { %>
              <span class="text-gray-400">—</span>
            <% } else {
              const budgetMargin = (job.budget_contract - (job.budget_spent || 0)) / job.budget_contract * 100;
            %>
              <span class="inline-block w-3 h-3 rounded-full <% if (budgetMargin > 20) { %>bg-emerald-500<% } else if (budgetMargin >= 0) { %>bg-orange-500<% } else { %>bg-red-500<% } %>" title="Margin: <%= budgetMargin.toFixed(1) %>%"></span>
            <% } %>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="mt-3 text-xs text-gray-400"><%= jobs.length %> project<%= jobs.length !== 1 ? 's' : '' %> found</div>
  <% } %>

</div><!-- #register -->

<!-- ── TAB 2: UPDATES ── -->
<div id="updates" class="tab-content">

  <!-- Filter + action row -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
    <form method="GET" action="/projects#updates" class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Filter by Project</label>
        <select name="update_job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Projects</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>" <%= updateJobFilter == j.id ? 'selected' : '' %>><%= j.job_number %> — <%= j.client %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
        <a href="/projects#updates" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      </div>
    </form>
  </div>

  <!-- Updates feed -->
  <% if (recentUpdates.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      <p class="text-gray-400 text-sm">No updates yet. <a href="/updates/new?return_to=/projects%23updates" class="text-brand-600 hover:underline">Submit the first one.</a></p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% recentUpdates.forEach(function(update) { %>
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 hover:border-gray-300 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <a href="/projects/<%= update.job_id %>" class="text-brand-600 font-semibold hover:underline text-sm"><%= update.job_number %></a>
                <span class="text-gray-400 text-sm">—</span>
                <span class="text-gray-700 text-sm font-medium"><%= update.client %></span>
              </div>
              <div class="flex items-center gap-4 text-xs text-gray-400 mb-3">
                <span>Week ending: <span class="text-gray-600"><%= update.week_ending ? new Date(update.week_ending).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %></span></span>
                <span>by <span class="text-gray-600"><%= update.submitted_by_name || 'Unknown' %></span></span>
              </div>
              <% if (update.summary) { %>
                <p class="text-gray-600 text-sm mb-3"><%= update.summary.length > 250 ? update.summary.substring(0, 250) + '…' : update.summary %></p>
              <% } %>
              <div class="flex flex-wrap gap-4 text-xs">
                <% if (update.milestones) { %>
                  <div>
                    <span class="text-emerald-600 font-medium">✓ Milestones: </span>
                    <span class="text-gray-500"><%= update.milestones.length > 80 ? update.milestones.substring(0, 80) + '…' : update.milestones %></span>
                  </div>
                <% } %>
                <% if (update.issues_risks) { %>
                  <div>
                    <span class="text-amber-600 font-medium">⚠ Issues: </span>
                    <span class="text-gray-500"><%= update.issues_risks.length > 80 ? update.issues_risks.substring(0, 80) + '…' : update.issues_risks %></span>
                  </div>
                <% } %>
                <% if (update.blockers) { %>
                  <div>
                    <span class="text-red-600 font-medium">✕ Blockers: </span>
                    <span class="text-gray-500"><%= update.blockers.length > 80 ? update.blockers.substring(0, 80) + '…' : update.blockers %></span>
                  </div>
                <% } %>
              </div>
            </div>
            <div class="flex flex-col items-end gap-2 flex-shrink-0">
              <span class="text-xs text-gray-400"><%= update.created_at ? new Date(update.created_at).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '' %></span>
              <a href="/updates/<%= update.id %>" class="text-xs text-brand-600 hover:underline">View full</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
    <div class="mt-3 text-xs text-gray-400"><%= recentUpdates.length %> update<%= recentUpdates.length !== 1 ? 's' : '' %> shown</div>
  <% } %>

</div><!-- #updates -->

</div><!-- .tab-group -->

<script>
  // Keep active tab highlighted and persist after filter submit
  (function() {
    const hash = window.location.hash || '#register';
    document.querySelectorAll('.tab-content').forEach(el => {
      el.style.display = el.id === hash.slice(1) ? 'block' : 'none';
    });
    document.querySelectorAll('nav a[href^="#"]').forEach(a => {
      const active = a.getAttribute('href') === hash;
      a.classList.toggle('border-brand-600', active);
      a.classList.toggle('text-brand-600', active);
      a.classList.toggle('border-transparent', !active);
      a.classList.toggle('text-gray-500', !active);
    });
    document.querySelectorAll('nav a[href^="#"]').forEach(a => {
      a.addEventListener('click', function() {
        const target = this.getAttribute('href').slice(1);
        document.querySelectorAll('.tab-content').forEach(el => {
          el.style.display = el.id === target ? 'block' : 'none';
        });
        document.querySelectorAll('nav a[href^="#"]').forEach(b => {
          const isActive = b === this;
          b.classList.toggle('border-brand-600', isActive);
          b.classList.toggle('text-brand-600', isActive);
          b.classList.toggle('border-transparent', !isActive);
          b.classList.toggle('text-gray-500', !isActive);
        });
      });
    });
  })();
</script>
