        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% costEntries.forEach(ce => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500 text-xs"><%= ce.entry_date %></td>
            <td class="px-4 py-3 text-gray-600"><%= ce.category ? ce.category.replace(/_/g, ' ') : '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= ce.description || '-' %></td>
            <td class="px-4 py-3 text-gray-500"><%= ce.supplier || '-' %></td>
            <td class="px-4 py-3 text-gray-900 text-right font-medium">$<%= (ce.amount || 0).toLocaleString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Accounts Tab (conditional) -->
  <% if (canViewAccounts) { %>
  <div id="accounts" class="tab-content">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Accounts</h2>
    </div>

    <!-- Accounts Status -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-3">Accounts Status</h3>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
        <% if (job.accounts_status === 'on_track') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
        <% } else if (job.accounts_status === 'overdue') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
        <% } else if (job.accounts_status === 'disputed') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
        <% } else { %>bg-white text-gray-500<% } %>">
        <%= job.accounts_status ? job.accounts_status.replace('_', ' ') : 'N/A' %>
      </span>
    </div>

    <!-- Accounts Documents -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Accounts Documents</h3>
      <% if (accountsDocs.length === 0) { %>
        <p class="text-gray-400 text-sm">No accounts documents uploaded yet.</p>
      <% } else { %>
        <%
          // Group documents by category
          const accountsGrouped = {};
          accountsDocs.forEach(doc => {
            const cat = doc.category || 'Uncategorised';
            if (!accountsGrouped[cat]) accountsGrouped[cat] = [];
            accountsGrouped[cat].push(doc);
          });
        %>
        <div class="space-y-4">
          <% Object.keys(accountsGrouped).forEach(category => { %>
          <div>
            <h4 class="text-sm font-medium text-gray-600 mb-2 capitalize"><%= category %></h4>
            <ul class="space-y-1">
              <% accountsGrouped[category].forEach(doc => { %>
              <li class="flex items-center justify-between py-2 px-3 bg-white/50 rounded-lg">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="text-sm text-gray-600"><%= doc.title || doc.filename %></span>
                </div>
                <% if (doc.file_path) { %>
                  <a href="<%= doc.file_path %>" target="_blank" class="text-xs text-brand-600 hover:text-brand-700 hover:underline">View</a>
                <% } %>
              </li>
              <% }) %>
            </ul>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
  <% } %>

</div>

<!-- Tab switching script -->
<script>
  function activateTab(clicked) {
    // Update tab styling
    const tabs = clicked.parentElement.querySelectorAll('a');
    tabs.forEach(tab => {
      tab.classList.remove('text-brand-700', 'border-brand-500');
      tab.classList.add('text-gray-500', 'border-transparent');
    });
    clicked.classList.remove('text-gray-500', 'border-transparent');
    clicked.classList.add('text-brand-700', 'border-brand-500');

    // Show/hide content
    const targetId = clicked.getAttribute('href').substring(1);
    document.querySelectorAll('.tab-content').forEach(content => {
      content.style.display = 'none';
    });
    const target = document.getElementById(targetId);
    if (target) target.style.display = 'block';
  }

  // Initialise: activate first tab or hash-targeted tab
  document.addEventListener('DOMContentLoaded', function() {
    const hash = window.location.hash;
    const tabs = document.querySelectorAll('nav a[href^="#"]');
    if (hash && document.querySelector('a[href="' + hash + '"]')) {
      activateTab(document.querySelector('a[href="' + hash + '"]'));
    } else if (tabs.length > 0) {
      activateTab(tabs[0]);
    }
  });
</script>
