                <% if (inc.investigation_status === 'closed' || inc.investigation_status === 'resolved') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                <% } else if (inc.investigation_status === 'investigating') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                <% } else { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20<% } %>"><%= inc.investigation_status ? inc.investigation_status.replace(/_/g, ' ') : 'reported' %></span>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= inc.reported_by_name || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
