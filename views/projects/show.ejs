                <% } else if (tp.status === 'rejected') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
                <% } else if (tp.status === 'expired') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else { %>bg-white text-gray-600<% } %>"><%= tp.status ? tp.status.replace(/_/g, ' ') : 'draft' %></span>
