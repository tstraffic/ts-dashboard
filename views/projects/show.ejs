          <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/incidents/<%= inc.id %>'">
            <td class="px-4 py-3 text-gray-600 text-xs"><%= inc.incident_date %></td>
            <td class="px-4 py-3 text-gray-600"><%= inc.incident_type ? inc.incident_type.replace(/_/g, ' ') : '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (inc.severity === 'critical') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
                <% } else if (inc.severity === 'high') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else if (inc.severity === 'medium') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else { %>bg-white text-gray-600<% } %>"><%= inc.severity %></span>
            </td>
            <td class="px-4 py-3 text-gray-600 max-w-xs truncate"><%= inc.description ? inc.description.substring(0, 80) : '-' %></td>
            <td class="px-4 py-3">
