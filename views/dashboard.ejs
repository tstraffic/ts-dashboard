<% locals.currentPage = 'dashboard' %>
<%
  const role = userRole || 'admin';
  const normalRole = { management: 'admin', accounts: 'finance', marketing: 'operations' }[role] || role;
  const isOps = ['admin', 'operations'].includes(normalRole);
  const isPlanning = ['admin', 'planning'].includes(normalRole);
  const isFinance = ['admin', 'finance'].includes(normalRole);
%>

<!-- Hero Banner -->
<div class="hero-banner relative bg-gradient-to-br from-brand-900 via-brand-800 to-brand-700 rounded-2xl p-4 sm:p-5 mb-4 overflow-hidden">
  <!-- Animated decorative orbs -->
  <div class="hero-orb absolute top-0 right-0 w-80 h-80 bg-gradient-to-br from-white/[0.07] to-transparent rounded-full -translate-y-1/2 translate-x-1/4"></div>
  <div class="hero-orb absolute bottom-0 left-1/4 w-56 h-56 bg-gradient-to-t from-white/[0.04] to-transparent rounded-full translate-y-1/2"></div>
  <div class="hero-orb absolute top-1/2 right-1/3 w-32 h-32 bg-brand-400/10 rounded-full blur-2xl"></div>
  <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="hero-greeting">
      <p class="text-brand-300 text-[10px] uppercase tracking-[0.15em] font-semibold mb-1"><%= normalRole %> Dashboard</p>
      <h1 class="text-xl sm:text-2xl font-extrabold text-white tracking-tight"><span id="greeting">Hello</span>, <%= user.full_name.split(' ')[0] %></h1>
      <p class="text-brand-200/80 text-sm mt-1 font-medium" id="today-date"></p>
    </div>
    <div class="flex gap-3 sm:gap-4">
      <% if (isOps) { %>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= kpi.activeJobs %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Active Jobs</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= allocatedToday %>">0</span><span class="text-brand-400 text-lg font-bold">/<%= totalActiveCrew %></span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Crew Today</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= Math.round(kpi.crewHoursThisWeek) %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Hours (7d)</p>
      </div>
      <% } else if (normalRole === 'planning') { %>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= kpi.rolPending + kpi.tmpPending %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Pending</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= kpi.overdueCompliance %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Overdue</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= kpi.ticketsExpiring %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Expiring</p>
      </div>
      <% } else if (normalRole === 'finance') { %>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none">$<span class="kpi-number" data-count="<%= Math.round(kpi.totalContractValue / 1000) %>">0</span>k</p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Contract Value</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none">$<span class="kpi-number" data-count="<%= Math.round(kpi.totalSpend / 1000) %>">0</span>k</p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Total Spend</p>
      </div>
      <div class="hero-kpi-card text-center bg-white/[0.08] backdrop-blur-sm rounded-xl px-4 py-3 min-w-[80px] ring-1 ring-white/10 hover:bg-white/[0.12] transition-colors">
        <p class="text-2xl sm:text-3xl font-extrabold text-white leading-none"><span class="kpi-number" data-count="<%= kpi.accountsOverdue %>">0</span></p>
        <p class="text-brand-300 text-[9px] uppercase tracking-wider font-semibold mt-1.5">Invoices Due</p>
      </div>
      <% } %>
    </div>
  </div>
</div>
<script>
  (function() {
    var h = new Date().getHours();
    var g = h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';
    document.getElementById('greeting').textContent = g;
    document.getElementById('today-date').textContent = new Date().toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
  })();
</script>

<% if (typeof onboarding !== 'undefined' && onboarding) { %>
<!-- Onboarding Checklist -->
<div class="bg-white border border-brand-200 rounded-2xl shadow-sm p-3 sm:p-4 mb-5 relative" id="onboarding-banner">
  <button onclick="fetch('/profile/dismiss-onboarding',{method:'POST',headers:{'Content-Type':'application/json','x-csrf-token':document.querySelector('meta[name=csrf-token]').content}}).then(()=>document.getElementById('onboarding-banner').remove())"
    class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 text-lg leading-none" title="Dismiss">&times;</button>
  <h3 class="text-sm font-bold text-gray-900 mb-0.5">Getting Started</h3>
  <p class="text-xs text-gray-500 mb-3">Complete these steps to get the most out of your dashboard.</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
    <% onboarding.forEach(item => { %>
    <a href="<%= item.link %>" class="flex items-center gap-2.5 px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors group">
      <span class="onboarding-check <%= item.done ? 'completed' : '' %>">
        <% if (item.done) { %><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg><% } %>
      </span>
      <span class="text-sm <%= item.done ? 'text-gray-400 line-through' : 'text-gray-700 group-hover:text-brand-600' %>"><%= item.label %></span>
    </a>
    <% }) %>
  </div>
  <div class="mt-3 bg-gray-100 rounded-full h-1.5 overflow-hidden">
    <% const doneCount = onboarding.filter(i => i.done).length; %>
    <div class="h-full bg-brand-500 rounded-full transition-all" style="width: <%= Math.round(doneCount / onboarding.length * 100) %>%"></div>
  </div>
  <p class="text-[10px] text-gray-400 mt-1"><%= onboarding.filter(i => i.done).length %>/<%= onboarding.length %> complete</p>
</div>
<% } %>

<!-- Urgency Tiles -->
<div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-2 sm:gap-3 mb-5 stagger-children">
  <!-- CRITICAL: Overdue Tasks -->
  <a href="/tasks" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.overdueTasks > 0 ? 'bg-red-50/60 border-l-red-500 border-t border-r border-b border-t-red-200 border-r-red-200 border-b-red-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.overdueTasks > 0 ? 'text-red-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.overdueTasks %>">0</span></p>
      <% if (kpi.overdueTasks > 0) { %><svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Overdue Tasks</p>
  </a>
  <!-- CRITICAL: Open Incidents -->
  <a href="/incidents" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.openIncidents > 0 ? 'bg-red-50/60 border-l-red-500 border-t border-r border-b border-t-red-200 border-r-red-200 border-b-red-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.openIncidents > 0 ? 'text-red-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.openIncidents %>">0</span></p>
      <% if (kpi.openIncidents > 0) { %><svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Open Incidents</p>
  </a>
  <!-- WARNING: Pending Timesheets -->
  <a href="/timesheets?approved=0" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.pendingTimesheets > 0 ? 'bg-amber-50/60 border-l-amber-500 border-t border-r border-b border-t-amber-200 border-r-amber-200 border-b-amber-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.pendingTimesheets > 0 ? 'text-amber-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.pendingTimesheets %>">0</span></p>
      <% if (kpi.pendingTimesheets > 0) { %><svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Pending Timesheets</p>
  </a>
  <!-- INFO: Unconfirmed -->
  <a href="/allocations" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.unconfirmedAllocations > 0 ? 'bg-blue-50/60 border-l-blue-500 border-t border-r border-b border-t-blue-200 border-r-blue-200 border-b-blue-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.unconfirmedAllocations > 0 ? 'text-blue-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.unconfirmedAllocations %>">0</span></p>
      <% if (kpi.unconfirmedAllocations > 0) { %><svg class="w-3.5 h-3.5 text-blue-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Unconfirmed</p>
  </a>
  <!-- WARNING: Open Defects -->
  <a href="/defects" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.openDefects > 0 ? 'bg-amber-50/60 border-l-amber-500 border-t border-r border-b border-t-amber-200 border-r-amber-200 border-b-amber-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.openDefects > 0 ? 'text-amber-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.openDefects %>">0</span></p>
      <% if (kpi.openDefects > 0) { %><svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Open Defects</p>
  </a>
  <!-- CRITICAL: Overdue Plans -->
  <a href="/compliance" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.overdueCompliance > 0 ? 'bg-red-50/60 border-l-red-500 border-t border-r border-b border-t-red-200 border-r-red-200 border-b-red-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.overdueCompliance > 0 ? 'text-red-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.overdueCompliance %>">0</span></p>
      <% if (kpi.overdueCompliance > 0) { %><svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Overdue Plans</p>
  </a>
  <!-- WARNING: Expiring Tickets -->
  <a href="/crew" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.ticketsExpiring > 0 ? 'bg-amber-50/60 border-l-amber-500 border-t border-r border-b border-t-amber-200 border-r-amber-200 border-b-amber-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.ticketsExpiring > 0 ? 'text-amber-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.ticketsExpiring %>">0</span></p>
      <% if (kpi.ticketsExpiring > 0) { %><svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Expiring Tickets</p>
  </a>
  <!-- CRITICAL: Crew Gaps -->
  <a href="/allocations" class="urgency-tile group rounded-xl p-3 border-l-4 <%= kpi.crewGaps > 0 ? 'bg-red-50/60 border-l-red-500 border-t border-r border-b border-t-red-200 border-r-red-200 border-b-red-200' : 'bg-white border-l-gray-200 border border-gray-200' %> hover:shadow-md transition-shadow">
    <div class="flex items-center justify-between">
      <p class="text-2xl font-extrabold <%= kpi.crewGaps > 0 ? 'text-red-600' : 'text-emerald-600' %>"><span class="kpi-number" data-count="<%= kpi.crewGaps %>">0</span></p>
      <% if (kpi.crewGaps > 0) { %><svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg><% } %>
    </div>
    <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wider mt-0.5">Crew Gaps</p>
  </a>
</div>

<!-- Needs Attention -->
<% if (actionItems.length > 0) { %>
<div class="needs-attention-card bg-white border border-red-200 rounded-2xl p-4 mb-5">
  <div class="flex items-center gap-2 mb-3">
    <div class="attention-dot w-2 h-2 rounded-full bg-red-500"></div>
    <h2 class="text-sm font-bold text-gray-900">Needs Attention</h2>
    <span class="text-[10px] font-medium text-red-600 bg-red-50 px-2 py-0.5 rounded-full"><%= actionItems.length %> item<%= actionItems.length !== 1 ? 's' : '' %></span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2">
    <% actionItems.forEach(item => { %>
    <a href="<%= item.link %>" class="flex items-center gap-2.5 p-2.5 rounded-xl hover:bg-gray-50 transition group border border-gray-100">
      <div class="w-2 h-2 rounded-full flex-shrink-0 <%= item.color === 'red' ? 'bg-red-500' : 'bg-amber-400' %>"></div>
      <span class="text-sm text-gray-700 group-hover:text-gray-900 truncate"><%= item.text %></span>
      <svg class="w-3.5 h-3.5 text-gray-300 ml-auto flex-shrink-0 group-hover:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Dashboard Tabs -->
<%
  const tabs = [];
  tabs.push({ id: 'my-work', label: 'My Work' });
  if (isOps) tabs.push({ id: 'operations', label: 'Operations' });
  tabs.push({ id: 'insights', label: 'Insights' });
  if (isPlanning || isOps) tabs.push({ id: 'plans-safety', label: 'Plans & Safety' });
  if (isFinance) tabs.push({ id: 'finance', label: 'Finance' });
%>

<div class="mb-5">
  <!-- Tab Nav -->
  <div class="flex gap-1 border-b border-gray-200 mb-4 overflow-x-auto scrollbar-hide">
    <% tabs.forEach((tab, i) => { %>
    <button data-tab="<%= tab.id %>" class="px-4 py-2.5 text-sm font-medium whitespace-nowrap transition-colors border-b-2 -mb-px <%= i === 0 ? 'text-brand-600 border-brand-600' : 'text-gray-500 border-transparent hover:text-gray-700 hover:border-gray-300' %>"><%= tab.label %></button>
    <% }) %>
  </div>

  <!-- Tab: My Work -->
  <div data-tab-panel="my-work" class="space-y-4">
    <!-- My Tasks -->
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          <h2 class="text-sm font-bold text-gray-900">My Tasks</h2>
          <span class="text-[10px] font-semibold text-brand-600 bg-brand-50 px-1.5 py-0.5 rounded-full"><%= myTasks.length %></span>
        </div>
        <a href="/tasks" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View all &rarr;</a>
      </div>
      <% if (myTasks.length === 0) { %>
        <div class="p-6 text-center">
          <div class="w-10 h-10 bg-brand-50 rounded-xl flex items-center justify-center mx-auto mb-2">
            <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
          </div>
          <p class="text-sm font-medium text-gray-700">No open tasks assigned to you</p>
          <p class="text-xs text-gray-400 mt-1">Tasks assigned to you will appear here.</p>
        </div>
      <% } else { %>
      <div class="divide-y divide-gray-100">
        <% myTasks.slice(0, 8).forEach(t => {
          const isOverdue = t.due_date < new Date().toISOString().split('T')[0];
          const priorityTag = t.priority === 'high' ? 'task-tag-high' : t.priority === 'medium' ? 'task-tag-medium' : 'task-tag-low';
          const statusTag = t.status === 'in_progress' ? 'task-tag-progress' : t.status === 'blocked' ? 'task-tag-blocked' : 'task-tag-default';
        %>
        <a href="/tasks/<%= t.id %>/edit" class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 truncate"><%= t.title %></p>
            <div class="flex items-center gap-2 mt-1.5">
              <% if (t.job_number) { %><span class="job-id-chip" style="font-size:10px;padding:1px 6px"><%= t.job_number %></span><% } %>
              <span class="task-tag <%= priorityTag %>"><%= t.priority %></span>
              <span class="task-tag <%= statusTag %>"><%= t.status.replace(/_/g, ' ') %></span>
            </div>
          </div>
          <div class="ml-3 text-right flex-shrink-0">
            <span class="text-xs font-semibold <%= isOverdue ? 'text-red-600' : 'text-gray-500' %>"><%= new Date(t.due_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' }) %></span>
            <% if (isOverdue) { %><p class="text-[10px] text-red-500 font-medium">OVERDUE</p><% } %>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- My Plans -->
    <% if (myPlans && myPlans.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <h2 class="text-sm font-bold text-gray-900">My Plans & Approvals</h2>
          <span class="text-[10px] font-semibold text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-full"><%= myPlans.length %></span>
        </div>
        <a href="/compliance" class="text-xs text-emerald-600 hover:text-emerald-700 font-medium">View all &rarr;</a>
      </div>
      <div class="divide-y divide-gray-100">
        <% myPlans.forEach(p => {
          const todayStr = new Date().toISOString().split('T')[0];
          const isOverdue = p.due_date && p.due_date < todayStr;
          const isDueSoon = !isOverdue && p.due_date && p.due_date <= new Date(Date.now() + 14 * 86400000).toISOString().split('T')[0];
          const statusColors = { not_started: 'bg-gray-100 text-gray-600', started: 'bg-purple-50 text-purple-700', submitted: 'bg-blue-50 text-blue-700', rejected: 'bg-red-50 text-red-700' };
          const sc = statusColors[p.status] || 'bg-gray-100 text-gray-600';
        %>
        <a href="/compliance/<%= p.id %>/edit" class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 truncate"><%= p.title %></p>
            <div class="flex items-center gap-2 mt-1.5">
              <% if (p.job_number) { %><span class="job-id-chip" style="font-size:10px;padding:1px 6px"><%= p.job_number %></span><% } %>
              <% if (p.client_name && !p.job_number) { %><span class="text-[10px] text-gray-400"><%= p.client_name %></span><% } %>
              <span class="inline-flex px-1.5 py-0.5 text-[10px] font-bold rounded-full <%= sc %>"><%= p.status.replace(/_/g, ' ') %></span>
            </div>
          </div>
          <div class="ml-3 text-right flex-shrink-0">
            <% if (p.due_date) { %>
              <span class="text-xs font-semibold <%= isOverdue ? 'text-red-600' : isDueSoon ? 'text-amber-600' : 'text-gray-500' %>"><%= new Date(p.due_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' }) %></span>
              <% if (isOverdue) { %><p class="text-[10px] text-red-500 font-medium">OVERDUE</p><% } %>
              <% if (isDueSoon) { %><p class="text-[10px] text-amber-500 font-medium">DUE SOON</p><% } %>
            <% } else { %>
              <span class="text-xs text-gray-400">No date</span>
            <% } %>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Tasks I Assigned -->
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <h2 class="text-sm font-bold text-gray-900">Tasks I Assigned</h2>
          <% if (tasksIAssigned.length > 0) { %><span class="text-[10px] font-semibold text-purple-600 bg-purple-50 px-1.5 py-0.5 rounded-full"><%= tasksIAssigned.length %></span><% } %>
        </div>
        <a href="/tasks" class="text-xs text-purple-600 hover:text-purple-700 font-medium">View all &rarr;</a>
      </div>
      <% if (tasksIAssigned.length === 0) { %>
        <div class="p-6 text-center">
          <p class="text-sm text-gray-500">No tasks assigned to others yet</p>
          <p class="text-xs text-gray-400 mt-1">When you create a task and assign it to someone else, it will appear here.</p>
        </div>
      <% } else { %>
      <div class="divide-y divide-gray-100">
        <% tasksIAssigned.forEach(t => {
          const isOverdue = t.due_date < new Date().toISOString().split('T')[0];
          const statusTag = t.status === 'in_progress' ? 'task-tag-progress' : t.status === 'blocked' ? 'task-tag-blocked' : 'task-tag-default';
        %>
        <div class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
          <div class="min-w-0 flex-1">
            <a href="/tasks/<%= t.id %>/edit" class="text-sm font-medium text-gray-900 hover:text-brand-600 truncate block"><%= t.title %></a>
            <div class="flex items-center gap-2 mt-1.5">
              <span class="text-[10px] text-gray-500">Assigned to <strong><%= t.owner_name %></strong></span>
              <span class="task-tag <%= statusTag %>"><%= t.status.replace(/_/g, ' ') %></span>
              <% if (isOverdue) { %><span class="task-tag task-tag-blocked">OVERDUE</span><% } %>
            </div>
          </div>
          <div class="ml-3 flex items-center gap-2 flex-shrink-0">
            <span class="text-xs text-gray-400"><%= new Date(t.due_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' }) %></span>
            <form action="/tasks/<%= t.id %>/renotify" method="POST" class="inline">
              <%- include('partials/csrf') %>
              <button type="submit" title="Send reminder to <%= t.owner_name %>" class="p-1.5 rounded-lg hover:bg-purple-50 text-gray-400 hover:text-purple-600 transition" onclick="return confirm('Send a reminder to <%= t.owner_name %>?')">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              </button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- My Jobs -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="dash-section-title">My Jobs</h2>
        <a href="/jobs/new" class="btn-new-job">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          New Job
        </a>
      </div>
      <% if (myJobs.length === 0) { %>
        <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center">
          <div class="w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <p class="text-sm font-medium text-gray-700">No jobs assigned yet</p>
          <p class="text-xs text-gray-400 mt-1">Create a new job or ask an admin to assign one to you.</p>
        </div>
      <% } else { %>
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden overflow-x-auto">
        <table class="w-full text-sm min-w-[400px]">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Client</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Health</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Progress</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% myJobs.slice(0, 8).forEach(job => {
              const healthClass = job.health === 'green' ? 'health-pill-green' : job.health === 'amber' ? 'health-pill-amber' : 'health-pill-red';
              const barClass = job.percent_complete >= 75 ? 'health-green' : job.percent_complete >= 40 ? 'health-blue' : 'health-amber';
            %>
            <tr class="cursor-pointer transition" onclick="window.location='/projects/<%= job.id %>'">
              <td class="px-3 sm:px-4 py-2.5"><span class="job-id-chip"><%= job.job_number %></span></td>
              <td class="px-3 sm:px-4 py-2.5 text-gray-600 text-sm"><%= job.client %></td>
              <td class="px-3 sm:px-4 py-2.5">
                <span class="health-pill <%= healthClass %>"><%= job.health %></span>
              </td>
              <td class="px-3 sm:px-4 py-2.5">
                <div class="flex items-center gap-2">
                  <div class="progress-track flex-1">
                    <div class="progress-bar-fill <%= barClass %>" style="width: <%= job.percent_complete %>%"></div>
                  </div>
                  <span class="text-xs text-gray-400 w-7 text-right tabular-nums"><%= job.percent_complete %>%</span>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% if (myJobs.length > 8) { %>
          <div class="px-4 py-2 border-t border-gray-100 text-center">
            <a href="/jobs" class="text-xs text-brand-600 hover:text-brand-500 font-medium">View all <%= myJobs.length %> jobs &rarr;</a>
          </div>
        <% } %>
      </div>
      <% } %>
    </div>

    <!-- Recent Updates -->
    <% if (recentUpdates.length > 0) { %>
    <div>
      <div class="flex items-center justify-between mb-3">
        <h2 class="dash-section-title">Recent Updates</h2>
        <a href="/updates" class="text-xs text-brand-600 hover:text-brand-500 font-medium">All &rarr;</a>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <div class="space-y-2.5">
          <% recentUpdates.slice(0, 5).forEach(u => { %>
          <a href="/projects/<%= u.job_id %>" class="block group">
            <p class="text-xs font-medium text-brand-600 group-hover:text-brand-500"><%= u.job_number %> &mdash; <%= u.client %></p>
            <p class="text-[11px] text-gray-500 mt-0.5 line-clamp-2"><%= u.summary.length > 100 ? u.summary.substring(0, 100) + '...' : u.summary %></p>
            <p class="text-[10px] text-gray-300 mt-0.5"><%= u.submitted_by_name %> &middot; <%= u.week_ending ? new Date(u.week_ending).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '' %></p>
          </a>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Tab: Operations (ops/admin only) -->
  <% if (isOps) { %>
  <div data-tab-panel="operations" class="hidden space-y-4">
    <!-- Today's Allocations -->
    <% if (todaysAllocations.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
      <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <h2 class="text-sm font-bold text-gray-900">Today's Allocations</h2>
          <span class="text-[10px] font-medium text-brand-600 bg-brand-50 px-2 py-0.5 rounded-full"><%= todaysAllocations.length %> crew</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xs text-gray-500"><span class="font-semibold text-emerald-600"><%= availableCrew %></span> available</span>
          <a href="/allocations" class="text-xs text-brand-600 hover:text-brand-500 font-medium">View all &rarr;</a>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Crew</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Role</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Location</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Time</th>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% todaysAllocations.slice(0, 15).forEach(a => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 text-gray-900 font-medium text-xs"><%= a.crew_name %></td>
              <td class="px-3 py-2 text-gray-500 text-xs hidden sm:table-cell"><%= a.crew_role ? a.crew_role.replace(/_/g, ' ') : '-' %></td>
              <td class="px-3 py-2">
                <a href="/projects/<%= a.job_id %>" class="text-brand-600 hover:text-brand-700 text-xs font-medium"><%= a.job_number %></a>
                <p class="text-gray-400 text-[10px] truncate max-w-[120px] sm:hidden"><%= a.client %></p>
              </td>
              <td class="px-3 py-2 text-gray-500 text-xs truncate max-w-[160px] hidden md:table-cell"><%= a.site_address || '-' %></td>
              <td class="px-3 py-2 text-gray-500 text-xs tabular-nums hidden md:table-cell"><%= a.start_time || '-' %> - <%= a.end_time || '-' %></td>
              <td class="px-3 py-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium
                  <%= a.status === 'confirmed' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' : a.status === 'declined' ? 'bg-red-50 text-red-700 ring-1 ring-red-600/20' : 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' %>">
                  <%= a.status %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (todaysAllocations.length > 15) { %>
      <div class="px-4 py-2 border-t border-gray-100 text-center">
        <a href="/allocations" class="text-xs text-brand-600 hover:text-brand-500 font-medium">View all <%= todaysAllocations.length %> allocations &rarr;</a>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center">
      <div class="w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-700">No allocations today</p>
      <p class="text-xs text-gray-400 mt-1">Schedule crew from the <a href="/allocations" class="text-brand-600 hover:text-brand-500">Allocations</a> page.</p>
    </div>
    <% } %>

    <!-- Crew & Equipment Row -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Crew Availability -->
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-3">Crew Availability</h3>
        <div class="flex items-center justify-center gap-2 mb-3">
          <div class="relative w-20 h-20">
            <svg viewBox="0 0 36 36" class="w-20 h-20 -rotate-90">
              <circle cx="18" cy="18" r="15.91549431" fill="none" stroke="#f3f4f6" stroke-width="3"></circle>
              <circle cx="18" cy="18" r="15.91549431" fill="none" stroke="#2B7FFF" stroke-width="3"
                stroke-dasharray="<%= totalActiveCrew > 0 ? (allocatedToday / totalActiveCrew * 100) : 0 %> <%= totalActiveCrew > 0 ? 100 - (allocatedToday / totalActiveCrew * 100) : 100 %>"
                stroke-linecap="round"></circle>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-lg font-extrabold text-gray-900"><%= allocatedToday %></span>
            </div>
          </div>
        </div>
        <div class="space-y-1.5 text-center">
          <div class="flex items-center justify-between px-2">
            <span class="text-xs text-gray-500">Allocated today</span>
            <span class="text-sm font-bold text-brand-600"><%= allocatedToday %></span>
          </div>
          <div class="flex items-center justify-between px-2">
            <span class="text-xs text-gray-500">Available</span>
            <span class="text-sm font-bold text-emerald-600"><%= availableCrew %></span>
          </div>
          <div class="flex items-center justify-between px-2">
            <span class="text-xs text-gray-500">Total active</span>
            <span class="text-sm font-bold text-gray-900"><%= totalActiveCrew %></span>
          </div>
        </div>
      </div>

      <!-- Operations Summary -->
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-3">Operations Summary</h3>
        <div class="space-y-2.5">
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Equipment deployed</span>
            <span class="text-sm font-bold text-gray-900"><%= kpi.equipmentDeployed %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Jobs starting soon</span>
            <span class="text-sm font-bold <%= kpi.startingSoon > 0 ? 'text-brand-600' : 'text-gray-900' %>"><%= kpi.startingSoon %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Missing weekly updates</span>
            <span class="text-sm font-bold <%= kpi.missingUpdates > 0 ? 'text-amber-600' : 'text-emerald-600' %>"><%= kpi.missingUpdates %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">Corrective actions due</span>
            <span class="text-sm font-bold <%= kpi.overdueCorrectiveActions > 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= kpi.overdueCorrectiveActions %></span>
          </div>
          <% if (kpi.notifiableIncidents > 0) { %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-red-600 font-medium">Notifiable incidents</span>
            <span class="text-sm font-bold text-red-600"><%= kpi.notifiableIncidents %></span>
          </div>
          <% } %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">ROL pending</span>
            <span class="text-sm font-bold <%= kpi.rolPending > 0 ? 'text-amber-600' : 'text-gray-400' %>"><%= kpi.rolPending %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500">TMP pending</span>
            <span class="text-sm font-bold <%= kpi.tmpPending > 0 ? 'text-amber-600' : 'text-gray-400' %>"><%= kpi.tmpPending %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Tab: Insights -->
  <div data-tab-panel="insights" class="hidden space-y-4">
    <!-- Charts Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-2">Job Pipeline</h3>
        <div class="relative" style="height: 180px;">
          <canvas id="jobStatusChart"></canvas>
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-2">Crew Hours (7 Days)</h3>
        <div class="relative" style="height: 180px;">
          <canvas id="crewHoursChart"></canvas>
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl p-4">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-3">Job Health</h3>
        <% if (jobHealthDist.length > 0) { %>
        <div class="relative mx-auto" style="height: 120px; width: 120px;">
          <canvas id="jobHealthChart"></canvas>
        </div>
        <div class="flex justify-center gap-3 mt-2">
          <% jobHealthDist.forEach(h => { %>
          <div class="flex items-center gap-1 text-xs text-gray-500">
            <span class="w-2 h-2 rounded-full <%= h.health === 'green' ? 'bg-emerald-500' : h.health === 'amber' ? 'bg-amber-400' : 'bg-red-500' %>"></span>
            <span class="capitalize"><%= h.health %> (<%= h.count %>)</span>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <p class="text-sm text-gray-400 text-center py-8">No active jobs</p>
        <% } %>
      </div>
    </div>

    <!-- Recent Activity -->
    <% if (recentActivity.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-2xl p-4">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider">Recent Activity</h3>
        <a href="/activity" class="text-xs text-brand-600 hover:text-brand-500 font-medium">All &rarr;</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <% recentActivity.slice(0, 9).forEach(a => {
          const actionColors = { create: 'bg-emerald-500', update: 'bg-blue-500', delete: 'bg-red-500', login: 'bg-purple-500', approve: 'bg-teal-500' };
          const dotColor = actionColors[a.action] || 'bg-gray-400';
        %>
        <div class="flex items-start gap-2.5 p-2 rounded-lg hover:bg-gray-50 transition">
          <div class="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0 <%= dotColor %>"></div>
          <div class="min-w-0">
            <p class="text-xs text-gray-700 truncate"><span class="font-medium"><%= a.user_name || 'System' %></span> <%= a.action %> <%= a.entity_type ? a.entity_type.replace(/_/g, ' ') : '' %></p>
            <% if (a.entity_label) { %><p class="text-[10px] text-gray-400 truncate"><%= a.entity_label %></p><% } %>
            <p class="text-[10px] text-gray-300"><%= new Date(a.created_at).toLocaleString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %></p>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Tab: Plans & Safety -->
  <% if (isPlanning || isOps) { %>
  <div data-tab-panel="plans-safety" class="hidden space-y-4">
    <% if (complianceUrgent.length > 0) { %>
    <div>
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-wider">Compliance & Approvals</h2>
        <a href="/compliance" class="text-xs text-brand-600 hover:text-brand-500 font-medium">View all &rarr;</a>
      </div>
      <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden overflow-x-auto">
        <table class="w-full text-sm min-w-[500px]">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Item</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Status</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Deadline</th>
              <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Urgency</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <%
              const todayDash = new Date().toISOString().split('T')[0];
              const soon14 = new Date(Date.now() + 14*24*60*60*1000).toISOString().split('T')[0];
              const soon30 = new Date(Date.now() + 30*24*60*60*1000).toISOString().split('T')[0];
              const typeLabels = { traffic_guidance: 'TGS', tmp_approval: 'CTMP', spa: 'SPA', rol: 'ROL', council_permit: 'Council' };
              const typeColors = { traffic_guidance: 'bg-blue-50 text-blue-700', tmp_approval: 'bg-purple-50 text-purple-700', spa: 'bg-orange-50 text-orange-700', rol: 'bg-teal-50 text-teal-700', council_permit: 'bg-amber-50 text-amber-700' };
              const statusLabels = { not_started: 'Not Started', submitted: 'Submitted', approved: 'Approved', rejected: 'Rejected', expired: 'Expired' };
            %>
            <% complianceUrgent.forEach(function(item) {
              const isOverdue = item.due_date && item.due_date < todayDash && item.status !== 'approved' && item.status !== 'expired';
              const isDueSoon = !isOverdue && item.due_date && item.due_date <= soon14 && item.status !== 'approved';
              const isExpired = item.expiry_date && item.expiry_date < todayDash;
              const isExpiringSoon = !isExpired && item.expiry_date && item.expiry_date <= soon30 && item.status === 'approved';
              let urgencyLabel = 'On Track'; let urgencyClass = 'bg-gray-100 text-gray-600';
              if (isOverdue) { urgencyLabel = 'OVERDUE'; urgencyClass = 'bg-red-100 text-red-700 font-semibold'; }
              else if (isExpired) { urgencyLabel = 'EXPIRED'; urgencyClass = 'bg-red-100 text-red-700 font-semibold'; }
              else if (isDueSoon) { urgencyLabel = 'Due Soon'; urgencyClass = 'bg-amber-100 text-amber-700 font-medium'; }
              else if (isExpiringSoon) { urgencyLabel = 'Expiring'; urgencyClass = 'bg-amber-100 text-amber-700 font-medium'; }
              const deadline = item.due_date || item.expiry_date;
              const tc = typeColors[item.item_type] || 'bg-gray-100 text-gray-600';
            %>
            <tr class="hover:bg-gray-50 transition-colors cursor-pointer" onclick="window.location='/compliance/<%= item.id %>/edit'">
              <td class="px-3 sm:px-4 py-2">
                <p class="text-gray-900 font-medium text-sm truncate max-w-[200px]"><%= item.title %></p>
                <p class="text-[11px] text-gray-400"><%= item.job_number ? item.job_number : (item.client_name || '') %></p>
              </td>
              <td class="px-3 sm:px-4 py-2">
                <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-semibold rounded-full <%= tc %>"><%= typeLabels[item.item_type] || item.item_type %></span>
              </td>
              <td class="px-3 sm:px-4 py-2 hidden sm:table-cell">
                <span class="text-xs text-gray-600"><%= statusLabels[item.status] || item.status %></span>
              </td>
              <td class="px-3 sm:px-4 py-2 whitespace-nowrap">
                <% if (deadline) { %>
                  <span class="text-xs <%= isOverdue || isExpired ? 'text-red-600 font-semibold' : isDueSoon || isExpiringSoon ? 'text-amber-600 font-medium' : 'text-gray-600' %>">
                    <%= new Date(deadline).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' }) %>
                  </span>
                <% } else { %><span class="text-gray-300 text-xs">-</span><% } %>
              </td>
              <td class="px-3 sm:px-4 py-2">
                <span class="inline-flex px-2 py-0.5 text-[10px] rounded-full <%= urgencyClass %>"><%= urgencyLabel %></span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-2xl p-8 text-center">
      <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-700">All clear</p>
      <p class="text-xs text-gray-400 mt-1">No urgent compliance or approval items right now.</p>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Tab: Finance -->
  <% if (isFinance) { %>
  <div data-tab-panel="finance" class="hidden space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Financial Summary -->
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-4">Financial Overview</h3>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">Total Contract Value</span>
            <span class="text-lg font-bold text-gray-900">$<%= kpi.totalContractValue.toLocaleString() %></span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500">Total Spend</span>
            <span class="text-lg font-bold text-brand-600">$<%= kpi.totalSpend.toLocaleString() %></span>
          </div>
          <% if (kpi.totalContractValue > 0) { %>
          <div>
            <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-brand-500 rounded-full" style="width: <%= Math.min(100, Math.round(kpi.totalSpend / kpi.totalContractValue * 100)) %>%"></div>
            </div>
            <p class="text-xs text-gray-400 text-center mt-1"><%= Math.round(kpi.totalSpend / kpi.totalContractValue * 100) %>% of budget used</p>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Accounts Status -->
      <div class="bg-white border border-gray-200 rounded-2xl p-5">
        <h3 class="text-xs font-bold text-gray-800 uppercase tracking-wider mb-4">Accounts Status</h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center p-4 rounded-xl <%= kpi.accountsOverdue > 0 ? 'bg-red-50' : 'bg-gray-50' %>">
            <p class="text-3xl font-extrabold <%= kpi.accountsOverdue > 0 ? 'text-red-600' : 'text-emerald-600' %>"><%= kpi.accountsOverdue %></p>
            <p class="text-[10px] font-medium text-gray-500 uppercase tracking-wider mt-1">Overdue</p>
          </div>
          <div class="text-center p-4 rounded-xl <%= kpi.accountsDisputed > 0 ? 'bg-amber-50' : 'bg-gray-50' %>">
            <p class="text-3xl font-extrabold <%= kpi.accountsDisputed > 0 ? 'text-amber-600' : 'text-emerald-600' %>"><%= kpi.accountsDisputed %></p>
            <p class="text-[10px] font-medium text-gray-500 uppercase tracking-wider mt-1">Disputed</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<!-- Mobile FAB (Quick Actions) -->
