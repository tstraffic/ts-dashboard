<% locals.currentPage = 'dashboard' %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-white">Dashboard</h1>
  <p class="text-slate-400 text-sm mt-1">Overview of all T&S Traffic Control projects</p>
</div>

<!-- KPI Cards -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Active Jobs</p>
    <p class="text-3xl font-bold text-white mt-1"><%= kpi.activeJobs %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Starting Next 14d</p>
    <p class="text-3xl font-bold text-blue-400 mt-1"><%= kpi.startingSoon %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.overdueTasks > 0 ? 'border-red-700' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Overdue Tasks</p>
    <p class="text-3xl font-bold <%= kpi.overdueTasks > 0 ? 'text-red-400' : 'text-emerald-400' %> mt-1"><%= kpi.overdueTasks %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.overdueCompliance > 0 ? 'border-red-700' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Overdue Compliance</p>
    <p class="text-3xl font-bold <%= kpi.overdueCompliance > 0 ? 'text-red-400' : 'text-emerald-400' %> mt-1"><%= kpi.overdueCompliance %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.missingUpdates > 0 ? 'border-amber-700' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Missing Updates</p>
    <p class="text-3xl font-bold <%= kpi.missingUpdates > 0 ? 'text-amber-400' : 'text-emerald-400' %> mt-1"><%= kpi.missingUpdates %></p>
  </div>
</div>

<!-- Safety & Ops KPIs -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.openIncidents > 0 ? 'border-red-800' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Open Incidents</p>
    <p class="text-3xl font-bold <%= kpi.openIncidents > 0 ? 'text-red-400' : 'text-emerald-400' %> mt-1"><%= kpi.openIncidents %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.overdueCorrectiveActions > 0 ? 'border-red-800' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Overdue Actions</p>
    <p class="text-3xl font-bold <%= kpi.overdueCorrectiveActions > 0 ? 'text-red-400' : 'text-emerald-400' %> mt-1"><%= kpi.overdueCorrectiveActions %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Crew Hours (7d)</p>
    <p class="text-3xl font-bold text-blue-400 mt-1"><%= Math.round(kpi.crewHoursThisWeek) %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Equipment Deployed</p>
    <p class="text-3xl font-bold text-blue-400 mt-1"><%= kpi.equipmentDeployed %></p>
  </div>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 <%= kpi.openDefects > 0 ? 'border-amber-800' : '' %>">
    <p class="text-xs text-slate-400 uppercase tracking-wide">Open Defects</p>
    <p class="text-3xl font-bold <%= kpi.openDefects > 0 ? 'text-amber-400' : 'text-emerald-400' %> mt-1"><%= kpi.openDefects %></p>
  </div>
</div>

<% if (canViewAccounts) { %>
<!-- Financial KPIs -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-slate-800 border border-amber-800 rounded-xl p-4">
    <p class="text-xs text-amber-400 uppercase tracking-wide">Total Contract Value</p>
    <p class="text-2xl font-bold text-white mt-1">$<%= kpi.totalContractValue.toLocaleString() %></p>
  </div>
  <div class="bg-slate-800 border border-amber-800 rounded-xl p-4">
    <p class="text-xs text-amber-400 uppercase tracking-wide">Total Spend</p>
    <p class="text-2xl font-bold text-amber-400 mt-1">$<%= kpi.totalSpend.toLocaleString() %></p>
  </div>
  <div class="bg-slate-800 border border-amber-800 rounded-xl p-4">
    <p class="text-xs text-amber-400 uppercase tracking-wide">Invoices Overdue</p>
    <p class="text-3xl font-bold text-amber-400 mt-1"><%= kpi.accountsOverdue %></p>
  </div>
  <div class="bg-slate-800 border border-amber-800 rounded-xl p-4">
    <p class="text-xs text-amber-400 uppercase tracking-wide">Invoices Disputed</p>
    <p class="text-3xl font-bold text-amber-400 mt-1"><%= kpi.accountsDisputed %></p>
  </div>
</div>
<% } %>

<!-- My Jobs -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-white">My Jobs</h2>
    <a href="/jobs/new" class="px-3 py-1.5 bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-medium rounded-lg">+ New Job</a>
  </div>
  <% if (myJobs.length === 0) { %>
    <p class="text-slate-500 text-sm bg-slate-800 rounded-xl border border-slate-700 p-4">No jobs assigned to you.</p>
  <% } else { %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-700">
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Health</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">% Done</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Last Update</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700">
        <% myJobs.forEach(job => { %>
        <tr class="hover:bg-slate-700/50 cursor-pointer" onclick="window.location='/jobs/<%= job.id %>'">
          <td class="px-4 py-3 font-medium text-blue-400"><%= job.job_number %></td>
          <td class="px-4 py-3 text-slate-300"><%= job.client %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (job.status === 'active') { %>bg-blue-900 text-blue-300
              <% } else if (job.status === 'on_hold') { %>bg-amber-900 text-amber-300
              <% } else if (job.status === 'won') { %>bg-emerald-900 text-emerald-300
              <% } else { %>bg-slate-700 text-slate-300<% } %>"><%= job.status.replace('_', ' ') %></span>
          </td>
          <td class="px-4 py-3"><span class="inline-block w-3 h-3 rounded-full <% if (job.health === 'green') { %>bg-emerald-500<% } else if (job.health === 'amber') { %>bg-amber-500<% } else { %>bg-red-500<% } %>"></span></td>
          <td class="px-4 py-3 text-slate-300"><%= job.percent_complete %>%</td>
          <td class="px-4 py-3 text-slate-400 text-xs"><%= job.last_update_date || 'Never' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Jobs Needing Attention -->
<% if (needsAttention.length > 0) { %>
<div class="mb-8">
  <h2 class="text-lg font-semibold text-white mb-4">Jobs Needing Attention</h2>
  <div class="bg-slate-800 border border-red-900/50 rounded-xl overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-700">
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Health</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">PM</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Last Update</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700">
        <% needsAttention.forEach(job => { %>
        <tr class="hover:bg-slate-700/50 cursor-pointer" onclick="window.location='/jobs/<%= job.id %>'">
          <td class="px-4 py-3 font-medium text-blue-400"><%= job.job_number %></td>
          <td class="px-4 py-3 text-slate-300"><%= job.client %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (job.health === 'red') { %>bg-red-900 text-red-300
              <% } else if (job.health === 'amber') { %>bg-amber-900 text-amber-300
              <% } else { %>bg-emerald-900 text-emerald-300<% } %>"><%= job.health %></span>
          </td>
          <td class="px-4 py-3 text-slate-300"><%= job.pm_name || '-' %></td>
          <td class="px-4 py-3 text-slate-400 text-xs"><%= job.last_update_date || 'Never' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Overdue Tasks -->
<% if (overdueTasksList.length > 0) { %>
<div class="mb-8">
  <h2 class="text-lg font-semibold text-white mb-4">Overdue Tasks</h2>
  <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-700">
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Task</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Owner</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Due</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Priority</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-700">
        <% overdueTasksList.forEach(t => { %>
        <tr class="hover:bg-slate-700/50">
          <td class="px-4 py-3 text-red-300"><%= t.title %></td>
          <td class="px-4 py-3"><a href="/jobs/<%= t.job_id %>" class="text-blue-400 hover:underline"><%= t.job_number %></a></td>
          <td class="px-4 py-3 text-slate-300"><%= t.owner_name %></td>
          <td class="px-4 py-3 text-red-400 text-xs"><%= t.due_date %></td>
          <td class="px-4 py-3"><span class="text-xs font-medium <%= t.priority === 'high' ? 'text-red-400' : t.priority === 'medium' ? 'text-amber-400' : 'text-slate-400' %>"><%= t.priority %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Recent Updates -->
<% if (recentUpdates.length > 0) { %>
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-white">Latest Project Updates</h2>
    <a href="/updates" class="text-sm text-blue-400 hover:text-blue-300">View all</a>
  </div>
  <div class="space-y-3">
    <% recentUpdates.forEach(u => { %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <a href="/jobs/<%= u.job_id %>" class="text-blue-400 font-medium text-sm hover:underline"><%= u.job_number %> &mdash; <%= u.client %></a>
        <span class="text-xs text-slate-500">Week ending <%= u.week_ending %></span>
      </div>
      <p class="text-slate-300 text-sm"><%= u.summary.length > 200 ? u.summary.substring(0, 200) + '...' : u.summary %></p>
      <p class="text-xs text-slate-500 mt-2">Submitted by <%= u.submitted_by_name %></p>
    </div>
    <% }) %>
  </div>
</div>
<% } %>
