<% locals.currentPage = 'dashboard' %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <p class="text-gray-500 text-sm mt-1">Overview of T&S operations</p>
</div>

<!-- Today's Operations -->
<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Today's Operations</h2>
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
  <div class="bg-white border border-gray-200 border-l-4 border-l-brand-500 rounded-xl p-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Jobs Active</p>
    <p class="text-3xl font-bold text-gray-900 mt-1"><%= kpi.activeJobs %></p>
  </div>
  <div class="bg-white border border-gray-200 border-l-4 border-l-brand-500 rounded-xl p-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Crew Deployed Today</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= kpi.crewDeployedToday %></p>
  </div>
  <div class="bg-white border border-gray-200 border-l-4 border-l-brand-500 rounded-xl p-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Equipment Out</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= kpi.equipmentDeployed %></p>
  </div>
  <a href="/allocations" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 hover:bg-gray-50 transition-colors <%= kpi.unconfirmedAllocations > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Unconfirmed Allocs</p>
    <p class="text-3xl font-bold <%= kpi.unconfirmedAllocations > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.unconfirmedAllocations %></p>
  </a>
  <div class="bg-white border border-gray-200 border-l-4 border-l-brand-500 rounded-xl p-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Crew Hours (7d)</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= Math.round(kpi.crewHoursThisWeek) %></p>
  </div>
</div>

<!-- Approvals & Compliance -->
<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Approvals & Compliance</h2>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.rolPending > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">ROL Pending</p>
    <p class="text-3xl font-bold <%= kpi.rolPending > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.rolPending %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.tmpPending > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">TMP Pending</p>
    <p class="text-3xl font-bold <%= kpi.tmpPending > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.tmpPending %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.ticketsExpiring > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Tickets Expiring</p>
    <p class="text-3xl font-bold <%= kpi.ticketsExpiring > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.ticketsExpiring %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.overdueCompliance > 0 ? 'border-red-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Overdue Compliance</p>
    <p class="text-3xl font-bold <%= kpi.overdueCompliance > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= kpi.overdueCompliance %></p>
  </div>
</div>

<!-- Jobs & Delivery -->
<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Jobs & Delivery</h2>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Starting Next 14d</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= kpi.startingSoon %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.overdueTasks > 0 ? 'border-red-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Overdue Tasks</p>
    <p class="text-3xl font-bold <%= kpi.overdueTasks > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= kpi.overdueTasks %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.missingUpdates > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Missing Updates</p>
    <p class="text-3xl font-bold <%= kpi.missingUpdates > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.missingUpdates %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.openDefects > 0 ? 'border-orange-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Open Defects</p>
    <p class="text-3xl font-bold <%= kpi.openDefects > 0 ? 'text-orange-600' : 'text-emerald-600' %> mt-1"><%= kpi.openDefects %></p>
  </div>
</div>

<!-- Safety -->
<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Safety</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.openIncidents > 0 ? 'border-red-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Open Incidents</p>
    <p class="text-3xl font-bold <%= kpi.openIncidents > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= kpi.openIncidents %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.overdueCorrectiveActions > 0 ? 'border-red-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Overdue Actions</p>
    <p class="text-3xl font-bold <%= kpi.overdueCorrectiveActions > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= kpi.overdueCorrectiveActions %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 <%= kpi.notifiableIncidents > 0 ? 'border-red-300' : '' %>">
    <p class="text-xs text-gray-500 uppercase tracking-wide">Notifiable Incidents</p>
    <p class="text-3xl font-bold <%= kpi.notifiableIncidents > 0 ? 'text-red-600' : 'text-emerald-600' %> mt-1"><%= kpi.notifiableIncidents %></p>
  </div>
</div>

<% if (canViewAccounts) { %>
<!-- Financial -->
<h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Financial</h2>
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
  <div class="bg-white border border-brand-200 rounded-xl p-4">
    <p class="text-xs text-brand-600 uppercase tracking-wide">Total Contract Value</p>
    <p class="text-2xl font-bold text-gray-900 mt-1">$<%= kpi.totalContractValue.toLocaleString() %></p>
  </div>
  <div class="bg-white border border-brand-200 rounded-xl p-4">
    <p class="text-xs text-brand-600 uppercase tracking-wide">Total Spend</p>
    <p class="text-2xl font-bold text-brand-600 mt-1">$<%= kpi.totalSpend.toLocaleString() %></p>
  </div>
  <div class="bg-white border border-brand-200 rounded-xl p-4">
    <p class="text-xs text-brand-600 uppercase tracking-wide">Revenue (Active Jobs)</p>
    <p class="text-2xl font-bold text-emerald-600 mt-1">$<%= kpi.revenueThisMonth.toLocaleString() %></p>
  </div>
  <div class="bg-white border border-brand-200 rounded-xl p-4">
    <p class="text-xs text-brand-600 uppercase tracking-wide">Invoices Overdue</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= kpi.accountsOverdue %></p>
  </div>
  <div class="bg-white border border-brand-200 rounded-xl p-4">
    <p class="text-xs text-brand-600 uppercase tracking-wide">Invoices Disputed</p>
    <p class="text-3xl font-bold text-brand-600 mt-1"><%= kpi.accountsDisputed %></p>
  </div>
</div>
<% } %>

<!-- My Jobs -->
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">My Jobs</h2>
    <a href="/projects/new" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg">+ New Job</a>
  </div>
  <% if (myJobs.length === 0) { %>
    <p class="text-gray-400 text-sm bg-white rounded-xl border border-gray-200 p-4">No jobs assigned to you.</p>
  <% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Health</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">% Done</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Update</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% myJobs.forEach(job => { %>
        <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/projects/<%= job.id %>'">
          <td class="px-4 py-3 font-medium text-brand-600"><%= job.job_number %></td>
          <td class="px-4 py-3 text-gray-600"><%= job.client %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
              <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
              <% } else if (job.status === 'won') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
              <% } else { %>bg-white text-gray-600<% } %>"><%= job.status.replace('_', ' ') %></span>
          </td>
          <td class="px-4 py-3"><span class="inline-block w-3 h-3 rounded-full <% if (job.health === 'green') { %>bg-emerald-500<% } else if (job.health === 'amber') { %>bg-orange-500<% } else { %>bg-red-500<% } %>"></span></td>
          <td class="px-4 py-3 text-gray-600"><%= job.percent_complete %>%</td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= job.last_update_date || 'Never' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Jobs Needing Attention -->
<% if (needsAttention.length > 0) { %>
<div class="mb-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Jobs Needing Attention</h2>
  <div class="bg-white border border-red-200 rounded-xl overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Client</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Health</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">PM</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Update</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% needsAttention.forEach(job => { %>
        <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/projects/<%= job.id %>'">
          <td class="px-4 py-3 font-medium text-brand-600"><%= job.job_number %></td>
          <td class="px-4 py-3 text-gray-600"><%= job.client %></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
              <% if (job.health === 'red') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
              <% } else if (job.health === 'amber') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
              <% } else { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20<% } %>"><%= job.health %></span>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= job.pm_name || '-' %></td>
          <td class="px-4 py-3 text-gray-500 text-xs"><%= job.last_update_date || 'Never' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Overdue Tasks -->
<% if (overdueTasksList.length > 0) { %>
<div class="mb-8">
  <h2 class="text-lg font-semibold text-gray-900 mb-4">Overdue Tasks</h2>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200">
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Task</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Job</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Owner</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Due</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Priority</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% overdueTasksList.forEach(t => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-red-600"><%= t.title %></td>
          <td class="px-4 py-3"><a href="/projects/<%= t.job_id %>" class="text-brand-600 hover:underline"><%= t.job_number %></a></td>
          <td class="px-4 py-3 text-gray-600"><%= t.owner_name %></td>
          <td class="px-4 py-3 text-red-600 text-xs"><%= t.due_date %></td>
          <td class="px-4 py-3"><span class="text-xs font-medium <%= t.priority === 'high' ? 'text-red-600' : t.priority === 'medium' ? 'text-orange-600' : 'text-gray-500' %>"><%= t.priority %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Recent Updates -->
<% if (recentUpdates.length > 0) { %>
<div class="mb-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Latest Project Updates</h2>
    <a href="/updates" class="text-sm text-brand-600 hover:text-brand-700">View all</a>
  </div>
  <div class="space-y-3">
    <% recentUpdates.forEach(u => { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <div class="flex items-center justify-between mb-2">
        <a href="/projects/<%= u.job_id %>" class="text-brand-600 font-medium text-sm hover:underline"><%= u.job_number %> &mdash; <%= u.client %></a>
        <span class="text-xs text-gray-400">Week ending <%= u.week_ending %></span>
      </div>
      <p class="text-gray-600 text-sm"><%= u.summary.length > 200 ? u.summary.substring(0, 200) + '...' : u.summary %></p>
      <p class="text-xs text-gray-400 mt-2">Submitted by <%= u.submitted_by_name %></p>
    </div>
    <% }) %>
  </div>
</div>
<% } %>
