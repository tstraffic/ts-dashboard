<% locals.currentPage = 'jobs' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-white">Jobs Register</h1>
    <p class="text-slate-400 text-sm mt-1">Manage and track all project jobs</p>
  </div>
  <a href="/jobs/new" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-medium rounded-lg transition-colors">+ New Job</a>
</div>

<!-- Filter Bar -->
<div class="bg-slate-800 border border-slate-700 rounded-xl p-4 mb-6">
  <form method="GET" action="/jobs" class="flex flex-wrap items-end gap-4">
    <!-- Search -->
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Job number, client, address..."
        class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent">
    </div>
    <!-- Status -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent">
        <option value="">All Statuses</option>
        <option value="lead" <%= filters.status === 'lead' ? 'selected' : '' %>>Lead</option>
        <option value="won" <%= filters.status === 'won' ? 'selected' : '' %>>Won</option>
        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="on_hold" <%= filters.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="lost" <%= filters.status === 'lost' ? 'selected' : '' %>>Lost</option>
      </select>
    </div>
    <!-- Suburb -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Suburb</label>
      <select name="suburb" class="w-full px-3 py-2 bg-slate-700 border border-slate-600 rounded-lg text-white text-sm focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent">
        <option value="">All Suburbs</option>
        <% suburbs.forEach(s => { %>
          <option value="<%= s %>" <%= filters.suburb === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/jobs" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Jobs Table -->
<% if (jobs.length === 0) { %>
  <div class="bg-slate-800 border border-slate-700 rounded-xl p-8 text-center">
    <p class="text-slate-500 text-sm">No jobs found matching your filters.</p>
  </div>
<% } else { %>
<div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-slate-700">
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Job Number</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Client</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Suburb</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Stage</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Health</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">% Complete</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Start Date</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">PM</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-700">
      <% jobs.forEach(job => { %>
      <tr class="hover:bg-slate-700/50">
        <td class="px-4 py-3 font-medium">
          <a href="/jobs/<%= job.id %>" class="text-blue-400 hover:text-blue-300 hover:underline"><%= job.job_number %></a>
        </td>
        <td class="px-4 py-3 text-slate-300"><%= job.client %></td>
        <td class="px-4 py-3 text-slate-300"><%= job.suburb || '-' %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (job.status === 'active') { %>bg-blue-900/60 text-blue-300
            <% } else if (job.status === 'on_hold') { %>bg-amber-900/60 text-amber-300
            <% } else if (job.status === 'completed') { %>bg-emerald-900/60 text-emerald-300
            <% } else if (job.status === 'won') { %>bg-teal-900/60 text-teal-300
            <% } else if (job.status === 'lead') { %>bg-purple-900/60 text-purple-300
            <% } else if (job.status === 'lost') { %>bg-red-900/60 text-red-300
            <% } else { %>bg-slate-700 text-slate-300<% } %>">
            <%= job.status ? job.status.replace('_', ' ') : '-' %>
          </span>
        </td>
        <td class="px-4 py-3 text-slate-300"><%= job.stage || '-' %></td>
        <td class="px-4 py-3">
          <% if (job.health) { %>
            <span class="inline-block w-3 h-3 rounded-full
              <% if (job.health === 'green') { %>bg-emerald-500
              <% } else if (job.health === 'amber') { %>bg-amber-500
              <% } else if (job.health === 'red') { %>bg-red-500
              <% } else { %>bg-slate-600<% } %>" title="<%= job.health %>"></span>
          <% } else { %>
            <span class="text-slate-600">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3">
          <div class="flex items-center gap-2">
            <div class="w-16 bg-slate-700 rounded-full h-2">
              <div class="h-2 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-blue-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
            </div>
            <span class="text-xs text-slate-400"><%= job.percent_complete || 0 %>%</span>
          </div>
        </td>
        <td class="px-4 py-3 text-slate-400 text-xs"><%= job.start_date || '-' %></td>
        <td class="px-4 py-3 text-slate-300"><%= job.pm_name || '-' %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-slate-500"><%= jobs.length %> job<%= jobs.length !== 1 ? 's' : '' %> found</div>
<% } %>
