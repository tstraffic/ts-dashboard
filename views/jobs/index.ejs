<% locals.currentPage = 'jobs' %>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Jobs Register</h1>
    <p class="text-gray-500 text-sm mt-0.5">Manage and track all project jobs</p>
  </div>
  <a href="/jobs/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Job</a>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Active</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.active %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">On Hold</p>
    <p class="text-xl font-bold <%= stats.onHold > 0 ? 'text-amber-600' : 'text-gray-900' %> mt-0.5"><%= stats.onHold %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Pipeline</p>
    <p class="text-xl font-bold text-brand-600 mt-0.5"><%= stats.tender %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Overdue</p>
    <p class="text-xl font-bold <%= stats.overdue > 0 ? 'text-red-600' : 'text-gray-900' %> mt-0.5"><%= stats.overdue %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 hidden sm:block">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Health Red</p>
    <p class="text-xl font-bold <%= stats.healthRed > 0 ? 'text-red-600' : 'text-gray-900' %> mt-0.5"><%= stats.healthRed %></p>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/jobs" data-module="jobs" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1 min-w-0 sm:min-w-[200px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Job number, client, address..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Statuses</option>
          <% settingsOptions.job_status.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Suburb</label>
        <select name="suburb" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Suburbs</option>
          <% suburbs.forEach(s => { %>
            <option value="<%= s %>" <%= filters.suburb === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <a href="/jobs" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/jobs.csv?status=<%= filters.status || '' %>&search=<%= encodeURIComponent(filters.search || '') %>&suburb=<%= encodeURIComponent(filters.suburb || '') %>"
        class="px-3 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="hidden sm:inline">CSV</span>
      </a>
    </div>
  </form>
</div>

<!-- Jobs Table -->
<% if (jobs.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
    <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No jobs found</h3>
    <p class="text-gray-500 text-sm mb-1">Jobs are the core of your operations — each one tracks a traffic management engagement.</p>
    <p class="text-gray-400 text-xs mb-4">Try adjusting your search or filters, or create a new job to get started.</p>
    <a href="/jobs/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      New Job
    </a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto" data-bulk-module="jobs">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-2 py-2.5 w-8"><input type="checkbox" data-bulk-all class="rounded border-gray-300 text-brand-600 focus:ring-brand-500"></th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Job</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Client</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Suburb</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Health</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Progress</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">PM</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Dates</th>
        <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Budget</th>
        <% } %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% jobs.forEach(job => {
        const today = new Date().toISOString().split('T')[0];
        const isOverdue = job.end_date && job.end_date < today && !['completed','closed'].includes(job.status);
        const isOnHold = job.status === 'on_hold';
      %>
      <tr class="hover:bg-gray-50 <%= job.priority === 'high' ? 'border-l-4 border-l-red-500 bg-red-50/30' : isOverdue ? 'border-l-4 border-l-red-400' : isOnHold ? 'border-l-4 border-l-amber-400' : '' %>">
        <td class="px-2 py-2.5 w-8" onclick="event.stopPropagation()"><input type="checkbox" data-bulk-id="<%= job.id %>" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500"></td>
        <td class="px-3 py-2.5">
          <div class="flex items-center gap-1">
            <a href="/jobs/<%= job.id %>" class="text-brand-600 hover:text-brand-700 font-semibold text-sm hover:underline"><%= job.job_number %></a>
            <% if (job.priority === 'high') { %>
              <span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" title="High Priority"></span>
            <% } %>
          </div>
          <p class="text-gray-400 text-xs truncate max-w-[180px] sm:hidden"><%= job.client %></p>
          <% if (job.overdue_tasks > 0 || job.overdue_compliance > 0) { %>
            <div class="flex flex-wrap gap-1 mt-0.5">
              <% if (job.overdue_tasks > 0) { %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20"><%= job.overdue_tasks %> task<%= job.overdue_tasks !== 1 ? 's' : '' %></span>
              <% } %>
              <% if (job.overdue_compliance > 0) { %>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20"><%= job.overdue_compliance %> plan<%= job.overdue_compliance !== 1 ? 's' : '' %></span>
              <% } %>
            </div>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-gray-600 text-xs hidden sm:table-cell max-w-[160px] truncate"><%= job.client %></td>
        <td class="px-3 py-2.5 text-gray-500 text-xs hidden lg:table-cell"><%= job.suburb || '-' %></td>
        <td class="px-3 py-2.5">
          <form method="POST" action="/jobs/<%= job.id %>/status" class="inline no-spinner">
            <%- include('../partials/csrf') %>
            <select name="status" onchange="this.form.submit()" class="text-xs font-medium px-2 py-1 rounded-full border-0 cursor-pointer appearance-none
              <% if (job.status === 'active') { %>bg-blue-50 text-blue-700
              <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700
              <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700
              <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700
              <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700
              <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700
              <% } else if (job.status === 'closed') { %>bg-gray-100 text-gray-500
              <% } else { %>bg-gray-50 text-gray-600<% } %> focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="tender" <%= job.status === 'tender' ? 'selected' : '' %>>Tender</option>
              <option value="won" <%= job.status === 'won' ? 'selected' : '' %>>Won</option>
              <option value="prestart" <%= job.status === 'prestart' ? 'selected' : '' %>>Prestart</option>
              <option value="active" <%= job.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="on_hold" <%= job.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
              <option value="completed" <%= job.status === 'completed' ? 'selected' : '' %>>Completed</option>
              <option value="closed" <%= job.status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </form>
        </td>
        <td class="px-3 py-2.5 text-center hidden md:table-cell">
          <% if (job.health) { %>
            <span class="inline-block w-3 h-3 rounded-full
              <% if (job.health === 'green') { %>bg-emerald-500
              <% } else if (job.health === 'amber') { %>bg-amber-500
              <% } else if (job.health === 'red') { %>bg-red-500
              <% } else { %>bg-gray-200<% } %>" title="Health: <%= job.health %>"></span>
          <% } else { %>
            <span class="text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 hidden md:table-cell">
          <div class="flex items-center gap-2">
            <div class="w-14 bg-gray-200 rounded-full h-1.5">
              <div class="h-1.5 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-brand-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
            </div>
            <span class="text-[11px] text-gray-500 tabular-nums"><%= job.percent_complete || 0 %>%</span>
          </div>
        </td>
        <td class="px-3 py-2.5 text-gray-600 text-xs hidden lg:table-cell truncate max-w-[100px]"><%= job.pm_name || '-' %></td>
        <td class="px-3 py-2.5 hidden xl:table-cell">
          <% if (job.start_date) { %>
            <span class="text-[11px] text-gray-500 tabular-nums"><%= job.start_date %></span>
            <% if (job.end_date) { %>
              <span class="text-gray-300 text-[10px] mx-0.5">-</span>
              <span class="text-[11px] tabular-nums <%= isOverdue ? 'text-red-600 font-semibold' : 'text-gray-500' %>"><%= job.end_date %></span>
            <% } %>
          <% } else { %>
            <span class="text-gray-300 text-xs">-</span>
          <% } %>
        </td>
        <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
        <td class="px-3 py-2.5 text-center hidden lg:table-cell">
          <% if (!job.budget_contract) { %>
            <span class="text-gray-300">-</span>
          <% } else {
            const budgetMargin = (job.budget_contract - (job.budget_spent || 0)) / job.budget_contract * 100;
          %>
            <span class="inline-block w-3 h-3 rounded-full <% if (budgetMargin > 20) { %>bg-emerald-500<% } else if (budgetMargin >= 0) { %>bg-orange-500<% } else { %>bg-red-500<% } %>" title="Margin: <%= budgetMargin.toFixed(1) %>%"></span>
          <% } %>
        </td>
        <% } %>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-2 text-xs text-gray-400"><%= jobs.length %> job<%= jobs.length !== 1 ? 's' : '' %> found</div>
<% } %>
