<% locals.currentPage = 'jobs' %>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Jobs Register</h1>
    <p class="text-gray-500 text-sm mt-1">Manage and track all project jobs</p>
  </div>
  <a href="/jobs/new" class="inline-flex items-center justify-center px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Job</a>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" action="/jobs" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-3 sm:gap-4">
    <!-- Search -->
    <div class="flex-1 min-w-0 sm:min-w-[200px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Job number, client, address..."
        class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <!-- Status & Suburb row -->
    <div class="flex gap-3 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[140px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Status</label>
        <select name="status" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Statuses</option>
          <% settingsOptions.job_status.forEach(opt => { %>
            <option value="<%= opt.key %>" <%= filters.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[140px]">
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Suburb</label>
        <select name="suburb" class="w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Suburbs</option>
          <% suburbs.forEach(s => { %>
            <option value="<%= s %>" <%= filters.suburb === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/jobs" class="px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      <a href="/exports/jobs.csv?status=<%= filters.status || '' %>&search=<%= encodeURIComponent(filters.search || '') %>&suburb=<%= encodeURIComponent(filters.suburb || '') %>"
        class="px-3 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span class="hidden sm:inline">Export CSV</span>
      </a>
    </div>
  </form>
</div>

<!-- Jobs Table -->
<% if (jobs.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <p class="text-gray-400 text-sm">No jobs found matching your filters.</p>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job Number</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Client</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden sm:table-cell">Suburb</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">Stage</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Health</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">% Complete</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">Start Date</th>
        <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">PM</th>
        <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Budget</th>
        <% } %>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% jobs.forEach(job => { %>
      <tr class="hover:bg-gray-50">
        <td class="px-3 sm:px-4 py-3 font-medium">
          <a href="/jobs/<%= job.id %>" class="text-brand-600 hover:text-brand-700 hover:underline"><%= job.job_number %></a>
        </td>
        <td class="px-3 sm:px-4 py-3 text-gray-600"><%= job.client %></td>
        <td class="px-3 sm:px-4 py-3 text-gray-600 hidden sm:table-cell"><%= job.suburb || '-' %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
            <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
            <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
            <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
            <% } else if (job.status === 'closed') { %>bg-gray-100/60 text-gray-600
            <% } else { %>bg-white text-gray-600<% } %>">
            <%= job.status ? job.status.replace('_', ' ') : '-' %>
          </span>
        </td>
        <td class="px-3 sm:px-4 py-3 text-gray-600 hidden lg:table-cell"><%= job.stage || '-' %></td>
        <td class="px-3 sm:px-4 py-3 hidden md:table-cell">
          <% if (job.health) { %>
            <span class="inline-block w-3 h-3 rounded-full
              <% if (job.health === 'green') { %>bg-emerald-500
              <% } else if (job.health === 'amber') { %>bg-brand-600
              <% } else if (job.health === 'red') { %>bg-red-500
              <% } else { %>bg-gray-100<% } %>" title="<%= job.health %>"></span>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-3 sm:px-4 py-3 hidden md:table-cell">
          <div class="flex items-center gap-2">
            <div class="w-16 bg-gray-200 rounded-full h-2">
              <div class="h-2 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-blue-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
            </div>
            <span class="text-xs text-gray-500"><%= job.percent_complete || 0 %>%</span>
          </div>
        </td>
        <td class="px-3 sm:px-4 py-3 text-gray-500 text-xs hidden lg:table-cell"><%= job.start_date || '-' %></td>
        <td class="px-3 sm:px-4 py-3 text-gray-600 hidden lg:table-cell"><%= job.pm_name || '-' %></td>
        <% if (typeof canViewAccounts !== 'undefined' && canViewAccounts) { %>
        <td class="px-4 py-3 text-center">
          <% if (!job.budget_contract) { %>
            <span class="text-gray-400">—</span>
          <% } else {
            const budgetMargin = (job.budget_contract - (job.budget_spent || 0)) / job.budget_contract * 100;
          %>
            <span class="inline-block w-3 h-3 rounded-full <% if (budgetMargin > 20) { %>bg-emerald-500<% } else if (budgetMargin >= 0) { %>bg-orange-500<% } else { %>bg-red-500<% } %>" title="Margin: <%= budgetMargin.toFixed(1) %>%"></span>
          <% } %>
        </td>
        <% } %>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-gray-400"><%= jobs.length %> job<%= jobs.length !== 1 ? 's' : '' %> found</div>
<% } %>
