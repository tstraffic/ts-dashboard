<% locals.currentPage = 'jobs' %>

<style>
  /* CSS-only tab navigation */
  .tab-content { display: none; }
  .tab-content:target { display: block; }
  .tab-content:first-of-type:not(:target) { display: block; }
  .tab-content:first-of-type:not(:target) ~ .tab-content:target ~ .tab-content:first-of-type { display: none; }
  /* When any tab is targeted, hide the default first tab */
  .tab-group:has(.tab-content:target) > .tab-content:first-of-type:not(:target) { display: none; }
</style>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-3 flex-wrap">
    <h1 class="text-2xl font-bold text-gray-900"><%= job.job_number %></h1>
    <span class="text-lg text-gray-500">&mdash;</span>
    <span class="text-lg text-gray-600"><%= job.client %></span>
    <!-- Status Badge -->
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
      <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
      <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
      <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
      <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
      <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
      <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
      <% } else if (job.status === 'closed') { %>bg-gray-100/60 text-gray-600
      <% } else { %>bg-white text-gray-600<% } %>">
      <%= job.status ? job.status.replace('_', ' ') : '-' %>
    </span>
    <!-- Health Dot -->
    <% if (job.health) { %>
      <span class="inline-block w-3 h-3 rounded-full
        <% if (job.health === 'green') { %>bg-emerald-500
        <% } else if (job.health === 'amber') { %>bg-brand-600
        <% } else if (job.health === 'red') { %>bg-red-500
        <% } else { %>bg-gray-100<% } %>" title="Health: <%= job.health %>"></span>
    <% } %>
  </div>
  <div class="flex items-center gap-2">
    <a href="/jobs/<%= job.id %>/edit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Edit</a>
    <a href="/documents/job/<%= job.id %>" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Documents</a>
  </div>
</div>

<!-- Info Grid -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4">
    <% /* Always show these core fields */ %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Client</p>
      <p class="text-sm text-gray-900 mt-1"><%= job.client %></p>
    </div>
    <% if (job.project_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Project Name</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.project_name %></p>
    </div>
    <% } %>
    <% if (job.client_project_number) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Client Project Number</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.client_project_number %></p>
    </div>
    <% } %>
    <% if (job.principal_contractor) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Principal Contractor</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.principal_contractor %></p>
    </div>
    <% } %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">State</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.state || 'NSW' %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Site Address</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.site_address || 'TBC' %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Suburb</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.suburb || 'TBC' %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Stage</p>
      <p class="text-sm text-gray-600 mt-1 capitalize"><%= job.stage ? job.stage.replace(/_/g, ' ') : 'Not set' %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">% Complete</p>
      <div class="flex items-center gap-2 mt-1">
        <div class="flex-1 max-w-[120px] bg-gray-200 rounded-full h-2">
          <div class="h-2 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-blue-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
        </div>
        <span class="text-sm text-gray-900"><%= job.percent_complete || 0 %>%</span>
      </div>
    </div>
    <% if (job.contract_value) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Contract Value</p>
      <p class="text-sm text-gray-900 mt-1">$<%= Number(job.contract_value).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
    </div>
    <% } %>
    <% if (job.estimated_hours) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Estimated Hours</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.estimated_hours %></p>
    </div>
    <% } %>
    <% if (job.crew_size) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Crew Size</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.crew_size %></p>
    </div>
    <% } %>
    <% if (job.vehicles) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Vehicles</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.vehicles %></p>
    </div>
    <% } %>
    <div class="col-span-2 lg:col-span-4">
      <p class="text-xs text-gray-400 uppercase tracking-wide mb-1.5">Approvals Required</p>
      <div class="flex flex-wrap gap-2">
        <% const approvals = [
          { key: 'rol_required', label: 'ROL' },
          { key: 'tmp_required', label: 'TMP' },
          { key: 'tgs_required', label: 'TGS' },
          { key: 'spa_required', label: 'SPA' },
          { key: 'council_approval', label: 'Council' },
          { key: 'bus_approval', label: 'Bus' },
        ]; %>
        <% approvals.forEach(function(a) { %>
          <% if (job[a.key]) { %>
            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20"><%= a.label %></span>
          <% } %>
        <% }) %>
        <% if (!approvals.some(function(a) { return job[a.key]; })) { %>
          <span class="text-sm text-gray-400">None</span>
        <% } %>
      </div>
    </div>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Start Date</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.start_date ? formatDate(job.start_date) : 'TBC' %></p>
    </div>
    <% if (job.end_date) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">End Date</p>
      <p class="text-sm text-gray-600 mt-1"><%= formatDate(job.end_date) %></p>
    </div>
    <% } %>
    <% if (job.pm_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Project Manager</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.pm_name %></p>
    </div>
    <% } %>
    <% if (job.ops_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Ops Supervisor</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.ops_name %></p>
    </div>
    <% } %>
    <% if (job.traffic_supervisor_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Traffic Supervisor</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.traffic_supervisor_name %></p>
    </div>
    <% } %>
    <% if (job.planning_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Planning Owner</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.planning_name %></p>
    </div>
    <% } %>
    <% if (job.marketing_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Marketing Owner</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.marketing_name %></p>
    </div>
    <% } %>
    <% if (canViewAccounts && job.accounts_name) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">Accounts Owner</p>
      <p class="text-sm text-gray-600 mt-1"><%= job.accounts_name %></p>
    </div>
    <% } %>
    <% if (job.sharepoint_url) { %>
    <div>
      <p class="text-xs text-gray-400 uppercase tracking-wide">SharePoint</p>
      <a href="<%= job.sharepoint_url %>" target="_blank" class="inline-flex items-center gap-1 mt-1 px-3 py-1 bg-blue-50 text-blue-700 text-sm font-medium rounded-lg hover:bg-blue-100 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        Open SharePoint
      </a>
    </div>
    <% } %>
  </div>
</div>

<!-- View Mode Toggle (Admin/Manager only) -->
<% const isAdmin = canAccess(user, 'admin'); %>
<% if (isAdmin) { %>
<div class="flex items-center gap-2 mb-4">
  <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">View as:</span>
  <a href="?view=planning" class="px-3 py-1 text-xs font-medium rounded-full transition-colors
    <%= (typeof viewMode !== 'undefined' && viewMode === 'planning') || (!viewMode && canAccess(user, 'planning_plans')) ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">Planning</a>
  <a href="?view=operations" class="px-3 py-1 text-xs font-medium rounded-full transition-colors
    <%= (typeof viewMode !== 'undefined' && viewMode === 'operations') ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">Operations</a>
  <a href="?view=all" class="px-3 py-1 text-xs font-medium rounded-full transition-colors
    <%= (typeof viewMode !== 'undefined' && viewMode === 'all') ? 'bg-brand-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">All</a>
</div>
<% } %>

<%
  // Determine effective view mode
  const effectiveView = (typeof viewMode !== 'undefined' && viewMode) ? viewMode
    : (isAdmin ? 'all' : (canAccess(user, 'planning_plans') ? 'planning' : 'operations'));
  const showPlanning = effectiveView === 'planning' || effectiveView === 'all';
  const showOps = effectiveView === 'operations' || effectiveView === 'all';
%>

<!-- Tab Navigation -->
<div class="border-b border-gray-200 mb-6">
  <nav class="flex gap-0 -mb-px overflow-x-auto">
    <a href="#overview" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Overview</a>

    <% /* ── PLANNING TABS ── */ %>
    <% if (showPlanning) { %>
    <a href="#diary" data-tab="diary" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Site Diary</a>
    <a href="#plans" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Traffic Plans</a>
    <a href="#chat" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Chat</a>
    <% } %>

    <% /* ── OPERATIONS TABS ── */ %>
    <% if (showOps) { %>
    <a href="#final-plans" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Final Plans</a>
    <a href="#tasks" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Tasks</a>
    <a href="#timesheets" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Timesheets</a>
    <a href="#incidents" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Incidents</a>
    <a href="#compliance" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Compliance</a>
    <a href="#contacts" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Contacts</a>
    <a href="#equipment" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Equipment</a>
    <a href="#defects" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Defects</a>
    <% if (canViewAccounts) { %>
    <a href="#budget" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Budget</a>
    <a href="#accounts" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-gray-500 hover:text-gray-900 border-transparent hover:border-gray-300
      focus:text-brand-700 focus:border-brand-500" onclick="activateTab(this)">Accounts</a>
    <% } %>
    <% } %>
  </nav>
</div>

<!-- Tab Content -->
<div class="tab-group">

  <!-- Overview Tab -->
  <div id="overview" class="tab-content">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Job Summary</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2">Details</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-gray-400">Job Number</dt>
              <dd class="text-sm text-gray-900"><%= job.job_number %></dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Client</dt>
              <dd class="text-sm text-gray-900"><%= job.client %></dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Site Address</dt>
              <dd class="text-sm text-gray-600"><%= job.site_address || 'Not specified' %></dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Suburb</dt>
              <dd class="text-sm text-gray-600"><%= job.suburb || 'Not specified' %></dd>
            </div>
          </dl>
        </div>
        <div>
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2">Progress</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-gray-400">Status</dt>
              <dd class="text-sm">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <% if (job.status === 'active') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                  <% } else if (job.status === 'on_hold') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                  <% } else if (job.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                  <% } else if (job.status === 'won') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
                  <% } else if (job.status === 'tender') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
                  <% } else if (job.status === 'prestart') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
                  <% } else if (job.status === 'closed') { %>bg-gray-100/60 text-gray-600
                  <% } else { %>bg-white text-gray-600<% } %>">
                  <%= job.status ? job.status.replace('_', ' ') : '-' %>
                </span>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Stage</dt>
              <dd class="text-sm text-gray-600"><%= job.stage ? job.stage.replace(/_/g, ' ') : '-' %></dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Health</dt>
              <dd class="text-sm flex items-center gap-2">
                <span class="inline-block w-3 h-3 rounded-full
                  <% if (job.health === 'green') { %>bg-emerald-500
                  <% } else if (job.health === 'amber') { %>bg-brand-600
                  <% } else if (job.health === 'red') { %>bg-red-500
                  <% } else { %>bg-gray-100<% } %>"></span>
                <span class="text-gray-600 capitalize"><%= job.health || '-' %></span>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-gray-400">Duration</dt>
              <dd class="text-sm text-gray-600"><%= job.start_date ? formatDate(job.start_date) : '?' %> &rarr; <%= job.end_date ? formatDate(job.end_date) : '?' %></dd>
            </div>
          </dl>
        </div>
      </div>
      <% if (job.notes) { %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2">Notes</h3>
        <p class="text-sm text-gray-600 whitespace-pre-wrap"><%= job.notes %></p>
      </div>
      <% } %>

      <!-- Recent Site Diary -->
      <% const recentDiary = (typeof diaryEntries !== 'undefined' ? diaryEntries : []).slice(0, 5); %>
      <% if (recentDiary.length > 0) { %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Recent Site Diary
          </h3>
          <button type="button" onclick="document.querySelector('[data-tab=diary]').click()" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View all &rarr;</button>
        </div>
        <div class="space-y-2">
          <% recentDiary.forEach(function(d) { %>
          <div class="flex items-start gap-3 text-sm">
            <span class="text-xs text-gray-400 whitespace-nowrap mt-0.5 font-mono"><%= d.entry_date ? formatDate(d.entry_date) : '' %></span>
            <div class="min-w-0">
              <span class="font-medium text-gray-900"><%= d.task || 'Entry' %></span>
              <% if (d.representative_name || d.representative) { %><span class="text-gray-400"> — <%= d.representative_name || d.representative %></span><% } %>
              <% if (d.outcomes) { %>
                <p class="text-gray-500 text-xs mt-0.5 truncate"><%= d.outcomes %></p>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- SharePoint Documents Link -->
      <% if (canAccess(user, 'documents')) { %>
      <div class="mt-6 pt-6 border-t border-gray-200">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide flex items-center gap-2">
            <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            SharePoint Documents
          </h3>
        </div>
        <% if (job.sharepoint_url) { %>
          <a href="<%= job.sharepoint_url %>" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-teal-50 border border-teal-200 rounded-lg text-teal-700 text-sm hover:bg-teal-100 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Open in SharePoint
          </a>
          <p class="mt-1 text-xs text-gray-400 break-all"><%= job.sharepoint_url %></p>
        <% } else { %>
          <p class="text-sm text-gray-400">No SharePoint folder linked. Set the SharePoint URL when editing this job.</p>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Final Plans Tab (Operations view — read-only) -->
  <% if (showOps) { %>
  <div id="final-plans" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Final Plans</h2>
      <span class="text-xs text-gray-400 uppercase tracking-wide">Operations View — Read Only</span>
    </div>
    <% const fp = typeof finalPlans !== 'undefined' ? finalPlans : []; %>
    <% if (fp.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
        <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-gray-400 text-sm">No plans have been finalised for this job yet.</p>
        <p class="text-gray-300 text-xs mt-1">Plans appear here once the planning team marks them as final.</p>
      </div>
    <% } else { %>
    <div class="space-y-3">
      <% fp.forEach(function(plan) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-sm font-bold text-gray-900"><%= plan.plan_number %></span>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">FINAL</span>
              <span class="text-xs text-gray-400"><%= plan.current_revision_label || 'Rev A' %></span>
            </div>
            <div class="flex flex-wrap gap-4 text-xs text-gray-500 mb-2">
              <span>Type: <span class="text-gray-700 font-medium"><%= (plan.plan_types || plan.plan_type || '').replace(/,/g, ' / ') %></span></span>
              <% if (plan.designer) { %><span>Designer: <span class="text-gray-700"><%= plan.designer %></span></span><% } %>
              <% if (plan.marked_final_at) { %><span>Finalised: <span class="text-gray-700"><%= new Date(plan.marked_final_at).toLocaleDateString('en-AU') %></span></span><% } %>
            </div>
            <% if (plan.notes) { %><p class="text-xs text-gray-500 mt-1"><%= plan.notes %></p><% } %>
          </div>
          <div class="flex flex-col items-end gap-2 flex-shrink-0">
            <% if (plan.file_link || plan.file_path) { %>
              <a href="<%= plan.file_link || plan.file_path %>" target="_blank" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-xs font-medium rounded-lg transition-colors inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                Download
              </a>
            <% } %>
            <% if (canAccess(user, 'ops_flag')) { %>
              <button type="button" onclick="document.getElementById('flag-form-<%= plan.id %>').classList.toggle('hidden')"
                class="px-3 py-1.5 bg-amber-50 hover:bg-amber-100 text-amber-700 text-xs font-medium rounded-lg border border-amber-200 transition-colors inline-flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/></svg>
                Flag for Review
              </button>
            <% } %>
          </div>
        </div>
        <!-- Flag Form (hidden) -->
        <div id="flag-form-<%= plan.id %>" class="hidden mt-3 pt-3 border-t border-gray-200">
          <form method="POST" action="/plans/<%= plan.id %>/flag">
            <%- include('../partials/csrf') %>
            <input type="hidden" name="return_to" value="/jobs/<%= job.id %>?view=operations#final-plans">
            <label class="block text-xs font-medium text-gray-500 mb-1">Describe the issue</label>
            <textarea name="description" rows="2" required placeholder="e.g. TGS doesn't match site conditions - lane widths are wrong"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-amber-500"></textarea>
            <div class="mt-2 flex justify-end">
              <button type="submit" class="px-4 py-1.5 bg-amber-600 hover:bg-amber-500 text-white text-xs font-medium rounded-lg transition-colors">Submit Flag</button>
            </div>
          </form>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Tasks Tab -->
  <div id="tasks" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Tasks</h2>
      <a href="/tasks/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Task</a>
    </div>
    <% if (tasks.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
        <p class="text-gray-400 text-sm">No tasks for this job yet.</p>
        <a href="/tasks/new?job_id=<%= job.id %>" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Create the first task</a>
      </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Title</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Division</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Owner</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Due Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Priority</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% tasks.forEach(task => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-600 font-medium"><%= task.title %></td>
            <td class="px-4 py-3 text-gray-500"><%= task.division || '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= task.owner_name || '-' %></td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= task.due_date ? formatDate(task.due_date) : '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (task.status === 'completed') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                <% } else if (task.status === 'in_progress') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                <% } else if (task.status === 'overdue') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
                <% } else if (task.status === 'blocked') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else { %>bg-white text-gray-600<% } %>">
                <%= task.status ? task.status.replace('_', ' ') : 'pending' %>
              </span>
            </td>
            <td class="px-4 py-3">
              <span class="text-xs font-medium
                <% if (task.priority === 'high') { %>text-red-600
                <% } else if (task.priority === 'medium') { %>text-brand-600
                <% } else { %>text-gray-500<% } %>">
                <%= task.priority || 'low' %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Compliance Tab — Document Upload -->
  <div id="compliance" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Compliance Documents</h2>
      <button type="button" onclick="document.getElementById('compliance-upload-form').classList.toggle('hidden')" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Upload Document
      </button>
    </div>

    <!-- Upload Form (hidden by default) -->
    <div id="compliance-upload-form" class="hidden bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-4">
      <form method="POST" action="/jobs/<%= job.id %>/compliance-upload" enctype="multipart/form-data">
        <%- include('../partials/csrf') %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Document Type</label>
            <select name="category" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="tgs">TGS (Traffic Guidance Scheme)</option>
              <option value="tmp">TMP (Traffic Management Plan)</option>
              <option value="rol">ROL (Road Occupancy Licence)</option>
              <option value="spa">SPA (Swept Path Analysis)</option>
              <option value="sza">SZA (Speed Zone Authorisation)</option>
              <option value="council_permit">Council Permit</option>
              <option value="swms">SWMS</option>
              <option value="insurance">Insurance</option>
              <option value="induction">Induction</option>
              <option value="environmental">Environmental</option>
              <option value="police_notification">Police Notification</option>
              <option value="letter_drop">Letter Drop</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Files</label>
            <input type="file" name="files" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg,.gif,.csv,.txt,.zip,.dwg,.dxf" class="w-full text-sm text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Upload</button>
          <button type="button" onclick="document.getElementById('compliance-upload-form').classList.add('hidden')" class="px-4 py-2 bg-gray-100 text-gray-600 text-sm font-medium rounded-lg">Cancel</button>
        </div>
      </form>
    </div>

    <% const cdocs = typeof complianceDocs !== 'undefined' ? complianceDocs : []; %>
    <% if (cdocs.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
        <svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-gray-400 text-sm">No compliance documents uploaded yet.</p>
        <button type="button" onclick="document.getElementById('compliance-upload-form').classList.remove('hidden')" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Upload the first document</button>
      </div>
    <% } else { %>
      <%
        const typeLabels = { tgs: 'TGS', tmp: 'TMP', rol: 'ROL', spa: 'SPA', sza: 'SZA', council_permit: 'Council Permit', swms: 'SWMS', insurance: 'Insurance', induction: 'Induction', environmental: 'Environmental', police_notification: 'Police', letter_drop: 'Letter Drop', other: 'Other', general: 'General' };
        const typeColors = { tgs: 'bg-blue-50 text-blue-700 ring-blue-600/20', tmp: 'bg-indigo-50 text-indigo-700 ring-indigo-600/20', rol: 'bg-purple-50 text-purple-700 ring-purple-600/20', spa: 'bg-cyan-50 text-cyan-700 ring-cyan-600/20', sza: 'bg-violet-50 text-violet-700 ring-violet-600/20', council_permit: 'bg-amber-50 text-amber-700 ring-amber-600/20', swms: 'bg-emerald-50 text-emerald-700 ring-emerald-600/20', insurance: 'bg-rose-50 text-rose-700 ring-rose-600/20' };
      %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50/50">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Document</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Type</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden sm:table-cell">Uploaded By</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Date</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% cdocs.forEach(doc => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <a href="/jobs/<%= job.id %>/compliance-doc/<%= doc.filename %>" class="text-brand-600 hover:text-brand-700 hover:underline font-medium flex items-center gap-1.5">
                  <svg class="w-4 h-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="truncate max-w-[200px]"><%= doc.original_name %></span>
                </a>
                <% if (doc.file_size) { %><span class="text-[10px] text-gray-400 ml-5"><%= Math.round(doc.file_size / 1024) %>KB</span><% } %>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium ring-1 <%= typeColors[doc.category] || 'bg-gray-50 text-gray-600 ring-gray-400/20' %>"><%= typeLabels[doc.category] || doc.category %></span>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs hidden sm:table-cell"><%= doc.uploaded_by_name || '-' %></td>
              <td class="px-4 py-3 text-gray-500 text-xs hidden md:table-cell"><%= doc.created_at ? formatDate(doc.created_at) : '-' %></td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <a href="/jobs/<%= job.id %>/compliance-doc/<%= doc.filename %>" class="text-brand-600 text-xs font-medium mr-2">Download</a>
                <form method="POST" action="/jobs/<%= job.id %>/compliance-doc/<%= doc.id %>/delete" class="inline" onsubmit="return confirm('Delete this document?')">
                  <%- include('../partials/csrf') %>
                  <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <!-- Linked Plans (collapsed summary) -->
    <% if (complianceItems.length > 0) { %>
    <div class="mt-4">
      <button type="button" onclick="document.getElementById('linked-plans-section').classList.toggle('hidden')" class="text-xs text-gray-400 hover:text-gray-600 flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <%= complianceItems.length %> linked plan<%= complianceItems.length !== 1 ? 's' : '' %> from register
      </button>
      <div id="linked-plans-section" class="hidden mt-2 space-y-1">
        <% complianceItems.forEach(item => { %>
        <a href="/compliance/<%= item.id %>/edit?return_to=/projects/<%= job.id %>%23compliance" class="block px-3 py-2 bg-gray-50 rounded-lg hover:bg-gray-100 text-sm text-gray-700 transition-colors">
          <span class="font-medium"><%= item.title %></span>
          <% if (item.reference_number) { %><span class="text-xs text-gray-400 ml-1">(<%= item.reference_number %>)</span><% } %>
          <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[10px] font-medium ml-2
            <% if (item.status === 'approved') { %>bg-emerald-50 text-emerald-700
            <% } else if (item.status === 'submitted') { %>bg-blue-50 text-blue-700
            <% } else { %>bg-gray-100 text-gray-500<% } %>"><%= item.status ? item.status.replace('_', ' ') : 'pending' %></span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Traffic Plans Tab -->
  <div id="plans" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Traffic Plans</h2>
      <div class="flex items-center gap-2">
        <button type="button" onclick="document.getElementById('link-plan-form').classList.toggle('hidden')" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition-colors">Link Existing</button>
        <a href="/compliance/new?job_id=<%= job.id %>&return_to=/projects/<%= job.id %>%23plans" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Plan</a>
      </div>
    </div>
    <!-- Link existing plan from register -->
    <div id="link-plan-form" class="hidden bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-4">
      <form method="POST" action="/jobs/<%= job.id %>/link-compliance">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="redirect_hash" value="plans">
        <div class="flex items-end gap-3">
          <div class="flex-1">
            <label class="block text-xs font-medium text-gray-500 mb-1">Select plan from register</label>
            <select name="compliance_id" required id="link-plan-select" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
              <option value="">Choose a plan...</option>
            </select>
          </div>
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">Link to Job</button>
          <button type="button" onclick="document.getElementById('link-plan-form').classList.add('hidden')" class="px-4 py-2 bg-gray-100 text-gray-600 text-sm font-medium rounded-lg">Cancel</button>
        </div>
      </form>
    </div>
    <%
      // Combine traffic_plans + compliance items with plan-related types for this tab
      const planTypes = ['traffic_guidance','tmp_approval','spa','rol'];
      const compliancePlans = (typeof complianceItems !== 'undefined' ? complianceItems : []).filter(function(c) {
        const types = (c.item_types || c.item_type || '').split(',');
        return types.some(function(t) { return planTypes.includes(t.trim()); });
      });
      const allPlans = compliancePlans;
      // Also include traffic_plans entries
      const tpEntries = typeof trafficPlans !== 'undefined' ? trafficPlans : [];
    %>
    <% if (allPlans.length === 0 && tpEntries.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
        <p class="text-gray-400 text-sm">No traffic plans for this job yet.</p>
        <a href="/compliance/new?job_id=<%= job.id %>&return_to=/projects/<%= job.id %>%23plans" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Create the first plan</a>
      </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Title / Ref</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Types</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Designer</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Due</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Expiry</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% allPlans.forEach(function(item) {
            const types = (item.item_types || item.item_type || '').split(',').filter(Boolean);
            const typeLabels = { traffic_guidance: 'TGS', tmp_approval: 'CTMP', spa: 'SPA', rol: 'ROL', council_permit: 'Council', bus_approval: 'Bus' };
            const statusColors = { not_started: 'bg-gray-100 text-gray-600', started: 'bg-purple-50 text-purple-700', submitted: 'bg-blue-50 text-blue-700', approved: 'bg-emerald-50 text-emerald-700', rejected: 'bg-red-50 text-red-700', expired: 'bg-amber-50 text-amber-700' };
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              <a href="/compliance/<%= item.id %>/edit" class="text-brand-600 hover:text-brand-700 font-medium"><%= item.title %></a>
              <% if (item.reference_number) { %><div class="text-xs text-gray-400"><%= item.reference_number %></div><% } %>
            </td>
            <td class="px-4 py-3">
              <div class="flex flex-wrap gap-1">
                <% types.forEach(function(t) { %>
                  <span class="inline-flex px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-blue-50 text-blue-700"><%= typeLabels[t] || t %></span>
                <% }) %>
              </div>
            </td>
            <td class="px-4 py-3 text-gray-600 text-xs"><%= item.designer || item.approver_name || '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex px-2 py-0.5 text-[10px] font-bold rounded-full <%= statusColors[item.status] || 'bg-gray-100 text-gray-600' %>"><%= (item.status || 'not_started').replace(/_/g, ' ') %></span>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= item.due_date ? formatDateShort(item.due_date) : '-' %></td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= item.expiry_date ? formatDateShort(item.expiry_date) : '-' %></td>
            <td class="px-4 py-3 whitespace-nowrap">
              <a href="/compliance/<%= item.id %>/edit" class="text-brand-600 hover:text-brand-700 text-xs font-medium mr-2">Edit</a>
              <form method="POST" action="/jobs/<%= job.id %>/unlink-compliance" class="inline" onsubmit="return confirm('Unlink this item from the job?')">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="compliance_id" value="<%= item.id %>">
                <input type="hidden" name="redirect_hash" value="plans">
                <button type="submit" class="text-red-500 hover:text-red-700 text-xs font-medium">Unlink</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% tpEntries.forEach(function(tp) { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-brand-600 font-medium"><%= tp.plan_number %></td>
            <td class="px-4 py-3">
              <span class="inline-flex px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-blue-50 text-blue-700"><%= tp.plan_type %></span>
            </td>
            <td class="px-4 py-3 text-gray-600 text-xs"><%= tp.designer || '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex px-2 py-0.5 text-[10px] font-bold rounded-full
                <% if (tp.is_final) { %>bg-emerald-50 text-emerald-700
                <% } else if (tp.status === 'approved') { %>bg-emerald-50 text-emerald-700
                <% } else if (tp.status === 'submitted') { %>bg-blue-50 text-blue-700
                <% } else { %>bg-gray-100 text-gray-600<% } %>"><%= tp.is_final ? 'FINAL' : (tp.status ? tp.status.replace(/_/g, ' ') : 'draft') %></span>
              <% if (tp.current_revision_label && tp.current_revision_label !== 'Rev A') { %>
                <span class="ml-1 text-[10px] text-gray-400"><%= tp.current_revision_label %></span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= tp.submitted_date ? formatDate(tp.submitted_date) : '-' %></td>
            <td class="px-4 py-3 text-gray-500 text-xs"><%= tp.expiry_date ? formatDate(tp.expiry_date) : '-' %></td>
            <td class="px-4 py-3 whitespace-nowrap">
              <a href="/plans/<%= tp.id %>" class="text-brand-600 hover:text-brand-700 text-xs font-medium mr-2">View</a>
              <% if (tp.is_final) { %>
                <form method="POST" action="/plans/<%= tp.id %>/revoke-final" class="inline" onsubmit="return confirm('Revoke this plan from operations? They will no longer see it.')">
                  <%- include('../partials/csrf') %>
                  <input type="hidden" name="return_to" value="/jobs/<%= job.id %>#plans">
                  <button type="submit" class="text-amber-600 hover:text-amber-700 text-xs font-medium">Revoke Final</button>
                </form>
              <% } else { %>
                <form method="POST" action="/plans/<%= tp.id %>/mark-final" class="inline" onsubmit="return confirm('Publish this plan to operations? They will be able to view and download it.')">
                  <%- include('../partials/csrf') %>
                  <input type="hidden" name="return_to" value="/jobs/<%= job.id %>#plans">
                  <button type="submit" class="text-emerald-600 hover:text-emerald-700 text-xs font-medium">Mark Final</button>
                </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

