      <p class="text-slate-500 text-sm">No budget set for this job yet.</p>
      <a href="/budgets/job/<%= job.id %>" class="text-brand-400 text-sm hover:underline mt-2 inline-block">Set up budget</a>
    </div>
    <% } %>
    <% if (costEntries.length > 0) { %>
    <h3 class="text-sm font-semibold text-white mb-3">Recent Cost Entries</h3>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Description</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Supplier</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-slate-400 uppercase">Amount</th>
