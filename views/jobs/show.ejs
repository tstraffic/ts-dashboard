<% locals.currentPage = 'jobs' %>

<style>
  /* CSS-only tab navigation */
  .tab-content { display: none; }
  .tab-content:target { display: block; }
  .tab-content:first-of-type:not(:target) { display: block; }
  .tab-content:first-of-type:not(:target) ~ .tab-content:target ~ .tab-content:first-of-type { display: none; }
  /* When any tab is targeted, hide the default first tab */
  .tab-group:has(.tab-content:target) > .tab-content:first-of-type:not(:target) { display: none; }
</style>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-3 flex-wrap">
    <h1 class="text-2xl font-bold text-white"><%= job.job_number %></h1>
    <span class="text-lg text-slate-400">&mdash;</span>
    <span class="text-lg text-slate-300"><%= job.client %></span>
    <!-- Status Badge -->
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
      <% if (job.status === 'active') { %>bg-blue-900/60 text-blue-300
      <% } else if (job.status === 'on_hold') { %>bg-orange-900/60 text-brand-300
      <% } else if (job.status === 'completed') { %>bg-emerald-900/60 text-emerald-300
      <% } else if (job.status === 'won') { %>bg-teal-900/60 text-teal-300
      <% } else if (job.status === 'lead') { %>bg-purple-900/60 text-purple-300
      <% } else if (job.status === 'lost') { %>bg-red-900/60 text-red-300
      <% } else { %>bg-slate-700 text-slate-300<% } %>">
      <%= job.status ? job.status.replace('_', ' ') : '-' %>
    </span>
    <!-- Health Dot -->
    <% if (job.health) { %>
      <span class="inline-block w-3 h-3 rounded-full
        <% if (job.health === 'green') { %>bg-emerald-500
        <% } else if (job.health === 'amber') { %>bg-brand-600
        <% } else if (job.health === 'red') { %>bg-red-500
        <% } else { %>bg-slate-600<% } %>" title="Health: <%= job.health %>"></span>
    <% } %>
  </div>
  <div class="flex items-center gap-2">
    <a href="/jobs/<%= job.id %>/edit" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors">Edit</a>
    <a href="/documents/job/<%= job.id %>" class="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium rounded-lg transition-colors">Documents</a>
  </div>
</div>

<!-- Info Grid -->
<div class="bg-slate-800 border border-slate-700 rounded-xl p-6 mb-6">
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4">
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Client</p>
      <p class="text-sm text-white mt-1"><%= job.client %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Site Address</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.site_address || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Suburb</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.suburb || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Stage</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.stage ? job.stage.replace(/_/g, ' ') : '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">% Complete</p>
      <div class="flex items-center gap-2 mt-1">
        <div class="flex-1 max-w-[120px] bg-slate-700 rounded-full h-2">
          <div class="h-2 rounded-full <%= (job.percent_complete || 0) >= 100 ? 'bg-emerald-500' : 'bg-blue-500' %>" style="width: <%= Math.min(job.percent_complete || 0, 100) %>%"></div>
        </div>
        <span class="text-sm text-white"><%= job.percent_complete || 0 %>%</span>
      </div>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Start Date</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.start_date || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">End Date</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.end_date || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Project Manager</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.pm_name || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Ops Supervisor</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.ops_name || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Planning Owner</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.planning_name || '-' %></p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Marketing Owner</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.marketing_name || '-' %></p>
    </div>
    <% if (canViewAccounts) { %>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Accounts Owner</p>
      <p class="text-sm text-slate-300 mt-1"><%= job.accounts_name || '-' %></p>
    </div>
    <% } %>
  </div>
</div>

<!-- Tab Navigation -->
<div class="border-b border-slate-700 mb-6">
  <nav class="flex gap-0 -mb-px overflow-x-auto">
    <a href="#overview" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Overview</a>
    <a href="#tasks" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Tasks</a>
    <a href="#updates" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Updates</a>
    <a href="#compliance" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Compliance</a>
    <a href="#incidents" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Incidents</a>
    <a href="#contacts" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Contacts</a>
    <a href="#timesheets" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Timesheets</a>
    <a href="#equipment" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Equipment</a>
    <a href="#defects" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Defects</a>
    <% if (canViewAccounts) { %>
    <a href="#budget" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Budget</a>
    <a href="#accounts" class="px-4 py-3 text-sm font-medium border-b-2 transition-colors
      text-slate-400 hover:text-white border-transparent hover:border-slate-500
      focus:text-white focus:border-brand-500" onclick="activateTab(this)">Accounts</a>
    <% } %>
  </nav>
</div>

<!-- Tab Content -->
<div class="tab-group">

  <!-- Overview Tab -->
  <div id="overview" class="tab-content">
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Job Summary</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wide mb-2">Details</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-slate-500">Job Number</dt>
              <dd class="text-sm text-white"><%= job.job_number %></dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Client</dt>
              <dd class="text-sm text-white"><%= job.client %></dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Site Address</dt>
              <dd class="text-sm text-slate-300"><%= job.site_address || 'Not specified' %></dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Suburb</dt>
              <dd class="text-sm text-slate-300"><%= job.suburb || 'Not specified' %></dd>
            </div>
          </dl>
        </div>
        <div>
          <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wide mb-2">Progress</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-xs text-slate-500">Status</dt>
              <dd class="text-sm">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <% if (job.status === 'active') { %>bg-blue-900/60 text-blue-300
                  <% } else if (job.status === 'on_hold') { %>bg-orange-900/60 text-brand-300
                  <% } else if (job.status === 'completed') { %>bg-emerald-900/60 text-emerald-300
                  <% } else if (job.status === 'won') { %>bg-teal-900/60 text-teal-300
                  <% } else if (job.status === 'lead') { %>bg-purple-900/60 text-purple-300
                  <% } else if (job.status === 'lost') { %>bg-red-900/60 text-red-300
                  <% } else { %>bg-slate-700 text-slate-300<% } %>">
                  <%= job.status ? job.status.replace('_', ' ') : '-' %>
                </span>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Stage</dt>
              <dd class="text-sm text-slate-300"><%= job.stage ? job.stage.replace(/_/g, ' ') : '-' %></dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Health</dt>
              <dd class="text-sm flex items-center gap-2">
                <span class="inline-block w-3 h-3 rounded-full
                  <% if (job.health === 'green') { %>bg-emerald-500
                  <% } else if (job.health === 'amber') { %>bg-brand-600
                  <% } else if (job.health === 'red') { %>bg-red-500
                  <% } else { %>bg-slate-600<% } %>"></span>
                <span class="text-slate-300 capitalize"><%= job.health || '-' %></span>
              </dd>
            </div>
            <div>
              <dt class="text-xs text-slate-500">Duration</dt>
              <dd class="text-sm text-slate-300"><%= job.start_date || '?' %> &rarr; <%= job.end_date || '?' %></dd>
            </div>
          </dl>
        </div>
      </div>
      <% if (job.notes) { %>
      <div class="mt-6 pt-6 border-t border-slate-700">
        <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wide mb-2">Notes</h3>
        <p class="text-sm text-slate-300 whitespace-pre-wrap"><%= job.notes %></p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Tasks Tab -->
  <div id="tasks" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Tasks</h2>
      <a href="/tasks/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Task</a>
    </div>
    <% if (tasks.length === 0) { %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 text-center">
        <p class="text-slate-500 text-sm">No tasks for this job yet.</p>
        <a href="/tasks/new?job_id=<%= job.id %>" class="text-brand-400 text-sm hover:underline mt-2 inline-block">Create the first task</a>
      </div>
    <% } else { %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Title</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Division</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Owner</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Due Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Priority</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700">
          <% tasks.forEach(task => { %>
          <tr class="hover:bg-slate-700/50">
            <td class="px-4 py-3 text-slate-300 font-medium"><%= task.title %></td>
            <td class="px-4 py-3 text-slate-400"><%= task.division || '-' %></td>
            <td class="px-4 py-3 text-slate-300"><%= task.owner_name || '-' %></td>
            <td class="px-4 py-3 text-slate-400 text-xs"><%= task.due_date || '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (task.status === 'completed') { %>bg-emerald-900/60 text-emerald-300
                <% } else if (task.status === 'in_progress') { %>bg-blue-900/60 text-blue-300
                <% } else if (task.status === 'overdue') { %>bg-red-900/60 text-red-300
                <% } else if (task.status === 'blocked') { %>bg-orange-900/60 text-brand-300
                <% } else { %>bg-slate-700 text-slate-300<% } %>">
                <%= task.status ? task.status.replace('_', ' ') : 'pending' %>
              </span>
            </td>
            <td class="px-4 py-3">
              <span class="text-xs font-medium
                <% if (task.priority === 'high') { %>text-red-400
                <% } else if (task.priority === 'medium') { %>text-brand-400
                <% } else { %>text-slate-400<% } %>">
                <%= task.priority || 'low' %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Updates Tab -->
  <div id="updates" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Project Updates</h2>
      <a href="/updates/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Submit Update</a>
    </div>
    <% if (updates.length === 0) { %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 text-center">
        <p class="text-slate-500 text-sm">No updates submitted for this job yet.</p>
        <a href="/updates/new?job_id=<%= job.id %>" class="text-brand-400 text-sm hover:underline mt-2 inline-block">Submit the first update</a>
      </div>
    <% } else { %>
    <div class="space-y-3">
      <% updates.forEach(update => { %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Week ending <%= update.week_ending %></span>
          <span class="text-xs text-slate-500">by <%= update.submitted_by_name || 'Unknown' %></span>
        </div>
        <p class="text-sm text-slate-300"><%= update.summary %></p>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Compliance Tab -->
  <div id="compliance" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Compliance Items</h2>
      <a href="/compliance/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Compliance Item</a>
    </div>
    <% if (complianceItems.length === 0) { %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 text-center">
        <p class="text-slate-500 text-sm">No compliance items for this job yet.</p>
        <a href="/compliance/new?job_id=<%= job.id %>" class="text-brand-400 text-sm hover:underline mt-2 inline-block">Create the first compliance item</a>
      </div>
    <% } else { %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Title</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Due Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wide">Approver</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700">
          <% complianceItems.forEach(item => { %>
          <tr class="hover:bg-slate-700/50">
            <td class="px-4 py-3 text-slate-300 font-medium"><%= item.title %></td>
            <td class="px-4 py-3 text-slate-400"><%= item.item_type || '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (item.status === 'approved') { %>bg-emerald-900/60 text-emerald-300
                <% } else if (item.status === 'submitted') { %>bg-blue-900/60 text-blue-300
                <% } else if (item.status === 'overdue') { %>bg-red-900/60 text-red-300
                <% } else if (item.status === 'expiring') { %>bg-orange-900/60 text-brand-300
                <% } else { %>bg-slate-700 text-slate-300<% } %>">
                <%= item.status ? item.status.replace('_', ' ') : 'pending' %>
              </span>
            </td>
            <td class="px-4 py-3 text-slate-400 text-xs"><%= item.due_date || '-' %></td>
            <td class="px-4 py-3 text-slate-300"><%= item.approver_name || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Incidents Tab -->
  <div id="incidents" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Safety & Incidents</h2>
      <a href="/incidents/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Report Incident</a>
    </div>
    <% if (incidents.length === 0) { %>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 text-center">
        <p class="text-slate-500 text-sm">No incidents recorded for this job.</p>
      </div>
    <% } else { %>
    <div class="bg-slate-800 border border-slate-700 rounded-xl overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-700">
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Severity</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Description</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Reported By</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700">
          <% incidents.forEach(inc => { %>
          <tr class="hover:bg-slate-700/50 cursor-pointer" onclick="window.location='/incidents/<%= inc.id %>'">
            <td class="px-4 py-3 text-slate-300 text-xs"><%= inc.incident_date %></td>
            <td class="px-4 py-3 text-slate-300"><%= inc.incident_type ? inc.incident_type.replace(/_/g, ' ') : '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (inc.severity === 'critical') { %>bg-red-900/60 text-red-300
                <% } else if (inc.severity === 'high') { %>bg-orange-900/60 text-orange-300
                <% } else if (inc.severity === 'medium') { %>bg-orange-900/60 text-brand-300
                <% } else { %>bg-slate-700 text-slate-300<% } %>"><%= inc.severity %></span>
            </td>
            <td class="px-4 py-3 text-slate-300 max-w-xs truncate"><%= inc.description ? inc.description.substring(0, 80) : '-' %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (inc.investigation_status === 'closed' || inc.investigation_status === 'resolved') { %>bg-emerald-900/60 text-emerald-300
                <% } else if (inc.investigation_status === 'investigating') { %>bg-blue-900/60 text-blue-300
                <% } else { %>bg-orange-900/60 text-brand-300<% } %>"><%= inc.investigation_status ? inc.investigation_status.replace(/_/g, ' ') : 'reported' %></span>
            </td>
            <td class="px-4 py-3 text-slate-400 text-xs"><%= inc.reported_by_name || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Contacts Tab -->
  <div id="contacts" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">Client Contacts</h2>
      <a href="/contacts/new?job_id=<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Add Contact</a>
    </div>
