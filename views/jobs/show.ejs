  <!-- Accounts Tab (conditional) -->
  <% if (canViewAccounts) { %>
  <div id="accounts" class="tab-content">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-white">Accounts</h2>
    </div>

    <!-- Accounts Status -->
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-6 mb-6">
      <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wide mb-3">Accounts Status</h3>
