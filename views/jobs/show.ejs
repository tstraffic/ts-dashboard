              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (ts.approved) { %>bg-emerald-900/60 text-emerald-300
                <% } else { %>bg-slate-700 text-slate-300<% } %>"><%= ts.approved ? 'Approved' : 'Pending' %></span>
            </td>
          </tr>
          <% }) %>
        </tbody>
