              <option value="">None</option>
              <% if (typeof tgsPlans !== 'undefined') { tgsPlans.forEach(function(tp) { %>
                <option value="<%= tp.id %>"><%= tp.plan_number %></option>
              <% }) } %>
            </select>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Compliance/TGS Item</label>
            <select name="compliance_item_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <option value="">None</option>
              <% (typeof complianceTgsItems !== 'undefined' ? complianceTgsItems : []).forEach(function(c) { %>
                <option value="<%= c.id %>"><%= c.title %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Equipment</label>
            <select name="equipment_assignment_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <option value="">None</option>
              <% (typeof equipmentAssignments !== 'undefined' ? equipmentAssignments : []).forEach(function(ea) { %>
                <option value="<%= ea.id %>"><%= ea.equipment_name %> (<%= ea.asset_number %>)</option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Attachments</label>
            <input type="file" name="attachments" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png"
              class="w-full text-sm text-gray-500 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 cursor-pointer">
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">SharePoint Link</label>
            <input type="url" name="sharepoint_link" placeholder="https://..."
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          </div>
        </div>
        <div class="flex items-center gap-3 mt-4">
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Add Entry</button>
          <button type="button" onclick="document.getElementById('diary-form').classList.add('hidden')" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</button>
        </div>
      </form>
    </div>

    <% if (typeof diaryEntries === 'undefined' || diaryEntries.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
        <p class="text-gray-400 text-sm">No diary entries yet.</p>
        <button onclick="document.getElementById('diary-form').classList.remove('hidden')" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Add the first entry</button>
      </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Task</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Representative</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Client Rep</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">Outcomes</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden xl:table-cell">Issues</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden xl:table-cell">Comments</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">Stage</th>
            <th class="px-3 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden xl:table-cell">TGS</th>
            <th class="px-3 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% diaryEntries.forEach(function(entry) {
            const entryAttach = (typeof diaryAttachments !== 'undefined' ? diaryAttachments : []).filter(a => a.diary_entry_id === entry.id);
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2.5 text-gray-600 text-xs whitespace-nowrap"><%= entry.entry_date ? formatDate(entry.entry_date) : '' %></td>
            <td class="px-3 py-2.5 text-gray-900 font-medium max-w-[200px] truncate">
              <%= entry.task || '-' %>
              <% if (entryAttach.length > 0) { %>
                <span class="inline-flex items-center gap-0.5 ml-1 text-gray-400" title="<%= entryAttach.length %> attachment(s)">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                  <span class="text-[10px]"><%= entryAttach.length %></span>
                </span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden md:table-cell"><%= entry.representative_name || entry.representative || '-' %></td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden md:table-cell"><%= entry.client_representative || '-' %></td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden lg:table-cell max-w-[200px] truncate"><%= entry.outcomes || '-' %></td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden xl:table-cell"><%= entry.issues || '-' %></td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden xl:table-cell max-w-[150px] truncate"><%= entry.comments || '-' %></td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden lg:table-cell"><%= entry.stage || '-' %></td>
            <td class="px-3 py-2.5 hidden xl:table-cell">
              <% if (entry.compliance_item_id) { %>
                <a href="/compliance/<%= entry.compliance_item_id %>/edit" class="text-teal-600 hover:underline text-xs"><%= entry.compliance_item_title %></a>
              <% } else if (entry.tgs_plan_id) { %>
                <a href="/compliance/<%= entry.tgs_plan_id %>/edit" class="text-brand-600 hover:underline text-xs"><%= entry.tgs_plan_number || entry.tgs_number %></a>
              <% } else if (entry.tgs_number) { %>
                <span class="text-gray-600 text-xs"><%= entry.tgs_number %> <% if (entry.tgs_scope) { %>(<%= entry.tgs_scope %>)<% } %></span>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-right whitespace-nowrap">
              <button type="button" onclick="document.getElementById('edit-diary-<%= entry.id %>').classList.toggle('hidden')" class="p-1.5 text-gray-400 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition" title="Edit">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <form method="POST" action="/jobs/<%= job.id %>/diary/<%= entry.id %>/delete" class="inline" onsubmit="return confirm('Delete this entry?')">
                <%- include('../partials/csrf') %>
                <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Delete">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </form>
            </td>
          </tr>
          <!-- Inline Edit Row -->
          <tr id="edit-diary-<%= entry.id %>" class="hidden">
            <td colspan="10" class="px-3 py-3 bg-gray-50">
              <form method="POST" action="/jobs/<%= job.id %>/diary/<%= entry.id %>" enctype="multipart/form-data">
                <%- include('../partials/csrf') %>
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 text-xs">
                  <input type="date" name="entry_date" value="<%= entry.entry_date %>" required class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="task" value="<%= entry.task || '' %>" placeholder="Task" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <select name="representative_id" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                    <option value="">Rep...</option>
                    <% (typeof allUsers !== 'undefined' ? allUsers : []).forEach(function(u) { %>
                      <option value="<%= u.id %>" <%= entry.representative_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
                    <% }) %>
                  </select>
                  <input type="text" name="client_representative" value="<%= entry.client_representative || '' %>" placeholder="Client rep" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="outcomes" value="<%= entry.outcomes || '' %>" placeholder="Outcomes" class="col-span-2 px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="issues" value="<%= entry.issues || '' %>" placeholder="Issues" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="comments" value="<%= entry.comments || '' %>" placeholder="Comments" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="stage" value="<%= entry.stage || '' %>" placeholder="Stage" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="tgs_number" value="<%= entry.tgs_number || '' %>" placeholder="TGS No." class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <input type="text" name="tgs_scope" value="<%= entry.tgs_scope || '' %>" placeholder="TGS Scope" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                  <select name="compliance_item_id" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                    <option value="">Compliance link...</option>
                    <% (typeof complianceTgsItems !== 'undefined' ? complianceTgsItems : []).forEach(function(c) { %>
                      <option value="<%= c.id %>" <%= entry.compliance_item_id == c.id ? 'selected' : '' %>><%= c.title %></option>
                    <% }) %>
                  </select>
                  <select name="equipment_assignment_id" class="px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
                    <option value="">Equipment...</option>
                    <% (typeof equipmentAssignments !== 'undefined' ? equipmentAssignments : []).forEach(function(ea) { %>
                      <option value="<%= ea.id %>" <%= entry.equipment_assignment_id == ea.id ? 'selected' : '' %>><%= ea.equipment_name %></option>
                    <% }) %>
                  </select>
                  <input type="file" name="attachments" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" class="col-span-2 text-xs text-gray-500 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:bg-brand-50 file:text-brand-700">
                </div>
                <% if (entryAttach.length > 0) { %>
                <div class="flex flex-wrap gap-2 mt-2">
                  <% entryAttach.forEach(function(a) { %>
                    <% if (a.sharepoint_link) { %>
                      <a href="<%= a.sharepoint_link %>" target="_blank" class="inline-flex items-center gap-1 px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-lg hover:bg-blue-100">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                        SharePoint
                      </a>
                    <% } else { %>
                      <a href="<%= a.file_path %>" target="_blank" class="inline-flex items-center gap-1 px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded-lg hover:bg-gray-200">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
                        <%= a.original_name %>
                      </a>
                    <% } %>
                  <% }) %>
                </div>
                <% } %>
                <div class="flex gap-2 mt-2">
                  <button type="submit" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-500">Save</button>
                  <button type="button" onclick="document.getElementById('edit-diary-<%= entry.id %>').classList.add('hidden')" class="px-3 py-1.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-lg hover:bg-gray-200">Cancel</button>
                </div>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Chat Tab -->
  <div id="chat" class="tab-content">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Job Chat</h2>
      <p class="text-sm text-gray-500 mt-1">Operational messages for this job</p>
      <% if (typeof chatMembers !== 'undefined') { %>
      <div class="mt-2">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-xs text-gray-400 uppercase tracking-wide font-medium">Members (<%= chatMembers.length %>)</span>
          <button type="button" onclick="document.getElementById('add-chat-member').classList.toggle('hidden')" class="w-5 h-5 flex items-center justify-center rounded-full bg-brand-600 hover:bg-brand-500 text-white text-xs transition" title="Add member">+</button>
        </div>
        <div class="flex flex-wrap gap-1.5">
          <% chatMembers.forEach(function(m) { %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700"><%= m.full_name %></span>
          <% }) %>
        </div>
        <!-- Add member form -->
        <div id="add-chat-member" class="hidden mt-2">
          <form method="POST" action="/jobs/<%= job.id %>/chat/add-member" class="flex items-center gap-2">
            <%- include('../partials/csrf') %>
            <select name="user_id" required class="flex-1 px-2 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-xs focus:ring-2 focus:ring-brand-500">
              <option value="">Select user...</option>
              <% const memberIds = chatMembers.map(function(m) { return m.id; }); %>
              <% (typeof allUsers !== 'undefined' ? allUsers : []).forEach(function(u) { %>
                <% if (!memberIds.includes(u.id)) { %>
                  <option value="<%= u.id %>"><%= u.full_name %></option>
                <% } %>
              <% }) %>
            </select>
            <button type="submit" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-500 transition">Add</button>
          </form>
        </div>
      </div>
      <% } %>
    </div>
    <% if (typeof chatThreadId !== 'undefined' && chatThreadId) { %>
      <%- include('../partials/chat-panel') %>
    <% } else { %>
      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <p class="text-gray-400 text-sm">Chat thread not available.</p>
      </div>
    <% } %>
  </div>

  <!-- Budget Tab (conditional) -->
  <% if (canViewAccounts) { %>
  <div id="budget" class="tab-content">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Budget & Costs</h2>
      <a href="/budgets/job/<%= job.id %>" class="px-3 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Edit Budget</a>
    </div>
    <% if (budget) { %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <p class="text-xs text-gray-500 uppercase">Contract Value</p>
        <p class="text-2xl font-bold text-gray-900 mt-1">$<%= (budget.contract_value || 0).toLocaleString() %></p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <p class="text-xs text-gray-500 uppercase">Total Budget</p>
        <p class="text-2xl font-bold text-blue-600 mt-1">$<%= ((budget.labour || 0) + (budget.materials || 0) + (budget.subcontractors || 0) + (budget.equipment || 0) + (budget.other || 0)).toLocaleString() %></p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <p class="text-xs text-gray-500 uppercase">Total Spend</p>
        <p class="text-2xl font-bold text-brand-700 mt-1">$<%= totalSpend.toLocaleString() %></p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <p class="text-xs text-gray-500 uppercase">Margin</p>
        <% const margin = (budget.contract_value || 0) - totalSpend; %>
        <p class="text-2xl font-bold <%= margin >= 0 ? 'text-emerald-600' : 'text-red-600' %> mt-1">$<%= margin.toLocaleString() %></p>
      </div>
    </div>
    <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center mb-6">
      <p class="text-gray-400 text-sm">No budget set for this job yet.</p>
      <a href="/budgets/job/<%= job.id %>" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Set up budget</a>
    </div>
    <% } %>
    <!-- Cost Breakdown by Source -->
    <% const allSourcesTotal = totalSpend + (complianceCosts || 0) + (equipmentCosts || 0); %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mb-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Cost Breakdown by Source</h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-brand-500"></span>
            <span class="text-sm text-gray-700">Manual Cost Entries</span>
          </div>
          <span class="text-sm font-semibold text-gray-900">$<%= totalSpend.toLocaleString() %></span>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-purple-500"></span>
            <a href="#compliance" onclick="activateTab(document.querySelector('a[href=\'#compliance\']'))" class="text-sm text-purple-700 hover:underline">Plans & Approvals (Council fees, TGS costs)</a>
          </div>
          <span class="text-sm font-semibold text-gray-900">$<%= (complianceCosts || 0).toLocaleString() %></span>
        </div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span>
            <a href="#equipment" onclick="activateTab(document.querySelector('a[href=\'#equipment\']'))" class="text-sm text-amber-700 hover:underline">Equipment Maintenance</a>
          </div>
          <span class="text-sm font-semibold text-gray-900">$<%= (equipmentCosts || 0).toLocaleString() %></span>
        </div>
        <div class="border-t border-gray-200 pt-3 flex items-center justify-between">
          <span class="text-sm font-bold text-gray-900">Total All Sources</span>
          <span class="text-base font-bold text-gray-900">$<%= allSourcesTotal.toLocaleString() %></span>
        </div>
      </div>
    </div>

    <% if (costEntries.length > 0) { %>
    <h3 class="text-sm font-semibold text-gray-900 mb-3">Recent Cost Entries</h3>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Supplier</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% costEntries.forEach(ce => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-500 text-xs"><%= ce.entry_date ? formatDate(ce.entry_date) : '' %></td>
            <td class="px-4 py-3 text-gray-600"><%= ce.category ? ce.category.replace(/_/g, ' ') : '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= ce.description || '-' %></td>
            <td class="px-4 py-3 text-gray-500"><%= ce.supplier || '-' %></td>
            <td class="px-4 py-3 text-gray-900 text-right font-medium">$<%= (ce.amount || 0).toLocaleString() %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
  <% } %>

  <!-- Accounts Tab (conditional) -->
  <% if (canViewAccounts) { %>
  <div id="accounts" class="tab-content">
    <div class="mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Accounts</h2>
    </div>

    <!-- Accounts Status -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-3">Accounts Status</h3>
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
        <% if (job.accounts_status === 'on_track') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
        <% } else if (job.accounts_status === 'overdue') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
        <% } else if (job.accounts_status === 'disputed') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
        <% } else { %>bg-white text-gray-500<% } %>">
        <%= job.accounts_status ? job.accounts_status.replace('_', ' ') : 'N/A' %>
      </span>
    </div>

    <!-- Accounts Documents -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4">Accounts Documents</h3>
      <% if (accountsDocs.length === 0) { %>
        <p class="text-gray-400 text-sm">No accounts documents uploaded yet.</p>
      <% } else { %>
        <%
          // Group documents by category
          const accountsGrouped = {};
          accountsDocs.forEach(doc => {
            const cat = doc.category || 'Uncategorised';
            if (!accountsGrouped[cat]) accountsGrouped[cat] = [];
            accountsGrouped[cat].push(doc);
          });
        %>
        <div class="space-y-4">
          <% Object.keys(accountsGrouped).forEach(category => { %>
          <div>
            <h4 class="text-sm font-medium text-gray-600 mb-2 capitalize"><%= category %></h4>
            <ul class="space-y-1">
              <% accountsGrouped[category].forEach(doc => { %>
              <li class="flex items-center justify-between py-2 px-3 bg-white/50 rounded-lg">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="text-sm text-gray-600"><%= doc.title || doc.filename %></span>
                </div>
                <% if (doc.file_path) { %>
                  <a href="<%= doc.file_path %>" target="_blank" class="text-xs text-brand-600 hover:text-brand-700 hover:underline">View</a>
                <% } %>
              </li>
              <% }) %>
            </ul>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
  <% } %>

</div>

<!-- Tab switching script -->
<script>
  function activateTab(clicked) {
    // Update tab styling
    const tabs = clicked.parentElement.querySelectorAll('a');
    tabs.forEach(tab => {
      tab.classList.remove('text-brand-700', 'border-brand-500');
      tab.classList.add('text-gray-500', 'border-transparent');
    });
    clicked.classList.remove('text-gray-500', 'border-transparent');
    clicked.classList.add('text-brand-700', 'border-brand-500');

    // Show/hide content
    const targetId = clicked.getAttribute('href').substring(1);
    document.querySelectorAll('.tab-content').forEach(content => {
      content.style.display = 'none';
    });
    const target = document.getElementById(targetId);
    if (target) target.style.display = 'block';
  }

  // Initialise: activate first tab or hash-targeted tab
  document.addEventListener('DOMContentLoaded', function() {
    const hash = window.location.hash;
    const tabs = document.querySelectorAll('nav a[href^="#"]');
    if (hash && document.querySelector('a[href="' + hash + '"]')) {
      activateTab(document.querySelector('a[href="' + hash + '"]'));
    } else if (tabs.length > 0) {
      activateTab(tabs[0]);
    }
  });

  // Load unlinked compliance items for the "Link Existing" dropdowns
  var complianceLoaded = false;
  function loadUnlinkedCompliance() {
    if (complianceLoaded) return;
    complianceLoaded = true;
    fetch('/jobs/api/compliance/unlinked?job_id=<%= job.id %>', { headers: csrfHeaders() })
      .then(function(r) { return r.json(); })
      .then(function(items) {
        ['link-compliance-select', 'link-plan-select'].forEach(function(id) {
          var sel = document.getElementById(id);
          if (!sel) return;
          items.forEach(function(item) {
            var opt = new Option(item.title + (item.item_type ? ' (' + item.item_type.replace(/_/g, ' ') + ')' : ''), item.id);
            sel.add(opt);
          });
        });
      }).catch(function() {});
  }
  // Load when either link form is shown
  document.querySelectorAll('[onclick*="link-compliance-form"], [onclick*="link-plan-form"]').forEach(function(btn) {
    btn.addEventListener('click', loadUnlinkedCompliance);
  });
</script>
