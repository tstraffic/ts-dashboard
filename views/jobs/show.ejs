                <% } else if (d.severity === 'moderate') { %>bg-orange-900/60 text-brand-300
                <% } else { %>bg-slate-700 text-slate-300<% } %>"><%= d.severity %></span>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (d.status === 'closed') { %>bg-emerald-900/60 text-emerald-300
                <% } else if (d.status === 'rectification') { %>bg-blue-900/60 text-blue-300
                <% } else if (d.status === 'investigating') { %>bg-orange-900/60 text-brand-300
                <% } else { %>bg-red-900/60 text-red-300<% } %>"><%= d.status ? d.status.replace(/_/g, ' ') : 'open' %></span>
            </td>
            <td class="px-4 py-3 text-slate-400"><%= d.assigned_to_name || '-' %></td>
            <td class="px-4 py-3 text-slate-400 text-xs"><%= d.target_close_date || '-' %></td>
