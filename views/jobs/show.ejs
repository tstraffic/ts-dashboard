        <p class="text-2xl font-bold text-blue-400 mt-1">$<%= ((budget.labour || 0) + (budget.materials || 0) + (budget.subcontractors || 0) + (budget.equipment || 0) + (budget.other || 0)).toLocaleString() %></p>
      </div>
      <div class="bg-slate-800 border border-slate-700 rounded-xl p-4">
        <p class="text-xs text-slate-400 uppercase">Total Spend</p>
