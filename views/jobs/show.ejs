        <% if (job.accounts_status === 'on_track') { %>bg-emerald-900/60 text-emerald-300
        <% } else if (job.accounts_status === 'overdue') { %>bg-red-900/60 text-red-300
        <% } else if (job.accounts_status === 'disputed') { %>bg-orange-900/60 text-brand-300
        <% } else { %>bg-slate-700 text-slate-400<% } %>">
        <%= job.accounts_status ? job.accounts_status.replace('_', ' ') : 'N/A' %>
      </span>
    </div>

    <!-- Accounts Documents -->
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-6">
      <h3 class="text-sm font-medium text-slate-400 uppercase tracking-wide mb-4">Accounts Documents</h3>
      <% if (accountsDocs.length === 0) { %>
        <p class="text-slate-500 text-sm">No accounts documents uploaded yet.</p>
      <% } else { %>
        <%
          // Group documents by category
          const accountsGrouped = {};
          accountsDocs.forEach(doc => {
            const cat = doc.category || 'Uncategorised';
            if (!accountsGrouped[cat]) accountsGrouped[cat] = [];
            accountsGrouped[cat].push(doc);
          });
        %>
        <div class="space-y-4">
          <% Object.keys(accountsGrouped).forEach(category => { %>
          <div>
            <h4 class="text-sm font-medium text-slate-300 mb-2 capitalize"><%= category %></h4>
            <ul class="space-y-1">
              <% accountsGrouped[category].forEach(doc => { %>
              <li class="flex items-center justify-between py-2 px-3 bg-slate-700/50 rounded-lg">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  <span class="text-sm text-slate-300"><%= doc.title || doc.filename %></span>
                </div>
                <% if (doc.file_path) { %>
                  <a href="<%= doc.file_path %>" target="_blank" class="text-xs text-blue-400 hover:text-blue-300 hover:underline">View</a>
                <% } %>
              </li>
              <% }) %>
            </ul>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
  <% } %>

</div>

<!-- Tab switching script -->
<script>
  function activateTab(clicked) {
    // Update tab styling
    const tabs = clicked.parentElement.querySelectorAll('a');
    tabs.forEach(tab => {
      tab.classList.remove('text-white', 'border-brand-500');
      tab.classList.add('text-slate-400', 'border-transparent');
    });
    clicked.classList.remove('text-slate-400', 'border-transparent');
    clicked.classList.add('text-white', 'border-brand-500');

    // Show/hide content
    const targetId = clicked.getAttribute('href').substring(1);
    document.querySelectorAll('.tab-content').forEach(content => {
      content.style.display = 'none';
    });
    const target = document.getElementById(targetId);
    if (target) target.style.display = 'block';
  }

  // Initialise: activate first tab or hash-targeted tab
  document.addEventListener('DOMContentLoaded', function() {
    const hash = window.location.hash;
    const tabs = document.querySelectorAll('nav a[href^="#"]');
    if (hash && document.querySelector('a[href="' + hash + '"]')) {
      activateTab(document.querySelector('a[href="' + hash + '"]'));
    } else if (tabs.length > 0) {
      activateTab(tabs[0]);
    }
  });
</script>
