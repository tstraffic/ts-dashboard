            <td class="px-4 py-3 text-blue-400 font-medium"><%= ea.asset_number || '-' %></td>
            <td class="px-4 py-3 text-slate-300"><%= ea.equipment_name || '-' %></td>
            <td class="px-4 py-3 text-slate-400"><%= ea.category ? ea.category.replace(/_/g, ' ') : '-' %></td>
            <td class="px-4 py-3">
