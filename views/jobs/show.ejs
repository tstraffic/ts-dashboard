            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Organisation</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Phone</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-slate-400 uppercase">Primary</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700">
