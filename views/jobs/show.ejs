                <% } else if (d.status === 'investigating') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else { %>bg-red-50 text-red-700 ring-1 ring-red-600/20<% } %>"><%= d.status ? d.status.replace(/_/g, ' ') : 'open' %></span>
