<% locals.currentPage = 'jobs' %>
<% const isEdit = job !== null && typeof job !== 'undefined' %>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/jobs" class="hover:text-gray-900 transition">Jobs</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? job.job_number : 'New Job' %></span>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Job' : 'Create New Job' %></h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update details for ' + job.job_number : 'Fill in the details to create a new job' %></p>
  </div>
</div>

<!-- Form -->
<form method="POST" action="<%= isEdit ? '/jobs/' + job.id : '/jobs' %>" class="space-y-5" data-wizard>
  <%- include('../partials/csrf') %>

  <!-- 1. Job Identification -->
  <div id="section-0" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="0" data-wizard-title="Identification">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Job Identification</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label for="job_number" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Job Number <span class="text-red-500">*</span></label>
        <input type="text" id="job_number" name="job_number" required
          placeholder="e.g. J-00123" value="<%= isEdit ? job.job_number : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <div class="flex items-center justify-between mb-1">
          <label for="client_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest">Client <span class="text-red-500">*</span></label>
          <button type="button" onclick="toggleJobClientAdd()" class="text-[10px] text-brand-600 hover:text-brand-700 font-medium">+ Add new</button>
        </div>
        <select id="client_id" name="client_id" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select client...</option>
          <% (typeof clients !== 'undefined' ? clients : []).forEach(function(c) { %>
            <option value="<%= c.id %>" <%= isEdit && job.client_id == c.id ? 'selected' : '' %>><%= c.company_name %></option>
          <% }) %>
        </select>
        <input type="hidden" id="client" name="client" value="<%= isEdit ? job.client : '' %>">
        <!-- Inline quick-add client -->
        <div id="jobQuickAddClient" class="hidden mt-2 p-2.5 bg-brand-50 border border-brand-200 rounded-lg">
          <div class="flex items-center gap-2">
            <input type="text" id="qa_job_client_name" placeholder="Company name" class="flex-1 bg-white border border-gray-300 text-gray-900 rounded-lg px-2.5 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <button type="button" onclick="saveJobClient()" class="px-3 py-1.5 bg-brand-600 text-white text-xs font-medium rounded-lg hover:bg-brand-500 transition">Create</button>
            <button type="button" onclick="toggleJobClientAdd()" class="text-xs text-gray-400 hover:text-gray-600">Cancel</button>
          </div>
        </div>
      </div>
      <div>
        <label for="job_name" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Job Name</label>
        <input type="text" id="job_name" name="job_name" value="<%= isEdit && job.job_name ? job.job_name : '' %>" placeholder="Descriptive name"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="client_project_number" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Client Project No.</label>
        <input type="text" id="client_project_number" name="client_project_number" value="<%= isEdit && job.client_project_number ? job.client_project_number : '' %>" placeholder="Client ref"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="principal_contractor" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Principal Contractor</label>
        <input type="text" id="principal_contractor" name="principal_contractor" value="<%= isEdit && job.principal_contractor ? job.principal_contractor : '' %>" placeholder="Principal contractor"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="state" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">State</label>
        <select id="state" name="state" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% (settingsOptions.state || []).forEach((opt, idx) => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.state === opt.key ? 'selected' : (!isEdit && idx === 0) ? 'selected' : '' %>><%= opt.key %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- 2. Location -->
  <div id="section-1" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="1" data-wizard-title="Location">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Location</h2>
    <!-- Address search -->
    <div class="mb-4 relative">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Search Address</label>
      <div class="relative">
        <input type="text" id="address_search" placeholder="Start typing an address..." autocomplete="off"
          class="w-full px-3 py-2 pl-9 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <div id="address_spinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
          <svg class="animate-spin w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        </div>
      </div>
      <div id="address_results" class="hidden absolute z-50 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg max-h-60 overflow-y-auto"></div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2">
        <label for="site_address" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Site Address</label>
        <input type="text" id="site_address" name="site_address" value="<%= isEdit && job.site_address ? job.site_address : '' %>" placeholder="Full site address"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="suburb" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Suburb</label>
        <input type="text" id="suburb" name="suburb" value="<%= isEdit && job.suburb ? job.suburb : '' %>" placeholder="Suburb"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="location_state" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">State</label>
        <input type="text" id="location_state" readonly tabindex="-1" value=""
          class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-600 text-sm">
      </div>
    </div>
  </div>

  <!-- 3. Status & Progress -->
  <div id="section-2" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="2" data-wizard-title="Status">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Status & Progress</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label for="status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</label>
        <select id="status" name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% (settingsOptions.job_status || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="stage" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Stage</label>
        <select id="stage" name="stage" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% (settingsOptions.job_stage || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.stage === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="health" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Health</label>
        <select id="health" name="health" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% (settingsOptions.job_health || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.health === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- 4. Dates & Completion -->
  <div id="section-3" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="3" data-wizard-title="Dates">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Dates & Completion</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label for="start_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Start Date <span class="text-red-500">*</span></label>
        <input type="date" id="start_date" name="start_date" required value="<%= isEdit && job.start_date ? job.start_date : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="end_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">End Date</label>
        <input type="date" id="end_date" name="end_date" value="<%= isEdit && job.end_date ? job.end_date : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="percent_complete" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">% Complete</label>
        <div class="flex items-center gap-2">
          <input type="range" id="percent_slider" min="0" max="100" value="<%= isEdit ? (job.percent_complete || 0) : 0 %>"
            class="flex-1 h-1.5 bg-gray-200 rounded-full appearance-none cursor-pointer accent-brand-600"
            oninput="document.getElementById('percent_complete').value=this.value; document.getElementById('percent_label').textContent=this.value+'%'">
          <input type="number" id="percent_complete" name="percent_complete" min="0" max="100" value="<%= isEdit ? (job.percent_complete || 0) : 0 %>"
            class="w-16 px-2 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm text-center focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
            oninput="document.getElementById('percent_slider').value=this.value; document.getElementById('percent_label').textContent=this.value+'%'">
          <span id="percent_label" class="text-xs text-gray-400 w-8"><%= isEdit ? (job.percent_complete || 0) : 0 %>%</span>
        </div>
      </div>
    </div>
  </div>

  <!-- 5. Operations Details -->
  <div id="section-4" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="4" data-wizard-title="Operations">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Operations Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label for="contract_value" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Contract Value ($)</label>
        <input type="number" id="contract_value" name="contract_value" step="0.01" min="0" value="<%= isEdit && job.contract_value ? job.contract_value : '' %>" placeholder="0.00"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="estimated_hours" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Estimated Hours</label>
        <input type="number" id="estimated_hours" name="estimated_hours" min="0" value="<%= isEdit && job.estimated_hours ? job.estimated_hours : '' %>" placeholder="0"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="crew_size" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Crew Size</label>
        <input type="number" id="crew_size" name="crew_size" min="0" value="<%= isEdit && job.crew_size ? job.crew_size : '' %>" placeholder="0"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
      <div>
        <label for="required_tcp_level" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Required TCP Level</label>
        <select id="required_tcp_level" name="required_tcp_level" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="" <%= isEdit && !job.required_tcp_level ? 'selected' : '' %>>Any</option>
          <% (settingsOptions.tcp_level || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.required_tcp_level === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="vehicles" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Vehicles</label>
        <input type="number" id="vehicles" name="vehicles" min="0" value="<%= isEdit && job.vehicles ? job.vehicles : '' %>" placeholder="0"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
    <div class="mt-4">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Approvals Required</label>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="rol_required" value="1" <%= isEdit && job.rol_required ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">ROL</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="tmp_required" value="1" <%= isEdit && job.tmp_required ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">TMP</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="tgs_required" value="1" <%= isEdit && job.tgs_required ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">TGS</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="spa_required" value="1" <%= isEdit && job.spa_required ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">SPA</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="council_approval" value="1" <%= isEdit && job.council_approval ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">Council</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="bus_approval" value="1" <%= isEdit && job.bus_approval ? 'checked' : '' %>
            class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500">
          <span class="text-sm font-medium text-gray-600">Bus Approval</span>
        </label>
      </div>
    </div>
  </div>

  <!-- 6. Team Assignment -->
  <div id="section-5" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="5" data-wizard-title="Team">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Team Assignment</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% const teamFields = [
        { id: 'project_manager_id', label: 'Project Manager' },
        { id: 'ops_supervisor_id', label: 'Ops Supervisor' },
        { id: 'traffic_supervisor_id', label: 'Traffic Supervisor' },
        { id: 'planning_owner_id', label: 'Planning Owner' },
        { id: 'marketing_owner_id', label: 'Marketing Owner' },
        { id: 'accounts_owner_id', label: 'Accounts Owner' },
      ]; %>
      <% teamFields.forEach(f => { %>
      <div>
        <label for="<%= f.id %>" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1"><%= f.label %></label>
        <select id="<%= f.id %>" name="<%= f.id %>" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select --</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= isEdit && job[f.id] == u.id ? 'selected' : '' %>><%= u.full_name %> (<%= u.role %>)</option>
          <% }) %>
        </select>
      </div>
      <% }) %>
      <div>
        <label for="accounts_status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Accounts Status</label>
        <select id="accounts_status" name="accounts_status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% (settingsOptions.accounts_status || []).forEach(opt => { %>
            <option value="<%= opt.key %>" <%= isEdit && job.accounts_status === opt.key ? 'selected' : '' %>><%= opt.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- 7. SharePoint & Notes -->
  <div id="section-6" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="6" data-wizard-title="Notes & Links">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Notes & Links</h2>
    <div class="space-y-4">
      <div>
        <label for="sharepoint_url" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">SharePoint URL</label>
        <input type="url" id="sharepoint_url" name="sharepoint_url" value="<%= isEdit && job.sharepoint_url ? job.sharepoint_url : '' %>" placeholder="https://..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="notes" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Notes</label>
        <textarea id="notes" name="notes" rows="3" placeholder="Additional notes..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"><%= isEdit && job.notes ? job.notes : '' %></textarea>
      </div>
    </div>
  </div>

  <!-- Actions (fallback for no-JS, hidden when wizard active) -->
  <noscript>
    <div class="sticky bottom-0 bg-gray-50/95 backdrop-blur-sm border-t border-gray-200 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 flex items-center gap-3">
      <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors">
        <%= isEdit ? 'Update Job' : 'Create Job' %>
      </button>
      <a href="/jobs" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</a>
    </div>
  </noscript>
</form>

<script>
function toggleJobClientAdd() {
  document.getElementById('jobQuickAddClient').classList.toggle('hidden');
}

function saveJobClient() {
  var name = document.getElementById('qa_job_client_name').value.trim();
  if (!name) { document.getElementById('qa_job_client_name').focus(); return; }
  fetch('/clients', {
    method: 'POST',
    headers: csrfHeaders({ 'Content-Type': 'application/json', 'Accept': 'application/json' }),
    body: JSON.stringify({ company_name: name })
  }).then(function(r) {
    if (!r.ok) return r.text().then(function(t) { throw new Error('HTTP ' + r.status + ': ' + t.substring(0, 100)); });
    return r.json();
  }).then(function(data) {
    if (data.success && data.client) {
      var sel = document.getElementById('client_id');
      var opt = new Option(data.client.company_name, data.client.id, true, true);
      sel.add(opt);
      sel.value = data.client.id;
      document.getElementById('client').value = data.client.company_name;
      document.getElementById('qa_job_client_name').value = '';
      document.getElementById('jobQuickAddClient').classList.add('hidden');
    } else {
      alert('Failed to create client: ' + JSON.stringify(data));
    }
  }).catch(function(e) { alert('Error creating client: ' + e.message); });
}

// Address autocomplete (OpenStreetMap Nominatim — free, no API key)
(function() {
  var input = document.getElementById('address_search');
  var results = document.getElementById('address_results');
  var spinner = document.getElementById('address_spinner');
  if (!input) return;
  var timer;

  input.addEventListener('input', function() {
    clearTimeout(timer);
    var q = input.value.trim();
    if (q.length < 3) { results.classList.add('hidden'); return; }
    timer = setTimeout(function() {
      spinner.classList.remove('hidden');
      fetch('https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&countrycodes=au&limit=6&q=' + encodeURIComponent(q), {
        headers: { 'Accept': 'application/json' }
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        spinner.classList.add('hidden');
        if (!data.length) { results.innerHTML = '<div class="px-3 py-2 text-sm text-gray-400">No results found</div>'; results.classList.remove('hidden'); return; }
        results.innerHTML = data.map(function(item, i) {
          var addr = item.address || {};
          var suburb = addr.suburb || addr.town || addr.city || addr.village || '';
          var state = addr.state || '';
          return '<button type="button" data-idx="' + i + '" class="w-full text-left px-3 py-2.5 hover:bg-brand-50 transition text-sm border-b border-gray-100 last:border-0">' +
            '<div class="font-medium text-gray-900 truncate">' + item.display_name.split(',').slice(0, 3).join(', ') + '</div>' +
            '<div class="text-xs text-gray-400 mt-0.5">' + (suburb ? suburb + ', ' : '') + state + '</div>' +
            '</button>';
        }).join('');
        results.classList.remove('hidden');
        // Store data for click handler
        results._data = data;
      })
      .catch(function() { spinner.classList.add('hidden'); });
    }, 350);
  });

  results.addEventListener('click', function(e) {
    var btn = e.target.closest('button[data-idx]');
    if (!btn || !results._data) return;
    var item = results._data[parseInt(btn.dataset.idx)];
    var addr = item.address || {};

    // Fill fields
    var street = (addr.road ? (addr.house_number ? addr.house_number + ' ' : '') + addr.road : '');
    var suburb = addr.suburb || addr.town || addr.city || addr.village || '';
    var state = addr.state || '';
    var fullAddr = street || item.display_name.split(',').slice(0, 2).join(', ').trim();

    document.getElementById('site_address').value = fullAddr + (suburb ? ', ' + suburb : '');
    document.getElementById('suburb').value = suburb;
    document.getElementById('location_state').value = state;

    // Also try to set the State dropdown on step 1 if it matches
    var stateSelect = document.getElementById('state');
    if (stateSelect) {
      var abbr = { 'New South Wales': 'NSW', 'Victoria': 'VIC', 'Queensland': 'QLD', 'South Australia': 'SA', 'Western Australia': 'WA', 'Tasmania': 'TAS', 'Northern Territory': 'NT', 'Australian Capital Territory': 'ACT' };
      var stateCode = abbr[state] || state;
      for (var i = 0; i < stateSelect.options.length; i++) {
        if (stateSelect.options[i].value === stateCode) { stateSelect.value = stateCode; break; }
      }
    }

    input.value = '';
    results.classList.add('hidden');
  });

  // Close results on outside click
  document.addEventListener('click', function(e) {
    if (!e.target.closest('#address_search') && !e.target.closest('#address_results')) {
      results.classList.add('hidden');
    }
  });
})();

// Sync hidden client name field on form submit
document.querySelector('form').addEventListener('submit', function() {
  var sel = document.getElementById('client_id');
  if (sel.selectedIndex > 0) {
    document.getElementById('client').value = sel.options[sel.selectedIndex].text;
  }
});
</script>
