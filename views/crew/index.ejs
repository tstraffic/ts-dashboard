<%
  const roleLabels = {
    traffic_controller: 'Traffic Controller',
    leading_hand: 'Leading Hand',
    supervisor: 'Supervisor',
    pilot_vehicle: 'Pilot Vehicle',
    spotter: 'Spotter',
    labourer: 'Labourer',
    other: 'Other'
  };

  function daysUntil(dateStr) {
    if (!dateStr) return null;
    const diff = Math.ceil((new Date(dateStr) - new Date(today)) / (1000 * 60 * 60 * 24));
    return diff;
  }

  function formatShortDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' });
  }

  function relativeDate(dateStr) {
    if (!dateStr) return '-';
    const d = daysUntil(dateStr);
    if (d === null) return '-';
    if (d < 0) return Math.abs(d) + 'd ago';
    if (d === 0) return 'Today';
    return d + 'd';
  }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Workforce</h1>
      <p class="text-sm text-gray-500 mt-1">Operational roster &middot; compliance &middot; allocation status</p>
    </div>
    <a href="/crew/new" class="inline-flex items-center justify-center px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Crew Member
    </a>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total Active</p>
      <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.totalActive %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Allocatable</p>
      <p class="text-xl font-bold text-emerald-600 mt-0.5"><%= stats.allocatable %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-red-400 uppercase tracking-widest">Compliance Issues</p>
      <p class="text-xl font-bold text-red-600 mt-0.5"><%= stats.complianceIssues %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-orange-400 uppercase tracking-widest">Fatigue Blocked</p>
      <p class="text-xl font-bold text-orange-600 mt-0.5"><%= stats.fatigueBlocked %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
      <p class="text-[10px] font-bold text-amber-400 uppercase tracking-widest">Expiring &lt;30d</p>
      <p class="text-xl font-bold text-amber-600 mt-0.5"><%= stats.expiringSoon %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <form method="GET" action="/crew" data-module="crew" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3">
      <%- include('../partials/csrf') %>
      <!-- Status Tabs -->
      <div class="flex rounded-lg overflow-hidden border border-gray-300 self-start">
        <a href="/crew?filter=all&search=<%= encodeURIComponent(search || '') %>&role=<%= encodeURIComponent(roleFilter || '') %>" class="px-3 py-2 text-xs font-medium <%= filter === 'all' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">All</a>
        <a href="/crew?filter=active&search=<%= encodeURIComponent(search || '') %>&role=<%= encodeURIComponent(roleFilter || '') %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'active' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Active</a>
        <a href="/crew?filter=blocked&search=<%= encodeURIComponent(search || '') %>&role=<%= encodeURIComponent(roleFilter || '') %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'blocked' ? 'bg-red-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Blocked</a>
        <a href="/crew?filter=fatigued&search=<%= encodeURIComponent(search || '') %>&role=<%= encodeURIComponent(roleFilter || '') %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'fatigued' ? 'bg-orange-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Fatigued</a>
        <a href="/crew?filter=expiring&search=<%= encodeURIComponent(search || '') %>&role=<%= encodeURIComponent(roleFilter || '') %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'expiring' ? 'bg-amber-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Expiring</a>
      </div>

      <!-- Role Filter -->
      <select name="role" onchange="this.form.submit()" class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 text-xs font-medium focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">All Roles</option>
        <% Object.entries(roleLabels).forEach(([val, label]) => { %>
          <option value="<%= val %>" <%= roleFilter === val ? 'selected' : '' %>><%= label %></option>
        <% }) %>
      </select>

      <!-- Search -->
      <div class="flex-1 min-w-0 sm:min-w-[200px]">
        <input type="text" name="search" value="<%= search %>" placeholder="Search name, ID, role, company..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <input type="hidden" name="filter" value="<%= filter %>">
      <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg border border-gray-300">Search</button>
    </form>
  </div>

  <!-- Crew Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (crew.length === 0) { %>
      <div class="p-6 text-center">
        <div class="w-10 h-10 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-1">No crew members found</h3>
        <p class="text-gray-500 text-sm mb-1">Your crew roster tracks traffic controllers, leading hands, supervisors, and other field staff.</p>
        <p class="text-gray-400 text-xs mb-4">Add crew members to manage allocations, compliance, and timesheets.</p>
        <a href="/crew/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Add Crew Member
        </a>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <% const crewSortParams = '&filter=' + encodeURIComponent(filter) + '&search=' + encodeURIComponent(search) + '&role=' + encodeURIComponent(roleFilter); %>
          <tr class="border-b border-gray-200">
            <th class="px-2 py-2 text-left w-8">
              <input type="checkbox" id="select-all" class="rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500" title="Select all">
            </th>
            <th class="px-3 sm:px-4 py-2 text-left"><%- include('../partials/sort-header', { label: 'Name', field: 'full_name', currentSort: sort, currentOrder: order, baseUrl: '/crew', extraParams: crewSortParams }) %></th>
            <th class="px-3 sm:px-4 py-2 text-left hidden sm:table-cell"><%- include('../partials/sort-header', { label: 'Employee ID', field: 'employee_id', currentSort: sort, currentOrder: order, baseUrl: '/crew', extraParams: crewSortParams }) %></th>
            <th class="px-3 sm:px-4 py-2 text-left hidden md:table-cell"><%- include('../partials/sort-header', { label: 'Role', field: 'role', currentSort: sort, currentOrder: order, baseUrl: '/crew', extraParams: crewSortParams }) %></th>
            <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
            <th class="px-3 sm:px-4 py-2 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Jobs</th>
            <th class="px-3 sm:px-4 py-2 text-left hidden lg:table-cell"><%- include('../partials/sort-header', { label: 'Next Expiry', field: 'licence_expiry', currentSort: sort, currentOrder: order, baseUrl: '/crew', extraParams: crewSortParams }) %></th>
            <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Last Worked</th>
            <th class="px-3 sm:px-4 py-2 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Company</th>
            <th class="px-3 sm:px-4 py-2 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% for (const c of crew) { %>
          <tr class="hover:bg-gray-50 transition <%= !c.active ? 'opacity-50' : '' %>">
            <td class="px-2 py-2">
              <input type="checkbox" class="bulk-checkbox rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500" value="<%= c.id %>">
            </td>
            <!-- Name + mobile subtitle -->
            <td class="px-3 sm:px-4 py-2">
              <a href="/crew/<%= c.id %>" class="text-brand-600 hover:text-brand-700 font-medium"><%= c.full_name %></a>
              <div class="sm:hidden text-[10px] text-gray-400 mt-0.5"><%= c.employee_id || '' %><% if (c.role) { %> &middot; <%= roleLabels[c.role] || c.role %><% } %></div>
            </td>

            <!-- Employee ID -->
            <td class="px-3 sm:px-4 py-2 text-gray-500 hidden sm:table-cell font-mono text-xs"><%= c.employee_id || '-' %></td>

            <!-- Role -->
            <td class="px-3 sm:px-4 py-2 hidden md:table-cell">
              <span class="text-xs text-gray-600"><%= roleLabels[c.role] || c.role || '-' %></span>
              <% if (c.tcp_level) { %>
                <span class="ml-1 text-[10px] text-gray-400">L<%= c.tcp_level %></span>
              <% } %>
            </td>

            <!-- Compliance Status Badges -->
            <td class="px-3 sm:px-4 py-2">
              <div class="flex flex-wrap gap-1">
                <% if (c.compliance.canAllocate) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">CLEAR</span>
                <% } else { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-600/20">BLOCKED</span>
                <% } %>
                <% if (!c.compliance.inductionComplete) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">INDUCTION</span>
                <% } %>
                <% if (!c.compliance.allTicketsValid) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">TICKETS</span>
                <% } else if (c.compliance.expiringItems.length > 0) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20">EXPIRING</span>
                <% } %>
                <% if (c.compliance.fatigueBlocked) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20">FATIGUE</span>
                <% } %>
                <% if (c.compliance.missingDocs) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20">DOCS</span>
                <% } %>
                <% if (c.compliance.supervisorApproved) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-50 text-purple-700 ring-1 ring-purple-600/20">APPROVED</span>
                <% } %>
              </div>
            </td>

            <!-- Active Jobs Count -->
            <td class="px-3 sm:px-4 py-2 text-center hidden lg:table-cell">
              <% if (c.activeJobs > 0) { %>
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-[10px] font-bold bg-brand-50 text-brand-700 ring-1 ring-brand-600/20"><%= c.activeJobs %></span>
              <% } else { %>
                <span class="text-gray-300">-</span>
              <% } %>
            </td>

            <!-- Next Expiry -->
            <td class="px-3 sm:px-4 py-2 hidden lg:table-cell">
              <% if (c.nearestExpiry) { %>
                <%
                  const days = daysUntil(c.nearestExpiry.date);
                  let expiryColor = 'text-gray-500';
                  if (days !== null) {
                    if (days < 0) expiryColor = 'text-red-600 font-semibold';
                    else if (days <= 14) expiryColor = 'text-red-600';
                    else if (days <= 30) expiryColor = 'text-amber-600';
                  }
                %>
                <span class="<%= expiryColor %> text-xs"><%= formatShortDate(c.nearestExpiry.date) %></span>
                <span class="block text-[10px] text-gray-400"><%= c.nearestExpiry.label %></span>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>

            <!-- Last Worked -->
            <td class="px-3 sm:px-4 py-2 hidden xl:table-cell">
              <% if (c.lastWorked) { %>
                <span class="text-xs text-gray-500"><%= formatShortDate(c.lastWorked) %></span>
              <% } else { %>
                <span class="text-gray-300 text-xs">Never</span>
              <% } %>
            </td>

            <!-- Company -->
            <td class="px-3 sm:px-4 py-2 text-gray-500 text-xs hidden xl:table-cell"><%= c.company || '-' %></td>

            <!-- Actions -->
            <td class="px-3 sm:px-4 py-2 text-right">
              <div class="flex items-center justify-end gap-1">
                <a href="/crew/<%= c.id %>" class="px-2.5 py-1.5 text-xs font-medium text-brand-600 hover:text-brand-700 hover:bg-brand-50 rounded-lg">View</a>
                <a href="/crew/<%= c.id %>/edit" class="px-2.5 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg">Edit</a>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="px-4 py-3 border-t border-gray-200 text-xs text-gray-500">
      Showing <%= crew.length %> crew member<%= crew.length !== 1 ? 's' : '' %>
    </div>
    <%- include('../partials/bulk-actions', { actions: [{ value: 'deactivate', label: 'Deactivate Selected' }], formAction: '/crew/bulk' }) %>
    <% } %>
  </div>
</div>
