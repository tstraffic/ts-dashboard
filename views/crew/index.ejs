<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Workforce</h1>
      <p class="text-sm text-gray-500 mt-1">Operational workforce roster with compliance status</p>
    </div>
    <a href="/crew/new" class="inline-flex items-center justify-center px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Crew Member
    </a>
  </div>

  <!-- Stat Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Active</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= stats.totalActive %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Allocatable</p>
      <p class="text-2xl font-bold text-emerald-600 mt-1"><%= stats.allocatable %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Compliance Issues</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= stats.complianceIssues %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Fatigue Blocked</p>
      <p class="text-2xl font-bold text-orange-600 mt-1"><%= stats.fatigueBlocked %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <form method="GET" action="/crew" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3">
      <div class="flex rounded-lg overflow-hidden border border-gray-300 self-start">
        <a href="/crew?filter=all&search=<%= search %>" class="px-3 py-2 text-xs font-medium <%= filter === 'all' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">All</a>
        <a href="/crew?filter=active&search=<%= search %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'active' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Active</a>
        <a href="/crew?filter=blocked&search=<%= search %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'blocked' ? 'bg-red-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Blocked</a>
        <a href="/crew?filter=fatigued&search=<%= search %>" class="px-3 py-2 text-xs font-medium border-l border-gray-300 <%= filter === 'fatigued' ? 'bg-orange-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Fatigued</a>
      </div>
      <div class="flex-1 min-w-0 sm:min-w-[200px]">
        <input type="text" name="search" value="<%= search %>" placeholder="Search name, ID, role, company..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <input type="hidden" name="filter" value="<%= filter %>">
      <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg border border-gray-300">Search</button>
    </form>
  </div>

  <!-- Crew Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (crew.length === 0) { %>
      <div class="p-12 text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <p class="text-gray-500 text-sm font-medium">No crew members match your filters</p>
        <p class="text-gray-400 text-xs mt-1">Try a different search term or filter setting</p>
        <a href="/crew/new" class="inline-flex items-center gap-1.5 mt-4 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Add Crew Member
        </a>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Name</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden sm:table-cell">Employee ID</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden md:table-cell">Role</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">TC Level</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Status</th>
            <th class="px-3 sm:px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide hidden lg:table-cell">Company</th>
            <th class="px-3 sm:px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% for (const c of crew) { %>
          <tr class="hover:bg-gray-50 transition <%= !c.active ? 'opacity-50' : '' %>">
            <td class="px-3 sm:px-4 py-3">
              <a href="/crew/<%= c.id %>" class="text-brand-600 hover:text-brand-700 font-medium"><%= c.full_name %></a>
            </td>
            <td class="px-3 sm:px-4 py-3 text-gray-600 hidden sm:table-cell"><%= c.employee_id || '—' %></td>
            <td class="px-3 sm:px-4 py-3 hidden md:table-cell">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white text-gray-600">
                <%= c.role ? c.role.replace('_', ' ') : '—' %>
              </span>
            </td>
            <td class="px-3 sm:px-4 py-3 text-gray-600 hidden lg:table-cell"><%= c.tcp_level || '—' %></td>
            <td class="px-3 sm:px-4 py-3">
              <div class="flex flex-wrap gap-1">
                <% if (c.compliance.canAllocate) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">CLEAR</span>
                <% } else { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-600/20">BLOCKED</span>
                <% } %>
                <% if (!c.compliance.inductionComplete) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">INDUCTION</span>
                <% } %>
                <% if (!c.compliance.allTicketsValid) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">TICKETS</span>
                <% } else if (c.compliance.expiringItems.length > 0) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20">EXPIRING</span>
                <% } %>
                <% if (c.compliance.fatigueBlocked) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-50 text-amber-700 ring-1 ring-amber-600/20">FATIGUE</span>
                <% } %>
                <% if (c.compliance.missingDocs) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20">DOCS</span>
                <% } %>
                <% if (c.compliance.supervisorApproved) { %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-purple-50 text-purple-700 ring-1 ring-purple-600/20">APPROVED</span>
                <% } %>
              </div>
            </td>
            <td class="px-3 sm:px-4 py-3 text-gray-600 hidden lg:table-cell"><%= c.company || '—' %></td>
            <td class="px-3 sm:px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-1">
                <a href="/crew/<%= c.id %>" class="px-2.5 py-1.5 text-xs font-medium text-brand-600 hover:text-brand-700 hover:bg-brand-50 rounded-lg">View</a>
                <a href="/crew/<%= c.id %>/edit" class="px-2.5 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg">Edit</a>
              </div>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="px-4 py-3 border-t border-gray-200 text-xs text-gray-500">
      Showing <%= crew.length %> crew member<%= crew.length !== 1 ? 's' : '' %>
    </div>
    <% } %>
  </div>
</div>
