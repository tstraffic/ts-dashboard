<% locals.currentPage = 'crew' %>
<% const isEdit = editMember !== null && typeof editMember !== 'undefined' %>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/crew" class="hover:text-gray-900 transition">Crew Roster</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? editMember.full_name : 'New Crew Member' %></span>
</div>

<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit' : 'Add' %> Crew Member</h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update crew member details' : 'Add a new field worker to the roster' %></p>
  </div>
</div>

<form method="POST" action="<%= isEdit ? '/crew/' + editMember.id : '/crew' %>" class="space-y-5" data-wizard>
  <%- include('../partials/csrf') %>

  <!-- Step 1: Identity & Role -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="0" data-wizard-title="Identity">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Identity & Role</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Full Name <span class="text-red-500">*</span></label>
        <input type="text" name="full_name" value="<%= isEdit ? editMember.full_name : '' %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Employee ID</label>
        <input type="text" name="employee_id" value="<%= isEdit ? (editMember.employee_id || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. TS001">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Role <span class="text-red-500">*</span></label>
        <select name="role" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% const roles = [
            {val: 'traffic_controller', label: 'Traffic Controller'},
            {val: 'leading_hand', label: 'Leading Hand'},
            {val: 'supervisor', label: 'Supervisor'},
            {val: 'pilot_vehicle', label: 'Pilot Vehicle'},
            {val: 'spotter', label: 'Spotter'},
            {val: 'labourer', label: 'Labourer'},
            {val: 'other', label: 'Other'},
          ]; %>
          <% roles.forEach(r => { %>
            <option value="<%= r.val %>" <%= isEdit && editMember.role === r.val ? 'selected' : '' %>><%= r.label %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">TC Level</label>
        <select name="tcp_level" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- None --</option>
          <option value="beginner" <%= isEdit && editMember.tcp_level === 'beginner' ? 'selected' : '' %>>Beginner</option>
          <option value="intermediate" <%= isEdit && editMember.tcp_level === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
          <option value="team_leader" <%= isEdit && editMember.tcp_level === 'team_leader' ? 'selected' : '' %>>Team Leader</option>
          <option value="supervisor" <%= isEdit && editMember.tcp_level === 'supervisor' ? 'selected' : '' %>>Supervisor</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Step 2: Contact -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="1" data-wizard-title="Contact">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Contact Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Phone</label>
        <input type="tel" name="phone" value="<%= isEdit ? (editMember.phone || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Email</label>
        <input type="email" name="email" value="<%= isEdit ? (editMember.email || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="For worker portal invitations">
      </div>
    </div>
  </div>

  <!-- Step 3: Qualifications & Tickets -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="2" data-wizard-title="Qualifications">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Licences & Tickets</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Licence Type</label>
        <input type="text" name="licence_type" value="<%= isEdit ? (editMember.licence_type || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. C, LR, MR, HR">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Licence Expiry</label>
        <input type="date" name="licence_expiry" value="<%= isEdit ? (editMember.licence_expiry || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">White Card</label>
        <input type="text" name="white_card" value="<%= isEdit ? (editMember.white_card || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">White Card Expiry</label>
        <input type="date" name="white_card_expiry" value="<%= isEdit ? (editMember.white_card_expiry || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Induction Date</label>
        <input type="date" name="induction_date" value="<%= isEdit ? (editMember.induction_date || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Medical Expiry</label>
        <input type="date" name="medical_expiry" value="<%= isEdit ? (editMember.medical_expiry || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- Step 4: Employment -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5" data-wizard-step="3" data-wizard-title="Employment">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Employment</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Company</label>
        <input type="text" name="company" value="<%= isEdit ? (editMember.company || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
          placeholder="e.g. T&S Traffic Control">
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Employment Type</label>
        <select name="employment_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="employee" <%= isEdit && editMember.employment_type === 'employee' ? 'selected' : '' %>>Employee</option>
          <option value="contractor" <%= isEdit && editMember.employment_type === 'contractor' ? 'selected' : '' %>>Contractor</option>
          <option value="casual" <%= isEdit && editMember.employment_type === 'casual' ? 'selected' : '' %>>Casual</option>
        </select>
      </div>
      <div>
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Hourly Rate ($)</label>
        <input type="number" step="0.01" name="hourly_rate" value="<%= isEdit ? (editMember.hourly_rate || '') : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
    <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gray-100">
      <input type="checkbox" name="active" id="active" value="1" <%= !isEdit || editMember.active ? 'checked' : '' %>
        class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
      <label for="active" class="text-sm text-gray-700">Active</label>
    </div>
  </div>

  <noscript>
    <div class="flex items-center gap-3">
      <button type="submit" class="px-5 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <%= isEdit ? 'Update' : 'Add' %> Crew Member
      </button>
      <a href="/crew" class="px-5 py-2 text-sm text-gray-500 hover:text-gray-700">Cancel</a>
    </div>
  </noscript>
</form>
