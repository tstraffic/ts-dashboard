<% locals.currentPage = 'clients' %>
<%
  const cType = company.company_type || 'client';
  const typeLabel = cType === 'subcontractor' ? 'Subcontractor' : cType.charAt(0).toUpperCase() + cType.slice(1);

  function formatDate(d) {
    if (!d) return '-';
    return new Date(d).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function daysUntil(d) {
    if (!d) return null;
    var diff = Math.ceil((new Date(d) - new Date()) / (1000 * 60 * 60 * 24));
    return diff;
  }
%>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <a href="/clients<%= cType !== 'client' ? '?type=' + cType : '' %>" class="text-gray-400 hover:text-gray-600 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900"><%= company.company_name %></h1>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
          <% if (cType === 'client') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
          <% } else if (cType === 'subcontractor') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
          <% } else { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20<% } %>">
          <%= typeLabel %>
        </span>
        <% if (company.active) { %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700">Active</span>
        <% } else { %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-600">Inactive</span>
        <% } %>
      </div>
      <p class="text-sm text-gray-500 ml-7"><%= company.abn ? 'ABN: ' + company.abn : '' %></p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/clients/<%= company.id %>/edit" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </a>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Sidebar Info -->
    <div class="lg:col-span-1 space-y-5">
      <!-- Contact Details -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Contact Details</h3>
        <dl class="space-y-2.5 text-sm">
          <% if (company.primary_contact_name) { %>
          <div>
            <dt class="text-gray-500 text-xs">Primary Contact</dt>
            <dd class="font-medium text-gray-900"><%= company.primary_contact_name %></dd>
          </div>
          <% } %>
          <% if (company.primary_contact_phone) { %>
          <div>
            <dt class="text-gray-500 text-xs">Phone</dt>
            <dd><a href="tel:<%= company.primary_contact_phone %>" class="text-brand-600 hover:underline"><%= company.primary_contact_phone %></a></dd>
          </div>
          <% } %>
          <% if (company.primary_contact_email) { %>
          <div>
            <dt class="text-gray-500 text-xs">Email</dt>
            <dd><a href="mailto:<%= company.primary_contact_email %>" class="text-brand-600 hover:underline text-xs break-all"><%= company.primary_contact_email %></a></dd>
          </div>
          <% } %>
          <% if (company.website) { %>
          <div>
            <dt class="text-gray-500 text-xs">Website</dt>
            <dd><a href="<%= company.website.startsWith('http') ? company.website : 'https://' + company.website %>" target="_blank" class="text-brand-600 hover:underline text-xs"><%= company.website %></a></dd>
          </div>
          <% } %>
          <% if (company.address) { %>
          <div>
            <dt class="text-gray-500 text-xs">Address</dt>
            <dd class="text-gray-900 text-xs"><%= company.address %></dd>
          </div>
          <% } %>
          <% if (company.billing_address) { %>
          <div>
            <dt class="text-gray-500 text-xs">Billing Address</dt>
            <dd class="text-gray-900 text-xs"><%= company.billing_address %></dd>
          </div>
          <% } %>
          <% if (company.payment_terms) { %>
          <div>
            <dt class="text-gray-500 text-xs">Payment Terms</dt>
            <dd class="text-gray-900"><%= company.payment_terms %></dd>
          </div>
          <% } %>
          <% if (company.rating > 0) { %>
          <div>
            <dt class="text-gray-500 text-xs">Rating</dt>
            <dd class="flex items-center gap-0.5 mt-0.5">
              <% for (let i = 1; i <= 5; i++) { %>
                <svg class="w-4 h-4 <%= i <= company.rating ? 'text-amber-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
            </dd>
          </div>
          <% } %>
        </dl>
      </div>

      <!-- Subcontractor Details -->
      <% if (cType === 'subcontractor') { %>
      <div class="bg-white border border-emerald-200 rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-emerald-700 uppercase tracking-wider mb-3">Subcontractor Details</h3>
        <dl class="space-y-2.5 text-sm">
          <% if (company.trade_specialty) { %>
          <div>
            <dt class="text-gray-500 text-xs">Trade / Specialty</dt>
            <dd class="font-medium text-gray-900 capitalize"><%= company.trade_specialty.replace(/_/g, ' ') %></dd>
          </div>
          <% } %>
          <div>
            <dt class="text-gray-500 text-xs">Approval Status</dt>
            <dd>
              <% if (company.approved) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Approved</span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-600/20">Not Approved</span>
              <% } %>
            </dd>
          </div>
          <% if (company.insurance_expiry) { %>
          <div>
            <dt class="text-gray-500 text-xs">Insurance Expiry</dt>
            <dd>
              <% var insDays = daysUntil(company.insurance_expiry); %>
              <span class="font-medium <%= insDays !== null && insDays < 0 ? 'text-red-600' : insDays !== null && insDays <= 30 ? 'text-amber-600' : 'text-gray-900' %>">
                <%= formatDate(company.insurance_expiry) %>
              </span>
              <% if (insDays !== null && insDays < 0) { %>
                <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-red-50 text-red-600">EXPIRED</span>
              <% } else if (insDays !== null && insDays <= 30) { %>
                <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-amber-50 text-amber-600"><%= insDays %> days</span>
              <% } %>
            </dd>
          </div>
          <% } %>
          <% if (company.insurance_policy) { %>
          <div>
            <dt class="text-gray-500 text-xs">Policy Number</dt>
            <dd class="text-gray-900 text-xs"><%= company.insurance_policy %></dd>
          </div>
          <% } %>
        </dl>
      </div>
      <% } %>

      <!-- Supplier Details -->
      <% if (cType === 'supplier') { %>
      <div class="bg-white border border-amber-200 rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-amber-700 uppercase tracking-wider mb-3">Supplier Details</h3>
        <dl class="space-y-2.5 text-sm">
          <% if (company.product_categories) { %>
          <div>
            <dt class="text-gray-500 text-xs">Product Categories</dt>
            <dd class="flex flex-wrap gap-1 mt-1">
              <% company.product_categories.split(',').forEach(cat => { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 ring-1 ring-amber-500/20 capitalize"><%= cat.replace(/_/g, ' ') %></span>
              <% }) %>
            </dd>
          </div>
          <% } %>
          <% if (company.account_number) { %>
          <div>
            <dt class="text-gray-500 text-xs">Account Number</dt>
            <dd class="font-medium text-gray-900"><%= company.account_number %></dd>
          </div>
          <% } %>
          <div>
            <dt class="text-gray-500 text-xs">Approval Status</dt>
            <dd>
              <% if (company.approved) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Approved</span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-50 text-red-700 ring-1 ring-red-600/20">Not Approved</span>
              <% } %>
            </dd>
          </div>
        </dl>
      </div>
      <% } %>

      <!-- CRM Overview -->
      <div class="bg-white border border-brand-200 rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-brand-700 uppercase tracking-wider mb-3">Sales & CRM</h3>
        <dl class="space-y-2.5 text-sm">
          <% if (company.owner_name) { %>
          <div>
            <dt class="text-gray-500 text-xs">Account Owner</dt>
            <dd class="font-medium text-gray-900"><%= company.owner_name %></dd>
          </div>
          <% } %>
          <% if (company.bdm_name) { %>
          <div>
            <dt class="text-gray-500 text-xs">BDM Owner</dt>
            <dd class="font-medium text-gray-900"><%= company.bdm_name %></dd>
          </div>
          <% } %>
          <div>
            <dt class="text-gray-500 text-xs">Priority</dt>
            <dd>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                <%= company.priority === 'strategic' ? 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20' : company.priority === 'high' ? 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' : company.priority === 'low' ? 'bg-gray-100 text-gray-600' : 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20' %>">
                <%= (company.priority || 'normal').charAt(0).toUpperCase() + (company.priority || 'normal').slice(1) %>
              </span>
            </dd>
          </div>
          <% if (typeof pipelineSummary !== 'undefined') { %>
          <div>
            <dt class="text-gray-500 text-xs">Open Pipeline</dt>
            <dd class="font-medium text-gray-900"><%= pipelineSummary.open_count %> opps &middot; $<%= (pipelineSummary.open_value || 0).toLocaleString() %></dd>
          </div>
          <div>
            <dt class="text-gray-500 text-xs">Won Deals</dt>
            <dd class="font-medium text-emerald-700"><%= pipelineSummary.won_count %> &middot; $<%= (pipelineSummary.won_value || 0).toLocaleString() %></dd>
          </div>
          <% } %>
          <% if (company.last_contacted_date) { %>
          <div>
            <dt class="text-gray-500 text-xs">Last Contacted</dt>
            <dd class="<%= daysUntil(company.last_contacted_date) !== null && Math.abs(daysUntil(company.last_contacted_date)) > 30 ? 'text-red-600 font-medium' : 'text-gray-900' %>">
              <%= formatDate(company.last_contacted_date) %>
            </dd>
          </div>
          <% } %>
          <% if (company.next_action_date) { %>
          <div>
            <dt class="text-gray-500 text-xs">Next Action</dt>
            <dd>
              <span class="<%= daysUntil(company.next_action_date) !== null && daysUntil(company.next_action_date) < 0 ? 'text-red-600 font-medium' : 'text-gray-900' %>"><%= formatDate(company.next_action_date) %></span>
              <% if (company.next_action_note) { %><p class="text-xs text-gray-500 mt-0.5"><%= company.next_action_note %></p><% } %>
            </dd>
          </div>
          <% } %>
          <% if (company.service_interests) { %>
          <div>
            <dt class="text-gray-500 text-xs">Service Interests</dt>
            <dd class="flex flex-wrap gap-1 mt-1">
              <% company.service_interests.split(',').forEach(svc => { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-brand-50 text-brand-700 ring-1 ring-brand-500/20 capitalize"><%= svc.replace(/_/g, ' ') %></span>
              <% }) %>
            </dd>
          </div>
          <% } %>
        </dl>
        <!-- Quick CRM Actions -->
        <div class="flex flex-wrap gap-2 mt-4 pt-3 border-t border-gray-100">
          <a href="/crm/activities/new?client_id=<%= company.id %>&type=call" class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-medium rounded-lg transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Log Call
          </a>
          <a href="/crm/activities/new?client_id=<%= company.id %>&type=meeting" class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-purple-50 hover:bg-purple-100 text-purple-700 text-xs font-medium rounded-lg transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Log Meeting
          </a>
          <a href="/opportunities/new?client_id=<%= company.id %>" class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-emerald-50 hover:bg-emerald-100 text-emerald-700 text-xs font-medium rounded-lg transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            New Opportunity
          </a>
        </div>
      </div>

      <!-- Notes -->
      <% if (company.notes) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3">Notes</h3>
        <p class="text-sm text-gray-600 whitespace-pre-line"><%= company.notes %></p>
      </div>
      <% } %>

      <!-- Contacts -->
      <% if (contacts.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Contacts (<%= contacts.length %>)</h3>
          <a href="/contacts/new?company_id=<%= company.id %>" class="text-xs text-brand-600 hover:underline font-medium">+ Add</a>
        </div>
        <div class="space-y-3">
          <% contacts.forEach(contact => { %>
          <div class="flex items-start gap-3 pb-3 border-b border-gray-100 last:border-0 last:pb-0">
            <div class="w-8 h-8 rounded-full bg-brand-50 flex items-center justify-center flex-shrink-0">
              <span class="text-xs font-medium text-brand-700"><%= contact.full_name.split(' ').map(n => n[0]).join('').substring(0, 2) %></span>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900"><%= contact.full_name %></p>
              <% if (contact.position) { %><p class="text-xs text-gray-500"><%= contact.position %></p><% } %>
              <% if (contact.phone) { %><p class="text-xs text-gray-500"><%= contact.phone %></p><% } %>
              <% if (contact.email) { %><p class="text-xs text-gray-500"><%= contact.email %></p><% } %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-5">
      <% if (cType === 'client') { %>
      <!-- Projects (clients only) -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Projects (<%= projects.length %>)</h3>
          <a href="/projects/new?client_id=<%= company.id %>" class="text-xs text-brand-600 hover:underline font-medium">+ New Project</a>
        </div>
        <% if (projects.length === 0) { %>
          <div class="p-6 text-center text-gray-500 text-sm">No projects linked to this client yet.</div>
        <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Job #</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden sm:table-cell">Suburb</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Status</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden md:table-cell">PM</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden lg:table-cell">Start</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% projects.forEach(p => { %>
              <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/projects/<%= p.id %>'">
                <td class="px-4 py-2.5 font-medium text-brand-600"><%= p.job_number %></td>
                <td class="px-4 py-2.5 text-gray-600 hidden sm:table-cell"><%= p.suburb %></td>
                <td class="px-4 py-2.5">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                    <%= p.status === 'active' ? 'bg-emerald-50 text-emerald-700' : p.status === 'on_hold' ? 'bg-amber-50 text-amber-700' : p.status === 'completed' ? 'bg-gray-100 text-gray-600' : 'bg-blue-50 text-blue-700' %>">
                    <%= p.status %>
                  </span>
                </td>
                <td class="px-4 py-2.5 text-gray-600 text-xs hidden md:table-cell"><%= p.pm_name || '-' %></td>
                <td class="px-4 py-2.5 text-gray-600 text-xs hidden lg:table-cell"><%= p.start_date || '-' %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Recent Shifts -->
      <% if (recentShifts.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Recent Shifts (<%= recentShifts.length %>)</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Job #</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden sm:table-cell">Suburb</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Date</th>
                <th class="px-4 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase">Crew</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% recentShifts.forEach(s => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-2.5 font-medium text-gray-900"><%= s.job_number %></td>
                <td class="px-4 py-2.5 text-gray-600 hidden sm:table-cell"><%= s.suburb %></td>
                <td class="px-4 py-2.5 text-gray-600 text-xs"><%= s.start_date %></td>
                <td class="px-4 py-2.5 text-center"><%= s.crew_count || 0 %></td>
                <td class="px-4 py-2.5">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                    <%= s.status === 'active' ? 'bg-emerald-50 text-emerald-700' : s.status === 'completed' ? 'bg-gray-100 text-gray-600' : 'bg-blue-50 text-blue-700' %>">
                    <%= s.status %>
                  </span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>
      <% } %>

      <!-- Opportunities -->
      <% if (typeof opportunities !== 'undefined' && opportunities.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Opportunities (<%= opportunities.length %>)</h3>
          <a href="/opportunities/new?client_id=<%= company.id %>" class="text-xs text-brand-600 hover:underline font-medium">+ New</a>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Opportunity</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden sm:table-cell">Stage</th>
                <th class="px-4 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase">Value</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden md:table-cell">Close Date</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase hidden lg:table-cell">Owner</th>
                <th class="px-4 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% opportunities.forEach(opp => { %>
              <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/opportunities/<%= opp.id %>'">
                <td class="px-4 py-2.5">
                  <p class="font-medium text-brand-600"><%= opp.opportunity_number %></p>
                  <p class="text-xs text-gray-500 truncate max-w-[200px]"><%= opp.title %></p>
                </td>
                <td class="px-4 py-2.5 hidden sm:table-cell">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-blue-50 text-blue-700 ring-1 ring-blue-600/20 capitalize"><%= (opp.stage || '').replace(/_/g, ' ') %></span>
                </td>
                <td class="px-4 py-2.5 text-right font-medium text-gray-900">$<%= (opp.estimated_value || 0).toLocaleString() %></td>
                <td class="px-4 py-2.5 text-gray-600 text-xs hidden md:table-cell"><%= formatDate(opp.expected_close_date) %></td>
                <td class="px-4 py-2.5 text-gray-600 text-xs hidden lg:table-cell"><%= opp.owner_name || '-' %></td>
                <td class="px-4 py-2.5">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                    <%= opp.status === 'won' ? 'bg-emerald-50 text-emerald-700' : opp.status === 'lost' ? 'bg-gray-100 text-gray-600' : opp.status === 'on_hold' ? 'bg-amber-50 text-amber-700' : 'bg-blue-50 text-blue-700' %>">
                    <%= opp.status %>
                  </span>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- CRM Activity Timeline -->
      <% if (typeof crmActivities !== 'undefined' && crmActivities.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">CRM Activity (<%= crmActivities.length %>)</h3>
          <a href="/crm/activities/new?client_id=<%= company.id %>" class="text-xs text-brand-600 hover:underline font-medium">+ Log Activity</a>
        </div>
        <div class="divide-y divide-gray-100">
          <% crmActivities.forEach(act => { %>
          <div class="px-5 py-3">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0
                <%= act.activity_type === 'call' ? 'bg-blue-50' : act.activity_type === 'email' ? 'bg-sky-50' : act.activity_type === 'meeting' ? 'bg-purple-50' : act.activity_type === 'site_visit' ? 'bg-emerald-50' : 'bg-gray-50' %>">
                <% if (act.activity_type === 'call') { %>
                  <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <% } else if (act.activity_type === 'email') { %>
                  <svg class="w-4 h-4 text-sky-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <% } else if (act.activity_type === 'meeting') { %>
                  <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <% } else { %>
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <% } %>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-0.5">
                  <span class="text-sm font-medium text-gray-900 truncate"><%= act.subject %></span>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-gray-100 text-gray-500 uppercase"><%= act.activity_type.replace(/_/g, ' ') %></span>
                  <% if (act.is_completed) { %>
                    <svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <% } %>
                </div>
                <% if (act.notes) { %><p class="text-xs text-gray-500 line-clamp-2"><%= act.notes %></p><% } %>
                <p class="text-[10px] text-gray-400 mt-1">
                  <%= formatDate(act.activity_date) %> by <%= act.owner_name || 'Unknown' %>
                  <% if (act.contact_name) { %> &middot; with <%= act.contact_name %><% } %>
                  <% if (act.opportunity_number) { %> &middot; <%= act.opportunity_number %><% } %>
                </p>
                <% if (act.next_step) { %>
                <p class="text-xs text-brand-600 mt-1">Next: <%= act.next_step %><% if (act.next_step_due_date) { %> (due <%= formatDate(act.next_step_due_date) %>)<% } %></p>
                <% } %>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Recent Communications (all types) -->
      <% if (typeof comms !== 'undefined' && comms.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-200 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Recent Communications</h3>
          <a href="/contacts/comms" class="text-xs text-brand-600 hover:underline font-medium">View All</a>
        </div>
        <div class="divide-y divide-gray-100">
          <% comms.forEach(comm => { %>
          <div class="px-5 py-3">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-0.5">
                  <% if (comm.direction === 'outgoing') { %>
                    <svg class="w-3.5 h-3.5 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                  <% } else { %>
                    <svg class="w-3.5 h-3.5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                  <% } %>
                  <span class="text-sm font-medium text-gray-900 truncate"><%= comm.subject %></span>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-gray-100 text-gray-500 uppercase"><%= comm.comm_type %></span>
                </div>
                <p class="text-xs text-gray-500 line-clamp-2 ml-5"><%= comm.summary %></p>
                <p class="text-[10px] text-gray-400 ml-5 mt-1">
                  <%= formatDate(comm.comm_date) %> by <%= comm.logged_by_name %>
                  <% if (comm.contact_name) { %> &middot; with <%= comm.contact_name %><% } %>
                </p>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (cType !== 'client' && projects.length === 0 && (typeof comms === 'undefined' || comms.length === 0)) { %>
      <!-- Empty state for non-client companies with no data -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
        <div class="w-14 h-14 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        </div>
        <h3 class="text-gray-900 font-semibold text-base mb-1">No activity yet</h3>
        <p class="text-gray-500 text-sm">Communication logs and linked projects will appear here.</p>
      </div>
      <% } %>
    </div>
  </div>
</div>
