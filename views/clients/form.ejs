<% locals.currentPage = 'clients' %>
<% const isEdit = company !== null && typeof company !== 'undefined' %>
<% const companyType = isEdit ? (company.company_type || 'client') : (typeof preselectedType !== 'undefined' ? preselectedType : 'client') %>

<div class="space-y-6 max-w-3xl">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit ' + company.company_name : 'Add New Company' %></h1>
      <p class="text-sm text-gray-500 mt-1"><%= isEdit ? 'Update company details' : 'Register a new client, subcontractor, or supplier' %></p>
    </div>
    <a href="<%= isEdit ? '/clients/' + company.id : '/clients' %>" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition border border-gray-300">
      Cancel
    </a>
  </div>

  <form method="POST" action="<%= isEdit ? '/clients/' + company.id : '/clients' %>" class="space-y-6">

    <!-- Company Type -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Company Type</h3>
      <div class="flex flex-wrap gap-3">
        <label class="flex-1 min-w-[120px] cursor-pointer">
          <input type="radio" name="company_type" value="client" class="peer sr-only" <%= companyType === 'client' ? 'checked' : '' %> onchange="toggleTypeFields()">
          <div class="peer-checked:ring-2 peer-checked:ring-blue-500 peer-checked:bg-blue-50 border border-gray-200 rounded-xl p-3 text-center transition-all hover:bg-gray-50">
            <svg class="w-6 h-6 mx-auto mb-1 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            <span class="text-sm font-semibold text-gray-900">Client</span>
            <p class="text-[10px] text-gray-500 mt-0.5">Companies you work for</p>
          </div>
        </label>
        <label class="flex-1 min-w-[120px] cursor-pointer">
          <input type="radio" name="company_type" value="subcontractor" class="peer sr-only" <%= companyType === 'subcontractor' ? 'checked' : '' %> onchange="toggleTypeFields()">
          <div class="peer-checked:ring-2 peer-checked:ring-emerald-500 peer-checked:bg-emerald-50 border border-gray-200 rounded-xl p-3 text-center transition-all hover:bg-gray-50">
            <svg class="w-6 h-6 mx-auto mb-1 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-sm font-semibold text-gray-900">Subcontractor</span>
            <p class="text-[10px] text-gray-500 mt-0.5">Companies you hire</p>
          </div>
        </label>
        <label class="flex-1 min-w-[120px] cursor-pointer">
          <input type="radio" name="company_type" value="supplier" class="peer sr-only" <%= companyType === 'supplier' ? 'checked' : '' %> onchange="toggleTypeFields()">
          <div class="peer-checked:ring-2 peer-checked:ring-amber-500 peer-checked:bg-amber-50 border border-gray-200 rounded-xl p-3 text-center transition-all hover:bg-gray-50">
            <svg class="w-6 h-6 mx-auto mb-1 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            <span class="text-sm font-semibold text-gray-900">Supplier</span>
            <p class="text-[10px] text-gray-500 mt-0.5">Companies you buy from</p>
          </div>
        </label>
      </div>
    </div>

    <!-- Company Information -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Company Information</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Company Name <span class="text-red-500">*</span></label>
          <input type="text" name="company_name" value="<%= isEdit ? company.company_name : '' %>" required
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. ABC Civil Contractors">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">ABN</label>
          <input type="text" name="abn" value="<%= isEdit ? company.abn : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. 12 345 678 901">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
          <input type="text" name="website" value="<%= isEdit ? (company.website || '') : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. www.company.com.au">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Payment Terms</label>
          <select name="payment_terms"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="" <%= !isEdit || !company.payment_terms ? 'selected' : '' %>>Select...</option>
            <% ['7 days','14 days','30 days','45 days','60 days','EOM','EOM+30','COD'].forEach(term => { %>
              <option value="<%= term %>" <%= isEdit && company.payment_terms === term ? 'selected' : '' %>><%= term === 'COD' ? 'Cash on Delivery' : term === 'EOM' ? 'End of Month' : term %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Rating</label>
          <div class="flex items-center gap-1 mt-1" id="rating-stars">
            <% for (let i = 1; i <= 5; i++) { %>
              <button type="button" onclick="setRating(<%= i %>)" class="star-btn p-0.5 transition-colors">
                <svg class="w-6 h-6 <%= isEdit && company.rating >= i ? 'text-amber-400' : 'text-gray-200' %> hover:text-amber-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </button>
            <% } %>
            <button type="button" onclick="setRating(0)" class="ml-2 text-xs text-gray-400 hover:text-gray-600">Clear</button>
            <input type="hidden" name="rating" id="rating-value" value="<%= isEdit ? (company.rating || 0) : 0 %>">
          </div>
        </div>
      </div>
    </div>

    <!-- Primary Contact -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Primary Contact</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contact Name</label>
          <input type="text" name="primary_contact_name" value="<%= isEdit ? company.primary_contact_name : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. John Smith">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <input type="text" name="primary_contact_phone" value="<%= isEdit ? company.primary_contact_phone : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. 0412 345 678">
        </div>
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="primary_contact_email" value="<%= isEdit ? company.primary_contact_email : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. john@company.com.au">
        </div>
      </div>
    </div>

    <!-- Subcontractor Fields -->
    <div id="subcontractor-fields" class="bg-white border border-emerald-200 rounded-xl shadow-sm p-6 <%= companyType !== 'subcontractor' ? 'hidden' : '' %>">
      <h3 class="text-sm font-semibold text-emerald-700 uppercase tracking-wider mb-4">Subcontractor Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Trade / Specialty</label>
          <select name="trade_specialty"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
            <option value="">Select trade...</option>
            <% ['traffic_control','line_marking','electrical','civil_works','signage','fencing','surveying','environmental','other'].forEach(trade => { %>
              <option value="<%= trade %>" <%= isEdit && company.trade_specialty === trade ? 'selected' : '' %>><%= trade.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Insurance Expiry</label>
          <input type="date" name="insurance_expiry" value="<%= isEdit && company.insurance_expiry ? company.insurance_expiry : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Insurance Policy #</label>
          <input type="text" name="insurance_policy" value="<%= isEdit ? (company.insurance_policy || '') : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
            placeholder="e.g. QBE-PL-123456">
        </div>
        <div class="flex items-end pb-1">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" name="approved" value="1"
              <%= isEdit ? (company.approved ? 'checked' : '') : 'checked' %>
              class="w-5 h-5 rounded border-gray-300 bg-white text-emerald-500 focus:ring-emerald-500 focus:ring-offset-0 focus:ring-2 cursor-pointer">
            <span class="text-sm text-gray-700">Approved Subcontractor</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Supplier Fields -->
    <div id="supplier-fields" class="bg-white border border-amber-200 rounded-xl shadow-sm p-6 <%= companyType !== 'supplier' ? 'hidden' : '' %>">
      <h3 class="text-sm font-semibold text-amber-700 uppercase tracking-wider mb-4">Supplier Details</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Product Categories</label>
          <p class="text-xs text-gray-400 mb-2">Select all that apply</p>
          <div class="flex flex-wrap gap-2">
            <%
              const productOptions = ['barriers','signs','cones','delineators','vms','lighting','arrow_boards','vehicles','ppe','other'];
              const selectedProducts = isEdit && company.product_categories ? company.product_categories.split(',') : [];
            %>
            <% productOptions.forEach(product => { %>
              <label class="cursor-pointer">
                <input type="checkbox" name="product_cat[]" value="<%= product %>"
                  <%= selectedProducts.includes(product) ? 'checked' : '' %>
                  class="peer sr-only" onchange="updateProductCategories()">
                <span class="peer-checked:bg-amber-100 peer-checked:text-amber-800 peer-checked:ring-1 peer-checked:ring-amber-500 inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-100 text-gray-600 transition-all hover:bg-gray-200">
                  <%= product.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %>
                </span>
              </label>
            <% }) %>
          </div>
          <input type="hidden" name="product_categories" id="product-categories-value" value="<%= isEdit ? (company.product_categories || '') : '' %>">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Account Number</label>
          <input type="text" name="account_number" value="<%= isEdit ? (company.account_number || '') : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"
            placeholder="e.g. ACC-12345">
        </div>
        <div class="flex items-end pb-1">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" name="approved" value="1"
              <%= isEdit ? (company.approved ? 'checked' : '') : 'checked' %>
              class="w-5 h-5 rounded border-gray-300 bg-white text-amber-500 focus:ring-amber-500 focus:ring-offset-0 focus:ring-2 cursor-pointer">
            <span class="text-sm text-gray-700">Approved Supplier</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Addresses -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Addresses</h3>
      <div class="grid grid-cols-1 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Office / Site Address</label>
          <input type="text" name="address" value="<%= isEdit ? company.address : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. 123 George St, Sydney NSW 2000">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Billing Address</label>
          <input type="text" name="billing_address" value="<%= isEdit ? company.billing_address : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="e.g. PO Box 456, Sydney NSW 2001">
        </div>
      </div>
    </div>

    <!-- Notes -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Notes</h3>
      <textarea name="notes" rows="3"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 resize-y"
        placeholder="Any additional notes..."><%= isEdit ? company.notes : '' %></textarea>
    </div>

    <% if (isEdit) { %>
    <!-- Status -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
      <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-4">Status</h3>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="active" value="1" <%= company.active ? 'checked' : '' %>
          class="w-4 h-4 text-brand-600 border-gray-300 rounded focus:ring-brand-500">
        <span class="text-sm text-gray-700">Active company</span>
      </label>
    </div>
    <% } %>

    <!-- Submit -->
    <div class="flex items-center gap-3">
      <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <%= isEdit ? 'Update Company' : 'Create Company' %>
      </button>
      <a href="<%= isEdit ? '/clients/' + company.id : '/clients' %>" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition border border-gray-300">
        Cancel
      </a>
    </div>
  </form>
</div>

<script>
function toggleTypeFields() {
  var type = document.querySelector('input[name="company_type"]:checked');
  if (!type) return;
  var val = type.value;
  document.getElementById('subcontractor-fields').classList.toggle('hidden', val !== 'subcontractor');
  document.getElementById('supplier-fields').classList.toggle('hidden', val !== 'supplier');
}

function setRating(val) {
  document.getElementById('rating-value').value = val;
  var stars = document.querySelectorAll('#rating-stars .star-btn svg');
  stars.forEach(function(svg, i) {
    svg.classList.toggle('text-amber-400', i < val);
    svg.classList.toggle('text-gray-200', i >= val);
  });
}

function updateProductCategories() {
  var checked = document.querySelectorAll('input[name="product_cat[]"]:checked');
  var values = [];
  checked.forEach(function(cb) { values.push(cb.value); });
  document.getElementById('product-categories-value').value = values.join(',');
}
</script>
