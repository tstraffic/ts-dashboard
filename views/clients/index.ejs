<% locals.currentPage = 'clients' %>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Company Directory</h1>
      <p class="text-sm text-gray-500 mt-0.5">Clients, subcontractors &amp; suppliers</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/clients/new<%= filters.type ? '?type=' + filters.type : '' %>" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add Company
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <a href="/clients" class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 hover-lift block <%= !filters.type ? 'ring-2 ring-brand-500' : '' %>">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">All Companies</p>
      <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.total %></p>
    </a>
    <a href="/clients?type=client" class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 hover-lift block <%= filters.type === 'client' ? 'ring-2 ring-blue-500' : '' %>">
      <p class="text-[10px] font-bold text-blue-500 uppercase tracking-widest">Clients</p>
      <p class="text-xl font-bold text-blue-700 mt-0.5"><%= stats.clients %></p>
    </a>
    <a href="/clients?type=subcontractor" class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 hover-lift block <%= filters.type === 'subcontractor' ? 'ring-2 ring-emerald-500' : '' %>">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Subcontractors</p>
      <p class="text-xl font-bold text-emerald-700 mt-0.5"><%= stats.subcontractors %></p>
    </a>
    <a href="/clients?type=supplier" class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 hover-lift block <%= filters.type === 'supplier' ? 'ring-2 ring-amber-500' : '' %>">
      <p class="text-[10px] font-bold text-amber-500 uppercase tracking-widest">Suppliers</p>
      <p class="text-xl font-bold text-amber-700 mt-0.5"><%= stats.suppliers %></p>
    </a>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <form method="GET" action="/clients" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
      <% if (filters.type) { %><input type="hidden" name="type" value="<%= filters.type %>"><% } %>
      <div class="flex-1 min-w-0 sm:min-w-[200px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Search</label>
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Company, ABN, contact, trade..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div class="flex gap-2 w-full sm:w-auto">
        <div class="flex-1 sm:flex-none sm:min-w-[120px]">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
          <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            <option value="">All</option>
            <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
        <a href="/clients<%= filters.type ? '?type=' + filters.type : '' %>" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
      </div>
    </form>
  </div>

  <!-- Companies Table -->
  <% if (companies.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No companies found</h3>
      <p class="text-gray-500 text-sm mb-4">Add clients, subcontractors, and suppliers to your directory.</p>
      <a href="/clients/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Add First Company
      </a>
    </div>
  <% } else { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Company</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Primary Contact</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Phone</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">
              <%= filters.type === 'subcontractor' ? 'Trade' : filters.type === 'supplier' ? 'Products' : 'Detail' %>
            </th>
            <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">
              <%= filters.type === 'subcontractor' || filters.type === 'supplier' ? 'Approved' : 'Projects' %>
            </th>
            <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Rating</th>
            <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% companies.forEach(c => { %>
          <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/clients/<%= c.id %>'">
            <td class="px-3 py-2.5">
              <span class="font-medium text-gray-900"><%= c.company_name %></span>
              <% if (c.abn) { %><span class="block text-[10px] text-gray-400">ABN: <%= c.abn %></span><% } %>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                <% if (c.company_type === 'client') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                <% } else if (c.company_type === 'subcontractor') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                <% } else if (c.company_type === 'supplier') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else { %>bg-gray-100 text-gray-600<% } %>">
                <%= c.company_type === 'subcontractor' ? 'SUBBIE' : c.company_type.toUpperCase() %>
              </span>
            </td>
            <td class="px-3 py-2.5 text-gray-600 text-xs hidden sm:table-cell"><%= c.primary_contact_name || '-' %></td>
            <td class="px-3 py-2.5 hidden md:table-cell">
              <% if (c.primary_contact_phone) { %>
                <a href="tel:<%= c.primary_contact_phone %>" class="text-gray-600 hover:text-brand-600 text-xs" onclick="event.stopPropagation()"><%= c.primary_contact_phone %></a>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-xs text-gray-600 hidden lg:table-cell">
              <% if (c.company_type === 'subcontractor' && c.trade_specialty) { %>
                <span class="capitalize"><%= c.trade_specialty.replace(/_/g, ' ') %></span>
              <% } else if (c.company_type === 'supplier' && c.product_categories) { %>
                <span class="capitalize"><%= c.product_categories.split(',').slice(0, 2).join(', ') %><%= c.product_categories.split(',').length > 2 ? '...' : '' %></span>
              <% } else if (c.company_type === 'client') { %>
                <%= c.payment_terms || '-' %>
              <% } else { %>
                <span class="text-gray-300">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-center hidden sm:table-cell">
              <% if (c.company_type === 'client') { %>
                <% if (c.active_jobs > 0) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700"><%= c.active_jobs %></span>
                <% } else { %>
                  <span class="text-gray-300">0</span>
                <% } %>
              <% } else { %>
                <% if (c.approved) { %>
                  <svg class="w-4 h-4 text-emerald-500 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <% } else { %>
                  <svg class="w-4 h-4 text-gray-300 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                <% } %>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-center hidden lg:table-cell">
              <% if (c.rating > 0) { %>
                <div class="flex items-center justify-center gap-0.5">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <svg class="w-3 h-3 <%= i <= c.rating ? 'text-amber-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  <% } %>
                </div>
              <% } else { %>
                <span class="text-gray-300 text-xs">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-center">
              <% if (c.active) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Active</span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-100 text-gray-500">Inactive</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <div class="mt-2 text-xs text-gray-400"><%= companies.length %> compan<%= companies.length !== 1 ? 'ies' : 'y' %> found</div>
  <% } %>
</div>
