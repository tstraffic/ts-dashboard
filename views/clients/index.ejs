<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Client Register</h1>
      <p class="text-sm text-gray-500 mt-1">Manage clients and their associated projects</p>
    </div>
    <a href="/clients/new" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Client
    </a>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Clients</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= clients.length %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Active Clients</p>
      <p class="text-2xl font-bold text-emerald-600 mt-1"><%= clients.filter(c => c.active).length %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">With Active Projects</p>
      <p class="text-2xl font-bold text-brand-600 mt-1"><%= clients.filter(c => c.active_jobs > 0).length %></p>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <form method="GET" action="/clients" class="flex flex-wrap items-center gap-3">
      <div class="flex rounded-lg overflow-hidden border border-gray-300">
        <a href="/clients?search=<%= filters.search || '' %>" class="px-3 py-1.5 text-xs font-medium <%= !filters.status ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">All</a>
        <a href="/clients?status=active&search=<%= filters.search || '' %>" class="px-3 py-1.5 text-xs font-medium border-l border-gray-300 <%= filters.status === 'active' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Active</a>
        <a href="/clients?status=inactive&search=<%= filters.search || '' %>" class="px-3 py-1.5 text-xs font-medium border-l border-gray-300 <%= filters.status === 'inactive' ? 'bg-gray-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-100' %>">Inactive</a>
      </div>
      <div class="flex-1 min-w-[200px]">
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search company, ABN, contact..."
          class="w-full px-3 py-1.5 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <% if (filters.status) { %><input type="hidden" name="status" value="<%= filters.status %>"><% } %>
      <button type="submit" class="px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg border border-gray-300">Search</button>
    </form>
  </div>

  <!-- Clients Table -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (clients.length === 0) { %>
      <div class="p-10 text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        <p class="text-gray-500 text-sm font-medium">No clients yet</p>
        <p class="text-gray-400 text-xs mt-1">Clients are the companies you deliver projects for. Add a client to start linking jobs and contacts.</p>
        <a href="/clients/new" class="inline-flex items-center mt-3 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Add First Client
        </a>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Company</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">ABN</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Primary Contact</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Phone</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Active Projects</th>
            <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% clients.forEach(client => { %>
          <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/clients/<%= client.id %>'">
            <td class="px-4 py-3">
              <span class="font-medium text-gray-900"><%= client.company_name %></span>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= client.abn || '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= client.primary_contact_name || '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= client.primary_contact_phone || '-' %></td>
            <td class="px-4 py-3 text-gray-600"><%= client.primary_contact_email || '-' %></td>
            <td class="px-4 py-3 text-center">
              <% if (client.active_jobs > 0) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700"><%= client.active_jobs %></span>
              <% } else { %>
                <span class="text-gray-400">0</span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if (client.active) { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">Active</span>
              <% } else { %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Inactive</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
