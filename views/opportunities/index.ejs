<% locals.currentPage = 'pipeline' %>
<%
  function formatCurrency(v) {
    return '$' + (v || 0).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }
  function formatDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }
  const today = new Date().toISOString().split('T')[0];

  // Stage colors from settingsOptions
  const stageColorMap = {};
  const stageLabelMap = {};
  if (typeof settingsOptions !== 'undefined' && settingsOptions.opportunity_stages) {
    settingsOptions.opportunity_stages.forEach(function(opt) {
      stageColorMap[opt.key] = opt.color || 'gray';
      stageLabelMap[opt.key] = opt.label || opt.key;
    });
  }

  function stageColor(stage) {
    const color = stageColorMap[stage] || 'gray';
    const map = {
      sky: 'bg-sky-50 text-sky-700 ring-1 ring-sky-600/20',
      blue: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
      indigo: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',
      purple: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
      amber: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
      emerald: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      green: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      red: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
      gray: 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20',
      orange: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
      teal: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20',
      rose: 'bg-rose-50 text-rose-700 ring-1 ring-rose-600/20'
    };
    return map[color] || map.gray;
  }
  function stageLabel(stage) {
    return stageLabelMap[stage] || (stage || '').replace(/_/g, ' ');
  }

  const statusColors = {
    open: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    won: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    lost: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    on_hold: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20'
  };
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Opportunities</h1>
    <p class="text-gray-500 text-sm mt-0.5">Track and manage your sales pipeline</p>
  </div>
  <div class="flex items-center gap-2">
    <a href="/opportunities/pipeline" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>
      Pipeline View
    </a>
    <a href="/opportunities/new" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      New Opportunity
    </a>
  </div>
</div>

<!-- Stat Cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Open</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= stats.total_open || 0 %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Pipeline Value</p>
    <p class="text-xl font-bold text-brand-600 mt-0.5"><%= formatCurrency(stats.pipeline_value) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Weighted Value</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= formatCurrency(stats.weighted_pipeline) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Won This Month</p>
    <p class="text-xl font-bold text-emerald-600 mt-0.5"><%= stats.won_this_month || 0 %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Lost This Month</p>
    <p class="text-xl font-bold <%= (stats.lost_this_month || 0) > 0 ? 'text-red-600' : 'text-gray-900' %> mt-0.5"><%= stats.lost_this_month || 0 %></p>
  </div>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/opportunities" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <div class="flex-1 min-w-0 sm:min-w-[180px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Title, account, opp number..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[120px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Owner</label>
        <select name="owner" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Owners</option>
          <% (users || []).forEach(function(u) { %>
            <option value="<%= u.id %>" <%= filters.owner == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Stage</label>
        <select name="stage" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Stages</option>
          <% if (typeof settingsOptions !== 'undefined' && settingsOptions.opportunity_stages) { %>
            <% settingsOptions.opportunity_stages.forEach(function(opt) { %>
              <option value="<%= opt.key %>" <%= filters.stage === opt.key ? 'selected' : '' %>><%= opt.label || opt.key %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[110px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Status</label>
        <select name="status" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="" <%= !filters.status ? 'selected' : '' %>>All</option>
          <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="won" <%= filters.status === 'won' ? 'selected' : '' %>>Won</option>
          <option value="lost" <%= filters.status === 'lost' ? 'selected' : '' %>>Lost</option>
          <option value="on_hold" <%= filters.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[140px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Sort</label>
        <select name="sort" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="updated" <%= filters.sort === 'updated' ? 'selected' : '' %>>Last Updated</option>
          <option value="created" <%= filters.sort === 'created' ? 'selected' : '' %>>Created</option>
          <option value="value_desc" <%= filters.sort === 'value_desc' ? 'selected' : '' %>>Value (High-Low)</option>
          <option value="value_asc" <%= filters.sort === 'value_asc' ? 'selected' : '' %>>Value (Low-High)</option>
          <option value="close_date" <%= filters.sort === 'close_date' ? 'selected' : '' %>>Close Date</option>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/opportunities" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Opportunities Table -->
<% if (!opportunities || opportunities.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
    <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No opportunities found</h3>
    <p class="text-gray-500 text-sm mb-1">Opportunities represent potential deals in your sales pipeline.</p>
    <p class="text-gray-400 text-xs mb-4">Try adjusting your filters or create a new opportunity.</p>
    <a href="/opportunities/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      New Opportunity
    </a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Opp #</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Title</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Account</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Stage</th>
        <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Value</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Close Date</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Owner</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Next Step</th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Status</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% opportunities.forEach(function(opp) {
        const closeDate = opp.expected_close_date ? opp.expected_close_date.split('T')[0] : null;
        const isOverdueClose = closeDate && closeDate < today && opp.status === 'open';
        const isWon = opp.status === 'won';
        const isLost = opp.status === 'lost';
      %>
      <tr class="hover:bg-gray-50 <%= isOverdueClose ? 'border-l-4 border-l-red-400' : isWon ? 'bg-emerald-50/30' : isLost ? 'opacity-60' : '' %>">
        <td class="px-3 py-2.5">
          <a href="/opportunities/<%= opp.id %>" class="text-brand-600 hover:text-brand-700 font-semibold text-sm hover:underline">OPP-<%= String(opp.id).padStart(3, '0') %></a>
        </td>
        <td class="px-3 py-2.5">
          <a href="/opportunities/<%= opp.id %>" class="text-sm font-medium text-gray-900 hover:text-brand-600 transition"><%= opp.title %></a>
          <p class="text-gray-400 text-xs truncate max-w-[180px] md:hidden"><%= opp.client_name || '-' %></p>
        </td>
        <td class="px-3 py-2.5 hidden md:table-cell">
          <% if (opp.client_id) { %>
            <a href="/clients/<%= opp.client_id %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium"><%= opp.client_name || '-' %></a>
          <% } else { %>
            <span class="text-xs text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= stageColor(opp.stage) %>">
            <%= stageLabel(opp.stage) %>
          </span>
        </td>
        <td class="px-3 py-2.5 text-right hidden sm:table-cell">
          <span class="text-sm font-medium text-gray-900 tabular-nums"><%= formatCurrency(opp.estimated_value) %></span>
        </td>
        <td class="px-3 py-2.5 hidden lg:table-cell">
          <% if (closeDate) { %>
            <span class="text-xs tabular-nums <%= isOverdueClose ? 'text-red-600 font-semibold' : 'text-gray-500' %>"><%= formatDate(closeDate) %></span>
          <% } else { %>
            <span class="text-xs text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-xs text-gray-600 hidden lg:table-cell truncate max-w-[100px]"><%= opp.owner_name || '-' %></td>
        <td class="px-3 py-2.5 hidden xl:table-cell">
          <% if (opp.next_step) { %>
            <p class="text-xs text-gray-600 truncate max-w-[140px]"><%= opp.next_step %></p>
            <% if (opp.next_step_due) { %>
              <span class="text-[10px] text-gray-400 tabular-nums">Due: <%= formatDate(opp.next_step_due) %></span>
            <% } %>
          <% } else { %>
            <span class="text-xs text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-center hidden sm:table-cell">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusColors[opp.status] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
            <%= (opp.status || 'open').replace(/_/g, ' ') %>
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-2 text-xs text-gray-400"><%= opportunities.length %> opportunit<%= opportunities.length !== 1 ? 'ies' : 'y' %> found</div>
<% } %>