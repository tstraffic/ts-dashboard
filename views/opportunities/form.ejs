<% locals.currentPage = 'pipeline' %>
<% const isEdit = opportunity !== null && typeof opportunity !== 'undefined' && opportunity %>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/opportunities" class="hover:text-gray-900 transition">Opportunities</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? 'OPP-' + String(opportunity.id).padStart(3, '0') : 'New Opportunity' %></span>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit: OPP-' + String(opportunity.id).padStart(3, '0') : 'New Opportunity' %></h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update opportunity details' : 'Create a new sales opportunity' %></p>
  </div>
</div>

<!-- Form -->
<form method="POST" action="<%= isEdit ? '/opportunities/' + opportunity.id : '/opportunities' %>" class="space-y-5">
  <%- include('../partials/csrf') %>

  <!-- 1. Opportunity Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Opportunity Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <label for="title" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Title <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required value="<%= isEdit ? (opportunity.title || '') : '' %>" placeholder="Opportunity title"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="service_type" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Service Type</label>
        <select id="service_type" name="service_type"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select service type...</option>
          <% if (typeof settingsOptions !== 'undefined' && settingsOptions.service_categories) { %>
            <% settingsOptions.service_categories.forEach(function(opt) { %>
                            <option value="<%= opt.key %>" <%= isEdit && opportunity.service_type === opt.key ? 'selected' : '' %>>
                <%= opt.label || opt.key %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div>
        <label for="source" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Source</label>
        <select id="source" name="source"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select source...</option>
          <% if (typeof settingsOptions !== 'undefined' && settingsOptions.lead_sources) { %>
            <% settingsOptions.lead_sources.forEach(function(opt) { %>
                            <option value="<%= opt.key %>" <%= isEdit && opportunity.source === opt.key ? 'selected' : '' %>>
                <%= opt.label || opt.key %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div>
        <label for="region" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Region</label>
        <input type="text" id="region" name="region" value="<%= isEdit ? (opportunity.region || '') : '' %>" placeholder="e.g. Sydney CBD, Western Sydney"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- 2. Account & Contact -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Account & Contact</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label for="client_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Account</label>
        <select id="client_id" name="client_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select account...</option>
          <% (clients || []).forEach(function(c) { %>
            <option value="<%= c.id %>" <%= isEdit && opportunity.client_id == c.id ? 'selected' : '' %>>
              <%= c.company_name || c.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="contact_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Contact</label>
        <select id="contact_id" name="contact_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select contact...</option>
          <% (contacts || []).forEach(function(ct) { %>
            <option value="<%= ct.id %>" data-client-id="<%= ct.client_id || ct.company_id || '' %>"
              <%= isEdit && opportunity.contact_id == ct.id ? 'selected' : '' %>>
              <%= ct.name || ct.full_name || ((ct.first_name || '') + ' ' + (ct.last_name || '')).trim() %>
            </option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="owner_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Owner</label>
        <select id="owner_id" name="owner_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Unassigned</option>
          <% (users || []).forEach(function(u) { %>
            <option value="<%= u.id %>" <%= isEdit && opportunity.owner_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- 3. Pipeline -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Pipeline</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label for="stage" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Stage</label>
        <select id="stage" name="stage"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <% if (typeof settingsOptions !== 'undefined' && settingsOptions.opportunity_stages) { %>
            <% settingsOptions.opportunity_stages.forEach(function(opt, idx) { %>
                            <option value="<%= opt.key %>"
                data-probability=""
                <%= isEdit && opportunity.stage === opt.key ? 'selected' : (!isEdit && idx === 0) ? 'selected' : '' %>>
                <%= opt.label || opt.key %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div>
        <label for="probability" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Probability %</label>
        <input type="number" id="probability" name="probability" min="0" max="100" step="5"
          value="<%= isEdit ? (opportunity.probability || 0) : '' %>" placeholder="0-100"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="estimated_value" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Estimated Value ($)</label>
        <input type="number" id="estimated_value" name="estimated_value" min="0" step="100"
          value="<%= isEdit ? (opportunity.estimated_value || '') : '' %>" placeholder="0"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="expected_close_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Expected Close Date</label>
        <input type="date" id="expected_close_date" name="expected_close_date"
          value="<%= isEdit && opportunity.expected_close_date ? opportunity.expected_close_date.split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- 4. Notes & Next Steps -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Notes & Next Steps</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label for="notes" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Notes</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Details about this opportunity..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= isEdit ? (opportunity.notes || '') : '' %></textarea>
      </div>
      <div class="space-y-4">
        <div>
          <label for="next_step" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Next Step</label>
          <input type="text" id="next_step" name="next_step" value="<%= isEdit ? (opportunity.next_step || '') : '' %>" placeholder="What needs to happen next..."
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
        <div>
          <label for="next_step_due_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Next Step Due Date</label>
          <input type="date" id="next_step_due_date" name="next_step_due_date"
            value="<%= isEdit && opportunity.next_step_due_date ? opportunity.next_step_due_date.split('T')[0] : '' %>"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        </div>
      </div>
    </div>
  </div>

  <!-- 5. Status (edit only) -->
  <% if (isEdit) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Status</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label for="status" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</label>
        <select id="status" name="status" onchange="toggleLossReason()"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="open" <%= opportunity.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="won" <%= opportunity.status === 'won' ? 'selected' : '' %>>Won</option>
          <option value="lost" <%= opportunity.status === 'lost' ? 'selected' : '' %>>Lost</option>
          <option value="on_hold" <%= opportunity.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
        </select>
      </div>
      <div id="loss-reason-field" class="<%= opportunity.status !== 'lost' ? 'hidden' : '' %>">
        <label for="loss_reason" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Loss Reason</label>
        <select id="loss_reason" name="loss_reason"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select reason...</option>
          <% if (typeof settingsOptions !== 'undefined' && settingsOptions.loss_reasons) { %>
            <% settingsOptions.loss_reasons.forEach(function(opt) { %>
                            <option value="<%= opt.key %>" <%= opportunity.loss_reason === opt.key ? 'selected' : '' %>>
                <%= opt.label || opt.key %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Submit -->
  <div class="flex items-center justify-end gap-3">
    <a href="<%= isEdit ? '/opportunities/' + opportunity.id : '/opportunities' %>" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</a>
    <button type="submit" class="px-6 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <%= isEdit ? 'Update Opportunity' : 'Create Opportunity' %>
    </button>
  </div>
</form>

<script>
  // Auto-update probability when stage changes
  document.getElementById('stage').addEventListener('change', function() {
    var selected = this.options[this.selectedIndex];
    var prob = selected.dataset.probability;
    if (prob !== undefined && prob !== '') {
      document.getElementById('probability').value = prob;
    }
  });

  // Filter contacts by selected account
  document.getElementById('client_id').addEventListener('change', function() {
    var clientId = this.value;
    var contactSelect = document.getElementById('contact_id');
    var options = contactSelect.querySelectorAll('option[data-client-id]');
    options.forEach(function(opt) {
      if (!clientId || opt.dataset.clientId === clientId) {
        opt.style.display = '';
      } else {
        opt.style.display = 'none';
        if (opt.selected) opt.selected = false;
      }
    });
  });

  // Toggle loss reason field visibility
  function toggleLossReason() {
    var status = document.getElementById('status');
    var lossField = document.getElementById('loss-reason-field');
    if (status && lossField) {
      if (status.value === 'lost') {
        lossField.classList.remove('hidden');
      } else {
        lossField.classList.add('hidden');
      }
    }
  }
</script>