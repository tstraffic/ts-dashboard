<% locals.currentPage = 'pipeline' %>
<%
  function formatCurrency(v) {
    return '$' + (v || 0).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }
  function formatDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short', year: 'numeric' });
  }
  function formatDateTime(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { timeZone: 'Australia/Sydney', day: '2-digit', month: 'short' }) + ' ' + dt.toLocaleTimeString('en-AU', { timeZone: 'Australia/Sydney', hour: '2-digit', minute: '2-digit' });
  }

  // Parse stage colors/labels from settingsOptions
  const stageColorMap = {};
  const stageLabelMap = {};
  if (typeof settingsOptions !== 'undefined' && settingsOptions.opportunity_stages) {
    settingsOptions.opportunity_stages.forEach(function(opt) {
      stageColorMap[opt.key] = opt.color || 'gray';
      stageLabelMap[opt.key] = opt.label || opt.key;
    });
  }

  function stageColor(stage) {
    const color = stageColorMap[stage] || 'gray';
    const map = {
      sky: 'bg-sky-50 text-sky-700 ring-1 ring-sky-600/20',
      blue: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
      indigo: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',
      purple: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
      amber: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
      emerald: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      green: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      red: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
      gray: 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20',
      orange: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
      teal: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20',
      rose: 'bg-rose-50 text-rose-700 ring-1 ring-rose-600/20'
    };
    return map[color] || map.gray;
  }
  function stageLabel(stage) {
    return stageLabelMap[stage] || (stage || '').replace(/_/g, ' ');
  }

  const statusColors = {
    open: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    won: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    lost: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    on_hold: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20'
  };

  const activityTypeIcons = {
    call: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    email: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    meeting: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    site_visit: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
    note: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z'
  };
  const activityTypeColors = {
    call: 'bg-green-50 text-green-600',
    email: 'bg-blue-50 text-blue-600',
    meeting: 'bg-purple-50 text-purple-600',
    site_visit: 'bg-amber-50 text-amber-600',
    note: 'bg-gray-50 text-gray-500',
    follow_up: 'bg-brand-50 text-brand-600',
    proposal_sent: 'bg-orange-50 text-orange-600',
    other: 'bg-gray-50 text-gray-500'
  };

  const isOverdue = opportunity.status === 'open' && opportunity.expected_close_date && new Date(opportunity.expected_close_date) < new Date();
  const oppNumber = opportunity.opportunity_number || ('OPP-' + String(opportunity.id).padStart(3, '0'));
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/opportunities" class="hover:text-gray-900 transition">Opportunities</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= oppNumber %></span>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-5">
  <div>
    <div class="flex items-center gap-2 flex-wrap mb-1">
      <h1 class="text-2xl font-bold text-gray-900"><%= opportunity.title %></h1>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= stageColor(opportunity.stage) %>">
        <%= stageLabel(opportunity.stage) %>
      </span>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusColors[opportunity.status] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
        <%= (opportunity.status || 'open').replace(/_/g, ' ') %>
      </span>
    </div>
    <div class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
      <span class="font-medium"><%= oppNumber %></span>
      <% if (opportunity.estimated_value) { %>
        <span class="text-gray-300">&middot;</span>
        <span class="font-bold text-gray-900"><%= formatCurrency(opportunity.estimated_value) %></span>
      <% } %>
      <% if (opportunity.client_name) { %>
        <span class="text-gray-300">&middot;</span>
        <a href="/clients/<%= opportunity.client_id %>" class="text-brand-600 hover:text-brand-700"><%= opportunity.client_name %></a>
      <% } %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/opportunities/<%= opportunity.id %>/edit" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Edit
    </a>
    <form method="POST" action="/opportunities/<%= opportunity.id %>/delete" class="inline"
      onsubmit="return confirm('Are you sure you want to delete this opportunity? This cannot be undone.')">
      <%- include('../partials/csrf') %>
      <button type="submit" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      </button>
    </form>
    <% if (opportunity.status === 'won' && !opportunity.related_job_id && !(typeof relatedJob !== 'undefined' && relatedJob)) { %>
    <form method="POST" action="/opportunities/<%= opportunity.id %>/convert" class="inline"
      onsubmit="return confirm('Convert this opportunity to a new job?')">
      <%- include('../partials/csrf') %>
      <button type="submit" class="inline-flex items-center px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Convert to Job
      </button>
    </form>
    <% } %>
  </div>
</div>

<!-- Info Grid -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 mb-5">
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4">
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Account</p>
      <% if (opportunity.client_name) { %>
        <a href="/clients/<%= opportunity.client_id %>" class="text-sm text-brand-600 hover:text-brand-700 font-medium mt-1 block"><%= opportunity.client_name %></a>
      <% } else { %>
        <p class="text-sm text-gray-600 mt-1">-</p>
      <% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Contact</p>
      <p class="text-sm text-gray-900 mt-1"><%= opportunity.contact_name || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Owner</p>
      <p class="text-sm text-gray-900 mt-1"><%= opportunity.owner_name || 'Unassigned' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Service Type</p>
      <p class="text-sm text-gray-600 mt-1"><%= opportunity.service_type ? opportunity.service_type.replace(/_/g, ' ') : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Source</p>
      <p class="text-sm text-gray-600 mt-1"><%= opportunity.source ? opportunity.source.replace(/_/g, ' ') : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Region</p>
      <p class="text-sm text-gray-600 mt-1"><%= opportunity.region || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Stage</p>
      <div class="mt-1">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= stageColor(opportunity.stage) %>">
          <%= stageLabel(opportunity.stage) %>
        </span>
      </div>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Probability</p>
      <p class="text-sm font-medium text-gray-900 mt-1"><%= opportunity.probability || 0 %>%</p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Estimated Value</p>
      <p class="text-sm font-bold text-gray-900 mt-1"><%= formatCurrency(opportunity.estimated_value) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Weighted Value</p>
      <p class="text-sm font-bold text-brand-600 mt-1"><%= formatCurrency(opportunity.weighted_value || ((opportunity.estimated_value || 0) * (opportunity.probability || 0) / 100)) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Expected Close Date</p>
      <p class="text-sm font-medium mt-1 <%= isOverdue ? 'text-red-600' : 'text-gray-900' %>"><%= formatDate(opportunity.expected_close_date) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Next Step</p>
      <p class="text-sm text-gray-600 mt-1"><%= opportunity.next_step || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Next Step Due</p>
      <p class="text-sm text-gray-600 mt-1"><%= formatDate(opportunity.next_step_due || opportunity.next_step_due_date) %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</p>
      <div class="mt-1">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusColors[opportunity.status] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
          <%= (opportunity.status || 'open').replace(/_/g, ' ') %>
        </span>
      </div>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Created</p>
      <p class="text-sm text-gray-600 mt-1"><%= formatDate(opportunity.created_at) %><% if (opportunity.created_by_name) { %> by <%= opportunity.created_by_name %><% } %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Updated</p>
      <p class="text-sm text-gray-600 mt-1"><%= formatDate(opportunity.updated_at) %></p>
    </div>
    <% if (opportunity.loss_reason) { %>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Loss Reason</p>
      <p class="text-sm text-red-600 font-medium mt-1"><%= opportunity.loss_reason.replace(/_/g, ' ') %></p>
    </div>
    <% } %>
  </div>
</div>

<!-- Notes -->
<% if (opportunity.notes) { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 mb-5">
  <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Notes</h2>
  <p class="text-sm text-gray-700 whitespace-pre-line"><%= opportunity.notes %></p>
</div>
<% } %>

<!-- Linked Job -->
<% if (typeof relatedJob !== 'undefined' && relatedJob) { %>
<div class="bg-white border border-emerald-200 rounded-xl shadow-sm p-4 sm:p-5 mb-5">
  <h2 class="text-xs font-bold text-emerald-700 uppercase tracking-widest mb-3">Linked Job</h2>
  <a href="/jobs/<%= relatedJob.id %>" class="flex items-center gap-3 p-3 bg-emerald-50 rounded-lg hover:bg-emerald-100 transition-colors">
    <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    </div>
    <div>
      <p class="text-sm font-semibold text-gray-900"><%= relatedJob.job_number %><% if (relatedJob.job_name) { %> &mdash; <%= relatedJob.job_name %><% } %></p>
      <p class="text-xs text-gray-500"><%= relatedJob.status %><% if (relatedJob.contract_value) { %> &middot; <%= formatCurrency(relatedJob.contract_value) %><% } %></p>
    </div>
  </a>
</div>
<% } %>

<!-- Activities Section -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Activities</h2>
    <div class="flex items-center gap-2">
      <a href="/crm/activities/new?opportunity_id=<%= opportunity.id %>&client_id=<%= opportunity.client_id || '' %>&type=call"
        class="inline-flex items-center px-2.5 py-1.5 bg-green-50 hover:bg-green-100 text-green-700 text-xs font-medium rounded-lg transition-colors">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.call %>"/></svg>
        Call
      </a>
      <a href="/crm/activities/new?opportunity_id=<%= opportunity.id %>&client_id=<%= opportunity.client_id || '' %>&type=meeting"
        class="inline-flex items-center px-2.5 py-1.5 bg-purple-50 hover:bg-purple-100 text-purple-700 text-xs font-medium rounded-lg transition-colors">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.meeting %>"/></svg>
        Meeting
      </a>
      <a href="/crm/activities/new?opportunity_id=<%= opportunity.id %>&client_id=<%= opportunity.client_id || '' %>&type=email"
        class="inline-flex items-center px-2.5 py-1.5 bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-medium rounded-lg transition-colors">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.email %>"/></svg>
        Email
      </a>
      <a href="/crm/activities/new?opportunity_id=<%= opportunity.id %>&client_id=<%= opportunity.client_id || '' %>"
        class="inline-flex items-center px-2.5 py-1.5 bg-brand-50 hover:bg-brand-100 text-brand-700 text-xs font-medium rounded-lg transition-colors">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Log
      </a>
    </div>
  </div>

  <% if (!activities || activities.length === 0) { %>
    <div class="text-center py-8">
      <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-gray-500 text-sm font-medium mb-1">No activities logged</h3>
      <p class="text-gray-400 text-xs mb-3">Track your interactions with this opportunity.</p>
      <a href="/crm/activities/new?opportunity_id=<%= opportunity.id %>&client_id=<%= opportunity.client_id || '' %>"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Log Activity
      </a>
    </div>
  <% } else { %>
    <!-- Activity Timeline -->
    <div class="space-y-4">
      <% activities.forEach(function(act) { %>
      <div class="flex gap-3">
        <div class="w-8 h-8 rounded-lg <%= activityTypeColors[act.activity_type] || 'bg-gray-50 text-gray-500' %> flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons[act.activity_type] || activityTypeIcons.note %>"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-sm font-medium text-gray-900"><%= act.subject || 'Activity' %></span>
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold <%= activityTypeColors[act.activity_type] || 'bg-gray-100 text-gray-500' %>">
              <%= (act.activity_type || 'note').replace(/_/g, ' ') %>
            </span>
          </div>
          <% if (act.notes) { %>
            <p class="text-xs text-gray-500 mt-0.5 line-clamp-2"><%= act.notes %></p>
          <% } %>
          <p class="text-xs text-gray-400 mt-1">
            <%= formatDateTime(act.activity_date) %>
            <% if (act.owner_name) { %> &middot; <%= act.owner_name %><% } %>
          </p>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>