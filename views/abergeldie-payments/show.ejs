<% locals.currentPage = 'abergeldie-payments' %>
<%
  function fmtDate(s) { if (!s) return ''; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <a href="/finance/abergeldie" class="text-sm text-brand-600 hover:underline">← <%= sheet.client_name %> Payment Sheet</a>
      <h1 class="text-2xl font-bold text-gray-900 mt-1"><%= sheet.label || periodLabel(sheet.period_start, sheet.period_end) %></h1>
      <p class="text-sm text-gray-500 mt-0.5 tabular-nums"><%= fmtDate(sheet.period_start) %> → <%= fmtDate(sheet.period_end) %></p>
      <% if (sheet.notes) { %><p class="text-xs text-gray-500 mt-1"><%= sheet.notes %></p><% } %>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" onclick="document.getElementById('editSheetModal').classList.remove('hidden')" class="inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-gray-300 hover:bg-brand-50 hover:border-brand-300 hover:text-brand-700 text-gray-700 text-xs font-semibold rounded-lg transition">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Edit
      </button>
      <a href="/finance/abergeldie/<%= sheet.id %>/export.xlsx" class="inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold rounded-lg transition" title="Download as Excel for emailing to Abergeldie">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export xlsx
      </a>
      <form method="POST" action="/finance/abergeldie/<%= sheet.id %>/delete" onsubmit="return confirm('Delete this payment sheet? This cannot be undone.')">
        <%- include('../partials/csrf') %>
        <button type="submit" class="px-3 py-2 text-xs font-semibold text-rose-700 bg-rose-50 hover:bg-rose-100 ring-1 ring-rose-200 rounded-lg">Delete</button>
      </form>
    </div>
  </div>

  <!-- Edit modal -->
  <div id="editSheetModal" class="fixed inset-0 z-50 hidden bg-black/50 backdrop-blur-sm overflow-y-auto" onclick="if(event.target===this)this.classList.add('hidden')">
    <div class="min-h-full flex items-center justify-center p-4">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
        <form method="POST" action="/finance/abergeldie/<%= sheet.id %>">
          <%- include('../partials/csrf') %>
          <div class="p-5 border-b border-gray-200">
            <h2 class="text-lg font-bold text-gray-900">Edit payment sheet</h2>
            <p class="text-xs text-gray-500 mt-0.5">Changing the fee per hour will recalculate every line.</p>
          </div>
          <div class="p-5 space-y-4">
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Label</label>
              <input type="text" name="label" value="<%= sheet.label || '' %>" maxlength="200" placeholder="e.g. April 2026" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period start <span class="text-rose-500">*</span></label>
                <input type="date" name="period_start" value="<%= sheet.period_start %>" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Period end <span class="text-rose-500">*</span></label>
                <input type="date" name="period_end" value="<%= sheet.period_end %>" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Fee per hour ($) <span class="text-rose-500">*</span></label>
              <input type="number" step="0.01" min="0" name="fee_per_hour" value="<%= (parseFloat(sheet.fee_per_hour) || 0).toFixed(2) %>" required class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm tabular-nums">
              <p class="text-[11px] text-amber-700 mt-1.5">Changing this re-runs hours × rate on all <%= grand.line_count %> line<%= grand.line_count !== 1 ? 's' : '' %>.</p>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1.5">Notes <span class="text-gray-400 font-normal lowercase tracking-normal">(optional)</span></label>
              <textarea name="notes" rows="2" maxlength="1000" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm"><%= sheet.notes || '' %></textarea>
            </div>
          </div>
          <div class="p-5 border-t border-gray-200 flex items-center justify-end gap-2">
            <button type="button" onclick="document.getElementById('editSheetModal').classList.add('hidden')" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-semibold rounded-lg">Cancel</button>
            <button type="submit" class="px-5 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Top totals strip -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Projects</p>
      <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= grand.project_count %></p>
    </div>
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Shifts</p>
      <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= grand.line_count %></p>
    </div>
    <div class="bg-white border border-emerald-200 rounded-xl p-4">
      <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Hours</p>
      <p class="text-2xl font-bold text-emerald-700 mt-1 tabular-nums"><%= fmtHours(grand.hours) %></p>
      <p class="text-[10px] text-gray-400 mt-0.5">@ $<%= fmtMoney(sheet.fee_per_hour) %>/hr</p>
    </div>
    <div class="bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-xl p-4">
      <p class="text-[10px] font-bold text-white/80 uppercase tracking-widest">Monthly Fee</p>
      <p class="text-2xl font-bold mt-1 tabular-nums">$<%= fmtMoney(grand.fee) %></p>
    </div>
  </div>

  <!-- Per-project breakdown -->
  <% if (groups.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <p class="text-sm text-gray-500">No matching shifts in this sheet.</p>
    </div>
  <% } else { %>
    <% groups.forEach(g => { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2">
          <div class="min-w-0">
            <h2 class="text-base font-bold text-gray-900 truncate"><%= g.project_name %></h2>
            <% if (g.job_number || g.booking_address) { %>
              <p class="text-[11px] text-gray-500">
                <% if (g.job_number) { %><span class="font-mono"><%= g.job_number %></span><% } %>
                <% if (g.job_number && g.booking_address) { %> · <% } %>
                <% if (g.booking_address) { %><%= g.booking_address %><% } %>
              </p>
            <% } %>
          </div>
          <div class="flex items-center gap-3 text-xs text-gray-700 flex-wrap">
            <span><%= g.lines.length %> shift<%= g.lines.length !== 1 ? 's' : '' %></span>
            <span class="opacity-50">·</span>
            <span class="font-semibold tabular-nums"><%= fmtHours(g.total_hours) %> hrs</span>
            <span class="opacity-50">·</span>
            <span class="font-bold tabular-nums text-emerald-700">$<%= fmtMoney(g.total_fee) %></span>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Worker</th>
                <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Date</th>
                <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest hidden md:table-cell">Time</th>
                <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Hours</th>
                <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Fee</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% g.lines.forEach(l => { %>
                <tr>
                  <td class="px-3 py-2">
                    <p class="font-semibold text-gray-900 text-sm leading-tight"><%= l.full_name %></p>
                    <% if (l.person_id) { %><p class="text-[10px] text-gray-400 font-mono mt-0.5"><%= l.person_id %></p><% } %>
                  </td>
                  <td class="px-2 py-2 text-xs text-gray-700 tabular-nums whitespace-nowrap"><%= fmtDate(l.shift_date) %></td>
                  <td class="px-2 py-2 text-xs text-gray-500 tabular-nums whitespace-nowrap hidden md:table-cell">
                    <% if (l.time_on || l.time_off) { %><%= l.time_on || '—' %> → <%= l.time_off || '—' %><% } else { %>—<% } %>
                  </td>
                  <td class="px-2 py-2 text-right text-sm tabular-nums text-gray-900"><%= fmtHours(l.hours) %></td>
                  <td class="px-2 py-2 text-right text-sm font-semibold tabular-nums text-emerald-700">$<%= fmtMoney(l.fee_total) %></td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="bg-gray-50 border-t-2 border-gray-300">
              <tr>
                <td colspan="3" class="px-3 py-2 text-right text-xs font-bold text-gray-700 uppercase tracking-widest">Project subtotal</td>
                <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-gray-900"><%= fmtHours(g.total_hours) %></td>
                <td class="px-2 py-2 text-right text-sm font-bold tabular-nums text-emerald-700">$<%= fmtMoney(g.total_fee) %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    <% }) %>

    <!-- Grand total -->
    <div class="bg-gradient-to-br from-brand-600 to-brand-700 text-white rounded-xl shadow-sm p-5 flex items-center justify-between flex-wrap gap-3">
      <div>
        <p class="text-[10px] font-bold text-white/80 uppercase tracking-widest">Sheet total</p>
        <p class="text-sm text-white/90"><%= grand.project_count %> project<%= grand.project_count !== 1 ? 's' : '' %> · <%= grand.line_count %> shift<%= grand.line_count !== 1 ? 's' : '' %> · <%= fmtHours(grand.hours) %> hrs @ $<%= fmtMoney(sheet.fee_per_hour) %>/hr</p>
      </div>
      <p class="text-3xl font-bold tabular-nums">$<%= fmtMoney(grand.fee) %></p>
    </div>
  <% } %>
</div>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
