<% locals.currentPage = 'contacts' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Communication Log</h1>
    <p class="text-gray-500 text-sm mt-1">Track all client and stakeholder communications</p>
  </div>
  <a href="/contacts/comms/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ Log Communication</a>
</div>

<!-- Sub Navigation -->
<div class="flex items-center gap-1 mb-6 border-b border-gray-200 pb-0">
  <a href="/contacts" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 hover:border-gray-300 -mb-px transition-colors">Contacts</a>
  <a href="/contacts/comms" class="px-4 py-2 text-sm font-medium border-b-2 border-brand-500 text-brand-600 -mb-px">Communication Log</a>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" action="/contacts/comms" class="flex flex-wrap items-end gap-4">
    <!-- Job -->
    <div class="min-w-[200px] flex-1">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
        <% }) %>
      </select>
    </div>
    <!-- Communication Type -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Type</label>
      <select name="comm_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Types</option>
        <option value="phone" <%= filters.comm_type === 'phone' ? 'selected' : '' %>>Phone</option>
        <option value="email" <%= filters.comm_type === 'email' ? 'selected' : '' %>>Email</option>
        <option value="meeting" <%= filters.comm_type === 'meeting' ? 'selected' : '' %>>Meeting</option>
        <option value="site_visit" <%= filters.comm_type === 'site_visit' ? 'selected' : '' %>>Site Visit</option>
        <option value="letter" <%= filters.comm_type === 'letter' ? 'selected' : '' %>>Letter</option>
        <option value="other" <%= filters.comm_type === 'other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>
    <!-- Follow-ups Due -->
    <div class="flex items-end pb-1">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" name="follow_up" value="1" <%= filters.follow_up === '1' ? 'checked' : '' %>
          class="w-4 h-4 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2 cursor-pointer">
        <span class="text-sm text-gray-600 whitespace-nowrap">Follow-ups Due</span>
      </label>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/contacts/comms" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Communication Log -->
<% if (comms.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    <p class="text-gray-400 text-sm">No communications found matching your filters.</p>
    <a href="/contacts/comms/new" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Log the first communication</a>
  </div>
<% } else { %>

<!-- Desktop Table -->
<div class="hidden lg:block bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Contact</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Type</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Dir</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Subject</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Logged By</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Follow-up</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% comms.forEach(comm => { %>
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3 text-gray-500 text-xs whitespace-nowrap"><%= comm.comm_date || '-' %></td>
        <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap"><%= comm.job_number %></td>
        <td class="px-4 py-3 text-gray-600">
          <% if (comm.contact_name) { %>
            <span class="text-gray-900 font-medium"><%= comm.contact_name %></span>
            <% if (comm.contact_company) { %><span class="text-gray-400 text-xs ml-1">(<%= comm.contact_company %>)</span><% } %>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (comm.comm_type === 'phone') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else if (comm.comm_type === 'email') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
            <% } else if (comm.comm_type === 'meeting') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
            <% } else if (comm.comm_type === 'site_visit') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (comm.comm_type === 'letter') { %>bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20
            <% } else { %>bg-white text-gray-600<% } %>">
            <%= comm.comm_type ? comm.comm_type.replace(/_/g, ' ') : '-' %>
          </span>
        </td>
        <td class="px-4 py-3 text-center">
          <% if (comm.direction === 'incoming') { %>
            <span class="inline-flex items-center text-emerald-600" title="Incoming">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            </span>
          <% } else { %>
            <span class="inline-flex items-center text-brand-600" title="Outgoing">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
            </span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-gray-900 font-medium max-w-[250px] truncate" title="<%= comm.subject %>"><%= comm.subject %></td>
        <td class="px-4 py-3 text-gray-500 text-xs"><%= comm.logged_by_name %></td>
        <td class="px-4 py-3 text-center">
          <% if (comm.follow_up_required && !comm.follow_up_done) { %>
            <div class="flex flex-col items-center gap-1">
              <span class="inline-flex items-center gap-1 text-brand-600 text-xs font-medium">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"/></svg>
                <% if (comm.follow_up_date) { %><%= comm.follow_up_date %><% } else { %>Due<% } %>
              </span>
              <form method="POST" action="/contacts/comms/<%= comm.id %>/follow-up-done" class="inline">
                <button type="submit" class="text-xs text-gray-400 hover:text-emerald-600 transition-colors" title="Mark done">Mark done</button>
              </form>
            </div>
          <% } else if (comm.follow_up_required && comm.follow_up_done) { %>
            <span class="text-emerald-500">
              <svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </span>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-center">
          <form method="POST" action="/contacts/comms/<%= comm.id %>/delete" class="inline" onsubmit="return confirm('Delete this communication entry?')">
            <button type="submit" class="text-gray-400 hover:text-red-600 transition" title="Delete">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Mobile Cards -->
<div class="lg:hidden space-y-3">
  <% comms.forEach(comm => { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-start justify-between mb-2">
      <div>
        <h3 class="text-gray-900 font-medium text-sm"><%= comm.subject %></h3>
        <p class="text-gray-500 text-xs mt-0.5"><%= comm.job_number %> &middot; <%= comm.comm_date %></p>
      </div>
      <div class="flex items-center gap-2">
        <% if (comm.direction === 'incoming') { %>
          <span class="text-emerald-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg></span>
        <% } else { %>
          <span class="text-brand-600"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg></span>
        <% } %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
          <% if (comm.comm_type === 'phone') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
          <% } else if (comm.comm_type === 'email') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
          <% } else if (comm.comm_type === 'meeting') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
          <% } else if (comm.comm_type === 'site_visit') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
          <% } else if (comm.comm_type === 'letter') { %>bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20
          <% } else { %>bg-white text-gray-600<% } %>">
          <%= comm.comm_type ? comm.comm_type.replace(/_/g, ' ') : '-' %>
        </span>
      </div>
    </div>
    <div class="flex items-center justify-between text-xs">
      <div class="text-gray-500">
        <% if (comm.contact_name) { %><span class="text-gray-600"><%= comm.contact_name %></span><% } %>
        &middot; Logged by <%= comm.logged_by_name %>
      </div>
      <% if (comm.follow_up_required && !comm.follow_up_done) { %>
        <form method="POST" action="/contacts/comms/<%= comm.id %>/follow-up-done" class="inline">
          <button type="submit" class="inline-flex items-center gap-1 text-brand-600 hover:text-emerald-600 font-medium transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"/></svg>
            <% if (comm.follow_up_date) { %><%= comm.follow_up_date %><% } else { %>Follow-up<% } %>
          </button>
        </form>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<div class="mt-3 text-xs text-gray-400"><%= comms.length %> communication<%= comms.length !== 1 ? 's' : '' %> found</div>
<% } %>
