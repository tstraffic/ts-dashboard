<% locals.currentPage = 'contacts' %>

<%
  function formatShortDate(dateStr) {
    if (!dateStr) return '-';
    return new Date(dateStr).toLocaleDateString('en-AU', { day: '2-digit', month: 'short' });
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Client Contacts</h1>
    <p class="text-gray-500 text-sm mt-0.5">Stakeholder directory &middot; communication tracking</p>
  </div>
  <a href="/contacts/new" class="inline-flex items-center justify-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
    New Contact
  </a>
</div>

<!-- Sub Navigation -->
<div class="flex items-center gap-1 mb-5 border-b border-gray-200 pb-0">
  <a href="/contacts" class="px-4 py-2 text-sm font-medium border-b-2 border-brand-500 text-brand-600 -mb-px">Contacts</a>
  <a href="/contacts/comms" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 hover:border-gray-300 -mb-px transition-colors">Communication Log</a>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/contacts" class="flex flex-col sm:flex-row sm:flex-wrap sm:items-end gap-2 sm:gap-3">
    <div class="flex-1 min-w-0 sm:min-w-[180px]">
      <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Name, company, email..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="flex gap-2 w-full sm:w-auto">
      <div class="flex-1 sm:flex-none sm:min-w-[160px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Job</label>
        <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Jobs</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex-1 sm:flex-none sm:min-w-[130px]">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Type</label>
        <select name="contact_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">All Types</option>
          <option value="client" <%= filters.contact_type === 'client' ? 'selected' : '' %>>Client</option>
          <option value="council" <%= filters.contact_type === 'council' ? 'selected' : '' %>>Council</option>
          <option value="utility" <%= filters.contact_type === 'utility' ? 'selected' : '' %>>Utility</option>
          <option value="rms" <%= filters.contact_type === 'rms' ? 'selected' : '' %>>RMS / TfNSW</option>
          <option value="subcontractor" <%= filters.contact_type === 'subcontractor' ? 'selected' : '' %>>Subcontractor</option>
          <option value="consultant" <%= filters.contact_type === 'consultant' ? 'selected' : '' %>>Consultant</option>
          <option value="other" <%= filters.contact_type === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
    </div>
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/contacts" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Contacts Table -->
<% if (contacts.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
    <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <h3 class="text-gray-900 font-semibold text-base mb-1">No contacts found</h3>
    <p class="text-gray-500 text-sm mb-1">Manage client reps, council officers, subcontractors, and key stakeholders for your jobs.</p>
    <p class="text-gray-400 text-xs mb-4">Add contacts to track communication history and link them to projects.</p>
    <a href="/contacts/new" class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Add Contact
    </a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Name</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Company</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Phone</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Email</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Job</th>
        <th class="px-3 py-2.5 text-center text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Comms</th>
        <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden xl:table-cell">Last Contact</th>
        <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% contacts.forEach(c => { %>
      <tr class="hover:bg-gray-50">
        <td class="px-3 py-2.5">
          <span class="font-medium text-gray-900"><%= c.full_name %></span>
          <% if (c.position) { %><span class="block text-[10px] text-gray-400"><%= c.position %></span><% } %>
          <span class="sm:hidden text-[10px] text-gray-400"><%= c.company %></span>
          <% if (c.is_primary) { %>
            <span class="inline-flex items-center ml-1 px-1 py-0.5 rounded text-[9px] font-bold bg-brand-50 text-brand-600 ring-1 ring-brand-600/20">PRIMARY</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-gray-600 text-xs hidden sm:table-cell"><%= c.company || '-' %></td>
        <td class="px-3 py-2.5">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
            <% if (c.contact_type === 'client') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else if (c.contact_type === 'council') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
            <% } else if (c.contact_type === 'utility') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
            <% } else if (c.contact_type === 'rms') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (c.contact_type === 'subcontractor') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
            <% } else if (c.contact_type === 'consultant') { %>bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20
            <% } else { %>bg-gray-100 text-gray-600<% } %>">
            <%= c.contact_type === 'rms' ? 'RMS' : (c.contact_type ? c.contact_type.toUpperCase() : '-') %>
          </span>
        </td>
        <td class="px-3 py-2.5 hidden md:table-cell">
          <% if (c.phone) { %>
            <a href="tel:<%= c.phone %>" class="text-gray-600 hover:text-brand-600 text-xs"><%= c.phone %></a>
          <% } else { %>
            <span class="text-gray-300 text-xs">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 hidden lg:table-cell">
          <% if (c.email) { %>
            <a href="mailto:<%= c.email %>" class="text-gray-600 hover:text-brand-600 text-xs truncate block max-w-[180px]"><%= c.email %></a>
          <% } else { %>
            <span class="text-gray-300 text-xs">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-gray-500 text-xs hidden lg:table-cell"><%= c.job_number || '-' %></td>
        <td class="px-3 py-2.5 text-center hidden sm:table-cell">
          <% if (c.comms_count > 0) { %>
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-[10px] font-bold bg-brand-50 text-brand-700 ring-1 ring-brand-600/20"><%= c.comms_count %></span>
          <% } else { %>
            <span class="text-gray-300">-</span>
          <% } %>
        </td>
        <td class="px-3 py-2.5 text-xs text-gray-500 hidden xl:table-cell"><%= formatShortDate(c.last_contact_date) %></td>
        <td class="px-3 py-2.5 text-right">
          <div class="flex items-center justify-end gap-1">
            <a href="/contacts/<%= c.id %>/edit" class="px-2.5 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg">Edit</a>
            <form method="POST" action="/contacts/<%= c.id %>/delete" class="inline" onsubmit="return confirm('Delete contact <%= c.full_name %>?')">
              <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-2 text-xs text-gray-400"><%= contacts.length %> contact<%= contacts.length !== 1 ? 's' : '' %> found</div>
<% } %>
