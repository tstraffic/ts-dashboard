<% locals.currentPage = 'contacts' %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Client Contacts</h1>
    <p class="text-gray-500 text-sm mt-1">Manage contacts across all projects and stakeholders</p>
  </div>
  <a href="/contacts/new" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">+ New Contact</a>
</div>

<!-- Sub Navigation -->
<div class="flex items-center gap-1 mb-6 border-b border-gray-200 pb-0">
  <a href="/contacts" class="px-4 py-2 text-sm font-medium border-b-2 border-brand-500 text-brand-600 -mb-px">Contacts</a>
  <a href="/contacts/comms" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-900 hover:border-gray-300 -mb-px transition-colors">Communication Log</a>
</div>

<!-- Filter Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <form method="GET" action="/contacts" class="flex flex-wrap items-end gap-4">
    <!-- Search -->
    <div class="flex-1 min-w-[200px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Search</label>
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Name, company, email..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <!-- Job -->
    <div class="min-w-[200px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Job</label>
      <select name="job_id" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Jobs</option>
        <% jobs.forEach(j => { %>
          <option value="<%= j.id %>" <%= filters.job_id == j.id ? 'selected' : '' %>><%= j.job_number %> - <%= j.client %></option>
        <% }) %>
      </select>
    </div>
    <!-- Contact Type -->
    <div class="min-w-[160px]">
      <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Type</label>
      <select name="contact_type" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
        <option value="">All Types</option>
        <option value="client" <%= filters.contact_type === 'client' ? 'selected' : '' %>>Client</option>
        <option value="council" <%= filters.contact_type === 'council' ? 'selected' : '' %>>Council</option>
        <option value="utility" <%= filters.contact_type === 'utility' ? 'selected' : '' %>>Utility</option>
        <option value="rms" <%= filters.contact_type === 'rms' ? 'selected' : '' %>>RMS / TfNSW</option>
        <option value="subcontractor" <%= filters.contact_type === 'subcontractor' ? 'selected' : '' %>>Subcontractor</option>
        <option value="consultant" <%= filters.contact_type === 'consultant' ? 'selected' : '' %>>Consultant</option>
        <option value="other" <%= filters.contact_type === 'other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>
    <!-- Buttons -->
    <div class="flex gap-2">
      <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Filter</button>
      <a href="/contacts" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Clear</a>
    </div>
  </form>
</div>

<!-- Contacts Table -->
<% if (contacts.length === 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
    <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    <p class="text-gray-400 text-sm">No contacts found matching your filters.</p>
    <a href="/contacts/new" class="text-brand-600 text-sm hover:underline mt-2 inline-block">Add the first contact</a>
  </div>
<% } else { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Name</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Company</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Position</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Phone</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Email</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Job</th>
        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wide">Primary</th>
        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% contacts.forEach(c => { %>
      <tr class="hover:bg-gray-50">
        <td class="px-4 py-3 font-medium text-gray-900"><%= c.full_name %></td>
        <td class="px-4 py-3 text-gray-600"><%= c.company %></td>
        <td class="px-4 py-3">
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            <% if (c.contact_type === 'client') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
            <% } else if (c.contact_type === 'council') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
            <% } else if (c.contact_type === 'utility') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
            <% } else if (c.contact_type === 'rms') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
            <% } else if (c.contact_type === 'subcontractor') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
            <% } else if (c.contact_type === 'consultant') { %>bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20
            <% } else { %>bg-white text-gray-600<% } %>">
            <%= c.contact_type === 'rms' ? 'RMS / TfNSW' : (c.contact_type ? c.contact_type.replace(/_/g, ' ') : '-') %>
          </span>
        </td>
        <td class="px-4 py-3 text-gray-500 text-xs"><%= c.position || '-' %></td>
        <td class="px-4 py-3 text-gray-600">
          <% if (c.phone) { %>
            <a href="tel:<%= c.phone %>" class="hover:text-brand-600 transition-colors"><%= c.phone %></a>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-gray-600">
          <% if (c.email) { %>
            <a href="mailto:<%= c.email %>" class="hover:text-brand-600 transition-colors text-xs"><%= c.email %></a>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-gray-500 text-xs"><%= c.job_number || '-' %></td>
        <td class="px-4 py-3 text-center">
          <% if (c.is_primary) { %>
            <svg class="w-5 h-5 text-brand-600 mx-auto" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <% } else { %>
            <span class="text-gray-400">-</span>
          <% } %>
        </td>
        <td class="px-4 py-3 text-right">
          <div class="flex items-center justify-end gap-2">
            <a href="/contacts/<%= c.id %>/edit" class="text-gray-500 hover:text-brand-600 transition-colors" title="Edit">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </a>
            <form method="POST" action="/contacts/<%= c.id %>/delete" class="inline" onsubmit="return confirm('Delete contact <%= c.full_name %>?')">
              <button type="submit" class="text-gray-500 hover:text-red-600 transition-colors" title="Delete">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<div class="mt-3 text-xs text-gray-400"><%= contacts.length %> contact<%= contacts.length !== 1 ? 's' : '' %> found</div>
<% } %>
