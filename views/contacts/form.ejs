<% locals.currentPage = 'contacts' %>
<% const isEdit = contact !== null && typeof contact !== 'undefined' %>

<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Contact: ' + contact.full_name : 'New Contact' %></h1>
  <p class="text-gray-500 text-sm mt-1"><%= isEdit ? 'Update contact details below' : 'Add a new client contact or stakeholder' %></p>
</div>

<!-- Form -->
<form method="POST" action="<%= isEdit ? '/contacts/' + contact.id : '/contacts' %>" class="space-y-6">

  <!-- Contact Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Contact Details</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Full Name -->
      <div>
        <label for="full_name" class="block text-sm font-medium text-gray-600 mb-1">Full Name <span class="text-red-600">*</span></label>
        <input type="text" id="full_name" name="full_name" required
          value="<%= isEdit ? contact.full_name : '' %>"
          placeholder="John Smith"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Linked Company (from directory) -->
      <div>
        <label for="company_id" class="block text-sm font-medium text-gray-600 mb-1">Company <span class="text-gray-400 text-xs">(from directory)</span></label>
        <select id="company_id" name="company_id" onchange="onCompanySelect(this)"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select from directory or type below --</option>
          <% if (typeof companies !== 'undefined' && companies) { %>
            <% companies.forEach(comp => { %>
              <option value="<%= comp.id %>" data-name="<%= comp.company_name %>"
                <%= (isEdit && contact.company_id == comp.id) || (!isEdit && preselectedCompanyId == comp.id) ? 'selected' : '' %>>
                <%= comp.company_name %> <% if (comp.company_type !== 'client') { %>(<%= comp.company_type %>)<% } %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <!-- Company (text fallback) -->
      <div>
        <label for="company" class="block text-sm font-medium text-gray-600 mb-1">Company Name <span class="text-red-600">*</span></label>
        <input type="text" id="company" name="company" required
          value="<%= isEdit ? contact.company : '' %>"
          placeholder="Company name"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Contact Type -->
      <div>
        <label for="contact_type" class="block text-sm font-medium text-gray-600 mb-1">Contact Type <span class="text-red-600">*</span></label>
        <select id="contact_type" name="contact_type" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Type --</option>
          <option value="client" <%= isEdit && contact.contact_type === 'client' ? 'selected' : '' %>>Client</option>
          <option value="council" <%= isEdit && contact.contact_type === 'council' ? 'selected' : '' %>>Council</option>
          <option value="utility" <%= isEdit && contact.contact_type === 'utility' ? 'selected' : '' %>>Utility</option>
          <option value="rms" <%= isEdit && contact.contact_type === 'rms' ? 'selected' : '' %>>RMS / TfNSW</option>
          <option value="subcontractor" <%= isEdit && contact.contact_type === 'subcontractor' ? 'selected' : '' %>>Subcontractor</option>
          <option value="consultant" <%= isEdit && contact.contact_type === 'consultant' ? 'selected' : '' %>>Consultant</option>
          <option value="other" <%= isEdit && contact.contact_type === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
      <!-- Position -->
      <div>
        <label for="position" class="block text-sm font-medium text-gray-600 mb-1">Position</label>
        <input type="text" id="position" name="position"
          value="<%= isEdit && contact.position ? contact.position : '' %>"
          placeholder="e.g. Project Manager, Site Supervisor"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- Contact Information -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Contact Information</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Phone -->
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-600 mb-1">Phone</label>
        <input type="tel" id="phone" name="phone"
          value="<%= isEdit && contact.phone ? contact.phone : '' %>"
          placeholder="04XX XXX XXX"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-gray-600 mb-1">Email</label>
        <input type="email" id="email" name="email"
          value="<%= isEdit && contact.email ? contact.email : '' %>"
          placeholder="john@company.com"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- Job & Notes -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Assignment & Notes</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Job -->
      <div>
        <label for="job_id" class="block text-sm font-medium text-gray-600 mb-1">Linked Job <span class="text-gray-400 text-xs">(optional)</span></label>
        <select id="job_id" name="job_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- No Job --</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>"
              <%= (isEdit && contact.job_id == j.id) || (!isEdit && preselectedJobId == j.id) ? 'selected' : '' %>>
              <%= j.job_number %> - <%= j.client %>
            </option>
          <% }) %>
        </select>
      </div>
      <!-- Is Primary -->
      <div class="flex items-end pb-1">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="is_primary" value="1"
            <%= isEdit && contact.is_primary ? 'checked' : '' %>
            class="w-5 h-5 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2 cursor-pointer">
          <span class="text-sm text-gray-600">Primary Contact for this Job</span>
        </label>
      </div>
    </div>
    <!-- Notes -->
    <div class="mt-4">
      <label for="notes" class="block text-sm font-medium text-gray-600 mb-1">Notes</label>
      <textarea id="notes" name="notes" rows="3"
        placeholder="Additional notes about this contact..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"><%= isEdit && contact.notes ? contact.notes : '' %></textarea>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3">
    <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors">
      <%= isEdit ? 'Update Contact' : 'Save Contact' %>
    </button>
    <a href="/contacts" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</a>
  </div>
</form>

<script>
function onCompanySelect(sel) {
  const opt = sel.options[sel.selectedIndex];
  if (opt && opt.dataset.name) {
    document.getElementById('company').value = opt.dataset.name;
  }
}
// On load: if a company is preselected, auto-fill
(function() {
  const sel = document.getElementById('company_id');
  const companyInput = document.getElementById('company');
  if (sel && sel.value && !companyInput.value) {
    const opt = sel.options[sel.selectedIndex];
    if (opt && opt.dataset.name) companyInput.value = opt.dataset.name;
  }
})();
</script>

<% if (typeof activityLog !== 'undefined' && activityLog.length > 0) { %>
<!-- Activity Timeline -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 mt-5">
  <h3 class="text-sm font-bold text-gray-900 mb-3">Activity</h3>
  <%- include('../partials/activity-timeline', { activities: activityLog }) %>
</div>
<% } %>
