<% locals.currentPage = 'contacts' %>
<%
  function formatDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }
  function formatDateTime(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { day: '2-digit', month: 'short' }) + ' ' + dt.toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' });
  }
  function formatCurrency(v) {
    return '$' + (v || 0).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  // Contact type badge colors
  const contactTypeColors = {
    client: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    council: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
    utility: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20',
    rms: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    subcontractor: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    consultant: 'bg-cyan-50 text-cyan-700 ring-1 ring-cyan-600/20',
    other: 'bg-gray-100 text-gray-600 ring-1 ring-gray-600/20'
  };

  // Relationship strength badge colors
  const strengthColors = {
    cold: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    warm: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
    strong: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    champion: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20'
  };

  // Influence level badge colors
  const influenceColors = {
    low: 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20',
    medium: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    high: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
    decision_maker: 'bg-red-50 text-red-700 ring-1 ring-red-600/20'
  };

  // Opportunity stage/status colors
  const stageColorMap = {};
  const stageLabelMap = {};
  if (typeof settingsOptions !== 'undefined' && settingsOptions && settingsOptions.opportunity_stages) {
    settingsOptions.opportunity_stages.forEach(function(opt) {
      stageColorMap[opt.key] = opt.color || 'gray';
      stageLabelMap[opt.key] = opt.label || opt.key;
    });
  }
  function stageColor(stage) {
    const color = stageColorMap[stage] || 'gray';
    const map = {
      sky: 'bg-sky-50 text-sky-700 ring-1 ring-sky-600/20',
      blue: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
      indigo: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',
      purple: 'bg-purple-50 text-purple-700 ring-1 ring-purple-600/20',
      amber: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
      emerald: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      green: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
      red: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
      gray: 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20',
      orange: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
      teal: 'bg-teal-50 text-teal-700 ring-1 ring-teal-600/20',
      rose: 'bg-rose-50 text-rose-700 ring-1 ring-rose-600/20'
    };
    return map[color] || map.gray;
  }
  function stageLabel(stage) {
    return stageLabelMap[stage] || (stage || '').replace(/_/g, ' ');
  }

  const statusColors = {
    open: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
    won: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
    lost: 'bg-red-50 text-red-700 ring-1 ring-red-600/20',
    on_hold: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20'
  };

  const activityTypeIcons = {
    call: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    email: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    meeting: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    site_visit: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
    note: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z'
  };
  const activityTypeColors = {
    call: 'bg-green-50 text-green-600',
    email: 'bg-blue-50 text-blue-600',
    meeting: 'bg-purple-50 text-purple-600',
    site_visit: 'bg-amber-50 text-amber-600',
    note: 'bg-gray-50 text-gray-500',
    follow_up: 'bg-brand-50 text-brand-600',
    proposal_sent: 'bg-orange-50 text-orange-600',
    other: 'bg-gray-50 text-gray-500'
  };

  // Owner name: use ownerUser object passed from route, or fall back to users array lookup
  const _ownerUser = (typeof ownerUser !== 'undefined' && ownerUser) ? ownerUser : ((typeof users !== 'undefined' && users) ? users.find(function(u) { return u.id === contact.contact_owner_id; }) : null);
  const ownerName = _ownerUser ? _ownerUser.full_name : 'Unassigned';
%>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/contacts" class="hover:text-gray-900 transition">Contacts</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= contact.full_name %></span>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-5">
  <div>
    <div class="flex items-center gap-2 flex-wrap mb-1">
      <h1 class="text-2xl font-bold text-gray-900"><%= contact.full_name %></h1>
      <% if (contact.contact_type) { %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= contactTypeColors[contact.contact_type] || contactTypeColors.other %>">
          <%= contact.contact_type === 'rms' ? 'RMS / TfNSW' : (contact.contact_type || '').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
        </span>
      <% } %>
      <% if (contact.relationship_strength) { %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= strengthColors[contact.relationship_strength] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
          <%= contact.relationship_strength.charAt(0).toUpperCase() + contact.relationship_strength.slice(1) %>
        </span>
      <% } %>
      <% if (contact.influence_level) { %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= influenceColors[contact.influence_level] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
          <%= contact.influence_level.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
        </span>
      <% } %>
    </div>
    <div class="flex items-center gap-2 text-sm text-gray-500 flex-wrap">
      <% if (contact.position) { %>
        <span class="text-gray-500"><%= contact.position %></span>
      <% } %>
      <% if (contact.position && (contact.company || (company && company.company_name))) { %>
        <span class="text-gray-300">&middot;</span>
      <% } %>
      <% if (company) { %>
        <a href="/clients/<%= company.id %>" class="text-brand-600 hover:text-brand-700"><%= company.company_name %></a>
      <% } else if (contact.company) { %>
        <span class="text-gray-500"><%= contact.company %></span>
      <% } %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/contacts/<%= contact.id %>/edit" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Edit
    </a>
    <form method="POST" action="/contacts/<%= contact.id %>/delete" class="inline"
      onsubmit="return confirm('Are you sure you want to delete this contact? This cannot be undone.')">
      <%- include('../partials/csrf') %>
      <button type="submit" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        Delete
      </button>
    </form>
  </div>
</div>

<!-- Quick Actions Bar -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <div class="flex items-center gap-2 flex-wrap">
    <a href="/crm/activities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>&type=call"
      class="inline-flex items-center px-3 py-2 bg-green-50 hover:bg-green-100 text-green-700 text-xs font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.call %>"/></svg>
      Log Call
    </a>
    <a href="/crm/activities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>&type=email"
      class="inline-flex items-center px-3 py-2 bg-blue-50 hover:bg-blue-100 text-blue-700 text-xs font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.email %>"/></svg>
      Log Email
    </a>
    <a href="/crm/activities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>&type=meeting"
      class="inline-flex items-center px-3 py-2 bg-purple-50 hover:bg-purple-100 text-purple-700 text-xs font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.meeting %>"/></svg>
      Log Meeting
    </a>
    <a href="/opportunities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>"
      class="inline-flex items-center px-3 py-2 bg-brand-50 hover:bg-brand-100 text-brand-700 text-xs font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      Create Opportunity
    </a>
  </div>
</div>

<!-- Info Grid -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 mb-5">
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-4">
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Phone</p>
      <% if (contact.phone) { %>
        <a href="tel:<%= contact.phone %>" class="text-sm text-brand-600 hover:text-brand-700 font-medium mt-1 block"><%= contact.phone %></a>
      <% } else { %>
        <p class="text-sm text-gray-600 mt-1">-</p>
      <% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Mobile</p>
      <% if (contact.mobile) { %>
        <a href="tel:<%= contact.mobile %>" class="text-sm text-brand-600 hover:text-brand-700 font-medium mt-1 block"><%= contact.mobile %></a>
      <% } else { %>
        <p class="text-sm text-gray-600 mt-1">-</p>
      <% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Email</p>
      <% if (contact.email) { %>
        <a href="mailto:<%= contact.email %>" class="text-sm text-brand-600 hover:text-brand-700 font-medium mt-1 block truncate"><%= contact.email %></a>
      <% } else { %>
        <p class="text-sm text-gray-600 mt-1">-</p>
      <% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Preferred Communication</p>
      <p class="text-sm text-gray-600 mt-1"><%= contact.preferred_comm_method ? contact.preferred_comm_method.charAt(0).toUpperCase() + contact.preferred_comm_method.slice(1) : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Referred By</p>
      <p class="text-sm text-gray-600 mt-1"><%= contact.referred_by || '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Account</p>
      <% if (company) { %>
        <a href="/clients/<%= company.id %>" class="text-sm text-brand-600 hover:text-brand-700 font-medium mt-1 block"><%= company.company_name %></a>
      <% } else if (contact.company) { %>
        <p class="text-sm text-gray-900 mt-1"><%= contact.company %></p>
      <% } else { %>
        <p class="text-sm text-gray-600 mt-1">-</p>
      <% } %>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Owner</p>
      <p class="text-sm text-gray-900 mt-1"><%= ownerName %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Buying Role</p>
      <p class="text-sm text-gray-600 mt-1"><%= contact.buying_role ? contact.buying_role.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) : '-' %></p>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Primary Contact</p>
      <div class="mt-1">
        <% if (contact.is_primary) { %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Yes</span>
        <% } else { %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-gray-50 text-gray-600 ring-1 ring-gray-600/20">No</span>
        <% } %>
      </div>
    </div>
    <div>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Created</p>
      <p class="text-sm text-gray-600 mt-1"><%= formatDate(contact.created_at) %></p>
    </div>
  </div>
</div>

<!-- Notes Section -->
<% if (contact.notes) { %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5 mb-5">
  <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-3">Notes</h2>
  <p class="text-sm text-gray-700 whitespace-pre-line"><%= contact.notes %></p>
</div>
<% } %>

<!-- Tabs -->
<div class="mb-5">
  <div class="flex items-center gap-1 border-b border-gray-200 pb-0" id="contact-tabs">
    <button type="button"
      class="tab-btn px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors"
      data-tab="opportunities"
      onclick="switchTab('opportunities')">
      Opportunities
      <% if (opportunities && opportunities.length > 0) { %>
        <span class="ml-1 inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold bg-brand-50 text-brand-700"><%= opportunities.length %></span>
      <% } %>
    </button>
    <button type="button"
      class="tab-btn px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors"
      data-tab="activities"
      onclick="switchTab('activities')">
      Activities
      <% if (activities && activities.length > 0) { %>
        <span class="ml-1 inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold bg-brand-50 text-brand-700"><%= activities.length %></span>
      <% } %>
    </button>
    <button type="button"
      class="tab-btn px-4 py-2 text-sm font-medium border-b-2 -mb-px transition-colors"
      data-tab="notes"
      onclick="switchTab('notes')">
      Notes
    </button>
  </div>
</div>

<!-- Tab: Opportunities -->
<div class="tab-content" id="tab-opportunities">
  <% if (!opportunities || opportunities.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No opportunities linked to this contact</h3>
      <p class="text-gray-500 text-sm mb-4">Create an opportunity to track potential business with this contact.</p>
      <a href="/opportunities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Create Opportunity
      </a>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Opp#</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Title</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Stage</th>
            <th class="px-3 py-2.5 text-right text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden sm:table-cell">Value</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Close Date</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% opportunities.forEach(function(opp) {
            const oppNumber = opp.opportunity_number || ('OPP-' + String(opp.id).padStart(3, '0'));
          %>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2.5">
              <a href="/opportunities/<%= opp.id %>" class="text-brand-600 hover:text-brand-700 text-xs font-semibold"><%= oppNumber %></a>
            </td>
            <td class="px-3 py-2.5">
              <a href="/opportunities/<%= opp.id %>" class="text-sm font-medium text-gray-900 hover:text-brand-600 transition"><%= opp.title %></a>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= stageColor(opp.stage) %>">
                <%= stageLabel(opp.stage) %>
              </span>
            </td>
            <td class="px-3 py-2.5 text-right hidden sm:table-cell">
              <span class="text-sm font-semibold text-gray-900"><%= formatCurrency(opp.estimated_value) %></span>
            </td>
            <td class="px-3 py-2.5 hidden md:table-cell">
              <span class="text-xs tabular-nums text-gray-600"><%= formatDate(opp.expected_close_date) %></span>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= statusColors[opp.status] || 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
                <%= (opp.status || 'open').replace(/_/g, ' ') %>
              </span>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mt-2 text-xs text-gray-400"><%= opportunities.length %> opportunit<%= opportunities.length !== 1 ? 'ies' : 'y' %></div>
  <% } %>
</div>

<!-- Tab: Activities -->
<div class="tab-content hidden" id="tab-activities">
  <% if (!activities || activities.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-10 text-center">
      <div class="w-14 h-14 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="text-gray-900 font-semibold text-base mb-1">No activities recorded</h3>
      <p class="text-gray-500 text-sm mb-4">Track your interactions with this contact.</p>
      <a href="/crm/activities/new?contact_id=<%= contact.id %>&client_id=<%= contact.company_id || '' %>"
        class="inline-flex items-center gap-1.5 px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Log Activity
      </a>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Date</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Type</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest">Subject</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Account</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden lg:table-cell">Outcome</th>
            <th class="px-3 py-2.5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-widest hidden md:table-cell">Owner</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% activities.forEach(function(act) { %>
          <tr class="hover:bg-gray-50">
            <td class="px-3 py-2.5">
              <span class="text-xs tabular-nums text-gray-600"><%= formatDateTime(act.activity_date) %></span>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold
                <% if (act.activity_type === 'call') { %>bg-green-50 text-green-700 ring-1 ring-green-600/20
                <% } else if (act.activity_type === 'email') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                <% } else if (act.activity_type === 'meeting') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
                <% } else if (act.activity_type === 'site_visit') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else if (act.activity_type === 'note') { %>bg-gray-50 text-gray-600 ring-1 ring-gray-600/20
                <% } else { %>bg-gray-50 text-gray-600 ring-1 ring-gray-600/20<% } %>">
                <%= (act.activity_type || 'note').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
              </span>
            </td>
            <td class="px-3 py-2.5">
              <span class="text-sm font-medium text-gray-900"><%= act.subject || '-' %></span>
            </td>
            <td class="px-3 py-2.5 hidden md:table-cell">
              <% if (act.client_id) { %>
                <a href="/clients/<%= act.client_id %>" class="text-xs text-brand-600 hover:text-brand-700 font-medium"><%= act.client_name || '-' %></a>
              <% } else { %>
                <span class="text-xs text-gray-300">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 hidden lg:table-cell">
              <% if (act.notes) { %>
                <p class="text-xs text-gray-500 truncate max-w-[200px]"><%= act.notes %></p>
              <% } else { %>
                <span class="text-xs text-gray-300">-</span>
              <% } %>
            </td>
            <td class="px-3 py-2.5 text-xs text-gray-600 hidden md:table-cell"><%= act.owner_name || '-' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <div class="mt-2 text-xs text-gray-400"><%= activities.length %> activit<%= activities.length !== 1 ? 'ies' : 'y' %></div>
  <% } %>
</div>

<!-- Tab: Notes -->
<div class="tab-content hidden" id="tab-notes">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <% if (contact.notes) { %>
      <p class="text-sm text-gray-700 whitespace-pre-line"><%= contact.notes %></p>
    <% } else { %>
      <div class="text-center py-8">
        <div class="w-12 h-12 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <h3 class="text-gray-500 text-sm font-medium mb-1">No notes</h3>
        <p class="text-gray-400 text-xs">Add notes by editing this contact.</p>
      </div>
    <% } %>
  </div>
</div>

<script>
function switchTab(tabName) {
  // Hide all tab content
  document.querySelectorAll('.tab-content').forEach(function(el) {
    el.classList.add('hidden');
  });
  // Deactivate all tab buttons
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.classList.remove('border-brand-500', 'text-brand-600');
    btn.classList.add('border-transparent', 'text-gray-500', 'hover:text-gray-900', 'hover:border-gray-300');
  });
  // Show selected tab content
  var tabEl = document.getElementById('tab-' + tabName);
  if (tabEl) tabEl.classList.remove('hidden');
  // Activate selected tab button
  var activeBtn = document.querySelector('.tab-btn[data-tab="' + tabName + '"]');
  if (activeBtn) {
    activeBtn.classList.add('border-brand-500', 'text-brand-600');
    activeBtn.classList.remove('border-transparent', 'text-gray-500', 'hover:text-gray-900', 'hover:border-gray-300');
  }
}

// Initialize: show first tab with content, or opportunities by default
(function() {
  var defaultTab = 'opportunities';
  <% if (opportunities && opportunities.length > 0) { %>
    defaultTab = 'opportunities';
  <% } else if (activities && activities.length > 0) { %>
    defaultTab = 'activities';
  <% } %>
  switchTab(defaultTab);
})();
</script>
