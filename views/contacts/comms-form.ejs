<% locals.currentPage = 'contacts' %>
<% const isEdit = comm !== null && typeof comm !== 'undefined' %>

<!-- Page Header -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Communication' : 'Log Communication' %></h1>
  <p class="text-gray-500 text-sm mt-1"><%= isEdit ? 'Update communication details' : 'Record a phone call, email, meeting or other communication' %></p>
</div>

<!-- Form -->
<form method="POST" action="/contacts/comms" class="space-y-6">
  <%- include('../partials/csrf') %>

  <!-- Communication Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Communication Details</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Job -->
      <div>
        <label for="job_id" class="block text-sm font-medium text-gray-600 mb-1">Job <span class="text-red-600">*</span></label>
        <select id="job_id" name="job_id" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Job --</option>
          <% jobs.forEach(j => { %>
            <option value="<%= j.id %>"
              <%= (isEdit && comm.job_id == j.id) || (!isEdit && preselectedJobId == j.id) ? 'selected' : '' %>>
              <%= j.job_number %> - <%= j.project_name ? j.project_name + ' (' + j.client + ')' : j.client %>
            </option>
          <% }) %>
        </select>
      </div>
      <!-- Contact -->
      <div>
        <label for="contact_id" class="block text-sm font-medium text-gray-600 mb-1">Contact <span class="text-gray-400 text-xs">(optional)</span></label>
        <select id="contact_id" name="contact_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Contact --</option>
          <% contacts.forEach(c => { %>
            <option value="<%= c.id %>" <%= isEdit && comm.contact_id == c.id ? 'selected' : '' %>>
              <%= c.full_name %> (<%= c.company %>)
            </option>
          <% }) %>
        </select>
      </div>
      <!-- Communication Type -->
      <div>
        <label for="comm_type" class="block text-sm font-medium text-gray-600 mb-1">Type <span class="text-red-600">*</span></label>
        <select id="comm_type" name="comm_type" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">-- Select Type --</option>
          <option value="phone" <%= isEdit && comm.comm_type === 'phone' ? 'selected' : '' %>>Phone</option>
          <option value="email" <%= isEdit && comm.comm_type === 'email' ? 'selected' : '' %>>Email</option>
          <option value="meeting" <%= isEdit && comm.comm_type === 'meeting' ? 'selected' : '' %>>Meeting</option>
          <option value="site_visit" <%= isEdit && comm.comm_type === 'site_visit' ? 'selected' : '' %>>Site Visit</option>
          <option value="letter" <%= isEdit && comm.comm_type === 'letter' ? 'selected' : '' %>>Letter</option>
          <option value="other" <%= isEdit && comm.comm_type === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
      <!-- Date -->
      <div>
        <label for="comm_date" class="block text-sm font-medium text-gray-600 mb-1">Date <span class="text-red-600">*</span></label>
        <input type="date" id="comm_date" name="comm_date" required
          value="<%= isEdit && comm.comm_date ? comm.comm_date : new Date().toISOString().split('T')[0] %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>

    <!-- Direction -->
    <div class="mt-4">
      <label class="block text-sm font-medium text-gray-600 mb-2">Direction</label>
      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="direction" value="outgoing"
            <%= (!isEdit || (isEdit && comm.direction === 'outgoing')) ? 'checked' : '' %>
            class="w-4 h-4 border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2">
          <span class="text-sm text-gray-600 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
            Outgoing
          </span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="direction" value="incoming"
            <%= isEdit && comm.direction === 'incoming' ? 'checked' : '' %>
            class="w-4 h-4 border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2">
          <span class="text-sm text-gray-600 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            Incoming
          </span>
        </label>
      </div>
    </div>
  </div>

  <!-- Subject & Summary -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Content</h2>
    <!-- Subject -->
    <div class="mb-4">
      <label for="subject" class="block text-sm font-medium text-gray-600 mb-1">Subject <span class="text-red-600">*</span></label>
      <input type="text" id="subject" name="subject" required
        value="<%= isEdit ? comm.subject : '' %>"
        placeholder="Brief subject of the communication"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <!-- Summary -->
    <div>
      <label for="summary" class="block text-sm font-medium text-gray-600 mb-1">Summary <span class="text-red-600">*</span></label>
      <textarea id="summary" name="summary" rows="4" required
        placeholder="Detailed summary of the communication, key points discussed, outcomes..."
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent resize-y"><%= isEdit && comm.summary ? comm.summary : '' %></textarea>
    </div>
  </div>

  <!-- Follow-up -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-4">Follow-up</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-start">
      <!-- Follow-up Required -->
      <div class="flex items-center pt-1">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="follow_up_required" name="follow_up_required" value="1"
            <%= isEdit && comm.follow_up_required ? 'checked' : '' %>
            onchange="document.getElementById('follow_up_date_wrap').classList.toggle('hidden', !this.checked)"
            class="w-5 h-5 rounded border-gray-300 bg-white text-brand-500 focus:ring-brand-500 focus:ring-offset-0 focus:ring-2 cursor-pointer">
          <span class="text-sm text-gray-600">Follow-up Required</span>
        </label>
      </div>
      <!-- Follow-up Date -->
      <div id="follow_up_date_wrap" class="<%= (isEdit && comm.follow_up_required) ? '' : 'hidden' %>">
        <label for="follow_up_date" class="block text-sm font-medium text-gray-600 mb-1">Follow-up Date</label>
        <input type="date" id="follow_up_date" name="follow_up_date"
          value="<%= isEdit && comm.follow_up_date ? comm.follow_up_date : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-3">
    <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition-colors">
      <%= isEdit ? 'Update Communication' : 'Log Communication' %>
    </button>
    <a href="/contacts/comms" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</a>
  </div>
</form>
