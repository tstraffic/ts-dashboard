<% locals.currentPage = 'tenders' %>
<%
  function fmtMoney(n) { const v = parseFloat(n) || 0; return '$' + v.toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); }
  function fmtDate(s) { if (!s) return '—'; return new Date(s + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }); }
  const STATUS_BADGE = {
    open:      'bg-amber-50 text-amber-700 ring-amber-200',
    submitted: 'bg-blue-50 text-blue-700 ring-blue-200',
    won:       'bg-emerald-50 text-emerald-700 ring-emerald-200',
    lost:      'bg-rose-50 text-rose-700 ring-rose-200',
    withdrawn: 'bg-gray-50 text-gray-700 ring-gray-200',
  };
%>

<div class="space-y-5 max-w-7xl">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Tenders</h1>
      <p class="text-sm text-gray-500 mt-1">Bids in flight. Group jobs and plans under a tender so the work history rolls up if the tender is won.</p>
    </div>
    <a href="/tenders/new" class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
      New tender
    </a>
  </div>

  <!-- Status summary strip -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
    <% statusValues.forEach(s => { %>
      <a href="/tenders?status=<%= s %>" class="bg-white border border-gray-200 hover:border-brand-300 rounded-xl p-3 transition">
        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= statusLabels[s] %></p>
        <p class="text-2xl font-bold text-gray-900 mt-1 tabular-nums"><%= counts[s] || 0 %></p>
      </a>
    <% }) %>
  </div>

  <!-- Filter row -->
  <form method="GET" action="/tenders" class="bg-white border border-gray-200 rounded-xl p-3 flex items-center gap-2 flex-wrap">
    <select name="status" onchange="this.form.submit()" class="px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All statuses</option>
      <% statusValues.forEach(s => { %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= statusLabels[s] %></option>
      <% }) %>
    </select>
    <select name="client_id" onchange="this.form.submit()" class="px-3 py-2 border border-gray-300 rounded-lg text-sm flex-1 max-w-xs">
      <option value="">All clients</option>
      <% clients.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(filters.client_id) === String(c.id) ? 'selected' : '' %>><%= c.company_name %></option>
      <% }) %>
    </select>
  </form>

  <!-- Tender list -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <% if (!tenders || tenders.length === 0) { %>
      <div class="p-10 text-center">
        <p class="text-sm text-gray-500 font-semibold">No tenders match your filter</p>
        <p class="text-xs text-gray-400 mt-1">Open a new tender to start grouping plans and jobs.</p>
        <a href="/tenders/new" class="inline-block mt-3 text-sm font-semibold text-brand-600">Create your first tender →</a>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-3 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">#</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Title</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Client</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Owner</th>
              <th class="px-2 py-2 text-right text-[10px] font-bold text-gray-500 uppercase tracking-widest">Est. value</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Due</th>
              <th class="px-2 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest">Jobs</th>
              <th class="px-2 py-2 text-center text-[10px] font-bold text-gray-500 uppercase tracking-widest">Plans</th>
              <th class="px-2 py-2 text-left text-[10px] font-bold text-gray-500 uppercase tracking-widest">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% tenders.forEach(t => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-3 py-2 font-mono text-xs text-gray-500"><%= t.tender_number %></td>
                <td class="px-2 py-2"><a href="/tenders/<%= t.id %>" class="font-semibold text-gray-900 hover:text-brand-600"><%= t.title %></a></td>
                <td class="px-2 py-2 text-xs text-gray-600"><%= t.client_name || '—' %></td>
                <td class="px-2 py-2 text-xs text-gray-600"><%= t.owner_name || '—' %></td>
                <td class="px-2 py-2 text-right text-xs tabular-nums text-gray-700"><%= fmtMoney(t.estimated_value) %></td>
                <td class="px-2 py-2 text-xs text-gray-600 tabular-nums"><%= fmtDate(t.submission_due) %></td>
                <td class="px-2 py-2 text-center text-xs tabular-nums text-gray-700"><%= t.job_count %></td>
                <td class="px-2 py-2 text-center text-xs tabular-nums text-gray-700"><%= t.plan_count %></td>
                <td class="px-2 py-2">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold ring-1 ring-inset <%= STATUS_BADGE[t.status] || 'bg-gray-50 text-gray-700 ring-gray-200' %>"><%= statusLabels[t.status] || t.status %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<% if (flash_success && flash_success.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-emerald-500 text-white text-sm font-semibold shadow-lg z-50" id="flash"><%= flash_success[0] %></div>
  <script>setTimeout(()=>document.getElementById('flash')?.remove(), 2800);</script>
<% } %>
<% if (flash_error && flash_error.length) { %>
  <div class="fixed top-20 right-4 px-4 py-2 rounded-lg bg-red-500 text-white text-sm font-semibold shadow-lg z-50" id="flasherr"><%= flash_error[0] %></div>
  <script>setTimeout(()=>document.getElementById('flasherr')?.remove(), 4000);</script>
<% } %>
