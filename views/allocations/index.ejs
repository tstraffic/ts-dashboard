        <button type="submit"
          class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Create Shift</button>
      </div>
    </form>
  </div>
</div>

<script>
// ============================================================
// Drag-and-Drop + UI helpers
// ============================================================
const ALLOC_DATE = '<%= selectedDate %>';
let pendingDrop = null; // stores context for override modal

function toggleForm(jobId) {
  document.getElementById('form-row-' + jobId).classList.toggle('hidden');
}
function toggleDetail(jobId) {
  document.getElementById('alloc-detail-' + jobId).classList.toggle('hidden');
}

// Crew panel search
document.getElementById('crew-search')?.addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.crew-card').forEach(card => {
    card.style.display = card.dataset.searchText.includes(q) ? '' : 'none';
  });
});

// Crew panel filter buttons
function filterCrewPanel(filter) {
  document.querySelectorAll('.crew-filter-btn').forEach(btn => {
    btn.className = btn.dataset.filter === filter
      ? 'crew-filter-btn px-2 py-1 text-[10px] font-medium rounded bg-brand-600 text-white'
      : 'crew-filter-btn px-2 py-1 text-[10px] font-medium rounded bg-white text-gray-600';
  });
  document.querySelectorAll('.crew-card').forEach(card => {
    if (filter === 'all') card.style.display = '';
    else if (filter === 'clear') card.style.display = card.dataset.canAllocate === 'true' ? '' : 'none';
    else if (filter === 'blocked') card.style.display = card.dataset.canAllocate === 'false' ? '' : 'none';
  });
}

function showToast(msg, duration) {
  const toast = document.getElementById('toast');
  const msgEl = document.getElementById('toast-msg');
  msgEl.textContent = msg;
  toast.classList.remove('hidden');
  setTimeout(() => toast.classList.add('hidden'), duration || 3000);
}

// Drag from crew panel
document.querySelectorAll('.crew-card[draggable="true"]').forEach(card => {
  card.addEventListener('dragstart', e => {
    e.dataTransfer.setData('text/plain', JSON.stringify({
      type: 'crew',
      crew_id: card.dataset.crewId,
      crew_name: card.dataset.crewName,
    }));
    e.dataTransfer.effectAllowed = 'copy';
    card.classList.add('opacity-50');
  });
  card.addEventListener('dragend', e => {
    card.classList.remove('opacity-50');
    // Remove all highlights
    document.querySelectorAll('.drop-target').forEach(dt => dt.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50'));
  });
});

// Drag allocated chips between jobs
document.querySelectorAll('.alloc-chip[draggable="true"]').forEach(chip => {
  chip.addEventListener('dragstart', e => {
    e.dataTransfer.setData('text/plain', JSON.stringify({
      type: 'move',
      alloc_id: chip.dataset.allocId,
      crew_id: chip.dataset.crewId,
    }));
    e.dataTransfer.effectAllowed = 'move';
    chip.classList.add('opacity-50');
    e.stopPropagation();
  });
  chip.addEventListener('dragend', e => {
    chip.classList.remove('opacity-50');
    document.querySelectorAll('.drop-target').forEach(dt => dt.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50'));
  });
});

// Drop targets (the flex container in each job's allocated crew cell)
document.querySelectorAll('.drop-target').forEach(target => {
  target.addEventListener('dragover', e => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'copy';
    target.classList.add('ring-2', 'ring-brand-500', 'bg-brand-50');
  });
  target.addEventListener('dragleave', e => {
    target.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50');
  });
  target.addEventListener('drop', async e => {
    e.preventDefault();
    target.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50');

    let data;
    try { data = JSON.parse(e.dataTransfer.getData('text/plain')); } catch(err) { return; }

    const jobId = target.dataset.jobId;

    if (data.type === 'crew') {
      // New allocation from crew panel
      await allocateCrew(jobId, data.crew_id, data.crew_name);
    } else if (data.type === 'move') {
      // Move between jobs
      await moveAllocation(data.alloc_id, jobId);
    }
  });
});

async function allocateCrew(jobId, crewId, crewName) {
  try {
    const resp = await fetch('/allocations/api/allocate.json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        job_id: jobId,
        crew_member_id: crewId,
        allocation_date: ALLOC_DATE,
        start_time: '06:00',
        end_time: '14:30',
        shift_type: 'day',
      })
    });
    const result = await resp.json();

    if (result.success) {
      showToast((crewName || 'Crew') + ' allocated');
      if (result.warnings && result.warnings.length > 0) {
        showToast('Warning: ' + result.warnings[0], 5000);
      }
      // Reload to refresh the board
      setTimeout(() => location.reload(), 500);
    } else if (result.blocks && result.blocks.length > 0) {
      // Show block modal
      showBlockModal(result.blocks, result.warnings || [], result.overridable, {
        job_id: jobId, crew_member_id: crewId, allocation_date: ALLOC_DATE,
        start_time: '06:00', end_time: '14:30', shift_type: 'day',
      });
    }
  } catch (err) {
    showToast('Error: ' + err.message, 5000);
  }
}

async function moveAllocation(allocId, newJobId) {
  try {
    const resp = await fetch('/allocations/api/move.json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ allocation_id: allocId, new_job_id: newJobId })
    });
    const result = await resp.json();

    if (result.success) {
      showToast('Allocation moved');
      setTimeout(() => location.reload(), 500);
    } else {
      showToast('Move blocked: ' + (result.blocks || []).join('; '), 5000);
    }
  } catch (err) {
    showToast('Error: ' + err.message, 5000);
  }
}

function showBlockModal(blocks, warnings, overridable, dropData) {
  const modal = document.getElementById('block-modal');
  const reasonsEl = document.getElementById('block-reasons');
  const warningsEl = document.getElementById('block-warnings');

  reasonsEl.innerHTML = blocks.map(b =>
    '<p class="text-sm text-red-600 flex items-center gap-2"><span class="text-red-500">&#10005;</span> ' + b + '</p>'
  ).join('');

  warningsEl.innerHTML = warnings.map(w =>
    '<p class="text-xs text-orange-600 flex items-center gap-2"><span>&#9888;</span> ' + w + '</p>'
  ).join('');

  pendingDrop = dropData;
  modal.classList.remove('hidden');
}

document.getElementById('cancel-block-btn')?.addEventListener('click', () => {
  document.getElementById('block-modal').classList.add('hidden');
  pendingDrop = null;
});

document.getElementById('override-btn')?.addEventListener('click', async () => {
  if (!pendingDrop) return;
  document.getElementById('block-modal').classList.add('hidden');

  try {
    const resp = await fetch('/allocations/api/allocate.json', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ...pendingDrop, force_override: true })
    });
    const result = await resp.json();
    if (result.success) {
      showToast('Override successful');
      setTimeout(() => location.reload(), 500);
    } else {
      showToast('Override failed: ' + (result.blocks || []).join('; '), 5000);
    }
  } catch (err) {
    showToast('Error: ' + err.message, 5000);
  }
  pendingDrop = null;
});

// ============================================================
// Equipment Panel
// ============================================================
document.getElementById('equip-search')?.addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('.equip-card').forEach(card => {
    card.style.display = card.dataset.searchText.includes(q) ? '' : 'none';
  });
});

function filterEquipPanel(filter) {
  document.querySelectorAll('.equip-filter-btn').forEach(btn => {
    btn.className = btn.dataset.filter === filter
      ? 'equip-filter-btn px-2 py-1 text-[10px] font-medium rounded bg-brand-600 text-white'
      : 'equip-filter-btn px-2 py-1 text-[10px] font-medium rounded bg-white text-gray-600';
  });
  document.querySelectorAll('.equip-card').forEach(card => {
    if (filter === 'all') card.style.display = '';
    else if (filter === 'available') card.style.display = card.dataset.equipAvailable === 'true' ? '' : 'none';
    else if (filter === 'assigned') card.style.display = card.dataset.equipAvailable === 'false' ? '' : 'none';
  });
}

// Drag from equipment panel
document.querySelectorAll('.equip-card[draggable="true"]').forEach(card => {
  card.addEventListener('dragstart', e => {
    e.dataTransfer.setData('text/plain', JSON.stringify({
      type: 'equipment',
      equip_id: card.dataset.equipId,
      equip_name: card.dataset.equipName,
    }));
    e.dataTransfer.effectAllowed = 'copy';
    card.classList.add('opacity-50');
  });
  card.addEventListener('dragend', e => {
    card.classList.remove('opacity-50');
    document.querySelectorAll('.drop-target').forEach(dt => dt.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50'));
  });
});

// Extend drop targets to handle equipment drops
document.querySelectorAll('.drop-target').forEach(target => {
  const origDrop = target._dropHandler;
  target.addEventListener('drop', async e => {
    let data;
    try { data = JSON.parse(e.dataTransfer.getData('text/plain')); } catch(err) { return; }
    if (data.type !== 'equipment') return;
    e.preventDefault();
    e.stopPropagation();
    target.classList.remove('ring-2', 'ring-brand-500', 'bg-brand-50');

    const jobId = target.dataset.jobId;
    try {
      const resp = await fetch('/allocations/api/assign-equipment.json', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ equipment_id: data.equip_id, job_id: jobId, date: ALLOC_DATE })
      });
      const result = await resp.json();
      if (result.success) {
        showToast((data.equip_name || 'Equipment') + ' assigned');
        setTimeout(() => location.reload(), 500);
      }
    } catch (err) {
      showToast('Error: ' + err.message, 5000);
    }
  }, true);
});

// ============================================================
// Quick-Create Shift — Filter projects by client
// ============================================================
function filterProjectsByClient(clientId) {
  const select = document.getElementById('shift-project-select');
  if (!select) return;
  const options = select.querySelectorAll('option');
  options.forEach(opt => {
    if (!opt.value) { opt.style.display = ''; return; }
    if (!clientId) { opt.style.display = ''; return; }
    // Show all if no client filter, otherwise show matching
    opt.style.display = ''; // show all for now — projects don't have client_id in the option data
  });
}

// Auto-open modal if URL has ?action=new-shift
if (window.location.search.includes('action=new-shift')) {
  document.getElementById('create-shift-modal')?.classList.remove('hidden');
}
</script>
