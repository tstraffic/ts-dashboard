          <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Required TC Level</label>
          <select name="required_tcp_level"
            class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
            <option value="">Any</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
