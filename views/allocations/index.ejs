      <div>
        <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Notes</label>
        <textarea name="notes" rows="2" placeholder="Special instructions, PPE requirements..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"></textarea>
