<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900">My Profile</h1>
    <p class="text-sm text-gray-500 mt-0.5">Contact details & settings</p>
  </div>

  <!-- Avatar -->
  <div class="flex items-center gap-4">
    <div class="w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center text-brand-700 font-bold text-xl">
      <%= member.full_name.split(' ').map(n => n[0]).join('').slice(0,2) %>
    </div>
    <div>
      <p class="text-lg font-bold text-gray-900"><%= member.full_name %></p>
      <p class="text-sm text-gray-500"><%= member.employee_id %> · <%= member.role ? member.role.replace(/_/g, ' ') : 'Field Worker' %></p>
    </div>
  </div>

  <!-- Contact Details -->
  <form method="POST" action="/w/profile" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Contact Details</h3>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Phone</label>
        <input type="tel" name="phone" value="<%= member.phone || '' %>" placeholder="0400 000 000" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Email</label>
        <input type="email" name="email" value="<%= member.email || '' %>" placeholder="you@example.com" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <button type="submit" class="w-full py-2.5 bg-brand-600 text-white rounded-lg font-medium text-sm hover:bg-brand-700 transition">Save Changes</button>
    </div>
  </form>

  <!-- Change PIN -->
  <form method="POST" action="/w/profile/pin" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Change PIN</h3>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Current PIN</label>
        <input type="password" name="current_pin" inputmode="numeric" maxlength="6" placeholder="••••" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">New PIN</label>
        <input type="password" name="new_pin" inputmode="numeric" maxlength="6" placeholder="4-6 digits" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Confirm New PIN</label>
        <input type="password" name="confirm_pin" inputmode="numeric" maxlength="6" placeholder="4-6 digits" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <button type="submit" class="w-full py-2.5 bg-gray-800 text-white rounded-lg font-medium text-sm hover:bg-gray-900 transition">Change PIN</button>
    </div>
  </form>

  <!-- Sign Out -->
  <a href="/w/logout" class="block w-full py-3 bg-red-50 border border-red-200 text-red-700 rounded-xl font-medium text-sm text-center hover:bg-red-100 transition">
    Sign Out
  </a>
</div>
