<%
  const displayName = (employee && employee.full_name) || (member && member.full_name) || 'My Profile';
  const initials = displayName.split(' ').map(n => n[0] || '').join('').slice(0, 2).toUpperCase();
  const empCode = (member && member.employee_id) || (employee && employee.employee_code) || '';
  const roleLabel = employee ? ((employee.role_title || '') || (employee.traffic_role_level || '')) : ((member && member.role) || '').replace(/_/g, ' ');
  const phone = (employee && employee.phone) || (member && member.phone) || '';
  const email = (employee && employee.email) || (member && member.email) || '';
  const addr1 = employee ? (employee.address_line1 || employee.address || '') : '';
  const addr2 = employee ? (employee.address_line2 || '') : '';
  const suburb = employee ? (employee.suburb || '') : '';
  const state = employee ? (employee.state || '') : '';
  const postcode = employee ? (employee.postcode || '') : '';
  const photo = employee ? employee.profile_photo_url : null;
%>

<style>
  .pf-wrap { padding: 0 0.5rem 0.5rem; }

  .pf-hero {
    position: relative;
    padding: 1.25rem 1rem 1rem;
    border-radius: 16px;
    background: linear-gradient(160deg, rgba(43,127,255,0.15), rgba(10,22,40,0.6));
    border: 1px solid rgba(255,255,255,0.08);
    text-align: center;
    margin-top: 0.5rem;
  }
  .pf-avatar-wrap { position: relative; width: 96px; height: 96px; margin: 0 auto; }
  .pf-avatar {
    width: 96px; height: 96px; border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, #1D6AE5, #00D2BE);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3), inset 0 0 0 3px rgba(255,255,255,0.1);
    overflow: hidden;
  }
  .pf-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .pf-camera {
    position: absolute; right: -2px; bottom: -2px;
    width: 32px; height: 32px; border-radius: 999px;
    background: #1D6AE5; color: #fff;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    border: 2px solid #0A1628; cursor: pointer;
  }
  .pf-name { font-size: 1.25rem; font-weight: 800; color: #fff; margin-top: 0.75rem; }
  .pf-meta { font-size: 0.75rem; color: rgba(255,255,255,0.55); margin-top: 0.125rem; letter-spacing: 0.02em; }
  .pf-meta .dot { opacity: 0.4; margin: 0 0.3rem; }
  .pf-lock-chip { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.1rem 0.5rem; border-radius: 999px; background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 0.65rem; margin-top: 0.5rem; }

  .pf-section {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    padding: 1rem; margin-top: 0.75rem;
  }
  .pf-section-title { font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.625rem; display: flex; align-items: center; justify-content: space-between; }

  .pf-field { margin-bottom: 0.75rem; }
  .pf-field:last-child { margin-bottom: 0; }
  .pf-label { display: block; font-size: 0.65rem; font-weight: 600; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; }
  .pf-input {
    width: 100%; background: rgba(255,255,255,0.05); color: #fff;
    border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
    padding: 0.6rem 0.75rem; font-size: 0.875rem;
  }
  .pf-input:focus { outline: none; border-color: #1D6AE5; box-shadow: 0 0 0 3px rgba(29,106,229,0.2); }
  .pf-input.is-invalid { border-color: #F87171; box-shadow: 0 0 0 3px rgba(248,113,113,0.15); }
  .pf-input[readonly] { opacity: 0.55; cursor: not-allowed; }
  .pf-help { font-size: 0.65rem; color: rgba(255,255,255,0.35); margin-top: 0.25rem; }
  .pf-err { font-size: 0.65rem; color: #F87171; margin-top: 0.25rem; display: none; }
  .pf-err.show { display: block; }
  .pf-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

  .pf-btn-primary {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.375rem;
    padding: 0.6rem 1rem; background: #1D6AE5; color: #fff;
    font-weight: 700; font-size: 0.85rem; border-radius: 10px;
    box-shadow: 0 2px 8px rgba(29,106,229,0.3);
  }
  .pf-btn-primary:disabled { opacity: 0.4; box-shadow: none; cursor: not-allowed; }
  .pf-btn-secondary {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.5rem 0.875rem; background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
    font-size: 0.8rem; font-weight: 600;
  }
  .pf-btn-danger {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.375rem 0.625rem; color: #F87171;
    font-size: 0.7rem; font-weight: 600; border-radius: 8px;
  }
  .pf-btn-danger:hover { background: rgba(239,68,68,0.1); }

  .pf-contact {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 0.75rem 0.875rem;
  }
  .pf-contact + .pf-contact { margin-top: 0.5rem; }
  .pf-contact-head { display: flex; align-items: start; justify-content: space-between; gap: 0.5rem; }
  .pf-contact-name { font-size: 0.9rem; font-weight: 700; color: #fff; }
  .pf-contact-rel { font-size: 0.7rem; color: rgba(255,255,255,0.45); margin-top: 1px; }
  .pf-contact-primary {
    display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.1rem 0.45rem;
    background: rgba(16,185,129,0.15); color: #34D399; border-radius: 999px;
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .pf-contact-body { font-size: 0.8rem; color: rgba(255,255,255,0.72); margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.15rem; }
  .pf-contact-actions { display: flex; gap: 0.25rem; margin-top: 0.5rem; }

  .pf-toast {
    position: fixed; left: 50%; bottom: 90px; transform: translateX(-50%) translateY(20px);
    padding: 0.625rem 1rem; border-radius: 12px;
    background: rgba(16,185,129,0.95); color: #fff; font-size: 0.8rem; font-weight: 600;
    box-shadow: 0 6px 20px rgba(0,0,0,0.3); z-index: 90;
    opacity: 0; pointer-events: none; transition: all 0.3s ease;
    display: inline-flex; align-items: center; gap: 0.5rem;
  }
  .pf-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); pointer-events: auto; }
  .pf-toast.error { background: rgba(239,68,68,0.95); }

  .pf-sheet-bg { position: fixed; inset: 0; background: rgba(0,0,0,0.55); backdrop-filter: blur(4px); z-index: 60; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  .pf-sheet-bg.open { opacity: 1; pointer-events: auto; }
  .pf-sheet {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 70;
    background: #0F1B30; color: #fff;
    border-radius: 18px 18px 0 0;
    max-height: 90vh; overflow-y: auto;
    transform: translateY(100%); transition: transform 0.25s ease;
    padding: 0.75rem 1rem 1.25rem;
    padding-bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px));
  }
  .pf-sheet.open { transform: translateY(0); }
  .pf-sheet-handle { width: 36px; height: 4px; background: rgba(255,255,255,0.2); border-radius: 2px; margin: 0.375rem auto 0.875rem; }
  .pf-sheet h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.75rem; }

  .pf-check {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 0.75rem; background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
    cursor: pointer;
  }
  .pf-check input { accent-color: #1D6AE5; }
  .pf-check span { font-size: 0.85rem; color: rgba(255,255,255,0.85); }
</style>

<div class="pf-wrap">

  <!-- HERO -->
  <div class="pf-hero">
    <div class="pf-avatar-wrap">
      <div class="pf-avatar">
        <% if (photo) { %>
          <img src="<%= photo %>" alt="<%= displayName %>">
        <% } else { %>
          <%= initials %>
        <% } %>
      </div>
      <label class="pf-camera" for="photo-input" aria-label="Change photo">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </label>
      <form id="photo-form" method="POST" action="/w/profile/photo" enctype="multipart/form-data" style="display:none;">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="file" id="photo-input" name="photo" accept="image/*" capture="user" onchange="pfUploadPhoto(this)">
      </form>
    </div>
    <p class="pf-name"><%= displayName %></p>
    <p class="pf-meta">
      <% if (empCode) { %><%= empCode %><span class="dot">·</span><% } %>
      <% if (roleLabel) { %><span class="capitalize"><%= roleLabel %></span><% } %>
    </p>
    <div class="pf-lock-chip">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      Name &amp; role managed by admin
    </div>
  </div>

  <!-- KUDOS SUMMARY -->
  <% if (kudosSummary) { %>
    <div class="pf-section">
      <div class="pf-section-title">
        Kudos received
        <a href="/w/feed?filter=mentions" class="text-xs font-semibold" style="color: #60A5FA; text-transform: none; letter-spacing: normal;">See all →</a>
      </div>
      <div style="display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: center;">
        <div style="width: 68px; height: 68px; border-radius: 16px; background: linear-gradient(135deg, #F59E0B, #EC4899); display: flex; flex-direction: column; align-items: center; justify-content: center;">
          <span style="font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1;"><%= kudosSummary.received %></span>
          <span style="font-size: 0.55rem; font-weight: 700; color: rgba(255,255,255,0.85); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 3px;">KUDOS</span>
        </div>
        <div style="min-width: 0;">
          <% if (kudosSummary.topValue) { %>
            <p style="font-size: 0.7rem; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700;">Most recognised for</p>
            <span style="display: inline-flex; align-items: center; gap: 5px; margin-top: 5px; padding: 4px 10px; border-radius: 999px; font-size: 0.78rem; font-weight: 700; background: <%= kudosSummary.topValue.colour %>22; color: <%= kudosSummary.topValue.colour %>;">★ <%= kudosSummary.topValue.name %></span>
          <% } else if (kudosSummary.received === 0) { %>
            <p style="font-size: 0.82rem; color: rgba(255,255,255,0.6);">No kudos yet — send one to a teammate and start the love.</p>
          <% } else { %>
            <p style="font-size: 0.82rem; color: rgba(255,255,255,0.75);">Recognised <%= kudosSummary.received %> time<%= kudosSummary.received === 1 ? '' : 's' %>.</p>
          <% } %>
        </div>
      </div>
      <% if (kudosSummary.recent && kudosSummary.recent.length > 0) { %>
        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.06);">
          <% kudosSummary.recent.forEach(function (r) { %>
            <a href="/w/feed/<%= r.id %>" style="display: block; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.04); text-decoration: none;">
              <div style="display: flex; align-items: start; gap: 8px;">
                <% if (r.value_name) { %><span style="display: inline-flex; align-items: center; padding: 2px 7px; border-radius: 999px; font-size: 0.62rem; font-weight: 700; background: <%= r.value_colour %>22; color: <%= r.value_colour %>; flex-shrink: 0;"><%= r.value_name %></span><% } %>
                <p style="font-size: 0.78rem; color: rgba(255,255,255,0.78); line-height: 1.3; flex: 1;">"<%= r.message.slice(0, 140) %><%= r.message.length > 140 ? '…' : '' %>" <span style="color: rgba(255,255,255,0.4);">— <%= r.sender_name %></span></p>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>

  <!-- CONTACT & ADDRESS (EDITABLE) -->
  <form id="profile-form" method="POST" action="/w/profile">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <div class="pf-section">
      <div class="pf-section-title">Contact</div>
      <div class="pf-field">
        <label class="pf-label">Phone</label>
        <input type="tel" name="phone" class="pf-input" value="<%= phone %>" placeholder="0400 000 000" autocomplete="tel" data-validate="phone">
        <p class="pf-err" data-err-for="phone">Enter a valid Australian number (e.g. 0400 000 000)</p>
      </div>
      <div class="pf-field">
        <label class="pf-label">Email</label>
        <input type="email" name="email" class="pf-input" value="<%= email %>" placeholder="you@example.com" autocomplete="email" data-validate="email">
        <p class="pf-err" data-err-for="email">Enter a valid email address</p>
      </div>
    </div>

    <div class="pf-section">
      <div class="pf-section-title">Address</div>
      <div class="pf-field">
        <label class="pf-label">Street address</label>
        <input type="text" name="address_line1" class="pf-input" value="<%= addr1 %>" placeholder="Unit / street number" autocomplete="address-line1">
      </div>
      <div class="pf-field">
        <input type="text" name="address_line2" class="pf-input" value="<%= addr2 %>" placeholder="Building name or apartment (optional)" autocomplete="address-line2">
      </div>
      <div class="pf-grid2">
        <div class="pf-field">
          <label class="pf-label">Suburb</label>
          <input type="text" name="suburb" class="pf-input" value="<%= suburb %>" autocomplete="address-level2">
        </div>
        <div class="pf-field">
          <label class="pf-label">State</label>
          <select name="state" class="pf-input">
            <% ['','NSW','VIC','QLD','WA','SA','TAS','ACT','NT'].forEach(s => { %>
              <option value="<%= s %>" <%= state === s ? 'selected' : '' %>><%= s || '—' %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <div class="pf-field">
        <label class="pf-label">Postcode</label>
        <input type="text" name="postcode" class="pf-input" value="<%= postcode %>" placeholder="2000" inputmode="numeric" pattern="\d{4}" maxlength="4" data-validate="postcode">
        <p class="pf-err" data-err-for="postcode">Postcode must be 4 digits</p>
      </div>
    </div>

    <div class="flex justify-end mt-3">
      <button type="submit" class="pf-btn-primary" id="save-btn" disabled>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Save changes
      </button>
    </div>
  </form>

  <!-- EMERGENCY CONTACTS -->
  <div class="pf-section">
    <div class="pf-section-title">
      Emergency contacts
      <button type="button" class="pf-btn-secondary" onclick="pfOpenContact()">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Add
      </button>
    </div>
    <% if (!contacts || contacts.length === 0) { %>
      <p class="text-sm text-white/50 text-center py-4">No emergency contacts yet.<br>Add at least one so we can reach someone if there's an issue at work.</p>
    <% } else { %>
      <% contacts.forEach(c => { %>
        <div class="pf-contact">
          <div class="pf-contact-head">
            <div>
              <p class="pf-contact-name"><%= c.name %></p>
              <% if (c.relationship) { %><p class="pf-contact-rel"><%= c.relationship %></p><% } %>
            </div>
            <% if (c.is_primary) { %>
              <span class="pf-contact-primary">★ Primary</span>
            <% } %>
          </div>
          <div class="pf-contact-body">
            <span><a href="tel:<%= c.phone %>" class="text-brand-400 underline-offset-2 hover:underline"><%= c.phone %></a></span>
            <% if (c.alt_phone) { %><span class="text-white/50"><a href="tel:<%= c.alt_phone %>"><%= c.alt_phone %></a> (alt)</span><% } %>
          </div>
          <div class="pf-contact-actions">
            <button type="button" class="pf-btn-secondary" onclick='pfOpenContact(<%- JSON.stringify(c) %>)'>Edit</button>
            <form method="POST" action="/w/profile/contacts/<%= c.id %>/delete" onsubmit="return confirm('Remove <%= c.name.replace(/'/g, "&#39;") %>?')">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <button type="submit" class="pf-btn-danger">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Remove
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- SECURITY (PIN) -->
  <div class="pf-section">
    <div class="pf-section-title">Security</div>
    <button type="button" class="w-full flex items-center justify-between p-3 rounded-lg hover:bg-white/5 transition" onclick="pfOpenPin()">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full flex items-center justify-center" style="background: rgba(167,139,250,0.15); color: #A78BFA;">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <div class="text-left">
          <p class="text-sm font-semibold text-white">Change PIN</p>
          <p class="text-xs text-white/40">Used to sign in to the worker portal</p>
        </div>
      </div>
      <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>
</div>

<!-- PIN SHEET -->
<div class="pf-sheet-bg" id="pin-bg" onclick="pfClosePin()"></div>
<div class="pf-sheet" id="pin-sheet" role="dialog" aria-label="Change PIN">
  <div class="pf-sheet-handle"></div>
  <h3>Change PIN</h3>
  <form method="POST" action="/w/profile/pin">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="pf-field">
      <label class="pf-label">Current PIN</label>
      <input type="password" name="current_pin" class="pf-input" inputmode="numeric" pattern="\d{4,6}" maxlength="6" required>
    </div>
    <div class="pf-field">
      <label class="pf-label">New PIN</label>
      <input type="password" name="new_pin" class="pf-input" inputmode="numeric" pattern="\d{4,6}" maxlength="6" required>
      <p class="pf-help">4–6 digits. Avoid sequences like 1234 or 0000.</p>
    </div>
    <div class="pf-field">
      <label class="pf-label">Confirm new PIN</label>
      <input type="password" name="confirm_pin" class="pf-input" inputmode="numeric" pattern="\d{4,6}" maxlength="6" required>
    </div>
    <div class="grid grid-cols-[1fr_2fr] gap-2 mt-4">
      <button type="button" class="pf-btn-secondary justify-center" onclick="pfClosePin()">Cancel</button>
      <button type="submit" class="pf-btn-primary">Update PIN</button>
    </div>
  </form>
</div>

<!-- EMERGENCY CONTACT SHEET -->
<div class="pf-sheet-bg" id="contact-bg" onclick="pfCloseContact()"></div>
<div class="pf-sheet" id="contact-sheet" role="dialog" aria-label="Emergency contact">
  <div class="pf-sheet-handle"></div>
  <h3 id="contact-title">Add emergency contact</h3>
  <form id="contact-form" method="POST" action="/w/profile/contacts">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <div class="pf-field">
      <label class="pf-label">Full name</label>
      <input type="text" name="name" id="c-name" class="pf-input" required>
    </div>
    <div class="pf-grid2">
      <div class="pf-field">
        <label class="pf-label">Relationship</label>
        <input type="text" name="relationship" id="c-rel" class="pf-input" placeholder="e.g. Spouse">
      </div>
      <div class="pf-field">
        <label class="pf-label">Primary?</label>
        <label class="pf-check">
          <input type="checkbox" name="is_primary" id="c-primary" value="1">
          <span>Primary contact</span>
        </label>
      </div>
    </div>
    <div class="pf-field">
      <label class="pf-label">Phone</label>
      <input type="tel" name="phone" id="c-phone" class="pf-input" placeholder="0400 000 000" required>
    </div>
    <div class="pf-field">
      <label class="pf-label">Alternate phone (optional)</label>
      <input type="tel" name="alt_phone" id="c-alt" class="pf-input" placeholder="02 8000 0000">
    </div>
    <div class="grid grid-cols-[1fr_2fr] gap-2 mt-4">
      <button type="button" class="pf-btn-secondary justify-center" onclick="pfCloseContact()">Cancel</button>
      <button type="submit" class="pf-btn-primary" id="c-submit">Save contact</button>
    </div>
  </form>
</div>

<!-- Toast -->
<% if (flash_success && flash_success.length) { %>
  <div class="pf-toast show" id="pf-toast">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    <span id="pf-toast-msg"><%= flash_success[0] %></span>
  </div>
<% } else if (flash_error && flash_error.length) { %>
  <div class="pf-toast show error" id="pf-toast">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
    <span id="pf-toast-msg"><%= flash_error[0] %></span>
  </div>
<% } else { %>
  <div class="pf-toast" id="pf-toast">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    <span id="pf-toast-msg">Saved</span>
  </div>
<% } %>

<script>
(function () {
  const AU_PHONE_RE = /^(?:\+?61\s?)?(?:0?4\d{2}\s?\d{3}\s?\d{3}|0?[237]\s?\d{4}\s?\d{4})$/;
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
  const POSTCODE_RE = /^\d{4}$/;

  const form = document.getElementById('profile-form');
  const saveBtn = document.getElementById('save-btn');
  const originals = {};
  form.querySelectorAll('input, select').forEach(el => { originals[el.name] = el.value; });

  function validateField(el) {
    const type = el.getAttribute('data-validate');
    const err = document.querySelector('[data-err-for="' + el.name + '"]');
    let ok = true;
    const v = (el.value || '').trim();
    if (v) {
      if (type === 'phone') ok = AU_PHONE_RE.test(v);
      else if (type === 'email') ok = EMAIL_RE.test(v);
      else if (type === 'postcode') ok = POSTCODE_RE.test(v);
    }
    el.classList.toggle('is-invalid', !ok);
    if (err) err.classList.toggle('show', !ok);
    return ok;
  }

  function checkDirty() {
    let dirty = false;
    let valid = true;
    form.querySelectorAll('input, select').forEach(el => {
      if (el.value !== originals[el.name]) dirty = true;
      if (el.getAttribute('data-validate') && !validateField(el)) valid = false;
    });
    saveBtn.disabled = !dirty || !valid;
  }

  form.addEventListener('input', checkDirty);
  form.addEventListener('change', checkDirty);

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    let valid = true;
    form.querySelectorAll('[data-validate]').forEach(el => { if (!validateField(el)) valid = false; });
    if (!valid) { pfToast('Please fix the highlighted fields', true); return; }

    const snapshot = { ...originals };
    const data = new URLSearchParams(new FormData(form));
    form.querySelectorAll('input, select').forEach(el => { originals[el.name] = el.value; });
    saveBtn.disabled = true;

    try {
      const r = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
        body: data.toString()
      });
      if (!r.ok) throw new Error('Server returned ' + r.status);
      const payload = await r.json().catch(() => ({ ok: true }));
      if (payload.ok === false) throw new Error(Object.values(payload.errors || {}).join(' ') || 'Save failed');
      pfToast('Profile saved');
    } catch (err) {
      Object.keys(snapshot).forEach(k => {
        const el = form.querySelector('[name="' + k + '"]');
        if (el) el.value = snapshot[k];
        originals[k] = snapshot[k];
      });
      pfToast('Could not save: ' + err.message, true);
      checkDirty();
    }
  });

  let toastTimer = null;
  window.pfToast = function (msg, isError) {
    const t = document.getElementById('pf-toast');
    const m = document.getElementById('pf-toast-msg');
    if (m) m.textContent = msg;
    t.classList.toggle('error', !!isError);
    t.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
  };
  setTimeout(() => { const t = document.getElementById('pf-toast'); if (t) t.classList.remove('show'); }, 3200);

  window.pfUploadPhoto = function (input) {
    if (!input.files || !input.files[0]) return;
    const file = input.files[0];
    if (file.size > 2 * 1024 * 1024) { pfToast('Image is larger than 2MB', true); input.value = ''; return; }
    const reader = new FileReader();
    reader.onload = (e) => {
      const av = document.querySelector('.pf-avatar');
      av.innerHTML = '<img src="' + e.target.result + '" alt="">';
    };
    reader.readAsDataURL(file);
    document.getElementById('photo-form').submit();
  };

  const pinBg = document.getElementById('pin-bg'), pinSheet = document.getElementById('pin-sheet');
  window.pfOpenPin = () => { pinBg.classList.add('open'); pinSheet.classList.add('open'); };
  window.pfClosePin = () => { pinBg.classList.remove('open'); pinSheet.classList.remove('open'); };

  const cBg = document.getElementById('contact-bg'), cSheet = document.getElementById('contact-sheet');
  const cForm = document.getElementById('contact-form');
  window.pfOpenContact = function (c) {
    if (c && c.id) {
      cForm.action = '/w/profile/contacts/' + c.id;
      document.getElementById('contact-title').textContent = 'Edit emergency contact';
      document.getElementById('c-name').value = c.name || '';
      document.getElementById('c-rel').value = c.relationship || '';
      document.getElementById('c-phone').value = c.phone || '';
      document.getElementById('c-alt').value = c.alt_phone || '';
      document.getElementById('c-primary').checked = !!c.is_primary;
      document.getElementById('c-submit').textContent = 'Update contact';
    } else {
      cForm.reset();
      cForm.action = '/w/profile/contacts';
      document.getElementById('contact-title').textContent = 'Add emergency contact';
      document.getElementById('c-submit').textContent = 'Save contact';
    }
    cBg.classList.add('open'); cSheet.classList.add('open');
  };
  window.pfCloseContact = () => { cBg.classList.remove('open'); cSheet.classList.remove('open'); };
})();
</script>
