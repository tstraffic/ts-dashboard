<div class="space-y-5">
  <a href="/w/hr" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to HR
  </a>

  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold text-gray-900">Leave Requests</h1>
  </div>

  <!-- New Leave Request Form -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Submit New Request</h3>
    <form method="POST" action="/w/hr/leave" class="space-y-3">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Leave Type</label>
        <select name="leave_type" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
          <option value="annual">Annual Leave</option>
          <option value="sick">Sick Leave</option>
          <option value="personal">Personal Leave</option>
          <option value="unpaid">Unpaid Leave</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">Start Date</label>
          <input type="date" name="start_date" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-600 mb-1">End Date</label>
          <input type="date" name="end_date" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Reason (optional)</label>
        <textarea name="reason" rows="2" placeholder="Brief reason..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
      </div>
      <button type="submit" class="w-full py-2.5 bg-brand-600 text-white rounded-lg font-medium text-sm hover:bg-brand-700 transition">Submit Request</button>
    </form>
  </div>

  <!-- Leave History -->
  <% if (leaveRequests.length > 0) { %>
    <div>
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Request History</h2>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm divide-y divide-gray-100">
        <% leaveRequests.forEach(l => { %>
          <div class="p-3">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium text-gray-700"><%= l.leave_type.charAt(0).toUpperCase() + l.leave_type.slice(1) %> Leave</span>
              <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold
                <%= l.status === 'approved' ? 'bg-emerald-50 text-emerald-700'
                  : l.status === 'rejected' ? 'bg-red-50 text-red-700'
                  : l.status === 'cancelled' ? 'bg-gray-100 text-gray-500'
                  : 'bg-amber-50 text-amber-700' %>">
                <%= l.status.charAt(0).toUpperCase() + l.status.slice(1) %>
              </span>
            </div>
            <p class="text-sm text-gray-900">
              <%= new Date(l.start_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) %> — <%= new Date(l.end_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) %>
              <span class="text-gray-400">(<%= l.total_days %> day<%= l.total_days > 1 ? 's' : '' %>)</span>
            </p>
            <% if (l.reason) { %><p class="text-xs text-gray-500 mt-0.5"><%= l.reason %></p><% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <p class="text-gray-500 text-sm">No leave requests yet</p>
    </div>
  <% } %>
</div>
