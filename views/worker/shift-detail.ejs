<div class="space-y-4">
  <!-- Back -->
  <a href="/w/shifts" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Shifts
  </a>

  <!-- Job Header -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-gray-500"><%= allocation.job_number %></span>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold
        <%= allocation.status === 'confirmed' ? 'bg-emerald-50 text-emerald-700'
          : allocation.status === 'completed' ? 'bg-blue-50 text-blue-700'
          : 'bg-amber-50 text-amber-700' %>">
        <%= allocation.status.charAt(0).toUpperCase() + allocation.status.slice(1) %>
      </span>
    </div>
    <h1 class="text-lg font-bold text-gray-900"><%= allocation.client %></h1>
    <% if (allocation.job_name) { %>
      <p class="text-sm text-gray-600 mt-0.5"><%= allocation.job_name %></p>
    <% } %>
  </div>

  <!-- Shift Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm divide-y divide-gray-100">
    <div class="p-4 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500">Date</p>
        <p class="text-sm font-medium text-gray-900"><%= new Date(allocation.allocation_date + 'T00:00:00').toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></p>
      </div>
    </div>
    <div class="p-4 flex items-center gap-3">
      <div class="w-9 h-9 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-gray-500">Time</p>
        <p class="text-sm font-medium text-gray-900"><%= allocation.start_time %> — <%= allocation.end_time %> (<%= allocation.shift_type %> shift)</p>
      </div>
    </div>
    <% if (allocation.role_on_site) { %>
      <div class="p-4 flex items-center gap-3">
        <div class="w-9 h-9 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500">Your Role</p>
          <p class="text-sm font-medium text-gray-900"><%= allocation.role_on_site.replace(/_/g, ' ') %></p>
        </div>
      </div>
    <% } %>
    <% if (allocation.site_address) { %>
      <a href="https://maps.google.com/?q=<%= encodeURIComponent(allocation.site_address + ', ' + allocation.suburb) %>" target="_blank" class="p-4 flex items-center gap-3 active:bg-gray-50">
        <div class="w-9 h-9 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-gray-500">Site Location</p>
          <p class="text-sm font-medium text-brand-600 truncate"><%= allocation.site_address %>, <%= allocation.suburb %></p>
          <p class="text-[10px] text-gray-400">Tap to open in Maps</p>
        </div>
        <svg class="w-4 h-4 text-gray-300 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    <% } %>
  </div>

  <!-- Supervisor -->
  <% if (allocation.supervisor_name) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Supervisor</h3>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-brand-100 flex items-center justify-center text-brand-700 font-semibold text-sm">
          <%= allocation.supervisor_name.split(' ').map(n => n[0]).join('').slice(0,2) %>
        </div>
        <div>
          <p class="text-sm font-medium text-gray-900"><%= allocation.supervisor_name %></p>
          <% if (allocation.supervisor_email) { %>
            <p class="text-xs text-gray-500"><%= allocation.supervisor_email %></p>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Crew on Site -->
  <% if (otherCrew.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Crew on Site (<%= otherCrew.length + 1 %>)</h3>
      <div class="space-y-2">
        <% otherCrew.forEach(c => { %>
          <div class="flex items-center justify-between py-1.5">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 text-xs font-medium">
                <%= c.full_name.split(' ').map(n => n[0]).join('').slice(0,2) %>
              </div>
              <div>
                <p class="text-sm text-gray-900"><%= c.full_name %></p>
                <p class="text-[10px] text-gray-400"><%= c.role_on_site ? c.role_on_site.replace(/_/g, ' ') : c.crew_role %></p>
              </div>
            </div>
            <% if (c.phone) { %>
              <a href="tel:<%= c.phone %>" class="w-8 h-8 rounded-full bg-brand-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </a>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Job Notes -->
  <% if (allocation.job_notes) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Job Notes</h3>
      <p class="text-sm text-gray-700 whitespace-pre-line"><%= allocation.job_notes %></p>
    </div>
  <% } %>

  <!-- Actions -->
  <div class="space-y-2">
    <% if (allocation.status === 'allocated' || allocation.status === 'scheduled') { %>
      <form method="POST" action="/w/shifts/<%= allocation.id %>/confirm">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <button type="submit" class="w-full py-3 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 active:bg-brand-800 transition">
          Confirm Attendance
        </button>
      </form>
    <% } %>

    <% if (!lastClock || lastClock.event_type !== 'clock_in') { %>
      <a href="/w/clock" class="block w-full py-3 bg-emerald-600 text-white rounded-xl font-semibold text-sm text-center hover:bg-emerald-700 active:bg-emerald-800 transition">
        Clock In for This Shift
      </a>
    <% } else { %>
      <a href="/w/clock" class="block w-full py-3 bg-red-600 text-white rounded-xl font-semibold text-sm text-center hover:bg-red-700 active:bg-red-800 transition">
        Clock Out
      </a>
    <% } %>
  </div>
</div>
