<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900">More</h1>
    <p class="text-sm text-gray-500 mt-0.5">All features & settings</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm divide-y divide-gray-100">
    <!-- Profile -->
    <% if (typeof isManager !== 'undefined' && isManager) { %>
      <a href="/w/manage" class="flex items-center gap-3 p-4 active:bg-gray-50 transition" style="background: linear-gradient(90deg, rgba(245,158,11,0.08), transparent);">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #F59E0B, #EC4899);">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <div class="flex-1"><p class="text-sm font-bold text-gray-900">Manager tools</p><p class="text-xs text-gray-500">Shifts, leave approvals, kudos moderation</p></div>
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    <% } %>
    <a href="/w/profile" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-brand-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">My Profile</p><p class="text-xs text-gray-500">Contact details, change PIN</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <!-- HR -->
    <a href="/w/hr" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-purple-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">HR & My Info</p><p class="text-xs text-gray-500">Certs, leave, employment details</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <!-- Timesheets -->
    <a href="/w/timesheets" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-emerald-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">Timesheets</p><p class="text-xs text-gray-500">View & submit hours</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <!-- Availability -->
    <a href="/w/availability" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-amber-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">Availability</p><p class="text-xs text-gray-500">4-week availability calendar</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <!-- Dockets -->
    <a href="/w/dockets" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">Dockets</p><p class="text-xs text-gray-500">Sign off work dockets</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
    <!-- Safety Forms -->
    <a href="/w/forms" class="flex items-center gap-3 p-4 active:bg-gray-50 transition">
      <div class="w-9 h-9 rounded-lg bg-red-50 flex items-center justify-center">
        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
      </div>
      <div class="flex-1"><p class="text-sm font-medium text-gray-900">Safety Forms</p><p class="text-xs text-gray-500">Prestart, Take 5, incidents, hazards</p></div>
      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
