<%- include('partials/kudos-style') %>

<div class="kd-wrap">
  <a href="/w/feed" class="inline-flex items-center gap-1 text-xs text-white/50 mt-2 mb-1">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    Feed
  </a>

  <div style="padding: 1rem; border-radius: 14px; background: linear-gradient(160deg, rgba(245,158,11,0.18), rgba(234,88,12,0.1)); border: 1px solid rgba(245,158,11,0.35); text-align: center; margin-top: 0.5rem;">
    <div style="font-size: 2rem;">🏆</div>
    <h1 style="font-size: 1.2rem; font-weight: 800; color: #fff;">Leaderboard</h1>
    <p style="font-size: 0.75rem; color: rgba(255,255,255,0.6); margin-top: 2px;">Recognising the best of the crew.</p>
  </div>

  <div class="kd-lb-head" style="margin-top: 12px;">
    <a href="?w=month" class="kd-pill <%= windowKey === 'month' ? 'on' : '' %>">This month</a>
    <a href="?w=quarter" class="kd-pill <%= windowKey === 'quarter' ? 'on' : '' %>">Quarter</a>
    <a href="?w=all" class="kd-pill <%= windowKey === 'all' ? 'on' : '' %>">All time</a>
  </div>

  <% boards.forEach(function (b) { %>
    <div class="kd-lb-cat">
      <p class="kd-lb-title"><%= b.label %></p>
      <% if (b.rows.length === 0) { %>
        <p style="font-size: 0.8rem; color: rgba(255,255,255,0.4); text-align: center; padding: 16px 0;">No data yet for this period.</p>
      <% } else { %>
        <% b.rows.forEach(function (row, i) { %>
          <div class="kd-lb-row">
            <span class="kd-lb-rank <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '' %>"><%= i + 1 %></span>
            <span class="kd-lb-name"><%= row.full_name %></span>
            <span class="kd-lb-count"><%= row.count %><span class="kd-lb-count-unit"><%= b.suffix %></span></span>
          </div>
        <% }) %>
      <% } %>
    </div>
  <% }) %>

  <!-- Opt out toggle -->
  <form method="POST" action="/w/leaderboard/optout" style="margin-top: 20px; text-align: center;">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <button type="submit" style="font-size: 0.72rem; color: rgba(255,255,255,0.5); text-decoration: underline;">Toggle my leaderboard visibility</button>
  </form>

  <% if (flash_success && flash_success.length) { %>
    <div class="fixed left-1/2 -translate-x-1/2 bottom-[90px] px-4 py-2 rounded-xl text-sm font-semibold text-white bg-emerald-500 shadow-lg z-50" id="kd-toast"><%= flash_success[0] %></div>
    <script>setTimeout(()=>{ document.getElementById('kd-toast')?.remove(); }, 2800);</script>
  <% } %>
</div>
