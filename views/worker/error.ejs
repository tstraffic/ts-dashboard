<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
  <div class="w-16 h-16 rounded-full bg-red-50 flex items-center justify-center mb-4">
    <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
    </svg>
  </div>
  <h1 class="text-xl font-bold text-gray-900 mb-2"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
  <p class="text-gray-500 mb-6"><%= typeof message !== 'undefined' ? message : 'Something went wrong.' %></p>
  <a href="/w/home" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-lg transition-colors">
    Go Home
  </a>
</div>
