<div class="px-4 pt-3 pb-4 space-y-4">
  <!-- Back + Title -->
  <div class="flex items-center gap-3">
    <a href="/w/jobs" class="text-sm font-medium" style="color:#00D2BE;">&larr; Jobs</a>
    <span class="text-sm text-gray-400">|</span>
    <span class="text-sm font-semibold"><%= booking.booking_number %></span>
  </div>

  <!-- Accept / Decline (if pending) -->
  <% if (myStatus === 'assigned' || myStatus === 'allocated') { %>
  <div class="flex gap-3">
    <form method="POST" action="/w/bookings/<%= booking.id %>/respond" class="flex-1">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="action" value="accept">
      <button type="submit" class="w-full py-3 rounded-xl text-sm font-bold transition" style="background:#16a34a;color:white;">
        &#10003; Accept
      </button>
    </form>
    <form method="POST" action="/w/bookings/<%= booking.id %>/respond" class="flex-1">
      <%- include('../partials/csrf') %>
      <input type="hidden" name="action" value="decline">
      <button type="submit" class="w-full py-3 rounded-xl text-sm font-bold transition" style="background:#dc2626;color:white;">
        &#10007; Decline
      </button>
    </form>
  </div>
  <% } else if (myStatus === 'confirmed') { %>
  <div class="p-3 rounded-xl text-center text-sm font-medium" style="background:rgba(22,163,74,0.12);color:#4ade80;border:1px solid rgba(22,163,74,0.25);">
    &#10003; You have accepted this shift
  </div>
  <% } %>

  <!-- Location -->
  <div>
    <p class="text-base font-semibold"><%= booking.site_address || booking.suburb || 'Location TBC' %><%= booking.suburb && booking.state ? ', ' + booking.state : '' %></p>
    <p class="text-sm text-gray-400 mt-1">
      Your shift: <%= startDay %>, <%= startDate %> at
      <% if (booking.depot_meeting_time) { %>Depot <%= booking.depot_meeting_time %><% } else { %><%= startTime %><% } %>
      <% if (endTime) { %> – <%= endTime %> (approx)<% } %>
    </p>
  </div>

  <!-- Tabs: DETAILS / DOCS / FORMS -->
  <div class="flex border-b" style="border-color:rgba(255,255,255,0.08);">
    <a href="?tab=details" class="px-4 py-2.5 text-sm font-semibold transition-colors <%= tab === 'details' ? 'border-b-2' : '' %>"
      style="<%= tab === 'details' ? 'color:#00D2BE;border-color:#00D2BE;' : 'color:rgba(255,255,255,0.45);' %>">DETAILS</a>
    <a href="?tab=docs" class="px-4 py-2.5 text-sm font-semibold transition-colors <%= tab === 'docs' ? 'border-b-2' : '' %>"
      style="<%= tab === 'docs' ? 'color:#00D2BE;border-color:#00D2BE;' : 'color:rgba(255,255,255,0.45);' %>">DOCS</a>
    <a href="?tab=forms" class="px-4 py-2.5 text-sm font-semibold transition-colors <%= tab === 'forms' ? 'border-b-2' : '' %>"
      style="<%= tab === 'forms' ? 'color:#00D2BE;border-color:#00D2BE;' : 'color:rgba(255,255,255,0.45);' %>">FORMS</a>
  </div>

  <!-- DETAILS TAB -->
  <% if (tab === 'details') { %>
  <div class="space-y-3">
    <h3 class="text-xs font-bold uppercase tracking-wider" style="color:#00D2BE;">Details</h3>
    <div class="space-y-2">
      <% var details = [
        ['Booking', (startTime || '') + ' – ' + (endTime || '') + ' (approx)'],
        ['Booking #', booking.booking_number],
        ['Depot', booking.depot || '-'],
        ['Depot Meeting', booking.depot_meeting_time || '-'],
        ['Client', booking.client_name || '-'],
        ['Site Address', (booking.site_address || '-') + (booking.suburb ? ', ' + booking.suburb : '')],
        ['Order #', booking.order_number || '-'],
        ['Billing Code', booking.billing_code || '-'],
        ['Status', booking.status],
      ]; %>
      <% details.forEach(function(d) { %>
        <div class="flex items-start justify-between py-2" style="border-bottom:1px solid rgba(255,255,255,0.06);">
          <span class="text-xs text-gray-400 w-28 shrink-0"><%= d[0] %></span>
          <span class="text-sm text-right flex-1"><%= d[1] %></span>
        </div>
      <% }); %>
    </div>

    <% if (booking.notes || booking.requirements_text) { %>
    <div class="mt-3">
      <h3 class="text-xs font-bold uppercase tracking-wider mb-2" style="color:#00D2BE;">Description</h3>
      <p class="text-sm text-gray-400 whitespace-pre-wrap"><%= booking.requirements_text || booking.notes || '' %></p>
    </div>
    <% } %>

    <!-- Crew and Resources -->
    <div class="mt-3">
      <h3 class="text-xs font-bold uppercase tracking-wider mb-2" style="color:#00D2BE;">Crew and resources</h3>
      <% if (crew.length > 0) { %>
        <div class="space-y-2">
          <% crew.forEach(function(c) { %>
          <div class="flex items-center gap-3 py-2" style="border-bottom:1px solid rgba(255,255,255,0.06);">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold shrink-0" style="background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.6);">
              <%= c.full_name.split(' ').map(n => n[0]).join('').slice(0,2) %>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium"><%= c.full_name %></p>
              <p class="text-xs text-gray-500"><%= c.role || c.role_on_site || 'Traffic Controller' %></p>
            </div>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-full <%= c.status === 'confirmed' ? 'bg-emerald-500/20 text-emerald-400' : c.status === 'declined' ? 'bg-red-500/20 text-red-400' : 'bg-amber-500/20 text-amber-400' %>">
              <%= c.status === 'confirmed' ? 'Accepted' : c.status === 'declined' ? 'Declined' : 'Pending' %>
            </span>
          </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-500">No crew assigned yet.</p>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- DOCS TAB -->
  <% if (tab === 'docs') { %>
    <%
      var DOC_TYPE_LABEL = {
        tgs:'TGS', tmp:'TMP', ctmp:'CTMP', rol:'ROL', rol_day:'ROL — Day', rol_night:'ROL — Night',
        stage_plan:'Stage Plan', swms:'SWMS', permit:'Permit', invoice:'Invoice', photo:'Photo', other:'Other',
      };
      function fmtSize(n) { if (!n) return ''; if (n < 1024) return n + ' B'; if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB'; return (n/1048576).toFixed(1) + ' MB'; }
    %>
    <div class="space-y-2">
      <p class="text-xs text-gray-500 mb-1">Site documents — review before commencing work.</p>
      <% if (!jobDocuments || jobDocuments.length === 0) { %>
        <div class="py-6 text-center" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;">
          <p class="text-sm font-medium" style="color:rgba(255,255,255,0.85);">No documents uploaded yet</p>
          <p class="text-xs text-gray-500 mt-1">Your allocator hasn't attached site docs to this booking.</p>
        </div>
      <% } else { %>
        <% jobDocuments.forEach(function (doc) { %>
          <a href="<%= doc.download_url %>" target="_blank" class="flex items-center gap-3 px-3 py-2.5 rounded-lg" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background:rgba(239,68,68,0.18);color:#F87171;">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/><path d="M14 2v6h6M9 14h6M9 18h6M9 10h2"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-white truncate"><%= doc.title || doc.original_name %></p>
              <p class="text-[11px] text-gray-500">
                <%= DOC_TYPE_LABEL[doc.doc_type] || doc.doc_type %>
                <% if (doc.source === 'booking') { %><span class="ml-1 inline-block px-1.5 py-0.5 rounded text-[9px] font-bold" style="background:rgba(43,127,255,0.18);color:#60A5FA;">THIS SHIFT</span><% } %>
                <% if (doc.size_bytes) { %> · <%= fmtSize(doc.size_bytes) %><% } %>
              </p>
            </div>
            <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        <% }) %>
      <% } %>
    </div>
  <% } %>

  <!-- FORMS TAB -->
  <% if (tab === 'forms') { %>
    <%
      // Show the full Job-Pack to every worker on the shift. Team Leader
      // Checklist is the responsibility of the TL but anyone acting as TL
      // for the shift can still submit it.
      var JOB_PACK = [
        { key: 'vehicle_prestart',   path: 'vehicle-prestart',   label: '1. Vehicle Pre-Start',           hint: 'Before starting the vehicle' },
        { key: 'risk_toolbox',       path: 'risk-assessment',    label: '2. Risk Assessment & Toolbox',   hint: 'Run with the crew on site' },
        { key: 'tc_prestart',        path: 'tc-prestart',        label: '3. TC Prestart Declaration',     hint: 'Per Traffic Controller' },
        { key: 'team_leader',        path: 'team-leader',        label: '4. Team Leader Checklist',       hint: 'Crew lead / acting TL' },
        { key: 'post_shift_vehicle', path: 'post-shift-vehicle', label: '5. Post-Shift Vehicle Checklist',hint: 'At end of shift' },
      ];
    %>
    <div class="space-y-3">
      <p class="text-xs text-gray-500 mb-1">Shift-specific checklists and the docket.</p>

      <% if (!allocation) { %>
        <!-- This branch only fires if the lazy-allocation insert in
             routes/worker/jobs.js failed for some unrecoverable reason
             (e.g. the booking row was deleted between rendering and now).
             Keep a soft fallback so the worker isn't staring at a dead
             screen, but it should be unreachable in normal flow. -->
        <div class="py-3 px-3 rounded-lg" style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.20);">
          <p class="text-xs" style="color:#FCA5A5;">Couldn't load checklists for this shift — try refreshing or let the office know.</p>
        </div>
      <% } else { %>
        <% JOB_PACK.forEach(function (jp) { var done = formStatus[jp.key]; %>
          <a href="/w/forms/<%= jp.path %>?allocationId=<%= allocation.id %>"
             class="flex items-center justify-between py-2.5 px-3 rounded-lg" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
                   style="background: <%= done ? 'rgba(16,185,129,0.20)' : 'rgba(255,255,255,0.06)' %>; color: <%= done ? '#34D399' : 'rgba(255,255,255,0.45)' %>;">
                <% if (done) { %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <% } else { %>
                  <span class="text-xs font-bold"><%= jp.label.charAt(0) %></span>
                <% } %>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-white truncate"><%= jp.label %></p>
                <% if (done) { %>
                  <p class="text-[11px]" style="color:#34D399;">Submitted <%= new Date(done.submitted_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></p>
                <% } else { %>
                  <p class="text-[11px] text-gray-500"><%= jp.hint %></p>
                <% } %>
              </div>
            </div>
            <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        <% }) %>

        <!-- Docket -->
        <a href="/w/dockets/sign/<%= allocation.id %>"
           class="flex items-center justify-between py-2.5 px-3 rounded-lg mt-2" style="background:linear-gradient(135deg, rgba(43,127,255,0.18), rgba(43,127,255,0.06));border:1px solid rgba(43,127,255,0.35);">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background:rgba(43,127,255,0.22);color:#60A5FA;">
              <% if (docket) { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><path d="M9 5a2 2 0 002 2h2a2 2 0 002-2"/><path d="M9 13h6M9 17h4"/></svg>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white">Docket</p>
              <% if (docket) { %>
                <p class="text-[11px]" style="color:#60A5FA;">Signed · <%= docket.total_hours || 0 %> h · <%= new Date(docket.signed_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></p>
              <% } else { %>
                <p class="text-[11px] text-gray-500">Sign at end of shift — proof of hours.</p>
              <% } %>
            </div>
          </div>
          <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% } %>
    </div>
  <% } %>
</div>
