<div class="space-y-5">
  <a href="/w/timesheets" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>

  <h1 class="text-xl font-bold text-gray-900">Submit Timesheet</h1>

  <form method="POST" action="/w/timesheets" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <!-- Job Selection -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <label class="block text-xs font-semibold text-gray-500 uppercase">Job / Shift</label>
      <select name="job_id" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        <option value="">Select a job...</option>
        <% recentAllocations.forEach(a => { %>
          <option value="<%= a.job_id %>"><%= a.job_number %> — <%= a.client %> (<%= new Date(a.allocation_date + 'T00:00:00').toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) %>)</option>
        <% }) %>
      </select>
    </div>

    <!-- Date & Times -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Date</label>
        <input type="date" name="work_date" value="<%= today %>" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Start Time</label>
          <input type="time" name="start_time" value="<%= todayClocks.length > 0 ? new Date(todayClocks[0].event_time).toTimeString().slice(0,5) : '06:00' %>" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">End Time</label>
          <input type="time" name="end_time" value="<%= todayClocks.length > 1 ? new Date(todayClocks[todayClocks.length-1].event_time).toTimeString().slice(0,5) : '14:00' %>" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Break (minutes)</label>
          <input type="number" name="break_minutes" value="30" min="0" max="120" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Shift Type</label>
          <select name="shift_type" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
            <option value="day">Day</option>
            <option value="night">Night</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Notes -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Notes (optional)</label>
      <textarea name="notes" rows="3" placeholder="Any additional notes..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 resize-none"></textarea>
    </div>

    <button type="submit" class="w-full py-3 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 active:bg-brand-800 transition">
      Submit Timesheet
    </button>
  </form>
</div>
