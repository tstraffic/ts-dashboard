<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#1D6AE5">
  <title>Reset PIN | T&S Worker Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/worker.css">
</head>
<body class="h-full bg-brand-50 flex items-center justify-center safe-area-top safe-area-bottom">
  <div class="w-full max-w-sm px-6">
    <div class="text-center mb-8">
      <img src="/images/logo-colour.jpg" alt="T&S Traffic Control" class="h-20 w-auto mx-auto mb-4 rounded-xl shadow-sm">
      <h1 class="text-xl font-bold text-gray-900">Reset PIN</h1>
    </div>

    <% if (error) { %>
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 text-center">
        <svg class="w-12 h-12 mx-auto mb-3 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        <p class="text-gray-700 mb-4"><%= error %></p>
        <a href="/w/forgot-pin" class="text-brand-600 hover:text-brand-500 font-medium">Request a new link</a>
      </div>
    <% } else { %>
      <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
        <% flash_error.forEach(msg => { %>
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm"><%= msg %></div>
        <% }) %>
      <% } %>

      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <form method="POST" action="/w/reset-pin/<%= token %>" class="space-y-5">
          <div>
            <label for="pin" class="block text-sm font-medium text-gray-700 mb-1">New PIN</label>
            <input type="password" id="pin" name="pin" required
              inputmode="numeric" maxlength="6" pattern="[0-9]{4,6}"
              placeholder="4-6 digits"
              class="w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-gray-900 text-base text-center tracking-[0.5em] placeholder:tracking-normal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          </div>
          <div>
            <label for="pin_confirm" class="block text-sm font-medium text-gray-700 mb-1">Confirm PIN</label>
            <input type="password" id="pin_confirm" name="pin_confirm" required
              inputmode="numeric" maxlength="6" pattern="[0-9]{4,6}"
              placeholder="Re-enter PIN"
              class="w-full px-4 py-3 bg-white border border-gray-300 rounded-lg text-gray-900 text-base text-center tracking-[0.5em] placeholder:tracking-normal placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          </div>
          <button type="submit" class="w-full py-3 bg-brand-600 hover:bg-brand-500 active:bg-brand-700 text-white font-semibold rounded-lg transition-colors text-base">
            Reset PIN
          </button>
        </form>
      </div>
    <% } %>
  </div>
</body>
</html>
