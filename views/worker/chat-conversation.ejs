<div class="flex items-center gap-3 px-4 py-3 border-b border-gray-200 bg-white sticky top-0 z-10">
  <a href="/w/chat" class="p-1 text-gray-400 hover:text-gray-600">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  </a>
  <div class="flex-1 min-w-0">
    <h1 class="text-base font-bold text-gray-900 truncate"><%= threadTitle %></h1>
  </div>
</div>

<div style="padding-bottom: 60px;">
  <% if (typeof canPost !== 'undefined' && canPost === false) { %>
    <!-- Read-only (announcement channel) -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm mx-3 mt-3"
         data-chat-thread="<%= chatThreadId %>"
         data-current-user-id="<%= worker.id %>"
         data-current-user-name="<%= worker.full_name %>">
      <div class="chat-pinned hidden border-b border-gray-200 bg-amber-50 px-3 py-2 text-xs"></div>
      <div class="chat-typing hidden px-4 py-1 text-xs text-gray-400 italic"></div>
      <div class="chat-messages overflow-y-auto p-4 space-y-1" style="max-height: calc(100vh - 220px);">
        <div class="text-center text-gray-400 text-sm py-4">Loading...</div>
      </div>
      <div class="border-t border-gray-200 p-3 text-center">
        <p class="text-xs text-gray-400">Announcement channel — read only</p>
      </div>
    </div>
  <% } else { %>
    <%
      // Set chatUser for chat-panel partial compatibility
      const chatUser = worker;
      const user = worker;
    %>
    <div class="mx-3 mt-3">
      <%- include('../partials/chat-panel') %>
    </div>
  <% } %>
</div>
