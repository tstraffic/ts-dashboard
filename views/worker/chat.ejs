<%
  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const d = new Date(dateStr + (dateStr.endsWith('Z') ? '' : 'Z'));
    const now = new Date();
    const diff = Math.floor((now - d) / 60000);
    if (diff < 1) return 'now';
    if (diff < 60) return diff + 'm';
    if (diff < 1440) return Math.floor(diff / 60) + 'h';
    return Math.floor(diff / 1440) + 'd';
  }
%>

<div class="px-4 pt-4 pb-2">
  <h1 class="text-xl font-bold text-gray-900">Messages</h1>
</div>

<% if (threads.length === 0) { %>
  <div class="flex flex-col items-center justify-center py-16 px-4 text-center">
    <svg class="w-12 h-12 text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    <p class="text-gray-400 text-sm">No messages yet</p>
    <p class="text-gray-300 text-xs mt-1">Your job threads and team channels will appear here</p>
  </div>
<% } else { %>
  <div class="divide-y divide-gray-100">
    <% threads.forEach(function(thread) { %>
      <%
        let link = '/w/chat';
        if (thread.thread_type === 'dm' && thread.dm_user) link = '/w/chat/dm/' + thread.dm_user.id;
        else if (['channel','announcement'].includes(thread.thread_type)) link = '/w/chat/channel/' + thread.id;

        let displayTitle = thread.thread_type === 'dm' && thread.dm_user ? thread.dm_user.full_name : thread.title;
        let preview = thread.last_message || '';
        if (thread.last_message_type === 'image') preview = 'Sent an image';
        if (preview.length > 60) preview = preview.substring(0, 60) + '...';

        const hasUnread = thread.unread_count > 0;
      %>
      <a href="<%= link %>" class="flex items-center gap-3 px-4 py-3 <%= hasUnread ? 'bg-brand-50/40' : '' %>">
        <% if (thread.thread_type === 'dm' && thread.dm_user) { %>
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-400 to-brand-600 text-white flex items-center justify-center text-sm font-bold flex-shrink-0">
            <%= thread.dm_user.full_name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase() %>
          </div>
        <% } else { %>
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
          </div>
        <% } %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center justify-between">
            <h3 class="text-sm font-semibold text-gray-900 truncate <%= hasUnread ? '' : 'font-medium' %>"><%= displayTitle %></h3>
            <span class="text-[10px] text-gray-400 flex-shrink-0 ml-2"><%= timeAgo(thread.last_message_at) %></span>
          </div>
          <p class="text-xs text-gray-500 truncate mt-0.5">
            <% if (thread.last_message_sender) { %><span class="font-medium text-gray-600"><%= thread.last_message_sender %>:</span> <% } %><%= preview %>
          </p>
        </div>
        <% if (hasUnread) { %>
          <span class="bg-brand-500 text-white text-[10px] font-bold rounded-full w-5 h-5 flex items-center justify-center flex-shrink-0"><%= thread.unread_count > 9 ? '9+' : thread.unread_count %></span>
        <% } %>
      </a>
    <% }) %>
  </div>
<% } %>
