<%
  function fmtTime(t) {
    if (!t) return '';
    const parts = String(t).split(':');
    let h = parseInt(parts[0], 10);
    const m = parts[1] || '00';
    const am = h < 12;
    h = h % 12; if (h === 0) h = 12;
    return h + (m === '00' ? '' : ':' + m) + (am ? 'am' : 'pm');
  }
  function relDay(iso) {
    const d = new Date(iso + 'T00:00:00');
    const today = new Date(); today.setHours(0,0,0,0);
    const diff = Math.round((d - today) / 86400000);
    if (diff === 0) return 'Today';
    if (diff === 1) return 'Tomorrow';
    if (diff < 7) return d.toLocaleDateString('en-AU', { weekday: 'long' });
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  function fmtClockTime(ts) {
    const d = new Date(ts);
    return d.toLocaleTimeString('en-AU', { hour: 'numeric', minute: '2-digit' });
  }

  // Default section order (manager card is inserted after the hero for managers only)
  // What the controller needs first: are they blocked, what's today, and
  // the shortcuts to act on it. Stats and weather drop below the fold.
  // Upcoming shifts are the single most important thing on this page —
  // lift them to right after Today's shift so workers see what's next
  // without scrolling. Compliance + actions slot in below.
  const defaultOrder = ['hero','manager','today','upcoming','compliance','actions','jobpack','week','timeline','cards','weather','streaks','activity'];
  const hidden = (prefs && prefs.hidden_sections) || [];
  const orderSource = (prefs && prefs.section_order && prefs.section_order.length) ? prefs.section_order : defaultOrder;
  // Preserve any new sections we added after the user saved their prefs
  const order = [...orderSource, ...defaultOrder.filter(s => !orderSource.includes(s))];
