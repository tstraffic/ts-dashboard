<div class="wh-wrap">

<% function section(name, body) {
  if (hidden.includes(name)) return '';
  return body();
} %>

<% order.forEach(function(section) { %>

<% if (section === 'hero' && !hidden.includes('hero')) { %>
  <div class="wh-hero">
    <p class="wh-hero-sub"><%= new Date().toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long' }) %></p>
    <h1 class="wh-hero-greet"><%= greeting %>,<br><%= firstName %>.</h1>
    <% if (subtext) { %>
      <p class="wh-hero-ctx <%= subtext.kind %>"><span class="dot"></span><%= subtext.text %></p>
    <% } %>

    <div class="wh-stats">
      <div class="wh-stat hrs"><p class="wh-stat-label">Hours this week</p><p class="wh-stat-value" data-count="<%= stats.hoursThisWeek %>"><%= stats.hoursThisWeek %><span class="wh-stat-unit">hrs</span></p><p class="wh-stat-sub">Mon–Sun</p>
        <div class="wh-stat-ico"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div></div>
      <div class="wh-stat days"><p class="wh-stat-label">Days worked</p><p class="wh-stat-value" data-count="<%= stats.daysWorked %>"><%= stats.daysWorked %><span class="wh-stat-unit">/7</span></p><p class="wh-stat-sub">Last 7 days</p>
        <div class="wh-stat-ico"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div></div>
      <div class="wh-stat up"><p class="wh-stat-label">Upcoming</p><p class="wh-stat-value" data-count="<%= stats.upcomingShifts %>"><%= stats.upcomingShifts %></p><p class="wh-stat-sub">Next 14 days</p>
        <div class="wh-stat-ico"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div></div>
      <div class="wh-stat leave"><p class="wh-stat-label">Pending leave</p><p class="wh-stat-value" data-count="<%= stats.pendingLeave %>"><%= stats.pendingLeave %></p><p class="wh-stat-sub">Awaiting approval</p>
        <div class="wh-stat-ico"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M2.5 19l19-7.5L2.5 4v7l13 .5-13 .5z"/></svg></div></div>
    </div>
  </div>
<% } %>

<% if (section === 'manager' && typeof isManager !== 'undefined' && isManager) { %>
  <a href="/w/manage" style="display: block; margin-top: 12px; padding: 14px 16px; border-radius: 14px; background: linear-gradient(135deg, rgba(245,158,11,0.18), rgba(236,72,153,0.14)); border: 1px solid rgba(245,158,11,0.3); text-decoration: none; display: flex; align-items: center; gap: 12px;">
    <div style="width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(135deg, #F59E0B, #EC4899); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <div style="flex: 1; min-width: 0;">
      <p style="font-size: 0.65rem; font-weight: 700; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.08em;">Manager tools</p>
      <p style="font-size: 0.95rem; font-weight: 800; color: #fff; margin-top: 1px;">Operations overview</p>
      <p style="font-size: 0.72rem; color: rgba(255,255,255,0.6); margin-top: 1px;">All shifts, leave approvals, moderation</p>
    </div>
    <svg style="width: 16px; height: 16px; color: rgba(255,255,255,0.5); flex-shrink: 0;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </a>
<% } %>

<% if (section === 'cards' && !hidden.includes('cards') && cards && cards.length > 0) { %>
  <div class="wh-section-head"><span class="wh-section-title">For you</span></div>
  <div class="wh-cards">
    <% cards.forEach(function(c) { %>
      <div class="wh-card" data-card-id="<%= c.id %>">
        <button type="button" class="wh-card-dismiss" aria-label="Dismiss" onclick="whDismissCard(<%= c.id %>)">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <div class="wh-card-top">
          <div class="wh-card-ic <%= c.payload.tone || 'blue' %>">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="wh-card-title"><%= c.payload.title %></div>
        </div>
        <p class="wh-card-body"><%= c.payload.body %></p>
        <% if (c.payload.cta && c.payload.link) { %>
          <a href="<%= c.payload.link %>" class="wh-card-cta" onclick="whActCard(<%= c.id %>)">
            <%= c.payload.cta %> <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } %>

<% if (section === 'jobpack' && !hidden.includes('jobpack') && typeof jobPackNudge !== 'undefined' && jobPackNudge) {
  var FORM_LABEL = {
    vehicle_prestart: 'Vehicle Pre-Start',
    risk_toolbox: 'Risk Assessment & Toolbox',
    tc_prestart: 'TC Prestart Declaration',
    team_leader: 'Team Leader Checklist',
    post_shift_vehicle: 'Post-Shift Vehicle Checklist',
  };
  var pct = jobPackNudge.pct;
  var tone = pct >= 90 ? 'emerald' : pct >= 60 ? 'amber' : 'red';
  var toneFg = tone === 'emerald' ? '#34D399' : tone === 'amber' ? '#F59E0B' : '#F87171';
  var toneBg = tone === 'emerald' ? 'rgba(16,185,129,0.12)' : tone === 'amber' ? 'rgba(245,158,11,0.12)' : 'rgba(239,68,68,0.12)';
  var headline = pct >= 90 ? 'On top of your checklists' : pct >= 60 ? 'Catch up on your checklists' : 'Several checklists outstanding';
%>
  <div class="wh-section-head"><span class="wh-section-title">Your checklist completion · last 7 days</span></div>
  <a href="/w/forms" style="display:block;text-decoration:none;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-left:3px solid <%= toneFg %>;border-radius:14px;padding:14px 16px;">
    <div style="display:flex;align-items:center;gap:14px;">
      <div style="width:54px;height:54px;border-radius:50%;background:<%= toneBg %>;color:<%= toneFg %>;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.95rem;flex-shrink:0;">
        <%= pct %>%
      </div>
      <div style="flex:1;min-width:0;">
        <p style="font-size:0.92rem;font-weight:700;color:#fff;line-height:1.2;"><%= headline %></p>
        <p style="font-size:0.72rem;color:rgba(255,255,255,0.55);margin-top:2px;">
          <%= jobPackNudge.submitted %> of <%= jobPackNudge.expected %> Job-Pack checklists filed.
          <% if (pct < 95 && jobPackNudge.worstKey) { %>
            Most missed: <span style="color:rgba(255,255,255,0.8);font-weight:600;"><%= FORM_LABEL[jobPackNudge.worstKey] || jobPackNudge.worstKey %></span>.
          <% } %>
        </p>
      </div>
      <svg style="width:16px;height:16px;color:rgba(255,255,255,0.4);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </div>
    <div style="margin-top:10px;height:5px;border-radius:3px;background:rgba(255,255,255,0.06);overflow:hidden;">
      <div style="height:100%;background:<%= toneFg %>;width:<%= pct %>%;"></div>
    </div>
  </a>
<% } %>

<% if (section === 'streaks' && !hidden.includes('streaks') && streaks) { %>
  <div class="wh-section-head"><span class="wh-section-title">Streaks &amp; milestones</span></div>
  <div class="wh-streaks">
    <% const streakEntries = [
      ['shift_streak', streaks.shift_streak],
      ['incident_free', streaks.incident_free],
      ['forms_streak', streaks.forms_streak],
      ['hours_milestone', streaks.hours_milestone],
    ]; streakEntries.forEach(function([k, s]) { if (!s) return; %>
      <div class="wh-streak" style="color: <%= s.tone === 'emerald' ? '#34D399' : s.tone === 'blue' ? '#60A5FA' : s.tone === 'purple' ? '#A78BFA' : '#F59E0B' %>;">
        <p class="wh-streak-label">
          <span class="wh-streak-ic <%= s.tone %>">
            <% if (s.iconKey === 'fire') { %><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2c1.5 4 5 5 5 9a5 5 0 11-10 0c0-1.5.5-3 1.5-4.5C9 8 11 5 12 2z"/></svg>
            <% } else if (s.iconKey === 'shield') { %><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <% } else if (s.iconKey === 'check') { %><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <% } else { %><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M5 3h14l-1 11H6L5 3zm3 14h8v2H8v-2z"/></svg>
            <% } %>
          </span>
          <%= s.label %>
        </p>
        <p class="wh-streak-value" data-count="<%= s.current %>"><%= s.current %><span class="wh-streak-unit"><%= s.unit %></span></p>
        <% if (s.progress != null) { %>
          <div class="wh-streak-bar"><div class="wh-streak-bar-fill" style="width: 0%;" data-target="<%= s.progress %>"></div></div>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<% if (section === 'weather' && !hidden.includes('weather') && weather) { %>
  <div class="wh-section-head"><span class="wh-section-title"><%= weather.source === 'depot' ? 'Weather at the depot' : 'Weather at next site' %><% if (weather.city) { %> · <%= weather.city %><% } %></span></div>
  <div class="wh-weather">
    <div style="font-size: 2.6rem; line-height: 1; flex-shrink: 0;"><%= weather.emoji || '🌡️' %></div>
    <div class="wh-weather-meta">
      <div class="flex items-baseline gap-1"><span class="wh-weather-temp"><%= weather.temp %>°</span><span class="text-xs text-white/50 ml-1">feels <%= weather.feels_like %>°</span></div>
      <p class="wh-weather-desc"><%= weather.description %></p>
      <p class="wh-weather-sub">
        <% if (weather.hi != null && weather.lo != null) { %>H <%= weather.hi %>° · L <%= weather.lo %>° · <% } %>
        Wind <%= weather.wind_kmh %> km/h<% if (weather.rain_chance) { %> · <%= weather.rain_chance %>% rain<% } %><% if (weather.uv != null) { %> · UV <%= weather.uv %><% } %>
      </p>
    </div>
  </div>
  <% if (weather.rain_chance && weather.rain_chance >= 40) { %>
    <div class="wh-weather-warn mt-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999A5.002 5.002 0 006.1 8H6a4 4 0 00-3 7zm8 2v-4m0 0v-2"/></svg>
      Wet weather PPE recommended — chance of rain above 40%
    </div>
  <% } %>
<% } %>

<% if (section === 'week' && !hidden.includes('week')) { %>
  <div class="wh-section-head"><span class="wh-section-title">This week</span><a href="/w/shifts" class="wh-section-link">Schedule ›</a></div>
  <div class="wh-week">
    <% weekDays.forEach(function(d) {
      let cls = ['wh-wday']; if (d.isToday) cls.push('today'); if (d.isPast && !d.kind) cls.push('past');
      if (d.kind === 'shift' && d.shiftType === 'night') cls.push('has-shift-night'); else if (d.kind === 'shift') cls.push('has-shift');
      if (d.kind === 'leave' && d.leaveStatus === 'pending') cls.push('has-leave-pending'); else if (d.kind === 'leave') cls.push('has-leave');
    %>
      <div class="<%= cls.join(' ') %>"><div class="wh-wday-letter"><%= d.dayLetter %></div><div class="wh-wday-num"><%= d.dayNum %></div><span class="wh-wday-pill"></span></div>
    <% }) %>
  </div>
<% } %>

<% if (section === 'timeline' && !hidden.includes('timeline') && timeline) { %>
  <div class="wh-section-head"><span class="wh-section-title">Today</span></div>
  <div class="wh-timeline">
    <p class="wh-timeline-head"><%= timeline.shiftLabel %></p>
    <p class="wh-timeline-sub"><%= fmtTime((Math.floor(timeline.startMin/60).toString().padStart(2,'0'))+':'+((timeline.startMin%60).toString().padStart(2,'0'))) %> – <%= fmtTime((Math.floor(timeline.endMin/60).toString().padStart(2,'0'))+':'+((timeline.endMin%60).toString().padStart(2,'0'))) %></p>
    <span class="wh-timeline-hint">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
      Recommended timeline only — actual times go on your docket
    </span>
    <div class="wh-timeline-track" data-start="<%= timeline.startMin %>" data-end="<%= timeline.endMin %>">
      <div class="wh-timeline-fill"></div>
      <div class="wh-timeline-now" id="wh-timeline-now"></div>
      <% timeline.blocks.forEach(function(b) {
        const [bh, bm] = (b.at || '00:00').split(':').map(Number);
        const pm = (bh*60) + (bm||0);
        const pct = Math.min(100, Math.max(0, ((pm - timeline.startMin) / Math.max(1, timeline.endMin - timeline.startMin)) * 100));
      %>
        <span class="wh-timeline-block-dot" style="left: <%= pct %>%;"></span>
      <% }) %>
    </div>
    <ul class="wh-timeline-legend">
      <% timeline.blocks.forEach(function(b) { %>
        <li class="wh-timeline-legend-row">
          <span class="wh-timeline-legend-pip"></span>
          <span class="wh-timeline-legend-time"><%= fmtTime(b.at) %></span>
          <span class="wh-timeline-legend-lbl"><%= b.label %></span>
        </li>
      <% }) %>
    </ul>
  </div>
<% } %>

<% if (section === 'compliance' && !hidden.includes('compliance') && compliance && (!compliance.canAllocate || compliance.fatigueBlocked || (compliance.expiringItems && compliance.expiringItems.length > 0) || (compliance.expiredItems && compliance.expiredItems.length > 0))) { %>
  <div class="wh-section-head"><span class="wh-section-title">Heads up</span></div>
  <div class="wh-alert">
    <h4>Compliance needs attention</h4>
    <ul class="list-disc pl-5">
      <% if (compliance.fatigueBlocked) { %><li>Fatigue limit reached (<%= compliance.daysWorked %>/7 days worked)</li><% } %>
      <% if (compliance.expiredItems && compliance.expiredItems.length > 0) { %><li>Expired: <%= compliance.expiredItems.join(', ') %></li><% } %>
      <% if (compliance.expiringItems && compliance.expiringItems.length > 0) { %><li>Expiring soon: <%= compliance.expiringItems.join(', ') %></li><% } %>
      <% if (!compliance.inductionComplete) { %><li>Induction not completed</li><% } %>
    </ul>
  </div>
<% } %>

<% if (section === 'today' && !hidden.includes('today')) { %>
  <div class="wh-section-head"><span class="wh-section-title">Today's shift</span></div>
  <% if (todaysShifts.length === 0) { %>
    <div class="wh-empty">
      <div class="wh-empty-ic"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
      <p class="text-sm text-white/70 font-semibold">No shift today</p>
      <p class="text-xs text-white/40 mt-1">Enjoy the day off</p>
    </div>
  <% } else { %>
    <% todaysShifts.forEach(shift => { %>
      <div class="wh-shift <%= shift.status === 'allocated' ? 'is-allocated' : '' %>">
        <div class="wh-shift-header">
          <span class="wh-shift-status <%= shift.status === 'confirmed' ? 'confirmed' : 'allocated' %>"><%= shift.status %></span>
          <span class="wh-shift-meta-time"><%= (shift.shift_type || 'day').toUpperCase() %> · <%= fmtTime(shift.start_time) %> – <%= fmtTime(shift.end_time) %></span>
        </div>
        <div class="wh-shift-body">
          <p class="wh-shift-client"><%= shift.client %></p>
          <p class="wh-shift-job mb-2"><%= shift.job_number %><% if (shift.job_name) { %> · <%= shift.job_name %><% } %></p>
          <% if (shift.site_address) { %>
            <div class="wh-meta-row">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span><%= shift.site_address %><% if (shift.suburb) { %>, <%= shift.suburb %><% } %></span>
            </div>
          <% } %>
          <% if (shift.supervisor_name) { %>
            <div class="wh-meta-row"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg><span>Supervisor: <strong><%= shift.supervisor_name %></strong></span></div>
          <% } %>
        </div>
        <%
          // T&S crews don't clock in/out — the prestart toolbox is proof of
          // attendance, the docket is proof of hours. Surface those two as
          // the primary CTA on the shift card instead. Pick the next
          // outstanding step: Pre-Start checklists if not all done, then
          // Sign Docket. Falls back to "Open shift" once everything is in.
          var jpDone = (typeof formStatus !== 'undefined' && formStatus) ? Object.values(formStatus).filter(function(v){return v && !Array.isArray(v);}).length : 0;
          var nextHref, nextLabel;
          var shiftLink = (shift.source === 'booking') ? ('/w/booking-shift/' + shift.booking_id) : ('/w/jobs/' + (shift.id || shift.job_id));
          // For booking shifts shift.id is the booking_crew row id, NOT a
          // crew_allocations.id — we can't link straight to /w/dockets/sign.
          // Route through the shift detail forms tab; booking-shift lazy-
          // creates the allocation, then they tap Docket from there.
          if (jpDone < 3) { nextHref = shiftLink + '?tab=forms'; nextLabel = 'Open checklists'; }
          else if (shift.source === 'booking') { nextHref = shiftLink + '?tab=forms'; nextLabel = 'Fill docket'; }
          else { nextHref = '/w/dockets/sign/' + shift.id; nextLabel = 'Fill docket'; }
        %>
        <div class="wh-shift-actions">
          <a href="<%= nextHref %>" class="wh-act-btn primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            <%= nextLabel %>
          </a>
          <a href="<%= shiftLink %>" class="wh-act-btn">Details ›</a>
        </div>
      </div>
    <% }) %>
  <% } %>
<% } %>

<% if (section === 'actions' && !hidden.includes('actions')) { %>
  <div class="wh-section-head"><span class="wh-section-title">Quick actions</span></div>
  <div class="wh-qa">
    <a href="/w/forms/prestart" class="wh-qa-btn"><div class="wh-qa-ic g"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><span class="wh-qa-lbl">Pre-Start</span></a>
    <a href="/w/forms/incident" class="wh-qa-btn"><div class="wh-qa-ic r"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg></div><span class="wh-qa-lbl">Incident</span></a>
    <a href="/w/dockets" class="wh-qa-btn"><div class="wh-qa-ic b"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg></div><span class="wh-qa-lbl">Dockets</span></a>
    <a href="/w/forms" class="wh-qa-btn"><div class="wh-qa-ic p"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div><span class="wh-qa-lbl">Forms</span></a>
    <a href="/w/timesheets" class="wh-qa-btn"><div class="wh-qa-ic t"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div><span class="wh-qa-lbl">Timesheet</span></a>
  </div>
<% } %>

<% if (section === 'upcoming' && !hidden.includes('upcoming') && upcomingShifts && upcomingShifts.length > 0) {
  // The next shift gets a hero treatment so it can't be missed; the
  // remainder render as a compact list underneath.
  const nextShift = upcomingShifts[0];
  const restShifts = upcomingShifts.slice(1);
  const nd = new Date(nextShift.allocation_date + 'T00:00:00');
  const ndNum = nd.getDate();
  const ndMon = nd.toLocaleDateString('en-AU', { month: 'short' });
  const ndDow = nd.toLocaleDateString('en-AU', { weekday: 'short' });
  const nextLink = nextShift.job_id ? ('/w/jobs/' + nextShift.job_id) : '/w/shifts';
  const isAllocated = (nextShift.status === 'allocated' || nextShift.status === 'assigned');
%>
  <div class="wh-section-head">
    <span class="wh-section-title">
      Coming up
      <span style="display:inline-flex;align-items:center;justify-content:center;min-width:18px;height:18px;padding:0 5px;margin-left:6px;border-radius:999px;background:rgba(43,127,255,0.18);color:#93C5FD;font-size:0.62rem;font-weight:800;letter-spacing:0;"><%= upcomingShifts.length %></span>
    </span>
    <a href="/w/shifts" class="wh-section-link">See all ›</a>
  </div>

  <!-- Hero: the next shift -->
  <a href="<%= nextLink %>" style="display:block;text-decoration:none;position:relative;border-radius:16px;overflow:hidden;background:linear-gradient(155deg, rgba(43,127,255,0.14), rgba(0,210,190,0.06) 60%, rgba(10,22,40,0.7));border:1px solid rgba(96,165,250,0.28);box-shadow:0 6px 24px rgba(0,0,0,0.25);">
    <span style="position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,#2B7FFF,#00D2BE);"></span>
    <div style="display:flex;gap:12px;padding:14px 14px 12px 16px;align-items:stretch;">
      <div style="width:54px;flex-shrink:0;border-radius:12px;background:rgba(43,127,255,0.18);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 0;">
        <span style="font-size:0.55rem;font-weight:700;color:#93C5FD;text-transform:uppercase;letter-spacing:0.08em;line-height:1;"><%= ndDow %></span>
        <span style="font-size:1.5rem;font-weight:800;line-height:1;margin-top:3px;"><%= ndNum %></span>
        <span style="font-size:0.55rem;font-weight:700;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.08em;margin-top:2px;line-height:1;"><%= ndMon %></span>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
          <span style="font-size:0.62rem;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;color:#93C5FD;"><%= relDay(nextShift.allocation_date) %></span>
          <% if (isAllocated) { %>
            <span style="display:inline-flex;align-items:center;padding:2px 7px;border-radius:999px;font-size:0.58rem;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;background:rgba(245,158,11,0.18);color:#FCD34D;border:1px solid rgba(245,158,11,0.35);">Tap to confirm</span>
          <% } else if (nextShift.status === 'confirmed') { %>
            <span style="display:inline-flex;align-items:center;padding:2px 7px;border-radius:999px;font-size:0.58rem;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;background:rgba(16,185,129,0.18);color:#6EE7B7;border:1px solid rgba(16,185,129,0.35);">Accepted</span>
          <% } %>
        </div>
        <p style="font-size:1rem;font-weight:700;color:#fff;line-height:1.2;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= nextShift.client %></p>
        <p style="font-size:0.78rem;color:rgba(255,255,255,0.7);margin-top:2px;display:flex;align-items:center;gap:5px;">
          <svg style="width:12px;height:12px;color:rgba(255,255,255,0.45);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <%= fmtTime(nextShift.start_time) %> – <%= fmtTime(nextShift.end_time) %>
          <% if (nextShift.suburb) { %>
            <span style="color:rgba(255,255,255,0.35);">·</span>
            <span style="color:rgba(255,255,255,0.6);"><%= nextShift.suburb %></span>
          <% } %>
        </p>
      </div>
      <svg style="width:14px;height:14px;color:rgba(255,255,255,0.4);align-self:center;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </div>
  </a>

  <!-- Compact list of the rest -->
  <% if (restShifts.length > 0) { %>
    <div style="margin-top:8px;">
      <% restShifts.forEach(s => {
        const d = new Date(s.allocation_date + 'T00:00:00');
        const dNum = d.getDate(); const dMon = d.toLocaleDateString('en-AU', { month: 'short' });
        const link = s.job_id ? ('/w/jobs/' + s.job_id) : '/w/shifts';
      %>
        <a href="<%= link %>" class="wh-up-item" style="text-decoration: none;">
          <div class="wh-up-date"<%= s.shift_type === 'night' ? ' style="background: rgba(59,130,246,0.12); color: #93C5FD;"' : '' %>>
            <span class="d"><%= dNum %></span><span class="m"><%= dMon %></span>
          </div>
          <div class="wh-up-body">
            <p class="wh-up-title"><%= s.client %></p>
            <p class="wh-up-sub"><%= relDay(s.allocation_date) %> · <%= fmtTime(s.start_time) %>–<%= fmtTime(s.end_time) %><% if (s.suburb) { %> · <%= s.suburb %><% } %></p>
          </div>
          <% if (s.status === 'allocated' || s.status === 'assigned') { %>
            <span style="font-size:0.58rem;font-weight:800;letter-spacing:0.05em;text-transform:uppercase;color:#FCD34D;background:rgba(245,158,11,0.15);padding:2px 6px;border-radius:999px;flex-shrink:0;">Confirm</span>
          <% } %>
        </a>
      <% }) %>
    </div>
  <% } %>
<% } %>

<% if (section === 'activity' && !hidden.includes('activity') && recentClocks && recentClocks.length > 0) { %>
  <div class="wh-section-head"><span class="wh-section-title">Recent activity</span></div>
  <% recentClocks.forEach(a => { %>
    <div class="wh-act-item">
      <div class="wh-act-ic <%= a.subtype === 'clock_in' ? 'in' : 'out' %>">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <% if (a.subtype === 'clock_in') { %><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/><% } else { %><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/><% } %>
        </svg>
      </div>
      <span class="wh-act-txt"><%= a.subtype === 'clock_in' ? 'Clocked in' : 'Clocked out' %></span>
      <span class="wh-act-when"><%= fmtClockTime(a.at) %></span>
    </div>
  <% }) %>
<% } %>

<% }); %>

</div>

<!-- FAB -->
<div class="wh-fab" id="wh-fab">
  <div class="wh-fab-menu">
    <a href="/w/jobs" class="wh-fab-action"><span class="wh-fab-action-ic" style="background: rgba(16,185,129,0.2); color: #34D399;"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg></span>Open my shifts</a>
    <a href="/w/hr/leave" class="wh-fab-action"><span class="wh-fab-action-ic" style="background: rgba(245,158,11,0.2); color: #F59E0B;"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M2.5 19l19-7.5L2.5 4v7l13 .5-13 .5z"/></svg></span>Request leave</a>
    <a href="/w/forms/incident" class="wh-fab-action"><span class="wh-fab-action-ic" style="background: rgba(239,68,68,0.2); color: #F87171;"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg></span>Submit hazard</a>
    <a href="/w/feed/new" class="wh-fab-action"><span class="wh-fab-action-ic" style="background: rgba(236,72,153,0.2); color: #F472B6;"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.9 6.3 6.6.6-5 4.5 1.5 6.8L12 17l-6 3.2 1.5-6.8-5-4.5 6.6-.6L12 2z"/></svg></span>Send kudos</a>
    <a href="/w/hr/payslips" class="wh-fab-action"><span class="wh-fab-action-ic" style="background: rgba(16,185,129,0.2); color: #34D399;"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg></span>Latest payslip</a>
  </div>
  <button type="button" class="wh-fab-main" aria-label="Quick actions" onclick="document.getElementById('wh-fab').classList.toggle('open')">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
  </button>
</div>

<script>
(function () {
  // ===== Animated counters =====
  function animateCount(el, target) {
    var start = 0, dur = 700, t0 = null;
    var isFloat = String(target).indexOf('.') !== -1;
    target = parseFloat(target) || 0;
    function step(ts) {
      if (!t0) t0 = ts;
      var p = Math.min(1, (ts - t0) / dur);
      var v = start + (target - start) * (1 - Math.pow(1 - p, 3));
      // Keep unit span intact
      var unit = el.querySelector('.wh-stat-unit, .wh-streak-unit');
      var display = isFloat ? v.toFixed(1) : Math.round(v);
      if (unit) {
        el.firstChild.nodeValue = display;
      } else {
        el.textContent = display;
      }
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  document.querySelectorAll('[data-count]').forEach(function (el) {
    var t = el.getAttribute('data-count');
    animateCount(el, t);
  });
  // Progress bars
  document.querySelectorAll('.wh-streak-bar-fill[data-target]').forEach(function (el) {
    setTimeout(function () { el.style.width = el.getAttribute('data-target') + '%'; }, 40);
  });

  // ===== Card dismiss / act =====
  window.whDismissCard = function (id) {
    var card = document.querySelector('[data-card-id="' + id + '"]');
    if (card) { card.style.opacity = '0'; card.style.transform = 'translateX(-20px)'; card.style.transition = 'all 0.25s ease'; }
    setTimeout(function () { if (card) card.remove(); }, 260);
    fetch('/w/home/cards/' + id + '/dismiss', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
      body: '_csrf=' + encodeURIComponent(document.querySelector('meta[name="csrf-token"]')?.content || '')
    }).catch(function () {});
  };
  window.whActCard = function (id) {
    fetch('/w/home/cards/' + id + '/act', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: '_csrf=' + encodeURIComponent(document.querySelector('meta[name="csrf-token"]')?.content || '')
    }).catch(function () {});
  };

  // ===== Timeline live indicator =====
  function updateTimeline() {
    var track = document.querySelector('.wh-timeline-track');
    if (!track) return;
    var now = document.getElementById('wh-timeline-now');
    var startMin = parseInt(track.getAttribute('data-start'), 10);
    var endMin = parseInt(track.getAttribute('data-end'), 10);
    var d = new Date();
    var curMin = d.getHours() * 60 + d.getMinutes();
    if (curMin < startMin) { now.style.left = '0%'; now.style.opacity = '0.35'; return; }
    if (curMin > endMin) { now.style.left = '100%'; now.style.opacity = '0.35'; return; }
    var pct = ((curMin - startMin) / Math.max(1, endMin - startMin)) * 100;
    now.style.left = pct + '%';
    now.style.opacity = '1';
  }
  updateTimeline();
  setInterval(updateTimeline, 30000);

  // ===== FAB close on outside click =====
  document.addEventListener('click', function (e) {
    var fab = document.getElementById('wh-fab');
    if (fab && !fab.contains(e.target)) fab.classList.remove('open');
  });
})();
</script>
