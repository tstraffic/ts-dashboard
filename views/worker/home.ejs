<%
  function fmtTime(t) {
    if (!t) return '';
    // Accept 'HH:MM' or 'HH:MM:SS'
    const parts = String(t).split(':');
    let h = parseInt(parts[0], 10);
    const m = parts[1] || '00';
    const am = h < 12;
    h = h % 12; if (h === 0) h = 12;
    return h + (m === '00' ? '' : ':' + m) + (am ? 'am' : 'pm');
  }
  function fmtDayMon(iso) {
    if (!iso) return '';
    const d = new Date(iso + 'T00:00:00');
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  function relDay(iso) {
    const d = new Date(iso + 'T00:00:00');
    const today = new Date(); today.setHours(0,0,0,0);
    const diff = Math.round((d - today) / 86400000);
    if (diff === 0) return 'Today';
    if (diff === 1) return 'Tomorrow';
    if (diff < 7) return d.toLocaleDateString('en-AU', { weekday: 'long' });
    return d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
  }
  function fmtClockTime(ts) {
    const d = new Date(ts);
    return d.toLocaleTimeString('en-AU', { hour: 'numeric', minute: '2-digit' });
  }
%>

<style>
  .wh-wrap { padding: 0.5rem; }

  /* Hero */
  .wh-hero {
    position: relative;
    padding: 1rem 1.1rem 1.1rem;
    border-radius: 16px;
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(43,127,255,0.25), transparent 60%),
      radial-gradient(120% 80% at 100% 100%, rgba(0,210,190,0.18), transparent 55%),
      linear-gradient(160deg, #0F1F3A, #0A1628);
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .wh-hero::before {
    content: ''; position: absolute; inset: -40% -40% 30% 30%;
    background: radial-gradient(closest-side, rgba(0,210,190,0.18), transparent);
    filter: blur(40px); pointer-events: none;
  }
  .wh-hero-greet { font-size: 1.5rem; font-weight: 800; color: #fff; letter-spacing: -0.01em; line-height: 1.15; }
  .wh-hero-sub { font-size: 0.8rem; color: rgba(255,255,255,0.55); margin-top: 0.125rem; }
  .wh-hero-status { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.25rem 0.625rem; font-size: 0.7rem; font-weight: 700; border-radius: 999px; margin-top: 0.75rem; }
  .wh-hero-status.on { background: rgba(16,185,129,0.15); color: #34D399; border: 1px solid rgba(16,185,129,0.3); }
  .wh-hero-status.off { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.6); border: 1px solid rgba(255,255,255,0.1); }
  .wh-hero-dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; animation: wh-pulse 2s infinite; }
  @keyframes wh-pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* Stats grid */
  .wh-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-top: 12px; }
  .wh-stat {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 10px 12px;
    position: relative;
  }
  .wh-stat-label { font-size: 0.625rem; font-weight: 700; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.07em; }
  .wh-stat-value { font-size: 1.5rem; font-weight: 800; color: #fff; margin-top: 2px; letter-spacing: -0.02em; line-height: 1; }
  .wh-stat-unit { font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.45); margin-left: 3px; }
  .wh-stat-sub { font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-top: 4px; }
  .wh-stat-ico {
    position: absolute; top: 10px; right: 10px; width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .wh-stat.hrs .wh-stat-ico { background: rgba(43,127,255,0.15); color: #60A5FA; }
  .wh-stat.days .wh-stat-ico { background: rgba(16,185,129,0.15); color: #34D399; }
  .wh-stat.up .wh-stat-ico { background: rgba(245,158,11,0.15); color: #F59E0B; }
  .wh-stat.leave .wh-stat-ico { background: rgba(167,139,250,0.15); color: #A78BFA; }

  /* Section heading */
  .wh-section-head { display: flex; align-items: center; justify-content: space-between; margin: 1.25rem 0 0.5rem; padding: 0 2px; }
  .wh-section-title { font-size: 0.7rem; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; }
  .wh-section-link { font-size: 0.75rem; font-weight: 600; color: #60A5FA; display: inline-flex; align-items: center; gap: 2px; }

  /* Week strip */
  .wh-week { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .wh-wday {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 10px;
    padding: 8px 2px 6px;
    text-align: center;
    color: rgba(255,255,255,0.6);
  }
  .wh-wday.today { box-shadow: 0 0 0 1.5px #F59E0B; color: #F59E0B; background: rgba(245,158,11,0.08); }
  .wh-wday-letter { font-size: 0.625rem; font-weight: 700; letter-spacing: 0.04em; opacity: 0.65; }
  .wh-wday-num { font-size: 0.95rem; font-weight: 700; margin-top: 1px; line-height: 1.1; color: #fff; }
  .wh-wday.past .wh-wday-num { opacity: 0.45; }
  .wh-wday-pill {
    display: inline-block; height: 4px; width: 20px; border-radius: 2px; margin-top: 4px;
    background: rgba(255,255,255,0.08);
  }
  .wh-wday.has-shift .wh-wday-pill { background: #00D2BE; }
  .wh-wday.has-shift-night .wh-wday-pill { background: #3B82F6; }
  .wh-wday.has-leave .wh-wday-pill { background: #F59E0B; }
  .wh-wday.has-leave-pending .wh-wday-pill {
    background: linear-gradient(90deg, #F59E0B 50%, transparent 50%);
    background-size: 4px 4px;
  }

  /* Alert banner */
  .wh-alert {
    padding: 12px; border-radius: 12px;
    background: linear-gradient(135deg, rgba(245,158,11,0.12), rgba(245,158,11,0.05));
    border: 1px solid rgba(245,158,11,0.25);
    color: #FDE68A;
  }
  .wh-alert h4 { font-size: 0.8rem; font-weight: 700; color: #F59E0B; }
  .wh-alert ul { margin-top: 4px; font-size: 0.75rem; color: #FCD34D; line-height: 1.4; }

  /* Shift card */
  .wh-shift {
    background: #fff; border: 1px solid #E5E7EB;
    border-radius: 14px; overflow: hidden;
  }
  .wh-shift-header {
    padding: 10px 14px;
    display: flex; align-items: center; justify-content: space-between;
    background: linear-gradient(90deg, #EFF6FF, #F8FAFC);
    border-bottom: 1px solid #E5E7EB;
  }
  .wh-shift-body { padding: 14px; color: #111827; }
  .wh-shift-client { font-size: 1rem; font-weight: 700; color: #111827; }
  .wh-shift-job { font-size: 0.7rem; color: #6B7280; font-family: ui-monospace, SFMono-Regular, monospace; }
  .wh-meta-row { display: flex; align-items: flex-start; gap: 8px; font-size: 0.82rem; color: #374151; }
  .wh-meta-row + .wh-meta-row { margin-top: 8px; }
  .wh-meta-row svg { width: 16px; height: 16px; color: #9CA3AF; flex-shrink: 0; margin-top: 1px; }

  .wh-shift-actions {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    padding: 10px 14px; background: #F9FAFB; border-top: 1px solid #E5E7EB;
  }
  .wh-act-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 4px;
    padding: 9px; font-size: 0.8rem; font-weight: 600;
    border-radius: 10px; background: #fff; color: #374151; border: 1px solid #E5E7EB;
  }
  .wh-act-btn.primary {
    background: #1D6AE5; color: #fff; border-color: #1D6AE5;
    box-shadow: 0 2px 6px rgba(29,106,229,0.3);
  }

  .wh-dark-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 12px 14px;
  }
  .wh-empty {
    text-align: center; padding: 24px 12px;
    background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.08);
    border-radius: 12px;
  }
  .wh-empty-ic {
    width: 40px; height: 40px; border-radius: 999px; margin: 0 auto 8px;
    background: rgba(255,255,255,0.04); display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,0.3);
  }

  /* Quick actions grid */
  .wh-qa { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .wh-qa-btn {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 10px 4px 8px;
    text-align: center;
    color: rgba(255,255,255,0.85);
  }
  .wh-qa-ic {
    width: 32px; height: 32px; border-radius: 10px; margin: 0 auto 5px;
    display: flex; align-items: center; justify-content: center;
  }
  .wh-qa-lbl { font-size: 0.68rem; font-weight: 600; line-height: 1.1; }
  .wh-qa-ic.g { background: rgba(16,185,129,0.15); color: #34D399; }
  .wh-qa-ic.r { background: rgba(239,68,68,0.15); color: #F87171; }
  .wh-qa-ic.b { background: rgba(43,127,255,0.15); color: #60A5FA; }
  .wh-qa-ic.y { background: rgba(245,158,11,0.15); color: #F59E0B; }
  .wh-qa-ic.p { background: rgba(167,139,250,0.15); color: #A78BFA; }
  .wh-qa-ic.t { background: rgba(0,210,190,0.15); color: #00D2BE; }

  /* Upcoming list */
  .wh-up-item { display: flex; gap: 10px; padding: 10px 12px;
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05);
    border-radius: 12px; align-items: center;
  }
  .wh-up-item + .wh-up-item { margin-top: 6px; }
  .wh-up-date {
    width: 44px; min-height: 44px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    border-radius: 10px; background: rgba(43,127,255,0.12); color: #60A5FA;
    flex-shrink: 0;
  }
  .wh-up-date .d { font-size: 1.1rem; font-weight: 800; line-height: 1; }
  .wh-up-date .m { font-size: 0.55rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }
  .wh-up-body { flex: 1; min-width: 0; }
  .wh-up-title { font-size: 0.85rem; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .wh-up-sub { font-size: 0.7rem; color: rgba(255,255,255,0.55); margin-top: 1px; }

  /* Activity */
  .wh-act-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px;
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);
    border-radius: 10px;
  }
  .wh-act-item + .wh-act-item { margin-top: 4px; }
  .wh-act-ic { width: 28px; height: 28px; border-radius: 999px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .wh-act-ic.in { background: rgba(16,185,129,0.15); color: #34D399; }
  .wh-act-ic.out { background: rgba(239,68,68,0.15); color: #F87171; }
  .wh-act-txt { font-size: 0.8rem; color: rgba(255,255,255,0.85); flex: 1; }
  .wh-act-when { font-size: 0.7rem; color: rgba(255,255,255,0.4); }
</style>

<div class="wh-wrap">

  <!-- HERO -->
  <div class="wh-hero">
    <p class="wh-hero-sub"><%= new Date().toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long' }) %></p>
    <h1 class="wh-hero-greet"><%= greeting %>,<br><%= firstName %>.</h1>
    <% if (onShift) { %>
      <span class="wh-hero-status on"><span class="wh-hero-dot"></span> On shift</span>
    <% } else if (todaysShifts.length > 0) { %>
      <span class="wh-hero-status on"><span class="wh-hero-dot"></span> Scheduled today</span>
    <% } else { %>
      <span class="wh-hero-status off">Off duty</span>
    <% } %>

    <!-- Stats grid -->
    <div class="wh-stats">
      <div class="wh-stat hrs">
        <p class="wh-stat-label">Hours this week</p>
        <p class="wh-stat-value"><%= stats.hoursThisWeek %><span class="wh-stat-unit">hrs</span></p>
        <p class="wh-stat-sub">Mon–Sun</p>
        <div class="wh-stat-ico">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
      <div class="wh-stat days">
        <p class="wh-stat-label">Days worked</p>
        <p class="wh-stat-value"><%= stats.daysWorked %><span class="wh-stat-unit">/7</span></p>
        <p class="wh-stat-sub">Last 7 days</p>
        <div class="wh-stat-ico">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
      </div>
      <div class="wh-stat up">
        <p class="wh-stat-label">Upcoming</p>
        <p class="wh-stat-value"><%= stats.upcomingShifts %></p>
        <p class="wh-stat-sub">Next 14 days</p>
        <div class="wh-stat-ico">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
      </div>
      <div class="wh-stat leave">
        <p class="wh-stat-label">Pending leave</p>
        <p class="wh-stat-value"><%= stats.pendingLeave %></p>
        <p class="wh-stat-sub">Awaiting approval</p>
        <div class="wh-stat-ico">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M2.5 19l19-7.5L2.5 4v7l13 .5-13 .5z"/></svg>
        </div>
      </div>
    </div>
  </div>

  <!-- THIS WEEK STRIP -->
  <div class="wh-section-head">
    <span class="wh-section-title">This week</span>
    <a href="/w/shifts" class="wh-section-link">Schedule ›</a>
  </div>
  <div class="wh-week">
    <% weekDays.forEach(d => {
      let cls = ['wh-wday'];
      if (d.isToday) cls.push('today');
      if (d.isPast && !d.kind) cls.push('past');
      if (d.kind === 'shift' && d.shiftType === 'night') cls.push('has-shift-night');
      else if (d.kind === 'shift') cls.push('has-shift');
      if (d.kind === 'leave' && d.leaveStatus === 'pending') cls.push('has-leave-pending');
      else if (d.kind === 'leave') cls.push('has-leave');
    %>
      <div class="<%= cls.join(' ') %>">
        <div class="wh-wday-letter"><%= d.dayLetter %></div>
        <div class="wh-wday-num"><%= d.dayNum %></div>
        <span class="wh-wday-pill"></span>
      </div>
    <% }) %>
  </div>

  <!-- COMPLIANCE ALERT -->
  <% if (compliance && (!compliance.canAllocate || compliance.fatigueBlocked || (compliance.expiringItems && compliance.expiringItems.length > 0) || (compliance.expiredItems && compliance.expiredItems.length > 0))) { %>
    <div class="wh-section-head">
      <span class="wh-section-title">Heads up</span>
    </div>
    <div class="wh-alert">
      <h4>Compliance needs attention</h4>
      <ul class="list-disc pl-5">
        <% if (compliance.fatigueBlocked) { %><li>Fatigue limit reached (<%= compliance.daysWorked %>/7 days worked)</li><% } %>
        <% if (compliance.expiredItems && compliance.expiredItems.length > 0) { %><li>Expired: <%= compliance.expiredItems.join(', ') %></li><% } %>
        <% if (compliance.expiringItems && compliance.expiringItems.length > 0) { %><li>Expiring soon: <%= compliance.expiringItems.join(', ') %></li><% } %>
        <% if (!compliance.inductionComplete) { %><li>Induction not completed</li><% } %>
      </ul>
    </div>
  <% } %>

  <!-- TODAY'S SHIFT -->
  <div class="wh-section-head">
    <span class="wh-section-title">Today's shift</span>
  </div>
  <% if (todaysShifts.length === 0) { %>
    <div class="wh-empty">
      <div class="wh-empty-ic">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-sm text-white/70 font-semibold">No shift today</p>
      <p class="text-xs text-white/40 mt-1">Enjoy the day off</p>
    </div>
  <% } else { %>
    <% todaysShifts.forEach(shift => { %>
      <div class="wh-shift">
        <div class="wh-shift-header">
          <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide
            <%= shift.status === 'confirmed' ? 'bg-emerald-100 text-emerald-700'
              : shift.status === 'completed' ? 'bg-blue-100 text-blue-700'
              : 'bg-amber-100 text-amber-700' %>">
            <%= shift.status %>
          </span>
          <span class="text-[10px] text-gray-500 font-semibold"><%= (shift.shift_type || 'day').toUpperCase() %> SHIFT · <%= fmtTime(shift.start_time) %> – <%= fmtTime(shift.end_time) %></span>
        </div>
        <div class="wh-shift-body">
          <p class="wh-shift-client"><%= shift.client %></p>
          <p class="wh-shift-job mb-2"><%= shift.job_number %><% if (shift.job_name) { %> · <%= shift.job_name %><% } %></p>

          <% if (shift.site_address) { %>
            <div class="wh-meta-row">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span><%= shift.site_address %><% if (shift.suburb) { %>, <%= shift.suburb %><% } %></span>
            </div>
          <% } %>
          <% if (shift.supervisor_name) { %>
            <div class="wh-meta-row">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <span>Supervisor: <strong><%= shift.supervisor_name %></strong></span>
            </div>
          <% } %>
          <% if (shift.role_on_site) { %>
            <div class="wh-meta-row">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
              <span>Role: <%= shift.role_on_site.replace(/_/g, ' ') %></span>
            </div>
          <% } %>
        </div>
        <div class="wh-shift-actions">
          <a href="/w/clock" class="wh-act-btn primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= onShift ? 'Clock out' : 'Clock in' %>
          </a>
          <a href="/w/jobs/<%= shift.job_id %>" class="wh-act-btn">Details ›</a>
        </div>
      </div>
    <% }) %>
  <% } %>

  <!-- QUICK ACTIONS -->
  <div class="wh-section-head">
    <span class="wh-section-title">Quick actions</span>
  </div>
  <div class="wh-qa">
    <a href="/w/forms/prestart" class="wh-qa-btn">
      <div class="wh-qa-ic g"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <span class="wh-qa-lbl">Pre-Start</span>
    </a>
    <a href="/w/forms/incident" class="wh-qa-btn">
      <div class="wh-qa-ic r"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg></div>
      <span class="wh-qa-lbl">Incident</span>
    </a>
    <a href="/w/dockets" class="wh-qa-btn">
      <div class="wh-qa-ic b"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg></div>
      <span class="wh-qa-lbl">Dockets</span>
    </a>
    <a href="/w/timesheets" class="wh-qa-btn">
      <div class="wh-qa-ic t"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></div>
      <span class="wh-qa-lbl">Timesheet</span>
    </a>
    <a href="/w/hr/leave" class="wh-qa-btn">
      <div class="wh-qa-ic y"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M2.5 19l19-7.5L2.5 4v7l13 .5-13 .5z"/></svg></div>
      <span class="wh-qa-lbl">Leave</span>
    </a>
    <a href="/w/forms" class="wh-qa-btn">
      <div class="wh-qa-ic p"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div>
      <span class="wh-qa-lbl">Forms</span>
    </a>
    <a href="/w/hr" class="wh-qa-btn">
      <div class="wh-qa-ic b"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg></div>
      <span class="wh-qa-lbl">Wallet</span>
    </a>
    <a href="/w/availability" class="wh-qa-btn">
      <div class="wh-qa-ic g"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>
      <span class="wh-qa-lbl">Availability</span>
    </a>
  </div>

  <!-- UPCOMING SHIFTS -->
  <% if (upcomingShifts && upcomingShifts.length > 0) { %>
    <div class="wh-section-head">
      <span class="wh-section-title">Upcoming shifts</span>
      <a href="/w/shifts" class="wh-section-link">See all ›</a>
    </div>
    <% upcomingShifts.forEach(s => {
      const d = new Date(s.allocation_date + 'T00:00:00');
      const dNum = d.getDate();
      const dMon = d.toLocaleDateString('en-AU', { month: 'short' });
    %>
      <a href="/w/jobs/<%= s.job_id %>" class="wh-up-item" style="text-decoration: none;">
        <div class="wh-up-date"<%= s.shift_type === 'night' ? ' style="background: rgba(59,130,246,0.12); color: #93C5FD;"' : '' %>>
          <span class="d"><%= dNum %></span>
          <span class="m"><%= dMon %></span>
        </div>
        <div class="wh-up-body">
          <p class="wh-up-title"><%= s.client %></p>
          <p class="wh-up-sub"><%= relDay(s.allocation_date) %> · <%= fmtTime(s.start_time) %>–<%= fmtTime(s.end_time) %><% if (s.suburb) { %> · <%= s.suburb %><% } %></p>
        </div>
      </a>
    <% }) %>
  <% } %>

  <!-- RECENT ACTIVITY -->
  <% if (recentClocks && recentClocks.length > 0) { %>
    <div class="wh-section-head">
      <span class="wh-section-title">Recent activity</span>
    </div>
    <% recentClocks.forEach(a => { %>
      <div class="wh-act-item">
        <div class="wh-act-ic <%= a.subtype === 'clock_in' ? 'in' : 'out' %>">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <% if (a.subtype === 'clock_in') { %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            <% } else { %>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
            <% } %>
          </svg>
        </div>
        <span class="wh-act-txt"><%= a.subtype === 'clock_in' ? 'Clocked in' : 'Clocked out' %></span>
        <span class="wh-act-when"><%= fmtClockTime(a.at) %></span>
      </div>
    <% }) %>
  <% } %>
</div>
