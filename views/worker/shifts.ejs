<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900">My Shifts</h1>
    <p class="text-sm text-gray-500 mt-0.5">Next 14 days</p>
  </div>

  <% if (allocations.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
      <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
        <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <p class="text-gray-500 text-sm">No upcoming shifts scheduled</p>
    </div>
  <% } else { %>
    <% Object.keys(groupedByDate).forEach(date => { %>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
          <%
            const d = new Date(date + 'T00:00:00');
            const isToday = date === today;
            const dayName = d.toLocaleDateString('en-AU', { weekday: 'long' });
            const dateStr = d.toLocaleDateString('en-AU', { day: 'numeric', month: 'short' });
          %>
          <%= isToday ? 'Today' : dayName %> · <%= dateStr %>
        </h2>
        <div class="space-y-2">
          <% groupedByDate[date].forEach(shift => { %>
            <a href="/w/shifts/<%= shift.id %>" class="block bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden active:bg-gray-50 transition">
              <div class="p-4">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-medium text-gray-500"><%= shift.job_number %></span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold
                    <%= shift.status === 'confirmed' ? 'bg-emerald-50 text-emerald-700'
                      : shift.status === 'completed' ? 'bg-blue-50 text-blue-700'
                      : 'bg-amber-50 text-amber-700' %>">
                    <%= shift.status.charAt(0).toUpperCase() + shift.status.slice(1) %>
                  </span>
                </div>
                <p class="font-semibold text-gray-900 text-sm"><%= shift.client %></p>
                <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <%= shift.start_time %> — <%= shift.end_time %>
                  </span>
                  <% if (shift.role_on_site) { %>
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
                      <%= shift.role_on_site.replace(/_/g, ' ') %>
                    </span>
                  <% } %>
                </div>
                <% if (shift.site_address) { %>
                  <p class="text-xs text-gray-400 mt-1.5 truncate"><%= shift.site_address %>, <%= shift.suburb %></p>
                <% } %>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
