<%
  function fmtTime(t) {
    if (!t) return '';
    const parts = String(t).split(':');
    let h = parseInt(parts[0], 10);
    const m = parts[1] || '00';
    const am = h < 12;
    h = h % 12; if (h === 0) h = 12;
    return h + (m === '00' ? '' : ':' + m) + (am ? 'am' : 'pm');
  }
  function dayHeading(iso) {
    const d = new Date(iso + 'T00:00:00');
    return d.toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'short' });
  }
%>

<style>
  .ws-wrap { padding: 0.5rem; }

  /* Month header + nav */
  .ws-month {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 4px;
  }
  .ws-month-btn {
    width: 38px; height: 38px; border-radius: 999px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.85);
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .ws-month-btn:active { background: rgba(255,255,255,0.10); }
  .ws-month-label {
    font-size: 0.95rem; font-weight: 700; color: #fff;
  }
  .ws-month-today {
    display: inline-block;
    font-size: 0.62rem; font-weight: 700; color: #00D2BE;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding: 3px 8px; border-radius: 999px;
    background: rgba(0,210,190,0.10); border: 1px solid rgba(0,210,190,0.25);
    margin-left: 8px;
  }

  /* Week strip */
  .ws-week {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
    padding: 4px 0 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ws-day {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 9px 2px 7px;
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: transform 0.1s;
  }
  .ws-day:active { transform: scale(0.97); }
  .ws-day-letter { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.06em; color: rgba(255,255,255,0.45); }
  .ws-day-num    { font-size: 1.05rem; font-weight: 800; line-height: 1.1; color: #fff; letter-spacing: -0.02em; }
  .ws-day.past .ws-day-num { color: rgba(255,255,255,0.45); }
  .ws-day-bar {
    width: 22px; height: 3px; border-radius: 2px;
    background: rgba(255,255,255,0.08);
  }
  .ws-day.has-shift .ws-day-bar { background: #00D2BE; }
  .ws-day.today {
    border-color: #F59E0B;
    box-shadow: inset 0 0 0 1px rgba(245,158,11,0.45);
  }
  .ws-day.today .ws-day-letter,
  .ws-day.today .ws-day-num { color: #FCD34D; }

  /* Day heading inside the list */
  .ws-day-head {
    display: flex; align-items: center; justify-content: space-between;
    margin: 14px 4px 6px;
  }
  .ws-day-title { font-size: 0.78rem; font-weight: 700; color: rgba(255,255,255,0.85); }
  .ws-day-title.today { color: #F59E0B; }
  .ws-day-meta  { font-size: 0.65rem; color: rgba(255,255,255,0.4); }

  /* Shift card */
  .ws-shift {
    display: flex; align-items: stretch; gap: 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    margin-bottom: 6px;
  }
  .ws-shift-bar {
    width: 3px; flex-shrink: 0;
    background: linear-gradient(180deg, #2B7FFF, #00D2BE);
  }
  .ws-shift.is-allocated .ws-shift-bar {
    background: linear-gradient(180deg, #F59E0B, #F97316);
  }
  .ws-shift-body { flex: 1; min-width: 0; padding: 11px 12px; }
  .ws-shift-top {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    margin-bottom: 3px;
  }
  .ws-shift-time {
    font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.85);
    font-variant-numeric: tabular-nums;
  }
  .ws-shift-pill {
    font-size: 0.55rem; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 2px 6px; border-radius: 999px;
  }
  .ws-shift-pill.allocated { background: rgba(245,158,11,0.18); color: #FCD34D; border: 1px solid rgba(245,158,11,0.35); }
  .ws-shift-pill.confirmed { background: rgba(16,185,129,0.18); color: #6EE7B7; border: 1px solid rgba(16,185,129,0.35); }
  .ws-shift-pill.completed { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.55); border: 1px solid rgba(255,255,255,0.10); }
  .ws-shift-client { font-size: 0.95rem; font-weight: 700; color: #fff; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ws-shift-meta   { font-size: 0.7rem; color: rgba(255,255,255,0.5); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ws-shift-arrow  { display: flex; align-items: center; padding-right: 12px; color: rgba(255,255,255,0.3); }

  /* Empty state */
  .ws-empty { text-align: center; padding: 56px 20px 20px; color: rgba(255,255,255,0.55); }
  .ws-empty-ic { width: 96px; height: 96px; margin: 0 auto 22px; color: rgba(255,255,255,0.18); }
  .ws-empty-ic svg { width: 100%; height: 100%; stroke-width: 1.4; }
  .ws-empty-title { font-size: 1rem; font-weight: 700; color: rgba(255,255,255,0.78); }
  .ws-empty-sub   { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 10px; max-width: 280px; margin-left: auto; margin-right: auto; line-height: 1.45; }
  .ws-empty-sub strong { color: rgba(255,255,255,0.85); font-weight: 700; }

  /* Always-on Requests banner */
  .ws-requests {
    margin-top: 10px;
    border-radius: 14px;
    background: linear-gradient(155deg, rgba(245,158,11,0.16), rgba(10,22,40,0.6) 70%);
    border: 1px solid rgba(245,158,11,0.32);
    overflow: hidden;
  }
  .ws-req-head {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .ws-req-head-ic {
    width: 26px; height: 26px; border-radius: 999px;
    background: rgba(245,158,11,0.22); color: #FCD34D;
    display: flex; align-items: center; justify-content: center;
  }
  .ws-req-head-title { font-size: 0.78rem; font-weight: 800; color: #FCD34D; }
  .ws-req-head-sub   { font-size: 0.66rem; color: rgba(255,255,255,0.55); margin-top: 1px; }
</style>

<div class="ws-wrap">

  <!-- Month + week navigation -->
  <div class="ws-month">
    <a href="/w/shifts?week=<%= prevWeek %>" class="ws-month-btn" aria-label="Previous week">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div style="text-align:center;">
      <span class="ws-month-label"><%= monthLabel %></span>
      <% if (!isThisWeek) { %>
        <a href="/w/shifts" class="ws-month-today">Jump to today</a>
      <% } %>
    </div>
    <a href="/w/shifts?week=<%= nextWeek %>" class="ws-month-btn" aria-label="Next week">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Week strip Mon → Sun -->
  <div class="ws-week" role="list" aria-label="Week days">
    <% weekDays.forEach(function (d) { %>
      <a class="ws-day <%= d.isToday ? 'today' : '' %> <%= d.isPast && !d.count ? 'past' : '' %> <%= d.count > 0 ? 'has-shift' : '' %>"
         href="#date-<%= d.iso %>"
         role="listitem"
         aria-label="<%= d.letter %> <%= d.day %><%= d.count ? ' — ' + d.count + ' shift' + (d.count === 1 ? '' : 's') : '' %>">
        <span class="ws-day-letter"><%= d.letter %></span>
        <span class="ws-day-num"><%= d.day %></span>
        <span class="ws-day-bar"></span>
      </a>
    <% }) %>
  </div>

  <!-- Always-on Requests -->
  <% if (requests && requests.length > 0) { %>
    <div class="ws-requests">
      <div class="ws-req-head">
        <span class="ws-req-head-ic">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        </span>
        <div>
          <p class="ws-req-head-title">
            <%= requests.length %> shift<%= requests.length === 1 ? '' : 's' %> need confirming
          </p>
          <p class="ws-req-head-sub">Always visible — regardless of the week you're viewing.</p>
        </div>
      </div>
      <% requests.forEach(function (s) {
        var link = (s.source === 'booking' && s.booking_id)
          ? ('/w/booking-shift/' + s.booking_id)
          : ('/w/jobs/' + s.id);
      %>
        <a href="<%= link %>" class="ws-shift is-allocated" style="margin: 6px 8px;">
          <span class="ws-shift-bar"></span>
          <div class="ws-shift-body">
            <div class="ws-shift-top">
              <span class="ws-shift-time">
                <%= new Date(s.allocation_date + 'T00:00:00').toLocaleDateString('en-AU', { weekday:'short', day:'numeric', month:'short' }) %>
                · <%= fmtTime(s.start_time) %>–<%= fmtTime(s.end_time) %>
              </span>
              <span class="ws-shift-pill allocated">Confirm</span>
            </div>
            <p class="ws-shift-client"><%= s.client || s.job_name || s.job_number %></p>
            <p class="ws-shift-meta"><%= s.job_number %><% if (s.suburb) { %> · <%= s.suburb %><% } %></p>
          </div>
          <span class="ws-shift-arrow">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      <% }) %>
    </div>
  <% } %>

  <!-- This week's shifts -->
  <% if (weekShifts.length === 0) { %>
    <div class="ws-empty">
      <div class="ws-empty-ic">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l4-4h10l4 4M3 8v11a1 1 0 001 1h16a1 1 0 001-1V8M3 8h18"/></svg>
      </div>
      <p class="ws-empty-title">There are no shifts this week!</p>
      <p class="ws-empty-sub">Shift requests will <strong>always</strong> appear above, regardless of the week you're viewing.</p>
    </div>
  <% } else { %>
    <% Object.keys(groupedByDate).sort().forEach(function (date) {
      var d = new Date(date + 'T00:00:00');
      var heading = dayHeading(date);
      var isToday = date === today;
    %>
      <div class="ws-day-head" id="date-<%= date %>">
        <span class="ws-day-title <%= isToday ? 'today' : '' %>">
          <%= isToday ? 'Today · ' + d.toLocaleDateString('en-AU', { day:'numeric', month:'short' }) : heading %>
        </span>
        <span class="ws-day-meta"><%= groupedByDate[date].length %> shift<%= groupedByDate[date].length === 1 ? '' : 's' %></span>
      </div>
      <% groupedByDate[date].forEach(function (s) {
        var link = (s.source === 'booking' && s.booking_id)
          ? ('/w/booking-shift/' + s.booking_id)
          : ('/w/jobs/' + s.id);
        var isAllocated = s.status === 'allocated' || s.status === 'assigned';
        var isCompleted = s.status === 'completed';
      %>
        <a href="<%= link %>" class="ws-shift <%= isAllocated ? 'is-allocated' : '' %>">
          <span class="ws-shift-bar"></span>
          <div class="ws-shift-body">
            <div class="ws-shift-top">
              <span class="ws-shift-time"><%= fmtTime(s.start_time) %>–<%= fmtTime(s.end_time) %></span>
              <% if (isAllocated) { %>
                <span class="ws-shift-pill allocated">Confirm</span>
              <% } else if (s.status === 'confirmed') { %>
                <span class="ws-shift-pill confirmed">Accepted</span>
              <% } else if (isCompleted) { %>
                <span class="ws-shift-pill completed">Done</span>
              <% } %>
            </div>
            <p class="ws-shift-client"><%= s.client || s.job_name || s.job_number %></p>
            <p class="ws-shift-meta"><%= s.job_number %><% if (s.suburb) { %> · <%= s.suburb %><% } %></p>
          </div>
          <span class="ws-shift-arrow">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      <% }) %>
    <% }) %>
  <% } %>

</div>
