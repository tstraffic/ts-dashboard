<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#020817">
  <title>Sign In | T&S Employee Portal</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/worker.css">
  <style>
    body {
      background: linear-gradient(135deg, #020817 0%, #0A1628 25%, #0F2847 50%, #0A1628 80%, #020817 100%) !important;
      background-attachment: fixed !important;
    }
  </style>
</head>
<body class="h-full font-sans antialiased flex items-center justify-center safe-area-top safe-area-bottom">
  <div class="w-full max-w-sm px-6">
    <!-- Logo & Title -->
    <div class="text-center mb-8">
      <img src="/images/logo-colour.jpg" alt="T&S Traffic Control" class="h-20 w-auto mx-auto mb-4 rounded-xl shadow-lg shadow-brand-600/20">
      <h1 class="text-xl font-bold text-white">Employee Portal</h1>
      <p class="text-gray-400 text-sm mt-1">Sign in with your Employee ID</p>
    </div>

    <!-- Flash Messages -->
    <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
      <% flash_error.forEach(msg => { %>
        <div class="mb-4 p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-300 text-sm backdrop-blur-sm"><%= msg %></div>
      <% }) %>
    <% } %>
    <% if (typeof flash_success !== 'undefined' && flash_success && flash_success.length > 0) { %>
      <% flash_success.forEach(msg => { %>
        <div class="mb-4 p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-300 text-sm backdrop-blur-sm"><%= msg %></div>
      <% }) %>
    <% } %>

    <!-- Login Form -->
    <form method="POST" action="/w/login" class="rounded-xl p-6 space-y-5" style="background: rgba(10,22,40,0.7); backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.08);">
      <%- include('../partials/csrf') %>
      <!-- Employee ID -->
      <div>
        <label for="employee_id" class="block text-sm font-medium text-gray-300 mb-1">Employee ID</label>
        <input type="text" id="employee_id" name="employee_id" required autofocus
          inputmode="text"
          autocomplete="username"
          placeholder="e.g. EMP-001"
          class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white text-base placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition">
      </div>

      <!-- PIN -->
      <div>
        <label for="pin" class="block text-sm font-medium text-gray-300 mb-1">PIN</label>
        <input type="password" id="pin" name="pin" required
          inputmode="numeric"
          autocomplete="current-password"
          maxlength="6"
          pattern="[0-9]{4,6}"
          placeholder="4-6 digit PIN"
          class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-lg text-white text-base text-center tracking-[0.5em] placeholder:tracking-normal placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent transition">
      </div>

      <!-- Submit -->
      <button type="submit" class="w-full py-3 bg-brand-600 hover:bg-brand-500 active:bg-brand-700 text-white font-semibold rounded-lg transition-all text-base shadow-lg shadow-brand-600/20">
        Sign In
      </button>
      <div class="text-center mt-3">
        <a href="/w/forgot-pin" class="text-sm text-brand-400 hover:text-brand-300 transition">Forgot PIN?</a>
      </div>
    </form>

    <!-- Admin Link -->
    <p class="text-center text-gray-600 text-xs mt-6">
      <a href="/login" class="hover:text-gray-400 transition">Admin Dashboard &rarr;</a>
    </p>
  </div>
</body>
</html>
