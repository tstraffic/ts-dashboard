<div class="space-y-5">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Clock History</h1>
      <p class="text-sm text-gray-500">Last 7 days</p>
    </div>
    <a href="/w/clock" class="inline-flex items-center gap-1 text-sm text-brand-600 font-medium">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    </a>
  </div>

  <% const dates = Object.keys(groupedByDate).sort((a, b) => b.localeCompare(a)); %>
  <% if (dates.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-gray-500 text-sm">No clock events in the last 7 days</p>
    </div>
  <% } else { %>
    <% dates.forEach(function(date) { %>
      <%
        const d = new Date(date + 'T00:00:00');
        const dateLabel = d.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
        const total = dailyTotals[date] || { hours: 0, mins: 0 };
        const events = groupedByDate[date].sort((a, b) => a.event_time.localeCompare(b.event_time));
      %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <!-- Day Header -->
        <div class="px-4 py-3 bg-gray-50 border-b border-gray-100 flex items-center justify-between">
          <span class="text-sm font-semibold text-gray-700"><%= dateLabel %></span>
          <span class="text-sm font-medium text-brand-600"><%= total.hours %>h <%= String(total.mins).padStart(2, '0') %>m</span>
        </div>

        <!-- Events -->
        <% events.forEach(function(evt, i) { %>
          <div class="flex items-center gap-3 px-4 py-2.5 <%= i < events.length - 1 ? 'border-b border-gray-50' : '' %>">
            <div class="w-7 h-7 rounded-full flex items-center justify-center shrink-0 <%=
              evt.event_type === 'clock_in' ? 'bg-emerald-100 text-emerald-600' :
              evt.event_type === 'clock_out' ? 'bg-red-100 text-red-600' :
              evt.event_type === 'break_start' ? 'bg-amber-100 text-amber-600' :
              'bg-blue-100 text-blue-600' %>">
              <% if (evt.event_type === 'clock_in') { %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14"/></svg>
              <% } else if (evt.event_type === 'clock_out') { %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7"/></svg>
              <% } else if (evt.event_type === 'break_start') { %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6"/></svg>
              <% } else { %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/></svg>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-800">
                <%= evt.event_type === 'clock_in' ? 'Clock In' : evt.event_type === 'clock_out' ? 'Clock Out' : evt.event_type === 'break_start' ? 'Break Start' : 'Break End' %>
              </p>
              <% if (evt.job_number) { %>
                <p class="text-xs text-gray-500"><%= evt.job_number %> - <%= evt.client %></p>
              <% } %>
              <% if (evt.notes) { %>
                <p class="text-xs text-gray-400"><%= evt.notes %></p>
              <% } %>
            </div>
            <div class="text-right shrink-0">
              <p class="text-sm text-gray-700">
                <%= new Date(evt.event_time + (evt.event_time.includes('Z') ? '' : 'Z')).toLocaleTimeString('en-AU', { timeZone: 'Australia/Sydney', hour: '2-digit', minute: '2-digit', hour12: true }) %>
              </p>
              <% if (evt.latitude) { %>
                <p class="text-[10px] text-gray-400">GPS</p>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } %>
</div>
