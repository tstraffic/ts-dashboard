<%
  const dateObj = new Date(allocation.allocation_date + 'T00:00:00');
  const dayName = dateObj.toLocaleDateString('en-AU', { weekday: 'long' });
  const dateFormatted = dateObj.toLocaleDateString('en-AU', { day: '2-digit', month: '2-digit' });
  const isPending = allocation.status === 'allocated';
  const isFinished = allocation.status === 'completed' || allocation.status === 'declined';
%>

<div class="space-y-4">

  <!-- Back + Header -->
  <div>
    <a href="/w/jobs" class="inline-flex items-center gap-1 text-sm text-brand-600 font-medium mb-3">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Home
    </a>

    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-xl font-bold text-gray-900">Job <%= allocation.job_number %></h1>
        <p class="text-sm text-gray-500 mt-0.5"><%= allocation.suburb %><% if (allocation.state) { %>, <%= allocation.state %><% } %></p>
      </div>
      <% if (!isPending && !isFinished) { %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
          Confirmed
        </span>
      <% } else if (isFinished) { %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold
          <%= allocation.status === 'completed' ? 'bg-blue-50 text-blue-600 ring-1 ring-blue-500/20' : 'bg-red-50 text-red-600 ring-1 ring-red-500/20' %>">
          <%= allocation.status.charAt(0).toUpperCase() + allocation.status.slice(1) %>
        </span>
      <% } %>
    </div>
  </div>

  <!-- Accept / Decline buttons (for pending allocations) -->
  <% if (isPending) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-amber-800 mb-3">This shift is awaiting your response</p>
      <div class="flex gap-3">
        <form method="POST" action="/w/jobs/<%= allocation.id %>/respond" class="flex-1">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="accept">
          <button type="submit" class="w-full py-3 px-4 rounded-lg bg-emerald-600 text-white font-semibold text-sm active:bg-emerald-700 transition-colors" style="min-height:44px;">
            Accept
          </button>
        </form>
        <form method="POST" action="/w/jobs/<%= allocation.id %>/respond" class="flex-1">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="decline">
          <button type="submit" class="w-full py-3 px-4 rounded-lg bg-red-600 text-white font-semibold text-sm active:bg-red-700 transition-colors" style="min-height:44px;">
            Decline
          </button>
        </form>
      </div>
    </div>
  <% } %>

  <!-- Your Shift -->
  <div class="bg-white border border-gray-200 rounded-xl p-4">
    <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-2">Your shift</h2>
    <p class="text-sm font-semibold text-gray-900">
      <%= dayName %>, <%= dateFormatted %>
      &nbsp;&nbsp;<%= allocation.start_time %> at <%= allocation.suburb || 'Depot' %>
      <% if (allocation.end_time) { %> &ndash; <%= allocation.end_time %> (approx)<% } %>
    </p>
    <% if (allocation.role_on_site) { %>
      <p class="text-xs text-gray-500 mt-1">
        Role: <span class="font-medium text-gray-700"><%= allocation.role_on_site.replace(/_/g, ' ') %></span>
      </p>
    <% } %>
    <% if (allocation.shift_type) { %>
      <p class="text-xs text-gray-500 mt-0.5">
        Shift: <span class="font-medium text-gray-700"><%= allocation.shift_type %></span>
      </p>
    <% } %>
  </div>

  <!-- Details Table -->
  <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
    <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider px-4 pt-4 pb-2">Details</h2>
    <table class="w-full text-sm">
      <tbody>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium w-1/3">Booking</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.start_time %><% if (allocation.end_time) { %> &ndash; <%= allocation.end_time %><% } %></td>
        </tr>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Job number</td>
          <td class="px-4 py-2.5 text-gray-900 font-medium"><%= allocation.job_number %></td>
        </tr>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Client</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.client %></td>
        </tr>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Client Order</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.client_project_number || '—' %></td>
        </tr>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Job title</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.job_name || '—' %></td>
        </tr>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Project</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.project_name || '—' %></td>
        </tr>
        <% if (allocation.job_notes) { %>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium align-top">Description</td>
            <td class="px-4 py-2.5 text-gray-900 whitespace-pre-line"><%= allocation.job_notes %></td>
          </tr>
        <% } %>
        <tr class="border-t border-gray-100">
          <td class="px-4 py-2.5 text-gray-500 font-medium">Location</td>
          <td class="px-4 py-2.5 text-gray-900"><%= allocation.site_address || '—' %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Crew and Resources -->
  <div class="bg-white border border-gray-200 rounded-xl p-4">
    <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-3">Crew and resources</h2>

    <!-- Current worker (you) -->
    <div class="flex items-center justify-between py-3 border-b border-gray-100">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center text-xs font-bold text-brand-700">
          <%= typeof worker !== 'undefined' && worker ? worker.full_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() : '?' %>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900"><%= typeof worker !== 'undefined' && worker ? worker.full_name : 'You' %> <span class="text-xs text-gray-400">(You)</span></p>
          <p class="text-xs text-gray-500"><%= allocation.role_on_site ? allocation.role_on_site.replace(/_/g, ' ') : (typeof worker !== 'undefined' && worker.role ? worker.role.replace(/_/g, ' ') : 'Crew') %></p>
          <p class="text-xs text-gray-400"><%= allocation.start_time %> at <%= allocation.suburb || 'depot' %></p>
        </div>
      </div>
    </div>

    <!-- Supervisor -->
    <% if (allocation.supervisor_name) { %>
      <div class="flex items-center justify-between py-3 border-b border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center text-xs font-bold text-amber-700">
            <%= allocation.supervisor_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= allocation.supervisor_name %></p>
            <p class="text-xs text-amber-600 font-medium">Supervisor</p>
          </div>
        </div>
        <% if (supervisorPhone) { %>
          <a href="tel:<%= supervisorPhone %>" class="w-11 h-11 rounded-full bg-brand-50 flex items-center justify-center active:bg-brand-100 transition-colors" style="min-width:44px;min-height:44px;">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </a>
        <% } %>
      </div>
    <% } %>

    <!-- Other Crew -->
    <% if (otherCrew.length > 0) { %>
      <% otherCrew.forEach(function(c) { %>
        <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500">
              <%= c.full_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= c.full_name %></p>
              <p class="text-xs text-gray-500"><%= c.role_on_site ? c.role_on_site.replace(/_/g, ' ') : c.crew_role.replace(/_/g, ' ') %></p>
              <p class="text-xs text-gray-400"><%= c.start_time %> at depot</p>
            </div>
          </div>
          <% if (c.phone) { %>
            <a href="tel:<%= c.phone %>" class="w-11 h-11 rounded-full bg-gray-50 flex items-center justify-center active:bg-gray-100 transition-colors" style="min-width:44px;min-height:44px;">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </a>
          <% } %>
        </div>
      <% }) %>
    <% } %>

    <% if (otherCrew.length === 0 && !allocation.supervisor_name) { %>
      <p class="text-sm text-gray-400 italic py-2">No other crew assigned to this date.</p>
    <% } %>
  </div>

  <!-- Allocation Notes -->
  <% if (allocation.notes) { %>
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-2">Allocation Notes</h2>
      <p class="text-sm text-gray-700 whitespace-pre-line"><%= allocation.notes %></p>
    </div>
  <% } %>

</div>
