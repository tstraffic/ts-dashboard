<%
  const dateObj = new Date(allocation.allocation_date + 'T00:00:00');
  const dayName = dateObj.toLocaleDateString('en-AU', { weekday: 'long' });
  const dateFormatted = dateObj.toLocaleDateString('en-AU', { day: '2-digit', month: '2-digit' });
  const isPending = allocation.status === 'allocated';
  const isFinished = allocation.status === 'completed' || allocation.status === 'declined';
  const today = new Date().toISOString().split('T')[0];
  const isToday = allocation.allocation_date === today;
  const isFuture = allocation.allocation_date >= today;

  // Count completed forms
  const formsCompleted = (formStatus.prestart ? 1 : 0) + (formStatus.take5 ? 1 : 0) + (formStatus.equipment ? 1 : 0);
  const formsRequired = 2; // prestart + take5 are typically required
  const hasDocket = !!docket;
%>

<div class="space-y-4">

  <!-- Back + Header -->
  <div>
    <a href="/w/jobs" class="inline-flex items-center gap-1 text-sm text-brand-600 font-medium mb-3">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    </a>

    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-xl font-bold text-gray-900">Job <%= allocation.job_number %></h1>
        <p class="text-sm text-gray-500 mt-0.5"><%= allocation.suburb %><% if (allocation.state) { %>, <%= allocation.state %><% } %></p>
      </div>
      <% if (!isPending && !isFinished) { %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
          Confirmed
        </span>
      <% } else if (isFinished) { %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold
          <%= allocation.status === 'completed' ? 'bg-blue-50 text-blue-600 ring-1 ring-blue-500/20' : 'bg-red-50 text-red-600 ring-1 ring-red-500/20' %>">
          <%= allocation.status.charAt(0).toUpperCase() + allocation.status.slice(1) %>
        </span>
      <% } %>
    </div>
  </div>

  <!-- Accept / Decline buttons (for pending allocations) -->
  <% if (isPending) { %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
      <p class="text-sm font-semibold text-amber-800 mb-3">This shift is awaiting your response</p>
      <div class="flex gap-3">
        <form method="POST" action="/w/jobs/<%= allocation.id %>/respond" class="flex-1">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="accept">
          <button type="submit" class="w-full py-3 px-4 rounded-lg bg-emerald-600 text-white font-semibold text-sm active:bg-emerald-700 transition-colors" style="min-height:44px;">
            Accept
          </button>
        </form>
        <form method="POST" action="/w/jobs/<%= allocation.id %>/respond" class="flex-1">
          <%- include('../partials/csrf') %>
          <input type="hidden" name="action" value="decline">
          <button type="submit" class="w-full py-3 px-4 rounded-lg bg-red-600 text-white font-semibold text-sm active:bg-red-700 transition-colors" style="min-height:44px;">
            Decline
          </button>
        </form>
      </div>
    </div>
  <% } %>

  <!-- Tab Navigation -->
  <div class="flex border-b border-gray-200">
    <button id="dtab-info" onclick="switchDetailTab('info')"
      class="dtab-btn flex-1 px-3 py-3 text-sm font-semibold tracking-wide transition-colors relative text-center">
      Info
    </button>
    <button id="dtab-docs" onclick="switchDetailTab('docs')"
      class="dtab-btn flex-1 px-3 py-3 text-sm font-semibold tracking-wide transition-colors relative text-center">
      Docs
      <% if (typeof jobDocuments !== 'undefined' && jobDocuments.length) { %>
        <span class="ml-1 inline-flex items-center justify-center w-5 h-5 text-[10px] font-bold rounded-full bg-brand-100 text-brand-700"><%= jobDocuments.length %></span>
      <% } %>
    </button>
    <button id="dtab-forms" onclick="switchDetailTab('forms')"
      class="dtab-btn flex-1 px-3 py-3 text-sm font-semibold tracking-wide transition-colors relative text-center">
      Forms
      <% if (isFuture || isToday) { %>
        <span class="ml-1 inline-flex items-center justify-center w-5 h-5 text-[10px] font-bold rounded-full
          <%= formsCompleted >= formsRequired ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
          <%= formsCompleted %>
        </span>
      <% } %>
    </button>
    <button id="dtab-docket" onclick="switchDetailTab('docket')"
      class="dtab-btn flex-1 px-3 py-3 text-sm font-semibold tracking-wide transition-colors relative text-center">
      Docket
      <% if (hasDocket) { %>
        <span class="ml-1 inline-flex items-center justify-center w-4 h-4 rounded-full bg-emerald-100">
          <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        </span>
      <% } %>
    </button>
  </div>

  <!-- ==================== DOCS TAB ==================== -->
  <%
    // Doc-type label map covers both the Job-Pack chips (job_documents:
    // tgs/tmp/rol_day/rol_night/stage_plan/swms/permit/other) AND the legacy
    // booking_documents.document_type values (tgs/ctmp/rol/permit/invoice/photo/other).
    var DOC_TYPE_LABEL = {
      tgs:'TGS', tmp:'TMP', ctmp:'CTMP', rol:'ROL', rol_day:'ROL — Day', rol_night:'ROL — Night',
      stage_plan:'Stage Plan', swms:'SWMS', permit:'Permit', invoice:'Invoice', photo:'Photo', other:'Other',
    };
    function fmtSize(n) { if (!n) return ''; if (n < 1024) return n + ' B'; if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB'; return (n/1048576).toFixed(1) + ' MB'; }
  %>
  <div id="dpanel-docs" class="dtab-panel space-y-4" style="display:none;">
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-4 pt-4 pb-2">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Site Documents</h2>
        <p class="text-xs text-gray-400 mt-0.5">Uploaded by your allocator — review before commencing work.</p>
      </div>
      <% if (!jobDocuments || jobDocuments.length === 0) { %>
        <div class="px-4 py-8 text-center text-xs text-gray-500 border-t border-gray-100">
          <p class="font-medium text-gray-700">No documents uploaded yet</p>
          <p class="mt-1">Your allocator hasn't attached any site documents to this job. If you're expecting a TGS / TMP / ROL, ask them to upload it.</p>
        </div>
      <% } else { %>
        <% jobDocuments.forEach(function (doc) { %>
          <a href="<%= doc.download_url %>" target="_blank" class="px-4 py-3 border-t border-gray-100 flex items-center gap-3 active:bg-gray-50">
            <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/><path d="M14 2v6h6M9 14h6M9 18h6M9 10h2"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= doc.title || doc.original_name %></p>
              <p class="text-[11px] text-gray-500">
                <%= DOC_TYPE_LABEL[doc.doc_type] || doc.doc_type %>
                <% if (doc.source === 'booking') { %><span class="ml-1 inline-block px-1.5 py-0.5 rounded text-[9px] font-bold bg-brand-50 text-brand-700 ring-1 ring-brand-600/10 uppercase tracking-wide">This shift</span><% } %>
                <% if (doc.size_bytes) { %> &middot; <%= fmtSize(doc.size_bytes) %><% } %>
              </p>
            </div>
            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- ==================== INFO TAB ==================== -->
  <div id="dpanel-info" class="dtab-panel space-y-4">

    <!-- Your Shift -->
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-2">Your shift</h2>
      <p class="text-sm font-semibold text-gray-900">
        <%= dayName %>, <%= dateFormatted %>
        &nbsp;&nbsp;<%= allocation.start_time %> at <%= allocation.suburb || 'Depot' %>
        <% if (allocation.end_time) { %> &ndash; <%= allocation.end_time %> (approx)<% } %>
      </p>
      <% if (allocation.role_on_site) { %>
        <p class="text-xs text-gray-500 mt-1">
          Role: <span class="font-medium text-gray-700"><%= allocation.role_on_site.replace(/_/g, ' ') %></span>
        </p>
      <% } %>
      <% if (allocation.shift_type) { %>
        <p class="text-xs text-gray-500 mt-0.5">
          Shift: <span class="font-medium text-gray-700"><%= allocation.shift_type %></span>
        </p>
      <% } %>
    </div>

    <!-- Details Table -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider px-4 pt-4 pb-2">Details</h2>
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium w-1/3">Booking</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.start_time %><% if (allocation.end_time) { %> &ndash; <%= allocation.end_time %><% } %></td>
          </tr>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Job number</td>
            <td class="px-4 py-2.5 text-gray-900 font-medium"><%= allocation.job_number %></td>
          </tr>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Client</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.client %></td>
          </tr>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Client Order</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.client_project_number || '—' %></td>
          </tr>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Job title</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.job_name || '—' %></td>
          </tr>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Project</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.project_name || '—' %></td>
          </tr>
          <% if (allocation.job_notes) { %>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-2.5 text-gray-500 font-medium align-top">Description</td>
              <td class="px-4 py-2.5 text-gray-900 whitespace-pre-line"><%= allocation.job_notes %></td>
            </tr>
          <% } %>
          <tr class="border-t border-gray-100">
            <td class="px-4 py-2.5 text-gray-500 font-medium">Location</td>
            <td class="px-4 py-2.5 text-gray-900"><%= allocation.site_address || '—' %></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Crew and Resources -->
    <div class="bg-white border border-gray-200 rounded-xl p-4">
      <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-3">Crew and resources</h2>

      <!-- Current worker (you) -->
      <div class="flex items-center justify-between py-3 border-b border-gray-100">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-brand-100 flex items-center justify-center text-xs font-bold text-brand-700">
            <%= typeof worker !== 'undefined' && worker ? worker.full_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() : '?' %>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900"><%= typeof worker !== 'undefined' && worker ? worker.full_name : 'You' %> <span class="text-xs text-gray-400">(You)</span></p>
            <p class="text-xs text-gray-500"><%= allocation.role_on_site ? allocation.role_on_site.replace(/_/g, ' ') : (typeof worker !== 'undefined' && worker.role ? worker.role.replace(/_/g, ' ') : 'Crew') %></p>
            <p class="text-xs text-gray-400"><%= allocation.start_time %> at <%= allocation.suburb || 'depot' %></p>
          </div>
        </div>
      </div>

      <!-- Supervisor -->
      <% if (allocation.supervisor_name) { %>
        <div class="flex items-center justify-between py-3 border-b border-gray-100">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center text-xs font-bold text-amber-700">
              <%= allocation.supervisor_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= allocation.supervisor_name %></p>
              <p class="text-xs text-amber-600 font-medium">Supervisor</p>
            </div>
          </div>
          <% if (supervisorPhone) { %>
            <a href="tel:<%= supervisorPhone %>" class="w-11 h-11 rounded-full bg-brand-50 flex items-center justify-center active:bg-brand-100 transition-colors" style="min-width:44px;min-height:44px;">
              <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </a>
          <% } %>
        </div>
      <% } %>

      <!-- Other Crew -->
      <% if (otherCrew.length > 0) { %>
        <% otherCrew.forEach(function(c) { %>
          <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500">
                <%= c.full_name.split(' ').map(function(n){return n[0]}).join('').slice(0,2).toUpperCase() %>
              </div>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= c.full_name %></p>
                <p class="text-xs text-gray-500"><%= c.role_on_site ? c.role_on_site.replace(/_/g, ' ') : c.crew_role.replace(/_/g, ' ') %></p>
                <p class="text-xs text-gray-400"><%= c.start_time %> at depot</p>
              </div>
            </div>
            <% if (c.phone) { %>
              <a href="tel:<%= c.phone %>" class="w-11 h-11 rounded-full bg-gray-50 flex items-center justify-center active:bg-gray-100 transition-colors" style="min-width:44px;min-height:44px;">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </a>
            <% } %>
          </div>
        <% }) %>
      <% } %>

      <% if (otherCrew.length === 0 && !allocation.supervisor_name) { %>
        <p class="text-sm text-gray-400 italic py-2">No other crew assigned to this date.</p>
      <% } %>
    </div>

    <!-- Allocation Notes -->
    <% if (allocation.notes) { %>
      <div class="bg-white border border-gray-200 rounded-xl p-4">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider mb-2">Allocation Notes</h2>
        <p class="text-sm text-gray-700 whitespace-pre-line"><%= allocation.notes %></p>
      </div>
    <% } %>
  </div>

  <!-- ==================== FORMS TAB ==================== -->
  <div id="dpanel-forms" class="dtab-panel space-y-4" style="display:none;">

    <!-- Job-Pack: the 5 Traffio-equivalent shift checklists, split into the
         two that are mandatory for every shift (Risk Assessment & Toolbox,
         Team Leader Checklist) and the three that fire a warning when
         skipped but don't block the docket on their own. -->
    <%
      var JOB_PACK_REQUIRED = [
        { key: 'risk_toolbox',  path: 'risk-assessment', label: '2. Risk Assessment & Toolbox', hint: 'Run with the crew on site' },
        { key: 'team_leader',   path: 'team-leader',     label: '4. Team Leader Checklist',     hint: 'Team Leader only' },
      ];
      var JOB_PACK_RECOMMENDED = [
        { key: 'vehicle_prestart',   path: 'vehicle-prestart',   label: '1. Vehicle Pre-Start',           hint: 'Before starting the vehicle' },
        { key: 'tc_prestart',        path: 'tc-prestart',        label: '3. TC Prestart Declaration',     hint: 'Per Traffic Controller' },
        { key: 'post_shift_vehicle', path: 'post-shift-vehicle', label: '5. Post-Shift Vehicle Checklist',hint: 'At end of shift' },
      ];
    %>

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-4 pt-4 pb-2">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Required checklists</h2>
        <p class="text-xs text-gray-400 mt-0.5">Must be filed for every shift</p>
      </div>
      <% JOB_PACK_REQUIRED.forEach(function (jp) { var done = formStatus[jp.key]; %>
        <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 <%= done ? 'bg-emerald-50' : 'bg-amber-50' %>">
              <% if (done) { %>
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= jp.label %></p>
              <% if (done) { %>
                <p class="text-xs text-emerald-600 font-medium">Submitted <%= new Date(done.created_at).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' }) %></p>
              <% } else { %>
                <p class="text-xs text-amber-600 font-semibold">Required &middot; <span class="font-normal text-gray-500"><%= jp.hint %></span></p>
              <% } %>
            </div>
          </div>
          <% if (!done && (isToday || isFuture)) { %>
            <a href="/w/forms/<%= jp.path %>?allocationId=<%= allocation.id %>" class="px-3 py-2 rounded-lg bg-brand-600 text-white text-xs font-semibold active:bg-brand-700 transition shrink-0" style="min-height:36px; display:flex; align-items:center;">
              Start
            </a>
          <% } else if (done) { %>
            <span class="text-[10px] font-semibold text-emerald-700 bg-emerald-50 ring-1 ring-emerald-200 px-2 py-1 rounded uppercase tracking-wide">Done</span>
          <% } %>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-4 pt-4 pb-2">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Recommended checklists</h2>
        <p class="text-xs text-gray-400 mt-0.5">Fill if applicable — you'll get a warning before docket sign if they're missing</p>
      </div>
      <% JOB_PACK_RECOMMENDED.forEach(function (jp) { var done = formStatus[jp.key]; %>
        <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 <%= done ? 'bg-emerald-50' : 'bg-gray-50' %>">
              <% if (done) { %>
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= jp.label %></p>
              <% if (done) { %>
                <p class="text-xs text-emerald-600 font-medium">Submitted <%= new Date(done.created_at).toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' }) %></p>
              <% } else { %>
                <p class="text-xs text-gray-500"><%= jp.hint %></p>
              <% } %>
            </div>
          </div>
          <% if (!done && (isToday || isFuture)) { %>
            <a href="/w/forms/<%= jp.path %>?allocationId=<%= allocation.id %>" class="px-3 py-2 rounded-lg bg-gray-100 text-gray-700 text-xs font-semibold active:bg-gray-200 transition shrink-0" style="min-height:36px; display:flex; align-items:center;">
              Start
            </a>
          <% } else if (done) { %>
            <span class="text-[10px] font-semibold text-emerald-700 bg-emerald-50 ring-1 ring-emerald-200 px-2 py-1 rounded uppercase tracking-wide">Done</span>
          <% } %>
        </div>
      <% }) %>
    </div>

    <!-- Reporting -->
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-4 pt-4 pb-2">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Reporting</h2>
        <p class="text-xs text-gray-400 mt-0.5">Submit if needed during shift</p>
      </div>

      <!-- Hazard Reports -->
      <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Hazard Report</p>
            <% if (formStatus.hazard.length > 0) { %>
              <p class="text-xs text-amber-600 font-medium"><%= formStatus.hazard.length %> submitted</p>
            <% } else { %>
              <p class="text-xs text-gray-400">None submitted</p>
            <% } %>
          </div>
        </div>
        <% if (isToday || isFuture) { %>
          <a href="/w/forms/hazard" class="px-3 py-2 rounded-lg bg-amber-50 text-amber-700 text-xs font-semibold active:bg-amber-100 transition" style="min-height:36px; display:flex; align-items:center;">
            Report
          </a>
        <% } %>
      </div>

      <!-- Incident Reports -->
      <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Incident Report</p>
            <% if (formStatus.incident.length > 0) { %>
              <p class="text-xs text-red-600 font-medium"><%= formStatus.incident.length %> submitted</p>
            <% } else { %>
              <p class="text-xs text-gray-400">None submitted</p>
            <% } %>
          </div>
        </div>
        <% if (isToday || isFuture) { %>
          <a href="/w/forms/incident" class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-xs font-semibold active:bg-red-100 transition" style="min-height:36px; display:flex; align-items:center;">
            Report
          </a>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ==================== DOCKET TAB ==================== -->
  <div id="dpanel-docket" class="dtab-panel space-y-4" style="display:none;">

    <% if (docket) { %>
      <!-- Signed Docket -->
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="px-4 pt-4 pb-2 flex items-center justify-between">
          <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Docket</h2>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">Signed</span>
        </div>
        <div class="px-4 pb-4 space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <p class="text-xs text-gray-500">Docket type</p>
              <p class="text-sm font-medium text-gray-900"><%= docket.docket_type ? docket.docket_type.replace(/_/g, ' ') : 'Daily Docket' %></p>
            </div>
            <div>
              <p class="text-xs text-gray-500">Signed at</p>
              <p class="text-sm font-medium text-gray-900"><%= docket.signed_at ? new Date(docket.signed_at).toLocaleString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—' %></p>
            </div>
            <% if (docket.client_name) { %>
              <div>
                <p class="text-xs text-gray-500">Client rep</p>
                <p class="text-sm font-medium text-gray-900"><%= docket.client_name %></p>
              </div>
            <% } %>
            <% if (docket.start_on_site) { %>
              <div>
                <p class="text-xs text-gray-500">On site</p>
                <p class="text-sm font-medium text-gray-900"><%= docket.start_on_site %> &ndash; <%= docket.finish_on_site || '—' %></p>
              </div>
            <% } %>
            <% if (docket.total_hours) { %>
              <div>
                <p class="text-xs text-gray-500">Total hours</p>
                <p class="text-sm font-medium text-gray-900"><%= docket.total_hours %>h</p>
              </div>
            <% } %>
          </div>
          <% if (docket.notes) { %>
            <div>
              <p class="text-xs text-gray-500">Notes</p>
              <p class="text-sm text-gray-700"><%= docket.notes %></p>
            </div>
          <% } %>
          <% if (docket.signature_data) { %>
            <div>
              <p class="text-xs text-gray-500 mb-1">Worker signature</p>
              <img src="<%= docket.signature_data %>" alt="Signature" class="h-16 border border-gray-200 rounded-lg bg-gray-50 p-1">
            </div>
          <% } %>
          <% if (docket.client_signature) { %>
            <div>
              <p class="text-xs text-gray-500 mb-1">Client signature</p>
              <img src="<%= docket.client_signature %>" alt="Client Signature" class="h-16 border border-gray-200 rounded-lg bg-gray-50 p-1">
            </div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <!-- No docket yet -->
      <div class="bg-white border border-gray-200 rounded-xl p-6 text-center">
        <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
        </div>
        <p class="text-gray-500 font-medium text-sm">No docket signed yet</p>
        <p class="text-gray-400 text-xs mt-1">Sign off at the end of your shift</p>
        <% if (isToday || isFuture) { %>
          <a href="/w/dockets/sign/<%= allocation.id %>" class="inline-block mt-4 px-6 py-3 bg-brand-600 text-white rounded-xl font-semibold text-sm active:bg-brand-700 transition" style="min-height:44px;">
            Sign Docket
          </a>
        <% } %>
      </div>
    <% } %>

    <% if (!docket && (isToday || isFuture)) { %>
    <% } else if (docket && (isToday || isFuture)) { %>
      <!-- Option to sign another docket -->
      <div class="text-center">
        <a href="/w/dockets/sign/<%= allocation.id %>" class="text-sm text-brand-600 font-medium">Sign another docket &rarr;</a>
      </div>
    <% } %>
  </div>

</div>

<script>
(function() {
  var activeTab = '<%= tab %>';

  function switchDetailTab(tabName) {
    activeTab = tabName;
    var url = new URL(window.location);
    if (tabName === 'info') {
      url.searchParams.delete('tab');
    } else {
      url.searchParams.set('tab', tabName);
    }
    window.history.replaceState({}, '', url);

    document.querySelectorAll('.dtab-panel').forEach(function(p) { p.style.display = 'none'; });
    var panel = document.getElementById('dpanel-' + tabName);
    if (panel) panel.style.display = '';

    document.querySelectorAll('.dtab-btn').forEach(function(btn) {
      btn.classList.remove('text-brand-600', 'border-b-2', 'border-brand-600');
      btn.classList.add('text-gray-400');
    });
    var activeBtn = document.getElementById('dtab-' + tabName);
    if (activeBtn) {
      activeBtn.classList.remove('text-gray-400');
      activeBtn.classList.add('text-brand-600', 'border-b-2', 'border-brand-600');
    }
  }

  window.switchDetailTab = switchDetailTab;
  switchDetailTab(activeTab);
})();
</script>
