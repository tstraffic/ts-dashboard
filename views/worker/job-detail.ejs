<div class="space-y-5">
  <!-- Back Button -->
  <a href="/w/jobs" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-900 transition">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Jobs
  </a>

  <!-- Job Header -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-xs text-gray-500 font-medium"><%= allocation.job_number %></p>
        <h1 class="text-xl font-bold text-gray-900 mt-0.5"><%= allocation.client %></h1>
      </div>
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
        <%= allocation.status === 'confirmed' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20'
          : allocation.status === 'completed' ? 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20'
          : 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' %>">
        <%= allocation.status.charAt(0).toUpperCase() + allocation.status.slice(1) %>
      </span>
    </div>
  </div>

  <!-- Shift Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Shift Details</h2>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <p class="text-xs text-gray-400">Date</p>
        <p class="text-sm font-medium text-gray-900">
          <%= new Date(allocation.allocation_date + 'T00:00:00').toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' }) %>
        </p>
      </div>
      <div>
        <p class="text-xs text-gray-400">Time</p>
        <p class="text-sm font-medium text-gray-900"><%= allocation.start_time %> — <%= allocation.end_time %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400">Shift Type</p>
        <p class="text-sm font-medium text-gray-900"><%= allocation.shift_type %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400">Your Role</p>
        <p class="text-sm font-medium text-gray-900"><%= allocation.role_on_site ? allocation.role_on_site.replace(/_/g, ' ') : '—' %></p>
      </div>
    </div>
  </div>

  <!-- Site Location -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Site Location</h2>
    <div class="flex items-start gap-3">
      <div class="w-8 h-8 rounded-full bg-brand-50 flex items-center justify-center shrink-0 mt-0.5">
        <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900"><%= allocation.site_address %></p>
        <p class="text-sm text-gray-500"><%= allocation.suburb %></p>
      </div>
    </div>
  </div>

  <!-- Supervisor -->
  <% if (allocation.supervisor_name) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Supervisor</h2>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900"><%= allocation.supervisor_name %></p>
            <% if (supervisorPhone) { %>
              <p class="text-xs text-gray-500"><%= supervisorPhone %></p>
            <% } %>
          </div>
        </div>
        <% if (supervisorPhone) { %>
          <a href="tel:<%= supervisorPhone %>" class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Site Notes -->
  <% if (allocation.job_notes) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Site Notes</h2>
      <p class="text-sm text-gray-600 whitespace-pre-line"><%= allocation.job_notes %></p>
    </div>
  <% } %>

  <!-- Other Crew on this Job -->
  <% if (otherCrew.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Crew on Site (<%= otherCrew.length + 1 %>)</h2>
      <div class="space-y-2">
        <% otherCrew.forEach(c => { %>
          <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500">
                <%= c.full_name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase() %>
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900"><%= c.full_name %></p>
                <p class="text-xs text-gray-500"><%= c.role_on_site ? c.role_on_site.replace(/_/g, ' ') : c.crew_role.replace(/_/g, ' ') %></p>
              </div>
            </div>
            <% if (c.phone) { %>
              <a href="tel:<%= c.phone %>" class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </a>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- Allocation Notes -->
  <% if (allocation.notes) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Notes</h2>
      <p class="text-sm text-gray-600"><%= allocation.notes %></p>
    </div>
  <% } %>
</div>
