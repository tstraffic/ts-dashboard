<div class="space-y-0">
  <!-- Page Header -->
  <div class="mb-4">
    <h1 class="text-2xl font-bold text-gray-900">My Shifts</h1>
  </div>

  <!-- Tabs -->
  <div class="flex border-b border-gray-200 mb-5">
    <button id="tab-upcoming" onclick="switchTab('upcoming')"
      class="tab-btn px-4 py-3 text-sm font-semibold tracking-wide transition-colors relative">
      COMING UP
    </button>
    <button id="tab-finished" onclick="switchTab('finished')"
      class="tab-btn px-4 py-3 text-sm font-semibold tracking-wide transition-colors relative">
      PAST
    </button>
  </div>

  <!-- ===================== COMING UP TAB ===================== -->
  <div id="panel-upcoming" class="tab-panel space-y-5">

    <% if (requests.length === 0 && confirmed.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl p-8 text-center">
        <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <p class="text-gray-500 font-medium">No upcoming shifts</p>
        <p class="text-gray-400 text-sm mt-1">Check back later for new allocations</p>
      </div>
    <% } else { %>

      <%# ---- Requests section ---- %>
      <% if (requests.length > 0) { %>
        <div>
          <h3 class="text-sm font-bold text-amber-600 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Requests (<%= requests.length %>)
          </h3>

          <% const reqDates = Object.keys(requestsByDate).sort(); %>
          <% reqDates.forEach(date => { %>
            <% const dateObj = new Date(date + 'T00:00:00'); %>
            <% const isToday = date === today; %>
            <% const dayName = isToday ? 'Today' : dateObj.toLocaleDateString('en-AU', { weekday: 'short' }); %>
            <% const dayNum = dateObj.getDate(); %>
            <% const monthName = dateObj.toLocaleDateString('en-AU', { month: 'short' }); %>

            <div class="flex items-center gap-2 mb-2 mt-4 first:mt-0">
              <span class="text-xs font-semibold text-gray-500 uppercase"><%= dayName %> <%= dayNum %> <%= monthName %></span>
              <% if (isToday) { %>
                <span class="text-[10px] font-bold text-brand-600 bg-brand-50 px-1.5 py-0.5 rounded">TODAY</span>
              <% } %>
            </div>

            <% requestsByDate[date].forEach(shift => { %>
              <a href="/w/<%= shift.source === 'booking' ? 'booking-shift/' + shift.booking_id : 'jobs/' + shift.id %>" class="block bg-white border border-gray-200 rounded-lg overflow-hidden mb-2 active:bg-gray-50 transition-colors" style="border-left: 4px solid #f59e0b;">
                <div class="px-4 py-3">
                  <div class="flex items-start justify-between">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-bold text-gray-900">
                        <%= shift.start_time %> at <%= shift.suburb || 'Depot' %><% if (shift.end_time) { %> to ~<%= shift.end_time %><% } %>
                      </p>
                      <p class="text-sm text-gray-700 mt-0.5 truncate">
                        <%= shift.client %><% if (shift.project_name) { %>, <%= shift.project_name %><% } %>
                      </p>
                      <p class="text-xs text-gray-400 mt-0.5"><%= shift.suburb %><% if (shift.state) { %>, <%= shift.state %><% } %></p>
                    </div>
                    <div class="text-right ml-3 shrink-0">
                      <span class="text-xs font-medium text-gray-500"><%= shift.job_number %></span>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 mt-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-amber-50 text-amber-700 ring-1 ring-amber-500/20">
                      Pending
                    </span>
                    <% if (shift.role_on_site) { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
                        as <%= shift.role_on_site.replace(/_/g, ' ') %>
                      </span>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          <% }) %>
        </div>
      <% } %>

      <%# ---- Confirmed section ---- %>
      <div>
        <h3 class="text-sm font-bold text-emerald-600 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Confirmed (<%= confirmed.length %>)
        </h3>

        <% if (confirmed.length === 0) { %>
          <p class="text-sm text-gray-400 italic pl-1">No confirmed shifts yet.</p>
        <% } else { %>
          <% const confDates = Object.keys(confirmedByDate).sort(); %>
          <% confDates.forEach(date => { %>
            <% const dateObj = new Date(date + 'T00:00:00'); %>
            <% const isToday = date === today; %>
            <% const dayName = isToday ? 'Today' : dateObj.toLocaleDateString('en-AU', { weekday: 'short' }); %>
            <% const dayNum = dateObj.getDate(); %>
            <% const monthName = dateObj.toLocaleDateString('en-AU', { month: 'short' }); %>

            <div class="flex items-center gap-2 mb-2 mt-4 first:mt-0">
              <span class="text-xs font-semibold text-gray-500 uppercase"><%= dayName %> <%= dayNum %> <%= monthName %></span>
              <% if (isToday) { %>
                <span class="text-[10px] font-bold text-brand-600 bg-brand-50 px-1.5 py-0.5 rounded">TODAY</span>
              <% } %>
            </div>

            <% confirmedByDate[date].forEach(shift => { %>
              <a href="/w/<%= shift.source === 'booking' ? 'booking-shift/' + shift.booking_id : 'jobs/' + shift.id %>" class="block bg-white border border-gray-200 rounded-lg overflow-hidden mb-2 active:bg-gray-50 transition-colors" style="border-left: 4px solid #10b981;">
                <div class="px-4 py-3">
                  <div class="flex items-start justify-between">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-bold text-gray-900">
                        <%= shift.start_time %> at <%= shift.suburb || 'Depot' %><% if (shift.end_time) { %> to ~<%= shift.end_time %><% } %>
                      </p>
                      <p class="text-sm text-gray-700 mt-0.5 truncate">
                        <%= shift.client %><% if (shift.project_name) { %>, <%= shift.project_name %><% } %>
                      </p>
                      <p class="text-xs text-gray-400 mt-0.5"><%= shift.suburb %><% if (shift.state) { %>, <%= shift.state %><% } %></p>
                    </div>
                    <div class="text-right ml-3 shrink-0">
                      <span class="text-xs font-medium text-gray-500"><%= shift.job_number %></span>
                    </div>
                  </div>
                  <div class="flex items-center gap-2 mt-2">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
                      Confirmed
                    </span>
                    <% if (shift.role_on_site) { %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
                        as <%= shift.role_on_site.replace(/_/g, ' ') %>
                      </span>
                    <% } %>
                  </div>
                </div>
              </a>
            <% }) %>
          <% }) %>
        <% } %>
      </div>

    <% } %>
  </div>

  <!-- ===================== FINISHED TAB ===================== -->
  <div id="panel-finished" class="tab-panel space-y-4" style="display:none;">

    <% if (finished.length === 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl p-8 text-center">
        <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-gray-500 font-medium">No past shifts yet</p>
      </div>
    <% } else { %>
      <% const finDates = Object.keys(finishedByDate).sort().reverse(); %>
      <% finDates.forEach(date => { %>
        <% const dateObj = new Date(date + 'T00:00:00'); %>
        <% const dayName = dateObj.toLocaleDateString('en-AU', { weekday: 'short' }); %>
        <% const dayNum = dateObj.getDate(); %>
        <% const monthName = dateObj.toLocaleDateString('en-AU', { month: 'short' }); %>

        <div class="flex items-center gap-2 mb-2 mt-4 first:mt-0">
          <span class="text-xs font-semibold text-gray-500 uppercase"><%= dayName %> <%= dayNum %> <%= monthName %></span>
        </div>

        <% finishedByDate[date].forEach(shift => { %>
          <a href="/w/<%= shift.source === 'booking' ? 'booking-shift/' + shift.booking_id : 'jobs/' + shift.id %>" class="block bg-white border border-gray-200 rounded-lg overflow-hidden mb-2 active:bg-gray-50 transition-colors" style="border-left: 4px solid #d1d5db;">
            <div class="px-4 py-3">
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-gray-500">
                    <%= shift.start_time %> at <%= shift.suburb || 'Depot' %><% if (shift.end_time) { %> to ~<%= shift.end_time %><% } %>
                  </p>
                  <p class="text-sm text-gray-500 mt-0.5 truncate">
                    <%= shift.client %><% if (shift.project_name) { %>, <%= shift.project_name %><% } %>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5"><%= shift.suburb %><% if (shift.state) { %>, <%= shift.state %><% } %></p>
                </div>
                <div class="text-right ml-3 shrink-0">
                  <span class="text-xs font-medium text-gray-400"><%= shift.job_number %></span>
                </div>
              </div>
              <div class="flex items-center gap-2 mt-2">
                <% if (shift.status === 'completed') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-blue-50 text-blue-600 ring-1 ring-blue-500/20">
                    Completed
                  </span>
                <% } else if (shift.status === 'declined') { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-red-50 text-red-600 ring-1 ring-red-500/20">
                    Declined
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-semibold bg-gray-100 text-gray-500">
                    Past
                  </span>
                <% } %>
                <% if (shift.role_on_site) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-500">
                    as <%= shift.role_on_site.replace(/_/g, ' ') %>
                  </span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      <% }) %>
    <% } %>
  </div>
</div>

<script>
(function() {
  var activeTab = '<%= tab %>';

  function switchTab(tabName) {
    activeTab = tabName;
    // Update URL without reload
    var url = new URL(window.location);
    if (tabName === 'upcoming') {
      url.searchParams.delete('tab');
    } else {
      url.searchParams.set('tab', tabName);
    }
    window.history.replaceState({}, '', url);

    // Toggle panels
    document.getElementById('panel-upcoming').style.display = tabName === 'upcoming' ? '' : 'none';
    document.getElementById('panel-finished').style.display = tabName === 'finished' ? '' : 'none';

    // Update tab button styles
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.classList.remove('text-brand-600', 'border-b-2', 'border-brand-600');
      btn.classList.add('text-gray-400');
    });
    var activeBtn = document.getElementById('tab-' + tabName);
    if (activeBtn) {
      activeBtn.classList.remove('text-gray-400');
      activeBtn.classList.add('text-brand-600', 'border-b-2', 'border-brand-600');
    }
  }

  // Expose globally for onclick
  window.switchTab = switchTab;

  // Init on load
  switchTab(activeTab);
})();
</script>
