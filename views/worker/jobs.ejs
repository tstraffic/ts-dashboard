<div class="space-y-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">My Jobs</h1>
    <p class="text-gray-500 text-sm mt-0.5">Your shifts for the next 7 days</p>
  </div>

  <% const dates = Object.keys(groupedByDate).sort(); %>
  <% if (dates.length === 0) { %>
    <!-- Empty State -->
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
      <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0h2a2 2 0 012 2v6.255M8 6H6a2 2 0 00-2 2v6.255"/>
        </svg>
      </div>
      <p class="text-gray-500">No shifts scheduled for the next 7 days</p>
      <p class="text-gray-400 text-sm mt-1">Check back later for new allocations</p>
    </div>
  <% } else { %>
    <% dates.forEach(date => { %>
      <% const shifts = groupedByDate[date]; %>
      <% const isToday = date === today; %>
      <% const dateObj = new Date(date + 'T00:00:00'); %>
      <% const dayLabel = isToday ? 'Today' : dateObj.toLocaleDateString('en-AU', { weekday: 'long' }); %>
      <% const dateLabel = dateObj.toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }); %>

      <!-- Date Section -->
      <div>
        <div class="flex items-center gap-2 mb-2">
          <h2 class="text-sm font-semibold <%= isToday ? 'text-brand-600' : 'text-gray-700' %>"><%= dayLabel %></h2>
          <span class="text-xs text-gray-400"><%= dateLabel %></span>
          <% if (isToday) { %>
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-brand-50 text-brand-700 ring-1 ring-brand-600/20">Today</span>
          <% } %>
        </div>

        <% shifts.forEach(shift => { %>
          <a href="/w/jobs/<%= shift.id %>" class="block bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden mb-2 active:bg-gray-50 transition">
            <div class="p-4">
              <div class="flex items-start justify-between">
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-gray-500"><%= shift.job_number %></p>
                  <p class="font-semibold text-gray-900 truncate"><%= shift.client %></p>
                  <p class="text-sm text-gray-500 mt-0.5"><%= shift.site_address %>, <%= shift.suburb %></p>
                </div>
                <div class="text-right ml-3 shrink-0">
                  <p class="text-sm font-medium text-gray-900"><%= shift.start_time %></p>
                  <p class="text-xs text-gray-400"><%= shift.end_time %></p>
                </div>
              </div>

              <div class="flex items-center gap-2 mt-3">
                <!-- Status Badge -->
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium
                  <%= shift.status === 'confirmed' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20'
                    : shift.status === 'completed' ? 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20'
                    : 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' %>">
                  <%= shift.status %>
                </span>
                <!-- Shift Type -->
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
                  <%= shift.shift_type %>
                </span>
                <!-- Role -->
                <% if (shift.role_on_site) { %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-purple-50 text-purple-700 ring-1 ring-purple-600/20">
                    <%= shift.role_on_site.replace(/_/g, ' ') %>
                  </span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% }) %>
  <% } %>
</div>
