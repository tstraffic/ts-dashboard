<%
  function fmtTime(t) {
    if (!t) return '';
    const parts = String(t).split(':');
    let h = parseInt(parts[0], 10);
    const m = parts[1] || '00';
    const am = h < 12;
    h = h % 12; if (h === 0) h = 12;
    return h + (m === '00' ? '' : ':' + m) + (am ? 'am' : 'pm');
  }
%>

<style>
  .ws-wrap { padding: 0; }

  /* Header */
  .ws-h1 {
    font-size: 1.5rem; font-weight: 800; color: #fff;
    letter-spacing: -0.01em;
    padding: 6px 4px 14px;
  }

  /* Tab strip */
  .ws-tabs {
    display: flex; gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 6px;
  }
  .ws-tab {
    padding: 10px 16px;
    font-size: 0.78rem; font-weight: 800; letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    border-bottom: 2px solid transparent;
    background: none; border-top: none; border-left: none; border-right: none;
    cursor: pointer;
  }
  .ws-tab.active { color: #00D2BE; border-bottom-color: #00D2BE; }

  /* Month + week navigation */
  .ws-month {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 4px 6px;
  }
  .ws-month-btn {
    width: 36px; height: 36px; border-radius: 999px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.85);
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .ws-month-btn:active { background: rgba(255,255,255,0.10); }
  .ws-month-label { font-size: 0.95rem; font-weight: 700; color: #fff; }
  .ws-month-today {
    display: inline-block;
    font-size: 0.62rem; font-weight: 700; color: #00D2BE;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding: 3px 8px; border-radius: 999px;
    background: rgba(0,210,190,0.10); border: 1px solid rgba(0,210,190,0.25);
    margin-left: 8px;
  }

  /* Week strip */
  .ws-week {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
    padding: 4px 0 12px;
  }
  .ws-day {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 9px 2px 7px;
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: transform 0.1s;
  }
  .ws-day:active { transform: scale(0.97); }
  .ws-day-letter { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.06em; color: rgba(255,255,255,0.45); }
  .ws-day-num { font-size: 1.05rem; font-weight: 800; line-height: 1.1; color: #fff; letter-spacing: -0.02em; }
  .ws-day.past .ws-day-num { color: rgba(255,255,255,0.45); }
  .ws-day-bar {
    width: 22px; height: 3px; border-radius: 2px;
    background: rgba(255,255,255,0.08);
  }
  .ws-day.has-shift .ws-day-bar { background: #00D2BE; }
  .ws-day.today {
    border-color: #F59E0B;
    box-shadow: inset 0 0 0 1px rgba(245,158,11,0.45);
  }
  .ws-day.today .ws-day-letter,
  .ws-day.today .ws-day-num { color: #FCD34D; }

  /* Section heading */
  .ws-section-head {
    display: flex; align-items: center; gap: 8px;
    margin: 14px 4px 8px;
  }
  .ws-section-head svg { width: 14px; height: 14px; }
  .ws-section-title {
    font-size: 0.9rem; font-weight: 800; letter-spacing: 0;
  }
  .ws-section-title.requests  { color: #FCD34D; }
  .ws-section-title.confirmed { color: #6EE7B7; }
  .ws-section-title.past      { color: rgba(255,255,255,0.6); }

  /* Day heading inside the list */
  .ws-day-head {
    display: flex; align-items: center; justify-content: space-between;
    margin: 12px 4px 6px;
  }
  .ws-day-title { font-size: 0.7rem; font-weight: 800; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.08em; }
  .ws-day-title.today { color: #FCD34D; }
  .ws-day-meta { font-size: 0.65rem; color: rgba(255,255,255,0.4); }

  /* Shift card — three-row layout:
       row 1: time chip + booking number (right)
       row 2: title (large)
       row 3: location with pin icon
       row 4: status + role pills
     Cleaner than the previous "6am at Greenacre to ~2:30pm" run-on line. */
  .ws-shift {
    display: flex; align-items: stretch; gap: 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    margin-bottom: 8px;
    transition: background 0.12s, border-color 0.12s, transform 0.1s;
  }
  .ws-shift:active { transform: scale(0.995); background: rgba(255,255,255,0.05); }
  .ws-shift-bar { width: 3px; flex-shrink: 0; background: linear-gradient(180deg, #2B7FFF, #00D2BE); }
  .ws-shift.is-allocated .ws-shift-bar { background: linear-gradient(180deg, #F59E0B, #F97316); }
  .ws-shift.is-past .ws-shift-bar { background: rgba(255,255,255,0.15); }
  .ws-shift-body { flex: 1; min-width: 0; padding: 12px 14px; }

  /* Row 1: time chip + booking # */
  .ws-shift-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .ws-shift-time {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 0.78rem; font-weight: 700; color: #fff;
    font-variant-numeric: tabular-nums; line-height: 1;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
    padding: 5px 10px;
  }
  .ws-shift-time svg { width: 12px; height: 12px; color: rgba(255,255,255,0.55); }
  .ws-shift.is-allocated .ws-shift-time { background: rgba(245,158,11,0.10); border-color: rgba(245,158,11,0.32); color: #FCD34D; }
  .ws-shift.is-allocated .ws-shift-time svg { color: rgba(252,211,77,0.7); }
  .ws-shift.is-past .ws-shift-time { color: rgba(255,255,255,0.55); }
  .ws-shift-num { font-size: 0.65rem; font-weight: 600; color: rgba(255,255,255,0.4); font-family: ui-monospace, SFMono-Regular, monospace; flex-shrink: 0; letter-spacing: 0.02em; }

  /* Row 2: title */
  .ws-shift-client { font-size: 1.02rem; font-weight: 700; color: #fff; line-height: 1.2; margin-top: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: -0.005em; }
  .ws-shift.is-past .ws-shift-client { color: rgba(255,255,255,0.6); }

  /* Row 3: location */
  .ws-shift-loc { display: flex; align-items: center; gap: 5px; font-size: 0.75rem; color: rgba(255,255,255,0.55); margin-top: 3px; }
  .ws-shift-loc svg { width: 12px; height: 12px; color: rgba(255,255,255,0.4); flex-shrink: 0; }

  /* Row 4: pills */
  .ws-shift-pills { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
  .ws-pill {
    font-size: 0.58rem; font-weight: 800; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 2px 7px; border-radius: 999px;
  }
  .ws-pill.allocated { background: rgba(245,158,11,0.18); color: #FCD34D; border: 1px solid rgba(245,158,11,0.35); }
  .ws-pill.confirmed { background: rgba(16,185,129,0.18); color: #6EE7B7; border: 1px solid rgba(16,185,129,0.35); }
  .ws-pill.completed { background: rgba(59,130,246,0.18); color: #93C5FD; border: 1px solid rgba(59,130,246,0.35); }
  .ws-pill.declined  { background: rgba(239,68,68,0.18); color: #FCA5A5; border: 1px solid rgba(239,68,68,0.35); }
  .ws-pill.past      { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.55); border: 1px solid rgba(255,255,255,0.10); }
  .ws-pill.role      { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.65); border: 1px solid rgba(255,255,255,0.08); text-transform: none; letter-spacing: 0; font-weight: 600; }

  /* Empty state */
  .ws-empty { text-align: center; padding: 56px 20px 20px; color: rgba(255,255,255,0.55); }
  .ws-empty-ic { width: 96px; height: 96px; margin: 0 auto 22px; color: rgba(255,255,255,0.18); }
  .ws-empty-ic svg { width: 100%; height: 100%; stroke-width: 1.4; }
  .ws-empty-title { font-size: 1rem; font-weight: 700; color: rgba(255,255,255,0.78); }
  .ws-empty-sub { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 10px; max-width: 280px; margin-left: auto; margin-right: auto; line-height: 1.45; }
  .ws-empty-sub strong { color: rgba(255,255,255,0.85); font-weight: 700; }
</style>

<div class="ws-wrap">

  <h1 class="ws-h1">My Shifts</h1>

  <!-- Tabs -->
  <div class="ws-tabs">
    <button id="tab-upcoming" type="button" onclick="switchTab('upcoming')" class="ws-tab">Coming up</button>
    <button id="tab-finished" type="button" onclick="switchTab('finished')" class="ws-tab">Past</button>
  </div>

  <!-- ============================================================ -->
  <!-- Coming up tab                                                -->
  <!-- ============================================================ -->
  <div id="panel-upcoming" class="tab-panel">

    <!-- Month + week nav -->
    <div class="ws-month">
      <a href="/w/jobs?week=<%= prevWeek %>" class="ws-month-btn" aria-label="Previous week">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div style="text-align:center;">
        <span class="ws-month-label"><%= monthLabel %></span>
        <% if (!isThisWeek) { %>
          <a href="/w/jobs" class="ws-month-today">Jump to today</a>
        <% } %>
      </div>
      <a href="/w/jobs?week=<%= nextWeek %>" class="ws-month-btn" aria-label="Next week">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Week strip Mon → Sun -->
    <div class="ws-week" role="list" aria-label="Week days">
      <% weekDays.forEach(function (d) { %>
        <a class="ws-day <%= d.isToday ? 'today' : '' %> <%= d.isPast && !d.count ? 'past' : '' %> <%= d.count > 0 ? 'has-shift' : '' %>"
           href="#date-<%= d.iso %>"
           role="listitem"
           aria-label="<%= d.letter %> <%= d.day %><%= d.count ? ' — ' + d.count + ' shift' + (d.count === 1 ? '' : 's') : '' %>">
          <span class="ws-day-letter"><%= d.letter %></span>
          <span class="ws-day-num"><%= d.day %></span>
          <span class="ws-day-bar"></span>
        </a>
      <% }) %>
    </div>

    <!-- Requests (always-on, regardless of week) -->
    <% if (requests.length > 0) { %>
      <div class="ws-section-head">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" style="color:#FCD34D;"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
        <span class="ws-section-title requests">Requests (<%= requests.length %>)</span>
      </div>
      <% Object.keys(requestsByDate).sort().forEach(function (date) {
        var d = new Date(date + 'T00:00:00');
        var isToday = date === today;
        var dayLabel = isToday ? 'Today' : d.toLocaleDateString('en-AU', { weekday: 'short' });
        var dayNum = d.getDate();
        var monthName = d.toLocaleDateString('en-AU', { month: 'short' });
      %>
        <div class="ws-day-head">
          <span class="ws-day-title <%= isToday ? 'today' : '' %>"><%= dayLabel %> <%= dayNum %> <%= monthName.toUpperCase() %></span>
        </div>
        <% requestsByDate[date].forEach(function (s) {
          var link = (s.source === 'booking' && s.booking_id)
            ? ('/w/booking-shift/' + s.booking_id)
            : ('/w/jobs/' + s.id);
        %>
          <a href="<%= link %>" class="ws-shift is-allocated">
            <span class="ws-shift-bar"></span>
            <div class="ws-shift-body">
              <div class="ws-shift-top">
                <span class="ws-shift-time">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
                  <%= fmtTime(s.start_time) %><% if (s.end_time) { %> – <%= fmtTime(s.end_time) %><% } %>
                </span>
                <span class="ws-shift-num"><%= s.job_number %></span>
              </div>
              <p class="ws-shift-client"><%= s.client || s.job_name %><% if (s.project_name && s.project_name !== s.client) { %> · <%= s.project_name %><% } %></p>
              <% if (s.suburb || s.state) { %>
                <p class="ws-shift-loc">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= s.suburb %><% if (s.state) { %>, <%= s.state %><% } %>
                </p>
              <% } %>
              <div class="ws-shift-pills">
                <span class="ws-pill allocated">Pending</span>
                <% if (s.role_on_site) { %>
                  <span class="ws-pill role">as <%= s.role_on_site.replace(/_/g, ' ') %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      <% }) %>
    <% } %>

    <!-- Confirmed (this week only) -->
    <div class="ws-section-head">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.4" style="color:#6EE7B7;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span class="ws-section-title confirmed">Confirmed (<%= confirmed.filter(s => s.allocation_date >= weekStartIso && s.allocation_date <= weekEndIso).length %>)</span>
    </div>

    <% if (Object.keys(confirmedByDate).length === 0) { %>
      <p class="text-sm italic" style="color:rgba(255,255,255,0.4); padding-left: 6px;">No confirmed shifts this week.</p>
    <% } else { %>
      <% Object.keys(confirmedByDate).sort().forEach(function (date) {
        var d = new Date(date + 'T00:00:00');
        var isToday = date === today;
        var dayLabel = isToday ? 'Today' : d.toLocaleDateString('en-AU', { weekday: 'short' });
        var dayNum = d.getDate();
        var monthName = d.toLocaleDateString('en-AU', { month: 'short' });
      %>
        <div class="ws-day-head" id="date-<%= date %>">
          <span class="ws-day-title <%= isToday ? 'today' : '' %>"><%= dayLabel %> <%= dayNum %> <%= monthName.toUpperCase() %></span>
          <span class="ws-day-meta"><%= confirmedByDate[date].length %> shift<%= confirmedByDate[date].length === 1 ? '' : 's' %></span>
        </div>
        <% confirmedByDate[date].forEach(function (s) {
          var link = (s.source === 'booking' && s.booking_id)
            ? ('/w/booking-shift/' + s.booking_id)
            : ('/w/jobs/' + s.id);
        %>
          <a href="<%= link %>" class="ws-shift">
            <span class="ws-shift-bar"></span>
            <div class="ws-shift-body">
              <div class="ws-shift-top">
                <span class="ws-shift-time">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
                  <%= fmtTime(s.start_time) %><% if (s.end_time) { %> – <%= fmtTime(s.end_time) %><% } %>
                </span>
                <span class="ws-shift-num"><%= s.job_number %></span>
              </div>
              <p class="ws-shift-client"><%= s.client || s.job_name %><% if (s.project_name && s.project_name !== s.client) { %> · <%= s.project_name %><% } %></p>
              <% if (s.suburb || s.state) { %>
                <p class="ws-shift-loc">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= s.suburb %><% if (s.state) { %>, <%= s.state %><% } %>
                </p>
              <% } %>
              <div class="ws-shift-pills">
                <span class="ws-pill confirmed">Accepted</span>
                <% if (s.role_on_site) { %>
                  <span class="ws-pill role">as <%= s.role_on_site.replace(/_/g, ' ') %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      <% }) %>
    <% } %>

    <!-- Empty state when nothing for this week and no requests -->
    <% if (requests.length === 0 && Object.keys(confirmedByDate).length === 0) { %>
      <div class="ws-empty">
        <div class="ws-empty-ic">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l4-4h10l4 4M3 8v11a1 1 0 001 1h16a1 1 0 001-1V8M3 8h18"/></svg>
        </div>
        <p class="ws-empty-title">No shifts this week</p>
        <p class="ws-empty-sub">Shift requests will <strong>always</strong> appear above, regardless of the week you're viewing.</p>
      </div>
    <% } %>

  </div>

  <!-- ============================================================ -->
  <!-- Past tab                                                     -->
  <!-- ============================================================ -->
  <div id="panel-finished" class="tab-panel" style="display:none;">

    <% if (finished.length === 0) { %>
      <div class="ws-empty">
        <div class="ws-empty-ic">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="ws-empty-title">No past shifts yet</p>
      </div>
    <% } else { %>
      <% Object.keys(finishedByDate).sort().reverse().forEach(function (date) {
        var d = new Date(date + 'T00:00:00');
        var dayLabel = d.toLocaleDateString('en-AU', { weekday: 'short' });
        var dayNum = d.getDate();
        var monthName = d.toLocaleDateString('en-AU', { month: 'short' });
      %>
        <div class="ws-day-head">
          <span class="ws-day-title"><%= dayLabel %> <%= dayNum %> <%= monthName.toUpperCase() %></span>
        </div>
        <% finishedByDate[date].forEach(function (s) {
          var link = (s.source === 'booking' && s.booking_id)
            ? ('/w/booking-shift/' + s.booking_id)
            : ('/w/jobs/' + s.id);
        %>
          <a href="<%= link %>" class="ws-shift is-past">
            <span class="ws-shift-bar"></span>
            <div class="ws-shift-body">
              <div class="ws-shift-top">
                <span class="ws-shift-time">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
                  <%= fmtTime(s.start_time) %><% if (s.end_time) { %> – <%= fmtTime(s.end_time) %><% } %>
                </span>
                <span class="ws-shift-num"><%= s.job_number %></span>
              </div>
              <p class="ws-shift-client"><%= s.client || s.job_name %><% if (s.project_name && s.project_name !== s.client) { %> · <%= s.project_name %><% } %></p>
              <% if (s.suburb || s.state) { %>
                <p class="ws-shift-loc">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <%= s.suburb %><% if (s.state) { %>, <%= s.state %><% } %>
                </p>
              <% } %>
              <div class="ws-shift-pills">
                <% if (s.status === 'completed') { %>
                  <span class="ws-pill completed">Completed</span>
                <% } else if (s.status === 'declined') { %>
                  <span class="ws-pill declined">Declined</span>
                <% } else { %>
                  <span class="ws-pill past">Past</span>
                <% } %>
                <% if (s.role_on_site) { %>
                  <span class="ws-pill role">as <%= s.role_on_site.replace(/_/g, ' ') %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      <% }) %>
    <% } %>

  </div>
</div>

<script>
(function() {
  var activeTab = '<%= tab %>';

  function switchTab(tabName) {
    activeTab = tabName;
    var url = new URL(window.location);
    if (tabName === 'upcoming') url.searchParams.delete('tab'); else url.searchParams.set('tab', tabName);
    window.history.replaceState({}, '', url);

    document.getElementById('panel-upcoming').style.display = tabName === 'upcoming' ? '' : 'none';
    document.getElementById('panel-finished').style.display = tabName === 'finished' ? '' : 'none';

    document.querySelectorAll('.ws-tab').forEach(function (b) { b.classList.remove('active'); });
    var btn = document.getElementById('tab-' + tabName);
    if (btn) btn.classList.add('active');
  }
  window.switchTab = switchTab;
  switchTab(activeTab);
})();
</script>
