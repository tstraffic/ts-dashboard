<div class="space-y-4">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-gray-900">My Incidents</h1>
      <p class="text-xs text-gray-500 mt-0.5">Incident reports you have submitted</p>
    </div>
    <a href="/w/incidents/new" class="inline-flex items-center gap-1.5 px-3 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition shadow-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      Report
    </a>
  </div>

  <% if (incidents && incidents.length > 0) { %>
    <div class="space-y-3">
      <% incidents.forEach(function(inc) {
        const severityColors = {
          low: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
          medium: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',
          high: 'bg-orange-50 text-orange-700 ring-1 ring-orange-600/20',
          critical: 'bg-red-50 text-red-700 ring-1 ring-red-600/20'
        };
        const statusColors = {
          reported: 'bg-yellow-50 text-yellow-700 ring-1 ring-yellow-600/20',
          investigating: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',
          resolved: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20',
          closed: 'bg-gray-100 text-gray-600 ring-1 ring-gray-400/20'
        };
      %>
      <a href="/w/incidents/<%= inc.id %>" class="block bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden hover:shadow-md transition">
        <div class="p-4">
          <div class="flex items-start justify-between gap-2 mb-2">
            <div class="min-w-0">
              <p class="text-xs text-gray-400 font-mono"><%= inc.incident_number %></p>
              <p class="font-semibold text-gray-900 text-sm mt-0.5 truncate"><%= (inc.incident_type || '').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %></p>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold shrink-0 <%= severityColors[inc.severity] || severityColors.low %>">
              <%= (inc.severity || '').toUpperCase() %>
            </span>
          </div>

          <p class="text-xs text-gray-600 line-clamp-2 mb-3"><%= inc.description %></p>

          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 text-xs text-gray-500">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <%= inc.incident_date ? new Date(inc.incident_date).toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' }) : '-' %>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-medium <%= statusColors[inc.investigation_status] || statusColors.reported %>">
              <%= (inc.investigation_status || '').replace(/_/g, ' ') %>
            </span>
          </div>

          <% if (inc.job_number || inc.client) { %>
          <div class="mt-2 pt-2 border-t border-gray-100 flex items-center gap-1.5 text-xs text-gray-400">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0h2a2 2 0 012 2v6.255M8 6H6a2 2 0 00-2 2v6.255"/></svg>
            <span><%= inc.job_number %> &mdash; <%= inc.client %></span>
          </div>
          <% } %>
        </div>
      </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 text-center">
      <div class="w-14 h-14 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-gray-500 text-sm font-medium">No incidents reported</p>
      <p class="text-gray-400 text-xs mt-1">You have not submitted any incident reports yet.</p>
      <a href="/w/incidents/new" class="inline-flex items-center gap-1.5 mt-4 px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded-lg transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        Report Incident
      </a>
    </div>
  <% } %>
</div>
