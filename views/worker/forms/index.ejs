<script>
function filterForms(q) {
  var items = document.querySelectorAll('.form-item');
  var query = q.toLowerCase().trim();
  items.forEach(function(item) {
    var name = item.dataset.name || item.textContent.toLowerCase();
    item.style.display = (!query || name.includes(query)) ? 'flex' : 'none';
  });
}
</script>
