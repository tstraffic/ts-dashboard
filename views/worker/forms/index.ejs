<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900">Forms & Checklists</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= recentCount %> submitted this week</p>
  </div>

  <!-- Today's Shift Requirements -->
  <% if (typeof shiftStatus !== 'undefined' && shiftStatus.length > 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-4 pt-4 pb-2">
        <h2 class="text-xs font-bold text-brand-600 uppercase tracking-wider">Today's Requirements</h2>
      </div>

      <% shiftStatus.forEach(s => { %>
        <div class="px-4 py-3 border-t border-gray-100">
          <div class="flex items-center justify-between mb-2">
            <p class="text-sm font-semibold text-gray-900"><%= s.client %></p>
            <span class="text-[10px] font-medium text-gray-400"><%= s.job_number %></span>
          </div>
          <div class="flex items-center gap-2 flex-wrap">
            <!-- Pre-Start -->
            <% if (s.hasPrestart) { %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                Pre-Start
              </span>
            <% } else { %>
              <a href="/w/forms/prestart?allocation_id=<%= s.id %>" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-amber-50 text-amber-700 ring-1 ring-amber-500/20 active:bg-amber-100">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                Pre-Start
              </a>
            <% } %>

            <!-- Take 5 -->
            <% if (s.hasTake5) { %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                Take 5
              </span>
            <% } else { %>
              <a href="/w/forms/take5?allocation_id=<%= s.id %>" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-amber-50 text-amber-700 ring-1 ring-amber-500/20 active:bg-amber-100">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                Take 5
              </a>
            <% } %>

            <!-- Docket -->
            <% if (s.hasDocket) { %>
              <span class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-500/20">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                Docket
              </span>
            <% } else { %>
              <a href="/w/dockets/sign/<%= s.id %>" class="inline-flex items-center gap-1 px-2 py-1 rounded-lg text-[10px] font-semibold bg-gray-100 text-gray-600 ring-1 ring-gray-300/50 active:bg-gray-200">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                Docket
              </a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <!-- Safety Checklists -->
  <div>
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Safety Checklists</h2>
    <div class="space-y-2">
      <a href="/w/forms/prestart" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
        <div class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-gray-900">Pre-Start Checklist</p>
          <p class="text-xs text-gray-500">Daily safety checks before starting work</p>
        </div>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a href="/w/forms/take5" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
        <div class="w-10 h-10 rounded-lg bg-brand-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-gray-900">Take 5 Safety Check</p>
          <p class="text-xs text-gray-500">Stop, look, assess, control, proceed</p>
        </div>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a href="/w/forms/equipment" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
        <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-gray-900">Equipment Check</p>
          <p class="text-xs text-gray-500">Vehicle & equipment condition checks</p>
        </div>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Dockets -->
  <div>
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Dockets</h2>
    <a href="/w/dockets" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
      <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
      </div>
      <div class="flex-1">
        <p class="text-sm font-semibold text-gray-900">Daily Dockets</p>
        <p class="text-xs text-gray-500">Sign off with time entries & signatures</p>
      </div>
      <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- Reporting -->
  <div>
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Reporting</h2>
    <div class="space-y-2">
      <a href="/w/forms/incident" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
        <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-gray-900">Incident Report</p>
          <p class="text-xs text-gray-500">Report workplace incidents</p>
        </div>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>

      <a href="/w/forms/hazard" class="flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 active:bg-gray-50 transition">
        <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
        </div>
        <div class="flex-1">
          <p class="text-sm font-semibold text-gray-900">Hazard Report</p>
          <p class="text-xs text-gray-500">Report workplace hazards</p>
        </div>
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- History Link -->
  <a href="/w/forms/history" class="flex items-center justify-center gap-2 text-sm font-medium text-brand-600 py-3">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    View Form History
  </a>
</div>
