<div class="space-y-5">
  <div>
    <h1 class="text-xl font-bold text-gray-900">Safety Forms</h1>
    <p class="text-sm text-gray-500 mt-0.5"><%= recentCount %> submitted this week</p>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <a href="/w/forms/prestart" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-emerald-50 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">Pre-Start</p>
      <p class="text-[10px] text-gray-500">Daily checklist</p>
    </a>
    <a href="/w/forms/take5" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-brand-50 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">Take 5</p>
      <p class="text-[10px] text-gray-500">Risk assessment</p>
    </a>
    <a href="/w/forms/incident" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">Incident</p>
      <p class="text-[10px] text-gray-500">Report incident</p>
    </a>
    <a href="/w/forms/hazard" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">Hazard</p>
      <p class="text-[10px] text-gray-500">Report hazard</p>
    </a>
    <a href="/w/forms/equipment" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">Equipment</p>
      <p class="text-[10px] text-gray-500">Equipment check</p>
    </a>
    <a href="/w/forms/history" class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 text-center active:bg-gray-50 transition">
      <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-2">
        <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-gray-900">History</p>
      <p class="text-[10px] text-gray-500">Past submissions</p>
    </a>
  </div>
</div>
