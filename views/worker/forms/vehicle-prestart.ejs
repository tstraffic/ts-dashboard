<meta name="color-scheme" content="light only">

<%
  // Vehicle Pre-Start now renders fully from the published revision of
  // the system_key='vehicle_prestart' template — every element comes
  // from /checklists/<id> on the admin side. The hardcoded vehicle
  // dropdown / ODO / inspection / photos / notes / signature blocks
  // are all admin-editable elements now (mig 153 seeded them).
%>

<style>
  .vps-wrap   { padding: 0.5rem; padding-bottom: 6rem; }
  .vps-back   { display: inline-flex; align-items: center; gap: 4px; color: #00D2BE; font-size: 0.85rem; font-weight: 600; }
  .vps-h1     { font-size: 1.4rem; font-weight: 800; color: #fff; margin-top: 0.25rem; letter-spacing: -0.01em; }
  .vps-sub    { font-size: 0.78rem; color: rgba(255,255,255,0.55); margin-top: 4px; }

  .vps-summary {
    background: linear-gradient(155deg, rgba(43,127,255,0.12), rgba(0,210,190,0.05) 60%, rgba(10,22,40,0.6));
    border: 1px solid rgba(96,165,250,0.25);
    border-radius: 14px;
    padding: 12px 14px;
    margin-top: 12px;
  }
  .vps-summary-client { font-size: 1rem; font-weight: 700; color: #fff; line-height: 1.2; }
  .vps-summary-meta   { font-size: 0.72rem; color: rgba(255,255,255,0.55); margin-top: 2px; }

  .vps-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin-top: 12px; }
  .vps-section-title { font-size: 0.65rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: #00D2BE; margin-bottom: 10px; }

  .vps-q { padding: 10px 0; border-top: 1px solid rgba(255,255,255,0.05); }
  .vps-q:first-child { border-top: none; padding-top: 0; }
  .vps-q-text { font-size: 0.88rem; color: #fff; font-weight: 600; line-height: 1.3; }
  .vps-q-required { color: #FCA5A5; margin-left: 4px; }
  .vps-q-row { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; align-items: center; }

  .vps-radio { position: relative; }
  .vps-radio input { position: absolute; opacity: 0; }
  .vps-radio span {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 7px 14px; border-radius: 999px;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.65); font-size: 0.78rem; font-weight: 600;
    cursor: pointer; transition: all 0.12s;
  }
  .vps-radio input:checked + span      { background: #10B981; border-color: #10B981; color: #fff; }
  .vps-radio input:checked + span.fail { background: #EF4444; border-color: #EF4444; color: #fff; }
  .vps-radio input:checked + span.na   { background: #6B7280; border-color: #6B7280; color: #fff; }

  .vps-input, .vps-textarea {
    width: 100%; background: #fff; color: #0F172A;
    border: 1px solid rgba(255,255,255,0.18); border-radius: 8px;
    padding: 9px 12px; font-size: 0.9rem; color-scheme: light;
  }
  .vps-input:focus, .vps-textarea:focus { outline: none; border-color: #2B7FFF; box-shadow: 0 0 0 3px rgba(43,127,255,0.18); }
  .vps-textarea { resize: vertical; min-height: 60px; }

  .vps-inline-row { padding: 8px 0; border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .vps-inline-row:first-child { border-top: none; padding-top: 0; }
  .vps-inline-row-q { font-size: 0.85rem; color: rgba(255,255,255,0.92); flex: 1; min-width: 0; }

  .vps-sig-pad { border: 2px dashed rgba(255,255,255,0.18); border-radius: 12px; background: #F8FAFC; height: 160px; }
  .vps-sig-pad.signed { border-style: solid; border-color: rgba(16,185,129,0.45); background: #F0FDF4; }
  .vps-sig-pad canvas { width: 100%; height: 100%; touch-action: none; display: block; }
  .vps-sig-clear { font-size: 0.7rem; font-weight: 600; color: rgba(255,255,255,0.65); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); padding: 4px 10px; border-radius: 6px; }

  .vps-display-info {
    background: rgba(99,102,241,0.10); border-left: 3px solid #6366F1;
    color: rgba(255,255,255,0.85); padding: 10px 12px; border-radius: 0 10px 10px 0;
    margin-top: 8px; font-size: 0.78rem; line-height: 1.45;
  }
  .vps-display-info p { margin: 0; white-space: pre-line; }
  .vps-display-info p + p { margin-top: 6px; }

  .vps-submit-bar { position: sticky; bottom: 0; padding: 16px 0 calc(16px + env(safe-area-inset-bottom, 0px)); background: linear-gradient(180deg, transparent, rgba(10,22,40,0.95) 35%); margin-top: 16px; }
  .vps-submit { width: 100%; padding: 16px; border-radius: 14px; font-size: 1rem; font-weight: 700;
                color: #fff; background: linear-gradient(135deg, #2B7FFF, #1D6AE5);
                border: none; box-shadow: 0 8px 24px rgba(29,106,229,0.45); cursor: pointer;
                display: flex; align-items: center; justify-content: center; gap: 8px; min-height: 56px; }

  .vps-unit { font-size: 0.85rem; font-weight: 600; color: rgba(255,255,255,0.8); padding: 0 10px; }
</style>

<div class="vps-wrap">
  <a href="<%= allocation ? ('/w/jobs/' + allocation.id + '?tab=forms') : '/w/forms' %>" class="vps-back">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>

  <h1 class="vps-h1">1. T&S Vehicle Pre-Start</h1>
  <p class="vps-sub">Tag out and notify a supervisor if any safety-critical item fails.</p>

  <% if (allocation) { %>
    <div class="vps-summary">
      <p class="vps-summary-client"><%= allocation.client || allocation.job_name || allocation.job_number %></p>
      <p class="vps-summary-meta"><%= allocation.job_number %><% if (allocation.site_address || allocation.suburb) { %> · <%= allocation.site_address || allocation.suburb %><% } %></p>
    </div>
  <% } %>

  <form method="POST" action="/w/forms/vehicle-prestart" enctype="multipart/form-data" id="vps-form">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <% if (allocation) { %><input type="hidden" name="allocation_id" value="<%= allocation.id %>"><% } %>

    <% sections.forEach(function (sec) {
      // Inspection section (the 22 OK/Not OK/N/A rows): render as a
      // tight inline-row layout so it reads like the paper docket.
      // Other sections render question-by-question.
      var allOkNotok = sec.items.length > 0 && sec.items.every(function (it) {
        return it.response_type === 'ok_notok_na' || it.response_type === 'heading' || it.response_type === 'information';
      });
    %>
      <div class="vps-card">
        <% if (sec.name) { %><p class="vps-section-title"><%= sec.name %></p><% } %>
        <% sec.items.forEach(function (it, idx) {
          var rt = it.response_type;
          if (rt === 'checklist') { rt = (it.options && it.options.scheme) || 'ok_notok_na'; }
        %>
          <% if (rt === 'heading') { %>
            <% if (idx > 0) { %><div style="height:6px;"></div><% } %>
            <h3 style="font-size:0.95rem;font-weight:800;color:#fff;margin-top:6px;"><%= it.question %></h3>
          <% } else if (rt === 'information') { %>
            <div class="vps-display-info">
              <% if (it.question) { %><p style="font-weight:600;color:#fff;"><%= it.question %></p><% } %>
              <% if (it.options && it.options.body) { %><p><%= it.options.body %></p><% } %>
            </div>
          <% } else if (rt === 'hyperlink') { %>
            <a href="<%= (it.options && it.options.url) || '#' %>" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:6px;font-size:0.85rem;font-weight:600;color:#60A5FA;text-decoration:underline;margin-top:8px;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              <%= it.question || (it.options && it.options.url) || 'Open link' %>
            </a>
          <% } else if (rt === 'media') { %>
            <% if (it.question) { %><p style="font-size:0.78rem;color:rgba(255,255,255,0.65);margin-top:8px;margin-bottom:6px;"><%= it.question %></p><% } %>
            <% if (it.options && it.options.url) { %>
              <img src="<%= it.options.url %>" alt="<%= it.options.alt || it.question || '' %>" style="max-width:100%;border-radius:10px;border:1px solid rgba(255,255,255,0.10);">
            <% } %>
          <% } else if (rt === 'ok_notok_na' && allOkNotok) { %>
            <!-- Inline tight row inside an inspection-style section. -->
            <div class="vps-inline-row">
              <span class="vps-inline-row-q"><%= it.question %><% if (it.required) { %><span class="vps-q-required">*</span><% } %></span>
              <div style="display:flex;gap:5px;flex-shrink:0;">
                <% [['ok','OK',''],['not_ok','Not OK','fail'],['na','N/A','na']].forEach(function (v) { %>
                  <label class="vps-radio">
                    <input type="radio" name="answer_<%= it.item_key %>" value="<%= v[0] %>" <%= it.required ? 'required' : '' %> <%= v[0] === 'ok' ? 'checked' : '' %>>
                    <span class="<%= v[2] %>" style="padding:5px 10px;font-size:0.7rem;"><%= v[1] %></span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } else { %>
            <div class="vps-q">
              <p class="vps-q-text"><%= it.question %><% if (it.required) { %><span class="vps-q-required">*</span><% } %></p>
              <div class="vps-q-row">
                <% if (rt === 'ok_notok_na') { %>
                  <% [['ok','OK',''],['not_ok','Not OK','fail'],['na','N/A','na']].forEach(function (v) { %>
                    <label class="vps-radio">
                      <input type="radio" name="answer_<%= it.item_key %>" value="<%= v[0] %>" <%= it.required ? 'required' : '' %>>
                      <span class="<%= v[2] %>"><%= v[1] %></span>
                    </label>
                  <% }) %>
                <% } else if (rt === 'yes_no_na') { %>
                  <% [['yes','Yes',''],['no','No','fail'],['na','N/A','na']].forEach(function (v) { %>
                    <label class="vps-radio">
                      <input type="radio" name="answer_<%= it.item_key %>" value="<%= v[0] %>" <%= it.required ? 'required' : '' %>>
                      <span class="<%= v[2] %>"><%= v[1] %></span>
                    </label>
                  <% }) %>
                <% } else if (rt === 'pass_fail') { %>
                  <% [['pass','Pass',''],['fail','Fail','fail']].forEach(function (v) { %>
                    <label class="vps-radio">
                      <input type="radio" name="answer_<%= it.item_key %>" value="<%= v[0] %>" <%= it.required ? 'required' : '' %>>
                      <span class="<%= v[2] %>"><%= v[1] %></span>
                    </label>
                  <% }) %>
                <% } else if (rt === 'number') { %>
                  <input type="number" name="answer_<%= it.item_key %>" class="vps-input" step="any" <%= it.required ? 'required' : '' %>>
                <% } else if (rt === 'measurement') { %>
                  <div style="display:flex;align-items:center;gap:8px;width:100%;">
                    <input type="number" name="answer_<%= it.item_key %>" class="vps-input" step="any" style="flex:1;" <%= it.required ? 'required' : '' %>>
                    <% if (it.options && it.options.unit) { %><span class="vps-unit"><%= it.options.unit %></span><% } %>
                  </div>
                <% } else if (rt === 'datetime') { %>
                  <input type="datetime-local" name="answer_<%= it.item_key %>" class="vps-input" <%= it.required ? 'required' : '' %>>
                <% } else if (rt === 'multiple_choice') { %>
                  <% var mcOpts = (it.options && Array.isArray(it.options.options)) ? it.options.options : []; var mcMulti = !!(it.options && it.options.multi); %>
                  <div style="display:flex;flex-direction:column;gap:6px;width:100%;">
                    <% mcOpts.forEach(function (opt, oi) { %>
                      <label class="vps-radio" style="justify-content:flex-start;">
                        <input type="<%= mcMulti ? 'checkbox' : 'radio' %>" name="answer_<%= it.item_key %><%= mcMulti ? '[]' : '' %>" value="<%= opt %>" <%= (it.required && !mcMulti && oi === 0) ? 'required' : '' %>>
                        <span><%= opt %></span>
                      </label>
                    <% }) %>
                  </div>
                <% } else if (rt === 'media_upload') { %>
                  <input type="file" name="answer_<%= it.item_key %>" accept="image/*" multiple class="vps-input">
                <% } else if (rt === 'signature') { %>
                  <div class="vps-sig-pad" id="sig-<%= it.item_key %>"><canvas data-sigkey="<%= it.item_key %>"></canvas></div>
                  <input type="hidden" name="answer_<%= it.item_key %>" id="sigval-<%= it.item_key %>">
                  <div style="margin-top:6px;display:flex;justify-content:flex-end;width:100%;">
                    <button type="button" class="vps-sig-clear" onclick="vpsClearSig('<%= it.item_key %>')">Clear</button>
                  </div>
                <% } else if (rt === 'textarea') { %>
                  <textarea name="answer_<%= it.item_key %>" class="vps-textarea" rows="3" <%= it.required ? 'required' : '' %>></textarea>
                <% } else { %>
                  <% if (it.item_key === 'vehicle' && Array.isArray(recentVehicles) && recentVehicles.length > 0) { %>
                    <input type="text" name="answer_<%= it.item_key %>" list="vps-vehicle-options" class="vps-input"
                           placeholder="e.g. TSTC004" value="<%= recentVehicles[0] || '' %>" <%= it.required ? 'required' : '' %>>
                    <datalist id="vps-vehicle-options">
                      <% recentVehicles.forEach(function (v) { %><option value="<%= v %>"><% }) %>
                    </datalist>
                  <% } else { %>
                    <input type="text" name="answer_<%= it.item_key %>" class="vps-input" <%= it.required ? 'required' : '' %>>
                  <% } %>
                <% } %>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
    <% }) %>

    <div class="vps-submit-bar">
      <button type="submit" class="vps-submit">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Submit Pre-Start
      </button>
    </div>
  </form>
</div>

<script>
(function () {
  // Wire any signature pads in the form. Each pad has a hidden input
  // named answer_<item_key>; we stamp the dataURL into it on pen-up.
  var pads = {};
  function setupSig(canvas, key) {
    var ctx = canvas.getContext('2d');
    var pad = document.getElementById('sig-' + key);
    var hidden = document.getElementById('sigval-' + key);
    var drawing = false, drawn = false;
    function resize() {
      var rect = canvas.parentElement.getBoundingClientRect();
      var data = drawn ? canvas.toDataURL() : null;
      canvas.width = rect.width; canvas.height = rect.height;
      ctx.strokeStyle = '#0F172A'; ctx.lineWidth = 2.4; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
      if (data && drawn) { var img = new Image(); img.onload = function () { ctx.drawImage(img, 0, 0); }; img.src = data; }
    }
    resize(); window.addEventListener('resize', resize);
    function pos(e) { var r = canvas.getBoundingClientRect(); return { x: e.clientX - r.left, y: e.clientY - r.top }; }
    canvas.addEventListener('pointerdown', function (e) { drawing = true; drawn = true; pad.classList.add('signed'); var p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); e.preventDefault(); });
    canvas.addEventListener('pointermove', function (e) { if (!drawing) return; var p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); e.preventDefault(); });
    canvas.addEventListener('pointerup',    function () { drawing = false; if (drawn && hidden) hidden.value = canvas.toDataURL('image/png'); });
    canvas.addEventListener('pointerleave', function () { drawing = false; });
    return { clear: function () { ctx.clearRect(0,0,canvas.width,canvas.height); drawn = false; pad.classList.remove('signed'); if (hidden) hidden.value = ''; } };
  }
  document.querySelectorAll('canvas[data-sigkey]').forEach(function (c) { pads[c.dataset.sigkey] = setupSig(c, c.dataset.sigkey); });
  window.vpsClearSig = function (key) { if (pads[key]) pads[key].clear(); };
})();
</script>
