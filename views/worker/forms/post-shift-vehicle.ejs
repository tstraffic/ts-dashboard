<div class="space-y-4 pb-24">
  <a href="<%= allocation ? ('/w/jobs/' + allocation.id + '?tab=forms') : '/w/forms' %>" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>

  <div>
    <h1 class="text-xl font-bold text-gray-900">5. Post-Shift Vehicle Checklist</h1>
    <p class="text-xs text-gray-500 mt-1">Complete at the end of your shift before leaving the vehicle.</p>
  </div>

  <% if (allocation) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-sm font-bold text-gray-900"><%= allocation.client %></p>
      <p class="text-xs text-gray-500"><%= allocation.job_number %> &middot; <%= allocation.site_address || allocation.suburb || '' %></p>
    </div>
  <% } %>

  <form method="POST" action="/w/forms/post-shift-vehicle" enctype="multipart/form-data" id="post-shift-form">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <% if (allocation) { %><input type="hidden" name="allocation_id" value="<%= allocation.id %>"><% } %>

    <div class="space-y-4">
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Vehicle</label>
          <input type="text" name="vehicle" required value="<%= suggestedVehicle %>" placeholder="e.g. TSTC004" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Driver Name</label>
          <input type="text" name="driver_name" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Total kms on the vehicle</label>
          <input type="number" name="odo_end_km" min="0" step="1" inputmode="numeric" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
      </div>

      <!-- Photo blocks -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Fuel gauge photo</label>
        <p class="text-[11px] text-gray-500">One photo of the fuel gauge at the end of the shift.</p>
        <input type="file" name="fuel_gauge_photos" accept="image/*" capture="environment" class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Vehicle interior photos</label>
        <p class="text-[11px] text-gray-500">Minimum 3 photos.</p>
        <input type="file" name="interior_photos" accept="image/*" capture="environment" multiple class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Equipment cage photos</label>
        <p class="text-[11px] text-gray-500">Minimum 3 photos showing the cage from all 3 angles.</p>
        <input type="file" name="equipment_photos" accept="image/*" capture="environment" multiple class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Arrow board photos (3 angles)</label>
        <p class="text-[11px] text-gray-500">Actuator (driver side), front-on, passenger side.</p>
        <input type="file" name="arrow_board_photos" accept="image/*" capture="environment" multiple class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <!-- Free-text follow-ups -->
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Signs left behind?</label>
        <textarea name="signs_left_behind" rows="2" placeholder="List any signs left, or write 'No'." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Equipment damaged or lost?</label>
        <textarea name="equipment_damaged_lost" rows="2" placeholder="Describe any damage / loss, or write 'No'." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Vehicle issues?</label>
        <p class="text-[11px] text-gray-500 mb-1">e.g. lights not working, arrow board fault, low tyre pressure.</p>
        <textarea name="vehicle_issues" rows="2" placeholder="Describe any issues, or write 'No'." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
      </div>

      <button type="submit" class="w-full py-3.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700" style="min-height:48px;">Submit Post-Shift Checklist</button>
    </div>
  </form>
</div>
