<div class="space-y-5">
  <a href="/w/forms" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>
  <h1 class="text-xl font-bold text-gray-900">Pre-Start Checklist</h1>

  <form method="POST" action="/w/forms/prestart" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <input type="hidden" name="latitude" id="lat">
    <input type="hidden" name="longitude" id="lng">

    <% if (todaysShifts.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Shift</label>
        <select name="allocation_id" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm">
          <% todaysShifts.forEach(s => { %><option value="<%= s.id %>"><%= s.job_number %> — <%= s.client %></option><% }) %>
        </select>
      </div>
    <% } %>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Safety Checks</h3>
      <% const checks = ['PPE complete and serviceable', 'Work area inspected and safe', 'Traffic management plan reviewed', 'Signage and devices in place', 'Communications equipment working', 'Vehicle/equipment pre-checked', 'Weather conditions assessed', 'Fatigue status acceptable', 'Emergency procedures known', 'Site-specific hazards identified']; %>
      <% checks.forEach((check, i) => { %>
        <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
          <span class="text-sm text-gray-700 flex-1 pr-3"><%= check %></span>
          <div class="flex items-center gap-2 shrink-0">
            <label class="flex items-center gap-1">
              <input type="radio" name="check_<%= i %>" value="yes" required class="text-emerald-600 focus:ring-emerald-500">
              <span class="text-xs text-emerald-700">Yes</span>
            </label>
            <label class="flex items-center gap-1">
              <input type="radio" name="check_<%= i %>" value="no" class="text-red-600 focus:ring-red-500">
              <span class="text-xs text-red-700">No</span>
            </label>
            <label class="flex items-center gap-1">
              <input type="radio" name="check_<%= i %>" value="na" class="text-gray-600 focus:ring-gray-500">
              <span class="text-xs text-gray-500">N/A</span>
            </label>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Comments (optional)</label>
      <textarea name="comments" rows="2" placeholder="Any issues or notes..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500"></textarea>
    </div>

    <button type="submit" class="w-full py-3 bg-emerald-600 text-white rounded-xl font-semibold text-sm hover:bg-emerald-700 transition">Submit Pre-Start</button>
  </form>
</div>
<script>
if (navigator.geolocation) {
  navigator.geolocation.getCurrentPosition(p => {
    document.getElementById('lat').value = p.coords.latitude;
    document.getElementById('lng').value = p.coords.longitude;
  }, () => {}, { enableHighAccuracy: true, timeout: 10000 });
}
</script>
