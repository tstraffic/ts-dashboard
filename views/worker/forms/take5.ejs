<div class="space-y-5">
  <a href="/w/forms" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>
  <h1 class="text-xl font-bold text-gray-900">Take 5 Safety Check</h1>

  <form method="POST" action="/w/forms/take5" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <% if (todaysShifts.length > 0) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Shift</label>
        <select name="allocation_id" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm">
          <% todaysShifts.forEach(s => { %><option value="<%= s.id %>"><%= s.job_number %> — <%= s.client %></option><% }) %>
        </select>
      </div>
    <% } %>

    <% const steps = [
      { num: 1, title: 'Stop', desc: 'Stop and think about the task ahead', q: 'Have you stopped and thought about the task?' },
      { num: 2, title: 'Look', desc: 'Look for hazards in and around the work area', q: 'Identify hazards present' },
      { num: 3, title: 'Assess', desc: 'Assess the risk level of identified hazards', q: 'What is the risk level?' },
      { num: 4, title: 'Control', desc: 'Put controls in place to manage risks', q: 'What controls are in place?' },
      { num: 5, title: 'Proceed', desc: 'Is it safe to proceed with the task?', q: 'Safe to proceed?' },
    ]; %>

    <% steps.forEach(step => { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <div class="flex items-center gap-2 mb-2">
          <span class="w-7 h-7 rounded-full bg-brand-600 text-white flex items-center justify-center text-xs font-bold"><%= step.num %></span>
          <h3 class="text-sm font-bold text-gray-900"><%= step.title %></h3>
        </div>
        <p class="text-xs text-gray-500 mb-2"><%= step.desc %></p>
        <textarea name="step_<%= step.num %>" rows="2" placeholder="<%= step.q %>" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500"></textarea>
      </div>
    <% }) %>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <label class="flex items-center gap-2">
        <input type="checkbox" name="safe_to_proceed" value="yes" required class="rounded text-brand-600 focus:ring-brand-500">
        <span class="text-sm font-medium text-gray-900">I confirm it is safe to proceed</span>
      </label>
    </div>

    <button type="submit" class="w-full py-3 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 transition">Submit Take 5</button>
  </form>
</div>
