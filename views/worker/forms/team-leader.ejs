<div class="space-y-4 pb-24">
  <a href="<%= allocation ? ('/w/jobs/' + allocation.id + '?tab=forms') : '/w/forms' %>" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>

  <div>
    <h1 class="text-xl font-bold text-gray-900">4. Team Leader Checklist</h1>
    <p class="text-xs text-gray-500 mt-1">Complete once your crew is on site and set up.</p>
  </div>

  <% if (!isManager) { %>
    <div class="bg-amber-50 border border-amber-200 text-amber-900 rounded-xl p-3 text-xs">
      <strong>Heads up —</strong> this form is normally completed by the Team Leader. If you're acting as TL today, continue. Otherwise ask your TL to fill it in.
    </div>
  <% } %>

  <% if (allocation) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <p class="text-sm font-bold text-gray-900"><%= allocation.client %></p>
      <p class="text-xs text-gray-500"><%= allocation.job_number %> &middot; <%= allocation.site_address || allocation.suburb || '' %></p>
    </div>
  <% } %>

  <form method="POST" action="/w/forms/team-leader" enctype="multipart/form-data" id="team-leader-form">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <% if (allocation) { %><input type="hidden" name="allocation_id" value="<%= allocation.id %>"><% } %>

    <div class="space-y-4">
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Team Leader's Name</label>
          <input type="text" name="team_leader_name" required class="w-full bg-white border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Are all workers present and on time?</label>
          <div class="grid grid-cols-2 gap-2 text-sm font-semibold mb-2">
            <label class="cursor-pointer"><input type="radio" name="workers_present" value="yes" class="peer sr-only" required><span class="block text-center px-3 py-2.5 rounded-lg border border-gray-300 text-gray-600 peer-checked:bg-brand-600 peer-checked:text-white peer-checked:border-brand-600">Yes</span></label>
            <label class="cursor-pointer"><input type="radio" name="workers_present" value="no" class="peer sr-only"><span class="block text-center px-3 py-2.5 rounded-lg border border-gray-300 text-gray-600 peer-checked:bg-red-600 peer-checked:text-white peer-checked:border-red-600">No</span></label>
          </div>
          <textarea name="late_notes" rows="2" placeholder="If anyone was late: who, why, was supervisor notified?" class="w-full bg-white border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 resize-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Worker photos (full PPE + radio)</label>
        <p class="text-[11px] text-gray-500">One photo per worker — show full PPE clearly.</p>
        <input type="file" name="team_photos" accept="image/*" multiple class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
        <label class="block text-xs font-semibold text-gray-500 uppercase">PPE check (every worker)</label>
        <div class="divide-y divide-gray-100">
          <% ppeItems.forEach(function (it) { %>
            <div class="py-2 flex items-center justify-between gap-3">
              <span class="text-sm text-gray-800 flex-1"><%= it.label %></span>
              <div class="flex gap-1 text-xs font-semibold">
                <label class="cursor-pointer"><input type="radio" name="ppe_<%= it.key %>" value="yes" class="peer sr-only" checked><span class="px-3 py-1.5 rounded-md border border-gray-300 text-gray-600 peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600">Yes</span></label>
                <label class="cursor-pointer"><input type="radio" name="ppe_<%= it.key %>" value="no" class="peer sr-only"><span class="px-3 py-1.5 rounded-md border border-gray-300 text-gray-600 peer-checked:bg-red-600 peer-checked:text-white peer-checked:border-red-600">No</span></label>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Setup correct (TCP &amp; ROL implemented)?</label>
        <div class="grid grid-cols-2 gap-2 text-sm font-semibold">
          <label class="cursor-pointer"><input type="radio" name="setup_correct" value="yes" class="peer sr-only" required><span class="block text-center px-3 py-2.5 rounded-lg border border-gray-300 text-gray-600 peer-checked:bg-brand-600 peer-checked:text-white peer-checked:border-brand-600">Yes</span></label>
          <label class="cursor-pointer"><input type="radio" name="setup_correct" value="no" class="peer sr-only"><span class="block text-center px-3 py-2.5 rounded-lg border border-gray-300 text-gray-600 peer-checked:bg-red-600 peer-checked:text-white peer-checked:border-red-600">No</span></label>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-2">
        <label class="block text-xs font-semibold text-gray-500 uppercase">Setup photos</label>
        <p class="text-[11px] text-gray-500">Minimum 5 photos showing the full setup.</p>
        <input type="file" name="setup_photos" accept="image/*" multiple class="block w-full text-xs text-gray-700 file:mr-3 file:py-2 file:px-3 file:rounded-md file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold">
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Notes (optional)</label>
        <textarea name="notes" rows="2" class="w-full bg-white border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-900 placeholder-gray-400 resize-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
      </div>

      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
        <div class="flex items-center justify-between mb-2">
          <label class="text-xs font-semibold text-gray-500 uppercase">Auditor's Signature</label>
          <button type="button" onclick="clearSig()" class="text-xs text-gray-400 hover:text-gray-600 bg-gray-100 px-2 py-1 rounded">Clear</button>
        </div>
        <div class="border-2 border-dashed border-gray-300 rounded-lg bg-gray-50 relative" style="height:160px;">
          <canvas id="sig-canvas" class="w-full h-full rounded-lg" style="touch-action: none;"></canvas>
        </div>
        <input type="hidden" name="signature_data" id="sig-data">
      </div>

      <button type="submit" onclick="captureSig()" class="w-full py-3.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700" style="min-height:48px;">Submit Team Leader Checklist</button>
    </div>
  </form>
</div>

<script>
(function () {
  var canvas = document.getElementById('sig-canvas');
  var ctx = canvas.getContext('2d');
  var drawing = false, hasDrawn = false;
  function resize() { var rect = canvas.parentElement.getBoundingClientRect(); var data = hasDrawn ? canvas.toDataURL() : null; canvas.width = rect.width; canvas.height = rect.height; ctx.strokeStyle = '#1D6AE5'; ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; if (data && hasDrawn) { var img = new Image(); img.onload = function () { ctx.drawImage(img, 0, 0); }; img.src = data; } }
  resize(); window.addEventListener('resize', resize);
  canvas.addEventListener('pointerdown', function (e) { drawing = true; hasDrawn = true; ctx.beginPath(); ctx.moveTo(e.offsetX, e.offsetY); e.preventDefault(); });
  canvas.addEventListener('pointermove', function (e) { if (drawing) { ctx.lineTo(e.offsetX, e.offsetY); ctx.stroke(); e.preventDefault(); } });
  canvas.addEventListener('pointerup', function () { drawing = false; });
  canvas.addEventListener('pointerleave', function () { drawing = false; });
  window.clearSig = function () { ctx.clearRect(0, 0, canvas.width, canvas.height); hasDrawn = false; };
  window.captureSig = function () { document.getElementById('sig-data').value = hasDrawn ? canvas.toDataURL('image/png') : ''; };
})();
</script>
