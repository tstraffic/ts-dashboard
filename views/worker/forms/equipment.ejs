<div class="space-y-5">
  <a href="/w/forms" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>
  <h1 class="text-xl font-bold text-gray-900">Equipment Check</h1>

  <form method="POST" action="/w/forms/equipment" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Equipment Type</label>
        <select name="equipment_type" required class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm">
          <option value="vehicle">Vehicle</option>
          <option value="truck_mounted_attenuator">TMA</option>
          <option value="variable_message_sign">VMS</option>
          <option value="arrow_board">Arrow Board</option>
          <option value="traffic_lights">Traffic Lights</option>
          <option value="signs_devices">Signs & Devices</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Equipment ID / Rego</label>
        <input type="text" name="equipment_id" placeholder="ID, rego, or serial number" class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-500">
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-3">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Condition Checks</h3>
      <% const checks = ['General condition acceptable', 'Lights and indicators working', 'Safety features operational', 'No visible damage or defects', 'Fluid levels adequate', 'Tyres/wheels in good condition', 'Clean and serviceable']; %>
      <% checks.forEach((check, i) => { %>
        <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
          <span class="text-sm text-gray-700 flex-1 pr-3"><%= check %></span>
          <div class="flex items-center gap-2 shrink-0">
            <label class="flex items-center gap-1">
              <input type="radio" name="equip_check_<%= i %>" value="pass" required class="text-emerald-600">
              <span class="text-xs text-emerald-700">Pass</span>
            </label>
            <label class="flex items-center gap-1">
              <input type="radio" name="equip_check_<%= i %>" value="fail" class="text-red-600">
              <span class="text-xs text-red-700">Fail</span>
            </label>
            <label class="flex items-center gap-1">
              <input type="radio" name="equip_check_<%= i %>" value="na" class="text-gray-600">
              <span class="text-xs text-gray-500">N/A</span>
            </label>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
      <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Defects / Notes</label>
      <textarea name="defects_notes" rows="2" placeholder="Note any defects or issues..." class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm resize-none focus:ring-2 focus:ring-brand-500"></textarea>
    </div>

    <button type="submit" class="w-full py-3 bg-blue-600 text-white rounded-xl font-semibold text-sm hover:bg-blue-700 transition">Submit Equipment Check</button>
  </form>
</div>
