<div class="space-y-5">
  <a href="/w/forms" class="inline-flex items-center text-sm text-brand-600 font-medium">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back
  </a>
  <h1 class="text-xl font-bold text-gray-900">Form History</h1>

  <% if (forms.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 text-center">
      <p class="text-gray-500 text-sm">No forms submitted yet</p>
    </div>
  <% } else { %>
    <%
      // Friendly form-type labels match the worker portal launcher / admin
      // review page so a worker sees "1. Vehicle Pre-Start" here, not
      // "Vehicle prestart" from the raw slug.
      var TYPE_LABEL = {
        prestart: 'Pre-Start (legacy)', take5: 'Take 5 (legacy)',
        incident: 'Incident', hazard: 'Hazard', equipment: 'Equipment Check',
        vehicle_prestart: '1. Vehicle Pre-Start',
        risk_toolbox: '2. Risk Assessment & Toolbox',
        tc_prestart: '3. TC Prestart Declaration',
        team_leader: '4. Team Leader Checklist',
        post_shift_vehicle: '5. Post-Shift Vehicle Checklist',
      };
      var TYPE_COLOR = {
        prestart: 'bg-emerald-50 text-emerald-700',
        take5: 'bg-brand-50 text-brand-700',
        incident: 'bg-red-50 text-red-700',
        hazard: 'bg-amber-50 text-amber-700',
        equipment: 'bg-blue-50 text-blue-700',
        vehicle_prestart: 'bg-brand-50 text-brand-700',
        risk_toolbox: 'bg-brand-50 text-brand-700',
        tc_prestart: 'bg-brand-50 text-brand-700',
        team_leader: 'bg-brand-50 text-brand-700',
        post_shift_vehicle: 'bg-brand-50 text-brand-700',
      };
    %>
    <div class="bg-white border border-gray-200 rounded-xl shadow-sm divide-y divide-gray-100">
      <% forms.forEach(function (f) { %>
        <div class="p-3">
          <div class="flex items-center justify-between mb-1">
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold <%= TYPE_COLOR[f.form_type] || 'bg-gray-100 text-gray-600' %>">
              <%= TYPE_LABEL[f.form_type] || f.form_type %>
            </span>
            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold
              <%= f.status === 'reviewed' ? 'bg-emerald-50 text-emerald-700' : f.status === 'submitted' ? 'bg-brand-50 text-brand-700' : 'bg-gray-100 text-gray-500' %>">
              <%= f.status.charAt(0).toUpperCase() + f.status.slice(1) %>
            </span>
          </div>
          <% if (f.client || f.job_number) { %>
            <p class="text-sm text-gray-900"><%= f.client || f.job_number %></p>
          <% } %>
          <p class="text-xs text-gray-500"><%= new Date(f.created_at).toLocaleString('en-AU', { timeZone: 'Australia/Sydney', day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
          <a href="/w/forms/history/<%= f.id %>/pdf" target="_blank"
             class="mt-2 inline-flex items-center gap-1 text-[11px] font-semibold text-brand-700 active:text-brand-900">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM14 2v6h6"/></svg>
            Open as PDF
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
