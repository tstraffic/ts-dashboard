<%
  // Shared Job-Pack panel — used by both booking-detail.ejs (booking-only
  // shifts) and job-detail.ejs (job-bound shifts) so the worker sees the
  // same UI regardless of how they got to the shift detail page.
  // Required vs Recommended split. Company policy is that all five are
  // mandatory; only the Required pair is gated at docket sign so a stuck
  // worker (no vehicle, etc.) can't be permanently blocked.
  var JOB_PACK_REQUIRED = [
    { key: 'risk_toolbox', path: 'risk-assessment', label: '2. Risk Assessment & Toolbox', hint: 'Run with the crew on site' },
    { key: 'team_leader',  path: 'team-leader',     label: '4. Team Leader Checklist',     hint: 'Crew lead / acting TL' },
  ];
  var JOB_PACK_RECOMMENDED = [
    { key: 'vehicle_prestart',   path: 'vehicle-prestart',   label: '1. Vehicle Pre-Start',           hint: 'Before starting the vehicle' },
    { key: 'tc_prestart',        path: 'tc-prestart',        label: '3. TC Prestart Declaration',     hint: 'Per Traffic Controller' },
    { key: 'post_shift_vehicle', path: 'post-shift-vehicle', label: '5. Post-Shift Vehicle Checklist',hint: 'At end of shift' },
  ];
  function jpRow(done, tone) {
    var bg = done ? 'rgba(16,185,129,0.18)'
                  : (tone === 'required' ? 'rgba(245,158,11,0.16)' : 'rgba(255,255,255,0.06)');
    var fg = done ? '#34D399'
                  : (tone === 'required' ? '#FBBF24' : 'rgba(255,255,255,0.45)');
    return { bg: bg, fg: fg };
  }
%>

<div class="space-y-3">
  <% if (!allocation) { %>
    <div class="py-3 px-3 rounded-lg" style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.20);">
      <p class="text-xs" style="color:#FCA5A5;">Couldn't load checklists for this shift — try refreshing or let the office know.</p>
    </div>
  <% } else { %>
    <p class="text-[11px] italic" style="color:rgba(255,255,255,0.5);">Company policy: all five checklists are mandatory every shift.</p>

    <!-- Required group -->
    <div class="rounded-xl overflow-hidden" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
      <div class="px-3.5 pt-3 pb-1">
        <h3 class="text-[11px] font-bold uppercase tracking-wider" style="color:#00D2BE;">Required checklists</h3>
        <p class="text-[11px]" style="color:rgba(255,255,255,0.45);">Must be filed before docket sign</p>
      </div>
      <% JOB_PACK_REQUIRED.forEach(function (jp) { var done = formStatus[jp.key]; var c = jpRow(done, 'required'); %>
        <a href="/w/forms/<%= jp.path %>?allocationId=<%= allocation.id %>"
           class="flex items-center justify-between py-2.5 px-3.5" style="border-top:1px solid rgba(255,255,255,0.05);">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
                 style="background: <%= c.bg %>; color: <%= c.fg %>;">
              <% if (done) { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white truncate"><%= jp.label %></p>
              <% if (done) { %>
                <p class="text-[11px]" style="color:#34D399;">Submitted <%= new Date(done.submitted_at || done.created_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></p>
              <% } else { %>
                <p class="text-[11px]" style="color:#FBBF24;font-weight:600;">Required <span style="color:rgba(255,255,255,0.45);font-weight:400;">· <%= jp.hint %></span></p>
              <% } %>
            </div>
          </div>
          <svg class="w-4 h-4 shrink-0" style="color:rgba(255,255,255,0.4);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% }) %>
    </div>

    <!-- Recommended group -->
    <div class="rounded-xl overflow-hidden" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);">
      <div class="px-3.5 pt-3 pb-1">
        <h3 class="text-[11px] font-bold uppercase tracking-wider" style="color:#00D2BE;">Recommended checklists</h3>
        <p class="text-[11px]" style="color:rgba(255,255,255,0.45);">Mandatory by company policy — you'll get a warning before docket sign if missing</p>
      </div>
      <% JOB_PACK_RECOMMENDED.forEach(function (jp) { var done = formStatus[jp.key]; var c = jpRow(done, 'recommended'); %>
        <a href="/w/forms/<%= jp.path %>?allocationId=<%= allocation.id %>"
           class="flex items-center justify-between py-2.5 px-3.5" style="border-top:1px solid rgba(255,255,255,0.05);">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"
                 style="background: <%= c.bg %>; color: <%= c.fg %>;">
              <% if (done) { %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <span class="text-xs font-bold"><%= jp.label.charAt(0) %></span>
              <% } %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white truncate"><%= jp.label %></p>
              <% if (done) { %>
                <p class="text-[11px]" style="color:#34D399;">Submitted <%= new Date(done.submitted_at || done.created_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></p>
              <% } else { %>
                <p class="text-[11px]" style="color:rgba(255,255,255,0.5);"><%= jp.hint %></p>
              <% } %>
            </div>
          </div>
          <svg class="w-4 h-4 shrink-0" style="color:rgba(255,255,255,0.4);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% }) %>
    </div>

    <!-- Docket -->
    <a href="/w/dockets/sign/<%= allocation.id %>"
       class="flex items-center justify-between py-2.5 px-3 rounded-lg mt-2" style="background:linear-gradient(135deg, rgba(43,127,255,0.18), rgba(43,127,255,0.06));border:1px solid rgba(43,127,255,0.35);">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background:rgba(43,127,255,0.22);color:#60A5FA;">
          <% if (typeof docket !== 'undefined' && docket) { %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <% } else { %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><path d="M9 5a2 2 0 002 2h2a2 2 0 002-2"/><path d="M9 13h6M9 17h4"/></svg>
          <% } %>
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-white">Docket</p>
          <% if (typeof docket !== 'undefined' && docket) { %>
            <p class="text-[11px]" style="color:#60A5FA;">Signed · <%= docket.total_hours || 0 %> h · <%= new Date(docket.signed_at).toLocaleString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %></p>
          <% } else { %>
            <p class="text-[11px]" style="color:rgba(255,255,255,0.5);">Sign at end of shift — proof of hours.</p>
          <% } %>
        </div>
      </div>
      <svg class="w-4 h-4 shrink-0" style="color:rgba(255,255,255,0.4);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  <% } %>
</div>
