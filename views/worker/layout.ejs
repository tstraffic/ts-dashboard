<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="T&S Employee">
  <meta name="theme-color" content="#020817">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <link rel="manifest" href="/manifest.json">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>T&S Employee Portal</title>

  <!-- Inter Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/custom.css">
  <link rel="stylesheet" href="/css/worker.css">
  <link rel="stylesheet" href="/css/chat.css?v=3">
</head>
<body class="h-full font-sans antialiased dark-glass flex flex-col">

  <!-- Top Header -->
  <header class="px-4 py-3 flex items-center justify-between shrink-0 safe-area-top" style="background: rgba(10,22,40,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.08);">
    <div class="flex items-center gap-3">
      <img src="/images/logo-colour.jpg" alt="T&S" class="h-8 w-8 rounded-md">
      <span class="font-semibold text-sm text-white">T&S Employee Portal</span>
    </div>
    <div class="flex items-center gap-3">
      <% if (typeof worker !== 'undefined' && worker) { %>
        <div class="w-8 h-8 rounded-full bg-brand-600/30 border border-brand-500/30 flex items-center justify-center text-brand-300 text-xs font-bold">
          <%= worker.full_name.split(' ').map(n => n[0]).join('').slice(0,2) %>
        </div>
      <% } %>
    </div>
  </header>

  <!-- Flash Messages -->
  <div class="px-4">
    <% if (typeof flash_success !== 'undefined' && flash_success && flash_success.length > 0) { %>
      <% flash_success.forEach(msg => { %>
        <div class="mt-3 p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-xl text-emerald-300 text-sm flex items-center justify-between backdrop-blur-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span><%= msg %></span>
          </div>
          <button onclick="this.parentElement.remove()" class="text-emerald-400/60 hover:text-emerald-300 ml-2">&times;</button>
        </div>
      <% }) %>
    <% } %>
    <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
      <% flash_error.forEach(msg => { %>
        <div class="mt-3 p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-300 text-sm flex items-center justify-between backdrop-blur-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01"/></svg>
            <span><%= msg %></span>
          </div>
          <button onclick="this.parentElement.remove()" class="text-red-400/60 hover:text-red-300 ml-2">&times;</button>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Main Content -->
  <main class="flex-1 overflow-auto px-4 py-4 pb-20">
    <%- body %>
  </main>

  <!-- Bottom Tab Navigation -->
  <nav class="fixed bottom-0 left-0 right-0 safe-area-bottom z-50" style="background: rgba(10,22,40,0.92); backdrop-filter: blur(16px); border-top: 1px solid rgba(255,255,255,0.08);">
    <div class="flex items-center justify-around h-16">
      <% const currentPath = typeof currentPage !== 'undefined' ? currentPage : ''; %>

      <!-- Home -->
      <a href="/w/home" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'home' ? 'text-brand-400' : 'text-gray-500' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'home' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'home' ? '0' : '1.5' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
        </svg>
        <span class="text-[10px] font-medium">Home</span>
      </a>

      <!-- Shifts -->
      <a href="/w/shifts" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'shifts' || currentPath === 'jobs' ? 'text-brand-400' : 'text-gray-500' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'shifts' || currentPath === 'jobs' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'shifts' || currentPath === 'jobs' ? '0' : '1.5' %>" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-[10px] font-medium">Shifts</span>
      </a>

      <!-- Chat -->
      <a href="/w/chat" class="relative flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'chat' ? 'text-brand-400' : 'text-gray-500' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'chat' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'chat' ? '0' : '1.5' %>" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        <span class="text-[10px] font-medium">Chat</span>
      </a>

      <!-- Forms -->
      <a href="/w/forms" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'forms' ? 'text-brand-400' : 'text-gray-500' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'forms' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'forms' ? '0' : '1.5' %>" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span class="text-[10px] font-medium">Forms</span>
      </a>

      <!-- More -->
      <a href="/w/more" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'more' || currentPath === 'profile' ? 'text-brand-400' : 'text-gray-500' %>">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <span class="text-[10px] font-medium">More</span>
      </a>
    </div>
  </nav>

  <script src="/js/worker.js"></script>
  <script src="/js/chat.js?v=3"></script>
  <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
