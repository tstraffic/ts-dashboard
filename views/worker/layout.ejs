<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#1D6AE5">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <link rel="manifest" href="/manifest.json">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>T&S Worker Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/worker.css">
</head>
<body class="h-full bg-gray-50 text-gray-900 flex flex-col">

  <!-- Top Header -->
  <header class="bg-brand-600 text-white px-4 py-3 flex items-center justify-between shrink-0 safe-area-top">
    <div class="flex items-center gap-3">
      <img src="/images/logo-colour.jpg" alt="T&S" class="h-8 w-8 rounded-md">
      <span class="font-semibold text-sm">T&S Worker Portal</span>
    </div>
    <div class="flex items-center gap-3">
      <% if (typeof worker !== 'undefined' && worker) { %>
        <span class="text-xs text-brand-100"><%= worker.full_name %></span>
        <a href="/w/logout" class="text-brand-200 hover:text-white transition" title="Sign Out">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        </a>
      <% } %>
    </div>
  </header>

  <!-- Flash Messages -->
  <div class="px-4">
    <% if (typeof flash_success !== 'undefined' && flash_success && flash_success.length > 0) { %>
      <% flash_success.forEach(msg => { %>
        <div class="mt-3 p-3 bg-emerald-50 border border-emerald-200 rounded-lg text-emerald-800 text-sm flex items-center justify-between">
          <span><%= msg %></span>
          <button onclick="this.parentElement.remove()" class="text-emerald-600 hover:text-emerald-800 ml-2">&times;</button>
        </div>
      <% }) %>
    <% } %>
    <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
      <% flash_error.forEach(msg => { %>
        <div class="mt-3 p-3 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm flex items-center justify-between">
          <span><%= msg %></span>
          <button onclick="this.parentElement.remove()" class="text-red-600 hover:text-red-800 ml-2">&times;</button>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Main Content -->
  <main class="flex-1 overflow-auto px-4 py-4 pb-20">
    <%- body %>
  </main>

  <!-- Bottom Tab Navigation -->
  <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 safe-area-bottom z-50">
    <div class="flex items-center justify-around h-16">
      <% const currentPath = typeof currentPage !== 'undefined' ? currentPage : ''; %>

      <!-- Home -->
      <a href="/w/home" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'home' ? 'text-brand-600' : 'text-gray-400' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'home' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'home' ? '0' : '1.5' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z"/>
        </svg>
        <span class="text-[10px] font-medium">Home</span>
      </a>

      <!-- Jobs -->
      <a href="/w/jobs" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'jobs' ? 'text-brand-600' : 'text-gray-400' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'jobs' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'jobs' ? '0' : '1.5' %>" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0h2a2 2 0 012 2v6.255M8 6H6a2 2 0 00-2 2v6.255"/>
        </svg>
        <span class="text-[10px] font-medium">Jobs</span>
      </a>

      <!-- Clock -->
      <a href="/w/clock" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'clock' ? 'text-brand-600' : 'text-gray-400' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'clock' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'clock' ? '0' : '1.5' %>" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-[10px] font-medium">Clock</span>
      </a>

      <!-- Profile -->
      <a href="/w/profile" class="flex flex-col items-center justify-center gap-0.5 w-16 py-1 <%= currentPath === 'profile' ? 'text-brand-600' : 'text-gray-400' %>">
        <svg class="w-6 h-6" fill="<%= currentPath === 'profile' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= currentPath === 'profile' ? '0' : '1.5' %>" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-[10px] font-medium">Profile</span>
      </a>
    </div>
  </nav>

  <script src="/js/worker.js"></script>
  <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
