<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Login | T&S Operations Dashboard</title>
  <meta name="theme-color" content="#0A2D66">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="apple-touch-icon" href="/images/logo-colour.jpg">
  <link rel="manifest" href="/manifest-admin.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'] },
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <style>
    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

    @keyframes fade-up {
      from { opacity: 0; transform: translateY(24px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-12px) rotate(1deg); }
    }
    @keyframes glow-pulse {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 0.7; }
    }
    .animate-fade-up {
      animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .animate-fade-up-delay {
      animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.15s forwards;
      opacity: 0;
    }
    .animate-fade-up-delay-2 {
      animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
      opacity: 0;
    }

    /* Background */
    .login-bg {
      background: linear-gradient(145deg, #051B3F 0%, #0A2D66 30%, #1555C0 70%, #2B7FFF 100%);
      position: relative;
      overflow: hidden;
    }

    /* Floating orbs */
    .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
      animation: glow-pulse 6s ease-in-out infinite;
    }
    .orb-1 {
      top: -15%;
      right: -10%;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(43,127,255,0.25) 0%, transparent 70%);
      animation-delay: 0s;
    }
    .orb-2 {
      bottom: -20%;
      left: -15%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(96,165,250,0.15) 0%, transparent 70%);
      animation-delay: 3s;
    }
    .orb-3 {
      top: 40%;
      left: 50%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(147,197,253,0.1) 0%, transparent 70%);
      animation-delay: 1.5s;
    }

    /* Grid pattern overlay */
    .grid-pattern {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 100%);
    }

    /* Glass card */
    .glass-card {
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      box-shadow:
        0 25px 60px -12px rgba(0, 0, 0, 0.25),
        0 0 0 1px rgba(255, 255, 255, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    input:focus {
      box-shadow: 0 0 0 3px rgba(43, 127, 255, 0.15);
    }
    button[type="submit"]:active {
      transform: scale(0.98);
    }
    #__tailwind_indicator,div[style*="z-index: 2147483647"]{display:none!important}
  </style>
</head>
<body class="h-full login-bg flex items-center justify-center p-4 font-sans antialiased">
  <!-- Background elements -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="grid-pattern"></div>

  <div class="w-full max-w-[380px] relative z-10">
    <!-- Logo + branding -->
    <div class="text-center mb-8 animate-fade-up">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-white shadow-2xl mb-5 overflow-hidden ring-1 ring-white/20" style="animation: float 6s ease-in-out infinite">
        <img src="/images/logo-colour.jpg" alt="T&S Traffic Control" class="h-16 w-auto">
      </div>
      <h1 class="text-2xl font-extrabold text-white tracking-tight">T&S Traffic Control</h1>
      <p class="text-brand-300/80 mt-1.5 text-sm font-medium">Operations Dashboard</p>
    </div>

    <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
      <% flash_error.forEach(msg => { %>
        <div class="mb-4 p-3.5 bg-red-500/90 backdrop-blur-sm border border-red-400/30 rounded-xl text-white text-sm font-medium flex items-center gap-2.5 animate-fade-up shadow-lg shadow-red-500/20">
          <div class="w-5 h-5 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
          <%= msg %>
        </div>
      <% }) %>
    <% } %>

    <!-- Login form card -->
    <form method="POST" action="/login" class="glass-card rounded-2xl p-7 sm:p-8 space-y-5 animate-fade-up-delay">
      <div class="text-center mb-1">
        <h2 class="text-lg font-bold text-gray-900">Welcome back</h2>
        <p class="text-sm text-gray-400 mt-0.5">Sign in to your account</p>
      </div>
      <div>
        <label for="username" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Username</label>
        <input type="text" id="username" name="username" required autofocus placeholder="Enter your username"
          class="w-full px-4 py-3 bg-gray-50/80 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all text-[15px]">
      </div>
      <div>
        <label for="password" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Password</label>
        <input type="password" id="password" name="password" required placeholder="Enter your password"
          class="w-full px-4 py-3 bg-gray-50/80 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all text-[15px]">
      </div>
      <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-600/25 text-[15px] hover:shadow-xl hover:shadow-brand-600/30 active:shadow-md">
        Sign In
      </button>
      <div class="text-center">
        <a href="/forgot-password" class="text-sm text-gray-400 hover:text-brand-600 transition font-medium">Forgot password?</a>
      </div>
    </form>

    <p class="text-center text-brand-300/40 text-xs mt-8 animate-fade-up-delay-2 font-medium">&copy; <%= new Date().getFullYear() %> T&S Traffic Control Pty Ltd</p>
  </div>
</body>
</html>
