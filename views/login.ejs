<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Login | T&S Operations Dashboard</title>
  <meta name="theme-color" content="#0A2D66">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <link rel="apple-touch-icon" href="/images/logo-colour.jpg">
  <link rel="manifest" href="/manifest-admin.json">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              50: '#EFF6FF', 100: '#DBEAFE', 200: '#BFDBFE', 300: '#93C5FD',
              400: '#60A5FA', 500: '#2B7FFF', 600: '#1D6AE5', 700: '#1555C0',
              800: '#0F3F8E', 900: '#0A2D66', 950: '#051B3F',
            }
          }
        }
      }
    }
  </script>
  <style>
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
      animation: fade-up 0.6s ease-out forwards;
    }
    .animate-fade-up-delay {
      animation: fade-up 0.6s ease-out 0.15s forwards;
      opacity: 0;
    }
    /* Gradient background */
    .login-bg {
      background: linear-gradient(135deg, #0A2D66 0%, #1555C0 50%, #2B7FFF 100%);
      position: relative;
      overflow: hidden;
    }
    .login-bg::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 60%);
      border-radius: 50%;
    }
    .login-bg::after {
      content: '';
      position: absolute;
      bottom: -30%;
      left: -30%;
      width: 80%;
      height: 80%;
      background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%);
      border-radius: 50%;
    }
    /* Glass card */
    .glass-card {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }
    @media (prefers-color-scheme: dark) {
      .glass-card {
        background: rgba(255, 255, 255, 0.95);
      }
    }
    /* Input focus glow */
    input:focus {
      box-shadow: 0 0 0 3px rgba(43, 127, 255, 0.15);
    }
    /* Button press effect */
    button[type="submit"]:active {
      transform: scale(0.98);
    }
    /* Hide Tailwind CDN dev indicator */
    #__tailwind_indicator,div[style*="z-index: 2147483647"]{display:none!important}
  </style>
</head>
<body class="h-full login-bg flex items-center justify-center p-4">
  <div class="w-full max-w-sm relative z-10">
    <!-- Logo + branding -->
    <div class="text-center mb-8 animate-fade-up">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-white shadow-2xl mb-5 overflow-hidden">
        <img src="/images/logo-colour.jpg" alt="T&S Traffic Control" class="h-16 w-auto">
      </div>
      <h1 class="text-2xl font-bold text-white">T&S Traffic Control</h1>
      <p class="text-brand-200 mt-1 text-sm">Operations Dashboard</p>
    </div>

    <% if (typeof flash_error !== 'undefined' && flash_error && flash_error.length > 0) { %>
      <% flash_error.forEach(msg => { %>
        <div class="mb-4 p-3 bg-red-500/90 backdrop-blur-sm border border-red-400/30 rounded-xl text-white text-sm font-medium flex items-center gap-2">
          <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          <%= msg %>
        </div>
      <% }) %>
    <% } %>

    <!-- Login form card -->
    <form method="POST" action="/login" class="glass-card rounded-2xl shadow-2xl p-7 space-y-5 animate-fade-up-delay">
      <div>
        <label for="username" class="block text-sm font-semibold text-gray-700 mb-1.5">Username</label>
        <input type="text" id="username" name="username" required autofocus placeholder="Enter your username"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all text-base">
      </div>
      <div>
        <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Password</label>
        <input type="password" id="password" name="password" required placeholder="Enter your password"
          class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 focus:bg-white transition-all text-base">
      </div>
      <button type="submit" class="w-full py-3.5 bg-gradient-to-r from-brand-600 to-brand-500 hover:from-brand-500 hover:to-brand-400 text-white font-bold rounded-xl transition-all shadow-lg shadow-brand-600/30 text-base">
        Sign In
      </button>
      <div class="text-center">
        <a href="/forgot-password" class="text-sm text-gray-500 hover:text-brand-600 transition font-medium">Forgot password?</a>
      </div>
    </form>

    <p class="text-center text-brand-300/60 text-xs mt-8">&copy; <%= new Date().getFullYear() %> T&S Traffic Control</p>
  </div>
</body>
</html>
