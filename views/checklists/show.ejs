<% locals.currentPage = 'checklists' %>
<%
  var typeBadges = {
    // Display
    heading:        { bg: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',  label: 'Heading' },
    information:    { bg: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',  label: 'Info block' },
    hyperlink:      { bg: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',  label: 'Hyperlink' },
    media:          { bg: 'bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20',  label: 'Media' },
    // Inputs
    text:           { bg: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',        label: 'Question' },
    textarea:       { bg: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',        label: 'Long question' },
    number:         { bg: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',        label: 'Number' },
    datetime:       { bg: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',        label: 'Date / Time' },
    measurement:    { bg: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20',        label: 'Measurement' },
    // Special
    checklist:      { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Checklist' },
    yes_no_na:      { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Yes / No / N/A' },
    ok_notok_na:    { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'OK / Not OK / N/A' },
    pass_fail:      { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Pass / Fail' },
    multiple_choice:{ bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Multiple choice' },
    radio:          { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Single choice' },
    checkbox:       { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Multi-select' },
    media_upload:   { bg: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20', label: 'Media upload' },
    signature:      { bg: 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20',       label: 'Signature' }
  };
%>

<div class="space-y-5">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
    <div>
      <a href="/checklists" class="text-sm text-gray-500 hover:text-gray-700 mb-1 inline-flex items-center gap-1">&larr; All Templates</a>
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-2xl font-bold text-gray-900"><%= template.name %></h1>
        <% if (template.system_key) { %>
          <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            System
          </span>
        <% } %>
      </div>
      <% if (template.description) { %><p class="text-sm text-gray-500 mt-1"><%= template.description %></p><% } %>
      <% if (template.system_key) { %>
        <p class="text-xs text-indigo-700 mt-2 bg-indigo-50 ring-1 ring-indigo-100 rounded-lg px-3 py-2 inline-flex items-start gap-2 max-w-xl">
          <svg class="w-3.5 h-3.5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>Built-in worker-portal checklist (<code class="bg-white px-1.5 py-0.5 rounded text-[10px]"><%= template.system_key %></code>). Edit questions below, then hit <strong>Publish</strong> — workers see the new revision on their next form open.</span>
        </p>
      <% } %>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase
        <%= template.status === 'active' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' : 'bg-gray-100 text-gray-400' %>"><%= template.status %></span>
      <span class="text-sm text-gray-400"><%= items.length %> question<%= items.length !== 1 ? 's' : '' %></span>
    </div>
  </div>

  <!-- Worker visibility + publish — admin authors a draft, then hits
       Publish to snapshot a revision that workers can fill in. The
       Publish button lights up amber when the draft has drifted from
       the latest published revision. -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 space-y-4">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div>
        <h2 class="text-sm font-bold text-gray-900">Worker portal</h2>
        <p class="text-xs text-gray-500 mt-0.5">
          <% if (template.worker_visible && template.published_revision) { %>
            Live · revision <%= template.published_revision %><% if (typeof responseCount !== 'undefined' && responseCount) { %> · <%= responseCount %> submission<%= responseCount === 1 ? '' : 's' %><% } %>
          <% } else if (template.worker_visible) { %>
            Visible to workers but no revision published yet — hit Publish below to make it fillable.
          <% } else { %>
            Hidden from workers. Tick the box and Save to make this template available to workers.
          <% } %>
        </p>
      </div>
      <% if (typeof dirty !== 'undefined' && dirty) { %>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-50 text-amber-700 ring-1 ring-amber-600/20">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
          Unpublished changes
        </span>
      <% } %>
    </div>
    <form method="POST" action="/checklists/<%= template.id %>/visibility" class="flex flex-wrap items-center gap-4">
      <%- include('../partials/csrf') %>
      <label class="inline-flex items-center gap-2 text-sm">
        <input type="checkbox" name="worker_visible" value="1" <%= template.worker_visible ? 'checked' : '' %> class="h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <span class="text-gray-700 font-medium">Visible to workers</span>
      </label>
      <label class="inline-flex items-center gap-2 text-sm">
        <input type="checkbox" name="require_signature" value="1" <%= template.require_signature ? 'checked' : '' %> class="h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <span class="text-gray-700">Require signature</span>
      </label>
      <label class="inline-flex items-center gap-2 text-sm">
        <input type="checkbox" name="require_photo" value="1" <%= template.require_photo ? 'checked' : '' %> class="h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500">
        <span class="text-gray-700">Photo prompt</span>
      </label>
      <button type="submit" class="ml-auto px-3 py-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-semibold rounded-lg">Save</button>
    </form>
    <form method="POST" action="/checklists/<%= template.id %>/publish" class="flex items-center gap-3" onsubmit="return confirm('Publish this draft as a new revision? Workers will see it from now on.');">
      <%- include('../partials/csrf') %>
      <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg <%= (typeof dirty !== 'undefined' && dirty) ? 'bg-emerald-600 hover:bg-emerald-700 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %> text-sm font-semibold">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
        <%= (template.published_revision || 0) === 0 ? 'Publish first revision' : 'Publish revision ' + ((template.published_revision || 0) + 1) %>
      </button>
      <% if (template.published_revision) { %>
        <span class="text-xs text-gray-500">Live: rev <%= template.published_revision %>
          <% if (template.published_at) { %>· <%= new Date(template.published_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %><% } %>
        </span>
      <% } %>
    </form>
  </div>

  <!-- Edit Template Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4">
    <form method="POST" action="/checklists/<%= template.id %>" class="flex flex-col sm:flex-row gap-3">
      <%- include('../partials/csrf') %>
      <div class="flex-1">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Name</label>
        <input type="text" name="name" value="<%= template.name %>" required
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div class="flex-1">
        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Description</label>
        <input type="text" name="description" value="<%= template.description || '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
      </div>
      <div class="flex items-end">
        <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-lg transition">Save</button>
      </div>
    </form>
  </div>

  <!-- Revision history -->
  <% if (typeof revisions !== 'undefined' && revisions.length > 0) { %>
    <details class="bg-white border border-gray-200 rounded-xl shadow-sm">
      <summary class="px-4 py-3 cursor-pointer flex items-center justify-between">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Revision history</h2>
        <span class="text-xs text-gray-500"><%= revisions.length %> revision<%= revisions.length === 1 ? '' : 's' %></span>
      </summary>
      <div class="border-t border-gray-100">
        <% revisions.forEach(function (r) { var iCount = (function () { try { return JSON.parse(r.items_json || '[]').length } catch(e){ return 0 } })(); %>
          <div class="px-4 py-2.5 border-b border-gray-100 flex items-center justify-between text-xs">
            <div>
              <span class="font-semibold text-gray-900">Revision <%= r.revision_number %></span>
              <% if (r.revision_number === template.published_revision) { %>
                <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">Live</span>
              <% } %>
              <span class="text-gray-400 ml-2"><%= iCount %> question<%= iCount === 1 ? '' : 's' %></span>
            </div>
            <span class="text-gray-500">
              <%= new Date(r.published_at).toLocaleDateString('en-AU', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
              <% if (r.publisher_name) { %> · <%= r.publisher_name %><% } %>
            </span>
          </div>
        <% }); %>
      </div>
    </details>
  <% } %>

  <!-- Questions List -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between flex-wrap gap-2">
      <div class="flex items-center gap-3">
        <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Questions</h2>
        <% if (items.length > 0) { %>
          <label class="inline-flex items-center gap-1.5 text-[11px] text-gray-500 font-medium cursor-pointer">
            <input type="checkbox" id="bulk-select-all" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
            Select all
          </label>
        <% } %>
      </div>
      <button type="button" onclick="document.getElementById('addItemForm').classList.toggle('hidden')" class="text-xs font-medium text-brand-600 hover:text-brand-700">+ Add Question</button>
    </div>

    <!-- Bulk-edit toolbar — appears as soon as one row is checked. Lets
         the admin re-type a batch of questions in one shot (e.g. flip
         all 22 vehicle inspection rows from yes_no_na to ok_notok_na). -->
    <% if (items.length > 0) { %>
      <form id="bulk-edit-form" method="POST" action="/checklists/<%= template.id %>/items/bulk" class="hidden px-4 py-3 bg-amber-50 border-b border-amber-200 flex items-center gap-3 flex-wrap">
        <%- include('../partials/csrf') %>
        <span class="text-xs font-semibold text-amber-800"><span id="bulk-count">0</span> selected</span>
        <div class="flex items-center gap-2">
          <label class="text-[10px] font-bold text-amber-800 uppercase tracking-widest">Set type</label>
          <select name="response_type" class="px-2.5 py-1.5 bg-white border border-amber-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-amber-500">
            <option value="">— keep —</option>
            <option value="ok_notok_na">OK / Not OK / N/A</option>
            <option value="yes_no_na">Yes / No / N/A</option>
            <option value="pass_fail">Pass / Fail</option>
            <option value="text">Text</option>
            <option value="textarea">Long text</option>
            <option value="number">Number</option>
            <option value="signature">Signature</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-[10px] font-bold text-amber-800 uppercase tracking-widest">Required</label>
          <select name="required" class="px-2.5 py-1.5 bg-white border border-amber-300 rounded-lg text-gray-900 text-xs focus:outline-none focus:ring-2 focus:ring-amber-500">
            <option value="">— keep —</option>
            <option value="1">Yes</option>
            <option value="0">No</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-[10px] font-bold text-amber-800 uppercase tracking-widest">Section</label>
          <input type="text" name="section" placeholder="— keep —"
            class="px-2.5 py-1.5 bg-white border border-amber-300 rounded-lg text-gray-900 text-xs w-32 focus:outline-none focus:ring-2 focus:ring-amber-500">
        </div>
        <button type="submit" class="ml-auto px-3 py-1.5 bg-amber-600 hover:bg-amber-700 text-white text-xs font-semibold rounded-lg transition">Apply to selected</button>
        <button type="button" id="bulk-clear" class="px-2 py-1 text-xs text-amber-700 hover:text-amber-900">Clear</button>
      </form>
    <% } %>

    <% if (items.length > 0) { %>
      <p class="px-4 py-2 text-[11px] text-gray-400 italic bg-gray-50 border-b border-gray-100">
        <svg class="w-3 h-3 inline-block mr-0.5 align-middle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        Drag the grip handle to reorder. Drop a row under a different section header to move it across.
      </p>
      <div id="itemsList">
        <%
          // Build a list of section names to render as drop-target headers,
          // even for items without a section (which fall under "(No section)").
          var sectionGroups = [];
          var seen = {};
          items.forEach(function (it) {
            var s = it.section || '';
            if (!seen[s]) { seen[s] = true; sectionGroups.push(s); }
          });
        %>
        <% sectionGroups.forEach(function (sec) { %>
          <div class="cl-section" data-section-name="<%= sec %>">
            <div class="cl-section-header px-4 py-2 bg-gray-50 border-b border-gray-200 flex items-center gap-2">
              <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest"><%= sec || '(No section)' %></span>
              <span class="text-[9px] text-gray-300">drop zone</span>
            </div>
            <% items.filter(function (it) { return (it.section || '') === sec; }).forEach(function(item) {
              // Parse options_json so the edit form can pre-fill type-
              // specific fields (url, unit, options, scheme, body, alt).
              var opts = {};
              if (item.options_json) { try { opts = JSON.parse(item.options_json) || {}; } catch (e) { opts = {}; } }
              // Whole row data the JS picker uses to populate the edit form.
              var rowData = {
                id: item.id,
                question: item.question || '',
                response_type: item.response_type || 'text',
                section: item.section || '',
                item_key: item.item_key || '',
                required: item.required ? 1 : 0,
                options: opts,
              };
            %>
              <div class="cl-row px-4 py-3 border-b border-gray-100 hover:bg-gray-50 transition" data-item-id="<%= item.id %>" data-row='<%- JSON.stringify(rowData) %>' draggable="true">
                <div class="flex items-start gap-2">
                  <span class="cl-grip cursor-grab text-gray-300 hover:text-gray-500 select-none mt-1.5" title="Drag to reorder" aria-hidden="true">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
                  </span>
                  <input type="checkbox" class="bulk-row-check mt-1 rounded border-gray-300 text-brand-600 focus:ring-brand-500 flex-shrink-0" data-item-id="<%= item.id %>">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <p class="text-sm text-gray-900 font-medium"><%= item.question %></p>
                      <% if (item.required) { %><span class="text-[9px] font-bold text-red-500 uppercase">Required</span><% } %>
                    </div>
                    <div class="flex items-center gap-2 mt-1">
                      <% var badge = typeBadges[item.response_type] || typeBadges.text; %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-medium <%= badge.bg %>"><%= badge.label %></span>
                      <% if (item.item_key) { %><span class="text-[10px] text-gray-300 font-mono">·  <%= item.item_key %></span><% } %>
                    </div>
                  </div>
                  <div class="flex items-center gap-1 flex-shrink-0">
                    <button type="button" onclick="window._editItemViaPicker(<%= item.id %>)" class="p-1.5 text-gray-400 hover:text-brand-600 transition" title="Edit">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </button>
                    <form method="POST" action="/checklists/<%= template.id %>/items/<%= item.id %>/delete" class="inline" onsubmit="return confirm('Remove this question?')">
                      <%- include('../partials/csrf') %>
                      <button type="submit" class="p-1.5 text-gray-400 hover:text-red-600 transition" title="Delete">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="p-8 text-center text-gray-400 text-sm">
        No questions yet. Click "Add Question" to start building your checklist.
      </div>
    <% } %>

    <!-- ── Insert form element — picker + config form ──
         Stage 1: a 3-column grid (Display / Inputs / Special) of element
         tiles. Click one → stage 2 reveals a config form pre-loaded for
         that element type, with type-specific extra fields shown only
         when relevant (URL for Hyperlink, Unit for Measurement, etc.). -->
    <div id="addItemForm" class="<%= items.length === 0 ? '' : 'hidden' %> p-4 bg-blue-50/30 border-t border-gray-200">

      <!-- Stage 1 — picker -->
      <div id="element-picker">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-bold text-gray-700 uppercase tracking-widest">Insert form element</p>
          <button type="button" onclick="document.getElementById('addItemForm').classList.add('hidden')" class="text-xs text-gray-400 hover:text-gray-600">Close</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% [
            ['display', 'Display', 'Read-only blocks shown to the worker.', [
              ['heading',     'Heading',     'H',  '#6366F1'],
              ['information', 'Information', 'i',  '#6366F1'],
              ['hyperlink',   'Hyperlink',   '↗',  '#6366F1'],
              ['media',       'Media',       '🖼', '#6366F1'],
            ]],
            ['input',   'Inputs',  'What the worker fills in.', [
              ['text',         'Question',     'Q', '#2563EB'],
              ['textarea',     'Long question','¶', '#2563EB'],
              ['datetime',     'Date / Time',  '◷', '#2563EB'],
              ['measurement',  'Measurement',  '#', '#2563EB'],
              ['number',       'Number',       '0', '#2563EB'],
            ]],
            ['special', 'Special', 'Richer worker inputs.', [
              ['checklist',       'Checklist',       '☑', '#059669'],
              ['multiple_choice', 'Multiple choice', '◉', '#059669'],
              ['media_upload',    'Media upload',    '📷', '#059669'],
              ['signature',       'Signature',       '✍', '#059669'],
            ]],
          ].forEach(function (group) { %>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1"><%= group[1] %></p>
              <p class="text-[11px] text-gray-400 mb-2"><%= group[2] %></p>
              <div class="grid grid-cols-2 gap-2">
                <% group[3].forEach(function (el) { %>
                  <button type="button" onclick="window._pickElement('<%= el[0] %>')"
                          class="flex items-center gap-2 px-3 py-2.5 rounded-lg border border-gray-200 bg-white hover:border-brand-400 hover:bg-brand-50 text-left transition">
                    <span class="w-6 h-6 rounded-md flex items-center justify-center flex-shrink-0 text-[11px] font-bold text-white" style="background:<%= el[3] %>;"><%= el[2] %></span>
                    <span class="text-xs font-semibold text-gray-700"><%= el[1] %></span>
                  </button>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Stage 2 — config form for the picked element -->
      <form id="elementConfigForm" method="POST" action="/checklists/<%= template.id %>/items" class="hidden mt-3 space-y-3">
        <%- include('../partials/csrf') %>
        <input type="hidden" name="response_type" id="cfgType" value="">

        <div class="flex items-center gap-2 pb-2 border-b border-gray-200">
          <button type="button" onclick="window._unpickElement()" class="text-xs text-gray-400 hover:text-gray-600 inline-flex items-center gap-1">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Pick a different element
          </button>
          <span class="text-xs text-gray-400">·</span>
          <span class="text-xs font-semibold text-gray-700" id="cfgTypeLabel">Question</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="sm:col-span-2">
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1" id="cfgQuestionLabel">Question text <span class="text-red-500">*</span></label>
            <input type="text" name="question" id="cfgQuestion" placeholder="e.g. Is all PPE worn correctly?"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Section (optional)</label>
            <input type="text" name="section" placeholder="e.g. Site Setup, Vehicle, PPE…"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Item key (optional)</label>
            <input type="text" name="item_key" placeholder="auto-generated"
              class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <p class="text-[10px] text-gray-400 mt-1">Stable handle for this row. Lowercase + underscores. Leave blank to auto-name.</p>
          </div>
        </div>

        <!-- Type-specific extra fields. Each block is shown only when its
             data-show-when matches the picked element type. -->
        <div data-show-when="hyperlink" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Link URL <span class="text-red-500">*</span></label>
          <input type="url" name="opt_url" placeholder="https://…" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div data-show-when="media" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Image / file URL <span class="text-red-500">*</span></label>
          <input type="url" name="opt_url" placeholder="https://…" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-3 mb-1">Alt text</label>
          <input type="text" name="opt_alt" placeholder="Describe the image" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div data-show-when="information" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Body</label>
          <textarea name="opt_body" rows="3" placeholder="Notes / instructions for the worker." class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
        </div>
        <div data-show-when="measurement" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Unit</label>
          <input type="text" name="opt_unit" placeholder="km, kg, °C, %…" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div data-show-when="checklist" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Answer scheme</label>
          <select name="opt_scheme" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="ok_notok_na">OK / Not OK / N/A</option>
            <option value="yes_no_na">Yes / No / N/A</option>
            <option value="pass_fail">Pass / Fail</option>
          </select>
        </div>
        <div data-show-when="multiple_choice" class="hidden">
          <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Options (one per line) <span class="text-red-500">*</span></label>
          <textarea name="opt_options" rows="4" placeholder="Option 1&#10;Option 2&#10;Option 3" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
          <label class="inline-flex items-center gap-2 mt-2 cursor-pointer">
            <input type="checkbox" name="opt_multi" value="1" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
            <span class="text-sm text-gray-700">Allow multiple selections</span>
          </label>
        </div>

        <div class="flex items-center justify-between pt-2 border-t border-gray-200">
          <label class="flex items-center gap-2 cursor-pointer" id="cfgRequiredWrap">
            <input type="checkbox" name="required" value="1" class="rounded border-gray-300 text-brand-600 focus:ring-brand-500">
            <span class="text-sm text-gray-600">Required</span>
          </label>
          <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition">Add element</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Preview -->
  <% if (items.length > 0) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-200">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Preview</h2>
    </div>
    <div class="p-4 space-y-3">
      <% var prevSection = ''; %>
      <% items.forEach(function(item) { %>
        <% if (item.section && item.section !== prevSection) { prevSection = item.section; %>
          <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest pt-3 pb-1 border-b border-gray-100"><%= prevSection %></p>
        <% } %>
        <div class="flex items-center justify-between gap-4">
          <div>
            <span class="text-sm text-gray-800"><%= item.question %></span>
            <% if (item.required) { %><span class="text-red-400 text-xs ml-1">*</span><% } %>
          </div>
          <div class="flex-shrink-0">
            <% if (item.response_type === 'yes_no_na') { %>
              <div class="flex gap-1">
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-emerald-50 text-emerald-600 border border-emerald-200">Yes</span>
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-red-50 text-red-600 border border-red-200">No</span>
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-gray-50 text-gray-400 border border-gray-200">N/A</span>
              </div>
            <% } else if (item.response_type === 'ok_notok_na') { %>
              <div class="flex gap-1">
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-emerald-50 text-emerald-600 border border-emerald-200">OK</span>
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-red-50 text-red-600 border border-red-200">Not OK</span>
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-gray-50 text-gray-400 border border-gray-200">N/A</span>
              </div>
            <% } else if (item.response_type === 'pass_fail') { %>
              <div class="flex gap-1">
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-emerald-50 text-emerald-600 border border-emerald-200">Pass</span>
                <span class="px-2 py-1 text-[10px] font-medium rounded bg-red-50 text-red-600 border border-red-200">Fail</span>
              </div>
            <% } else if (item.response_type === 'text') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-gray-50 text-gray-400 border border-gray-200">Text input</span>
            <% } else if (item.response_type === 'textarea') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-gray-50 text-gray-400 border border-gray-200">Long text</span>
            <% } else if (item.response_type === 'number') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-purple-50 text-purple-500 border border-purple-200"># Number</span>
            <% } else if (item.response_type === 'radio') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-blue-50 text-blue-600 border border-blue-200">Single choice</span>
            <% } else if (item.response_type === 'checkbox') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-blue-50 text-blue-600 border border-blue-200">Multi-select</span>
            <% } else if (item.response_type === 'signature') { %>
              <span class="px-2 py-1 text-[10px] font-medium rounded bg-amber-50 text-amber-600 border border-amber-200">Signature</span>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>
</div>

<script>
// ── Edit-via-picker ──
// Reuses the same Insert-form-element config form (with all the
// type-specific fields like URL / Unit / Options / Scheme / Body / Alt)
// pre-loaded with the row's current values. Pencil click loads the
// row data → shows the picker config in edit mode → submits to the
// per-item update endpoint.
window._editItemViaPicker = function (itemId) {
  var row = document.querySelector('.cl-row[data-item-id="' + itemId + '"]');
  if (!row) return;
  var data;
  try { data = JSON.parse(row.getAttribute('data-row') || '{}'); } catch (e) { data = {}; }

  var form = document.getElementById('elementConfigForm');
  var picker = document.getElementById('element-picker');
  var addWrap = document.getElementById('addItemForm');
  if (!form || !picker || !addWrap) return;

  // Repoint the form at the per-item update endpoint.
  form.action = '/checklists/<%= template.id %>/items/' + itemId;

  // Use the same picker meta to swap labels + show only the relevant
  // type-specific section. _pickElement is defined just above.
  var rt = data.response_type || 'text';
  if (typeof window._pickElement === 'function') window._pickElement(rt);

  // Pre-fill the standard fields.
  form.querySelector('input[name="question"]').value = data.question || '';
  form.querySelector('input[name="section"]').value = data.section || '';
  form.querySelector('input[name="item_key"]').value = data.item_key || '';
  var reqWrap = document.getElementById('cfgRequiredWrap');
  if (reqWrap) {
    var reqInp = reqWrap.querySelector('input[type="checkbox"]');
    if (reqInp) reqInp.checked = !!data.required;
  }
  // Pre-fill type-specific fields from data.options.
  var opts = data.options || {};
  function setVal(name, val) { var el = form.querySelector('[name="' + name + '"]'); if (el && val != null) el.value = val; }
  setVal('opt_url',   opts.url || '');
  setVal('opt_alt',   opts.alt || '');
  setVal('opt_unit',  opts.unit || '');
  setVal('opt_body',  opts.body || '');
  setVal('opt_scheme', opts.scheme || 'ok_notok_na');
  if (Array.isArray(opts.options)) setVal('opt_options', opts.options.join('\n'));
  var multiInp = form.querySelector('[name="opt_multi"]');
  if (multiInp) multiInp.checked = !!opts.multi;

  // Swap the submit button label so it's clearly an edit.
  var submitBtn = form.querySelector('button[type="submit"]');
  if (submitBtn) submitBtn.textContent = 'Save changes';

  // Make sure the panel is visible + scroll the form into view.
  addWrap.classList.remove('hidden');
  form.scrollIntoView({ behavior: 'smooth', block: 'center' });
};

// ── Drag-to-reorder (cross-section) ──
// Each row is draggable; each .cl-section block is a drop zone. On
// drop, scan the DOM, infer each row's new section from the section
// block it now lives under, and POST to /reorder with [{id, section}].
(function () {
  var list = document.getElementById('itemsList');
  if (!list) return;

  var dragId = null;
  function rowsInOrder() {
    var out = [];
    list.querySelectorAll('.cl-section').forEach(function (sec) {
      var section = sec.getAttribute('data-section-name') || '';
      sec.querySelectorAll('.cl-row').forEach(function (r) {
        out.push({ id: parseInt(r.dataset.itemId, 10), section: section });
      });
    });
    return out;
  }

  function postOrder() {
    var items = rowsInOrder().filter(function (r) { return !isNaN(r.id); });
    fetch('/checklists/<%= template.id %>/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>' },
      body: JSON.stringify({ items: items }),
    }).catch(function () {});
  }

  // Edge auto-scroll while a drag is in flight — when the cursor sits
  // within 80px of the top or bottom of the viewport, scroll the page
  // so the user can keep dragging past the visible area instead of
  // getting stuck. Activated on dragstart, torn down on dragend.
  var scrollY = 0;          // latest pointer Y (viewport coords)
  var scrollRaf = null;
  function startEdgeScroll() {
    if (scrollRaf) return;
    var EDGE = 80, MAX_PX = 18;
    function tick() {
      var h = window.innerHeight;
      var dy = 0;
      if (scrollY < EDGE)         dy = -((EDGE - scrollY) / EDGE) * MAX_PX;
      else if (scrollY > h - EDGE) dy =  ((scrollY - (h - EDGE)) / EDGE) * MAX_PX;
      if (dy !== 0) window.scrollBy(0, dy);
      scrollRaf = requestAnimationFrame(tick);
    }
    scrollRaf = requestAnimationFrame(tick);
  }
  function stopEdgeScroll() {
    if (scrollRaf) { cancelAnimationFrame(scrollRaf); scrollRaf = null; }
  }
  // Capture the latest pointer Y from any dragover bubbling up.
  document.addEventListener('dragover', function (e) {
    if (!dragId) return;
    scrollY = e.clientY;
  }, true);

  list.querySelectorAll('.cl-row').forEach(function (row) {
    row.addEventListener('dragstart', function (e) {
      dragId = row.dataset.itemId;
      row.classList.add('opacity-50');
      try { e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', row.dataset.itemId); } catch (_) {}
      scrollY = e.clientY != null ? e.clientY : 0;
      startEdgeScroll();
    });
    row.addEventListener('dragend', function () {
      row.classList.remove('opacity-50');
      dragId = null;
      stopEdgeScroll();
    });
    row.addEventListener('dragover', function (e) {
      if (!dragId) return;
      e.preventDefault();
      var rect = row.getBoundingClientRect();
      var before = (e.clientY - rect.top) < (rect.height / 2);
      var dragged = list.querySelector('.cl-row[data-item-id="' + dragId + '"]');
      if (!dragged || dragged === row) return;
      row.parentNode.insertBefore(dragged, before ? row : row.nextSibling);
    });
    row.addEventListener('drop', function (e) { e.preventDefault(); postOrder(); });
  });

  // Section header is itself a drop target — drop into the empty
  // space at the top of the section to land an item there.
  list.querySelectorAll('.cl-section').forEach(function (sec) {
    var header = sec.querySelector('.cl-section-header');
    if (!header) return;
    header.addEventListener('dragover', function (e) {
      if (!dragId) return;
      e.preventDefault();
      var dragged = list.querySelector('.cl-row[data-item-id="' + dragId + '"]');
      if (!dragged) return;
      // Insert as the first item of this section (right after the header).
      sec.insertBefore(dragged, header.nextSibling);
    });
    header.addEventListener('drop', function (e) { e.preventDefault(); postOrder(); });
  });
})();

// ── Insert form element picker → config form wiring ──
(function () {
  // Drives stage 2 of the Add UI: which fields to show, what labels to
  // use, and whether Required is even meaningful (display elements
  // aren't filled in by the worker so Required doesn't apply).
  var ELEMENT_META = {
    heading:        { label: 'Heading',        questionLabel: 'Heading text *',     placeholder: 'Section heading shown to the worker', requiresQuestion: true,  showRequired: false },
    information:    { label: 'Information',    questionLabel: 'Title (optional)',   placeholder: 'Optional title above the body',       requiresQuestion: false, showRequired: false },
    hyperlink:      { label: 'Hyperlink',      questionLabel: 'Link text *',        placeholder: 'e.g. View site map',                  requiresQuestion: true,  showRequired: false },
    media:          { label: 'Media',          questionLabel: 'Caption (optional)', placeholder: 'Optional caption',                    requiresQuestion: false, showRequired: false },
    text:           { label: 'Question',       questionLabel: 'Question text *',    placeholder: 'e.g. Is all PPE worn correctly?',     requiresQuestion: true,  showRequired: true  },
    textarea:       { label: 'Long question',  questionLabel: 'Question text *',    placeholder: 'e.g. Describe the site setup',        requiresQuestion: true,  showRequired: true  },
    number:         { label: 'Number',         questionLabel: 'Question text *',    placeholder: 'e.g. How many cones deployed?',       requiresQuestion: true,  showRequired: true  },
    datetime:       { label: 'Date / Time',    questionLabel: 'Question text *',    placeholder: 'e.g. When did the shift start?',      requiresQuestion: true,  showRequired: true  },
    measurement:    { label: 'Measurement',    questionLabel: 'Question text *',    placeholder: 'e.g. ODO at start of shift',          requiresQuestion: true,  showRequired: true  },
    checklist:      { label: 'Checklist',      questionLabel: 'Question text *',    placeholder: 'e.g. Brakes',                         requiresQuestion: true,  showRequired: true  },
    multiple_choice:{ label: 'Multiple choice',questionLabel: 'Question text *',    placeholder: 'e.g. Which weather conditions apply?', requiresQuestion: true, showRequired: true  },
    media_upload:   { label: 'Media upload',   questionLabel: 'Question text *',    placeholder: 'e.g. Upload arrow board photos',      requiresQuestion: true,  showRequired: true  },
    signature:      { label: 'Signature',      questionLabel: 'Label *',            placeholder: 'e.g. Driver signature',               requiresQuestion: true,  showRequired: true  },
    ok_notok_na:    { label: 'OK / Not OK / N/A', questionLabel: 'Question text *', placeholder: 'e.g. Brakes',                         requiresQuestion: true,  showRequired: true  },
    yes_no_na:      { label: 'Yes / No / N/A', questionLabel: 'Question text *',    placeholder: 'e.g. PPE compliant',                  requiresQuestion: true,  showRequired: true  },
    pass_fail:      { label: 'Pass / Fail',    questionLabel: 'Question text *',    placeholder: 'e.g. Tyre tread acceptable',          requiresQuestion: true,  showRequired: true  },
  };

  var picker = document.getElementById('element-picker');
  var cfgForm = document.getElementById('elementConfigForm');
  if (!picker || !cfgForm) return;

  window._pickElement = function (type) {
    var meta = ELEMENT_META[type] || ELEMENT_META.text;
    document.getElementById('cfgType').value = type;
    document.getElementById('cfgTypeLabel').textContent = meta.label;
    var qInput = document.getElementById('cfgQuestion');
    var qLabel = document.getElementById('cfgQuestionLabel');
    qLabel.innerHTML = meta.questionLabel.replace('*', '<span class="text-red-500">*</span>');
    qInput.placeholder = meta.placeholder;
    qInput.required = !!meta.requiresQuestion;
    var rWrap = document.getElementById('cfgRequiredWrap');
    rWrap.style.display = meta.showRequired ? '' : 'none';
    rWrap.querySelector('input[type="checkbox"]').checked = false;
    // Show only this element's extra-config block.
    document.querySelectorAll('[data-show-when]').forEach(function (el) {
      el.classList.toggle('hidden', el.getAttribute('data-show-when') !== type);
    });
    picker.classList.add('hidden');
    cfgForm.classList.remove('hidden');
    setTimeout(function () { qInput.focus(); }, 50);
  };

  window._unpickElement = function () {
    cfgForm.classList.add('hidden');
    picker.classList.remove('hidden');
    cfgForm.reset();
    document.querySelectorAll('[data-show-when]').forEach(function (el) { el.classList.add('hidden'); });
    // Reset the form back to "Add" mode in case it was switched into
    // edit mode by _editItemViaPicker (action repointed at /:itemId,
    // submit label changed). Without this, picking a new element after
    // editing one would still post to the edit endpoint.
    cfgForm.action = '/checklists/<%= template.id %>/items';
    var submitBtn = cfgForm.querySelector('button[type="submit"]');
    if (submitBtn) submitBtn.textContent = 'Add element';
  };
})();

// ── Bulk-edit toolbar wiring ──
(function () {
  var bulkForm = document.getElementById('bulk-edit-form');
  var countEl  = document.getElementById('bulk-count');
  var selectAll = document.getElementById('bulk-select-all');
  var clearBtn  = document.getElementById('bulk-clear');
  if (!bulkForm) return;

  function selectedIds() {
    return Array.from(document.querySelectorAll('.bulk-row-check:checked')).map(function (c) { return c.dataset.itemId; });
  }
  function refresh() {
    var ids = selectedIds();
    countEl.textContent = ids.length;
    bulkForm.classList.toggle('hidden', ids.length === 0);
    // Keep the master checkbox tri-state-ish — checked when every row is.
    if (selectAll) {
      var rows = document.querySelectorAll('.bulk-row-check');
      selectAll.checked = ids.length > 0 && ids.length === rows.length;
    }
    // Sync hidden ids[] inputs into the form so submit picks them up.
    bulkForm.querySelectorAll('input[name="ids[]"]').forEach(function (n) { n.remove(); });
    ids.forEach(function (id) {
      var inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = 'ids[]'; inp.value = id;
      bulkForm.appendChild(inp);
    });
  }

  document.querySelectorAll('.bulk-row-check').forEach(function (c) {
    c.addEventListener('change', refresh);
  });

  if (selectAll) {
    selectAll.addEventListener('change', function () {
      var on = selectAll.checked;
      document.querySelectorAll('.bulk-row-check').forEach(function (c) { c.checked = on; });
      refresh();
    });
  }
  if (clearBtn) {
    clearBtn.addEventListener('click', function () {
      document.querySelectorAll('.bulk-row-check').forEach(function (c) { c.checked = false; });
      if (selectAll) selectAll.checked = false;
      refresh();
    });
  }

  bulkForm.addEventListener('submit', function (e) {
    if (selectedIds().length === 0) { e.preventDefault(); return; }
    // Require at least one of the change fields to be set.
    var rType = bulkForm.querySelector('select[name="response_type"]').value;
    var rReq  = bulkForm.querySelector('select[name="required"]').value;
    var rSec  = bulkForm.querySelector('input[name="section"]').value.trim();
    if (!rType && !rReq && !rSec) {
      e.preventDefault();
      alert('Pick at least one field to change (type, required, or section).');
    }
  });
})();
</script>
