<% const a = audit; %>
<% function fmtDate(d) { if (!d) return '—'; try { return new Date(d).toLocaleString('en-AU', { timeZone: 'Australia/Sydney' }); } catch(e) { return d; } } %>
<% function findingLabel(f) { return f === 'pass_with_actions' ? 'Pass with actions' : (f||'—').replace('_',' '); } %>
<% function stateOf(r) { if (!r) return ''; if (r.state) return r.state; if (r.na) return 'na'; if (r.checked) return 'yes'; return ''; } %>
<% const ctxMap = (typeof attachmentsByContext !== 'undefined') ? (attachmentsByContext || {}) : {}; %>
<% function thumbGrid(items) {
  if (!items || !items.length) return '';
  let html = '<div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2 mt-2">';
  items.forEach(function(att) {
    const isImg = (att.mime_type || '').startsWith('image/');
    html += '<div class="bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">';
    if (isImg) {
      html += '<a href="' + att.file_path + '" target="_blank"><img src="' + att.file_path + '" alt="' + att.original_name + '" class="w-full h-20 sm:h-24 object-cover"></a>';
    } else {
      html += '<a href="' + att.file_path + '" target="_blank" class="flex items-center justify-center h-20 sm:h-24 bg-gray-100 text-gray-400">📄</a>';
    }
    if (att.caption) html += '<p class="text-[10px] text-gray-600 truncate px-1.5 py-1">' + att.caption + '</p>';
    html += '</div>';
  });
  html += '</div>';
  return html;
} %>

<div class="px-4 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex items-start justify-between gap-3 mb-6">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <a href="/audits" class="text-sm text-brand-600 hover:underline">← All audits</a>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Audit #<%= a.id %>: <%= a.project_site || 'Untitled site' %></h1>
      <p class="text-sm text-gray-500"><%= fmtDate(a.audit_datetime || a.created_at) %></p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/audits/<%= a.id %>/pdf" target="_blank" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-semibold rounded-lg inline-flex items-center gap-1.5" title="Export PDF">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export PDF
      </a>
      <% if (a.status !== 'signed_off') { %>
        <a href="/audits/<%= a.id %>/edit" class="px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-lg">Edit</a>
      <% } %>
      <% if (a.status === 'submitted') { %>
        <form method="POST" action="/audits/<%= a.id %>/sign-off" class="inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button class="px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-lg">Sign Off</button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Score card -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
    <div class="lg:col-span-1 bg-gradient-to-br from-brand-600 to-brand-800 text-white rounded-xl p-6">
      <p class="text-xs font-semibold uppercase tracking-wide opacity-80">Overall Score</p>
      <p class="text-5xl font-bold mt-2"><%= score.percent %>%</p>
      <p class="text-sm opacity-90 mt-1"><%= score.total %> / <%= score.max %> items passed</p>
      <div class="mt-4 pt-4 border-t border-white/20">
        <p class="text-xs font-semibold uppercase tracking-wide opacity-80">Finding</p>
        <p class="text-lg font-bold mt-1 capitalize"><%= findingLabel(a.overall_finding) %></p>
      </div>
    </div>
    <div class="lg:col-span-2 bg-white border border-gray-200 rounded-xl p-5">
      <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-3">Scoring by Area</h3>
      <div class="space-y-2">
        <% score.groups.forEach(function(g) { const c = g.percent >= 90 ? 'emerald' : g.percent >= 70 ? 'amber' : 'red'; %>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium text-gray-700"><%= g.label %></span>
              <span class="font-bold text-gray-900"><%= g.score %>/<%= g.max %> <span class="text-xs text-gray-500">(<%= g.percent %>%)</span></span>
            </div>
            <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
              <div class="h-full bg-<%= c %>-500" style="width: <%= g.percent %>%"></div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Meta -->
  <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Client</p><p class="text-gray-900 mt-0.5"><%= a.client || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Location</p><p class="text-gray-900 mt-0.5"><%= a.location || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Project</p><p class="text-gray-900 mt-0.5"><%= a.job_number ? a.job_number + ' — ' + (a.job_client || '') : '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">TGS / TCP Ref</p><p class="text-gray-900 mt-0.5"><%= a.tgs_ref || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Shift</p><p class="text-gray-900 mt-0.5 capitalize"><%= a.shift || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Weather</p><p class="text-gray-900 mt-0.5"><%= a.weather || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Auditor</p><p class="text-gray-900 mt-0.5"><%= a.auditor_name || a.created_by_name || '—' %></p></div>
    <div><p class="text-xs text-gray-500 font-semibold uppercase">Supervisor / STMS</p><p class="text-gray-900 mt-0.5"><%= a.supervisor_name || '—' %></p></div>
  </div>

  <!-- Site Overview Evidence -->
  <% if ((ctxMap['overview'] || []).length) { %>
    <section class="bg-white border border-gray-200 rounded-xl p-5 mb-4">
      <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-2">Site Overview Evidence</h2>
      <%- thumbGrid(ctxMap['overview']) %>
    </section>
  <% } %>

  <!-- Sections -->
  <% sections.forEach(function(section) { %>
    <section class="bg-white border border-gray-200 rounded-xl overflow-hidden mb-4">
      <header class="bg-gray-50 border-b border-gray-200 px-5 py-3">
        <h2 class="text-sm font-bold text-gray-900"><%= section.key %>. <%= section.title %></h2>
      </header>
      <div class="divide-y divide-gray-100">
        <% section.items.forEach(function(item, idx) {
          const key = section.key + '.' + (idx + 1);
          const r = responses[key] || {};
          const st = stateOf(r);
          let icon, iconClass;
          if (st === 'na') { icon = 'N/A'; iconClass = 'bg-gray-100 text-gray-500'; }
          else if (st === 'yes') { icon = 'Yes'; iconClass = 'bg-emerald-100 text-emerald-700'; }
          else if (st === 'no') { icon = 'No'; iconClass = 'bg-red-100 text-red-700'; }
          else { icon = '—'; iconClass = 'bg-gray-50 text-gray-400'; }
        %>
          <div class="px-5 py-3 flex items-start gap-3">
            <span class="inline-flex items-center justify-center w-8 h-6 rounded text-xs font-bold flex-shrink-0 <%= iconClass %>"><%= icon %></span>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-gray-800"><span class="text-gray-500 font-mono mr-1"><%= key %></span><%= item %></p>
              <% if (r.notes) { %><p class="text-xs text-gray-600 italic mt-1"><%= r.notes %></p><% } %>
            </div>
          </div>
        <% }) %>
      </div>
      <% if (sectionComments[section.key]) { %>
        <div class="px-5 py-3 bg-gray-50 border-t border-gray-200">
          <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-wide">Comments</p>
          <p class="text-sm text-gray-700 mt-0.5"><%= sectionComments[section.key] %></p>
        </div>
      <% } %>
      <% const _secItems = ctxMap['section_' + section.key] || []; if (_secItems.length) { %>
        <div class="px-5 py-3 bg-blue-50/30 border-t border-gray-200">
          <p class="text-[11px] font-semibold text-brand-700 uppercase tracking-wide">Evidence (<%= _secItems.length %>)</p>
          <%- thumbGrid(_secItems) %>
        </div>
      <% } %>
    </section>
  <% }) %>

  <!-- Non-conformances -->
  <% if (nonconformances && nonconformances.length) { %>
    <section class="bg-white border border-gray-200 rounded-xl overflow-hidden mb-6">
      <header class="bg-red-50 border-b border-red-200 px-5 py-3">
        <h2 class="text-sm font-bold text-red-900">Non-Conformance Register</h2>
      </header>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs uppercase font-semibold text-gray-500">
            <tr><th class="px-4 py-2 text-left">#</th><th class="px-4 py-2 text-left">Issue</th><th class="px-4 py-2 text-left">Risk</th><th class="px-4 py-2 text-left">Action</th><th class="px-4 py-2 text-left">Responsible</th><th class="px-4 py-2 text-left">Due</th><th class="px-4 py-2">Closed</th></tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% nonconformances.forEach(function(nc, i) { const ncItems = ctxMap['nc_' + (i + 1)] || []; %>
              <tr>
                <td class="px-4 py-2 text-gray-500"><%= i + 1 %></td>
                <td class="px-4 py-2 text-gray-900"><%= nc.issue %></td>
                <td class="px-4 py-2"><%= nc.risk || '—' %></td>
                <td class="px-4 py-2"><%= nc.action || '—' %></td>
                <td class="px-4 py-2"><%= nc.responsible || '—' %></td>
                <td class="px-4 py-2"><%= nc.due_date || '—' %></td>
                <td class="px-4 py-2 text-center"><%= nc.closed ? '✓' : '—' %></td>
              </tr>
              <% if (ncItems.length) { %>
                <tr class="bg-red-50/30">
                  <td></td>
                  <td colspan="6" class="px-4 pb-3"><%- thumbGrid(ncItems) %></td>
                </tr>
              <% } %>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>

  <!-- General photos & documents (non-contextual) -->
  <% const _generalAtts = (ctxMap['general'] || []); %>
  <section class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide">General Photos & Documents</h2>
      <span class="text-xs text-gray-500"><%= _generalAtts.length %> file(s) · <%= (typeof attachments !== 'undefined' ? attachments.length : 0) %> total</span>
    </div>

    <!-- Upload form -->
    <form method="POST" action="/audits/<%= a.id %>/attachments" enctype="multipart/form-data" class="mb-5 p-4 bg-gray-50 border border-dashed border-gray-300 rounded-lg">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <input type="hidden" name="return_to" value="/audits/<%= a.id %>">
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="file" name="files" multiple accept="image/*,application/pdf,.doc,.docx,.xls,.xlsx" class="flex-1 text-sm">
        <input name="caption" placeholder="Caption / which item (optional)" class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg">
        <button class="px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-lg">Upload</button>
      </div>
      <p class="text-[11px] text-gray-500 mt-2">Max 25MB per file · Images, PDF, Word, Excel</p>
    </form>

    <% if (_generalAtts.length) { %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <% _generalAtts.forEach(function(att) { const isImg = (att.mime_type || '').startsWith('image/'); %>
          <div class="group relative bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
            <% if (isImg) { %>
              <a href="<%= att.file_path %>" target="_blank">
                <img src="<%= att.file_path %>" alt="<%= att.original_name %>" class="w-full h-32 object-cover">
              </a>
            <% } else { %>
              <a href="<%= att.file_path %>" target="_blank" class="flex items-center justify-center h-32 bg-gray-100">
                <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </a>
            <% } %>
            <div class="p-2">
              <p class="text-xs font-medium text-gray-800 truncate" title="<%= att.original_name %>"><%= att.original_name %></p>
              <% if (att.caption) { %><p class="text-[11px] text-gray-500 truncate"><%= att.caption %></p><% } %>
            </div>
            <form method="POST" action="/audits/<%= a.id %>/attachments/<%= att.id %>/delete" onsubmit="return confirm('Delete this file?')" class="absolute top-1 right-1">
              <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
              <input type="hidden" name="return_to" value="/audits/<%= a.id %>">
              <button class="w-7 h-7 bg-red-600 hover:bg-red-700 text-white rounded-full text-sm font-bold opacity-0 group-hover:opacity-100 focus:opacity-100 transition shadow-lg" title="Delete">×</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-sm text-gray-500 text-center py-4">No photos or documents uploaded yet.</p>
    <% } %>
  </section>

  <!-- Signatures / Annotated TGS -->
  <% if (a.auditor_signature_text || a.supervisor_signature_text || (ctxMap['annotated_tgs'] || []).length) { %>
    <section class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
      <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-3">Sign-off &amp; Annotations</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% if (a.auditor_signature_text) { %>
          <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-xs text-gray-500 uppercase font-semibold">Auditor</p>
            <p class="text-2xl text-gray-900 mt-1" style="font-family:'Brush Script MT','Segoe Script',cursive;"><%= a.auditor_signature_text %></p>
            <p class="text-[11px] text-emerald-700 mt-1">✓ Signed <%= fmtDate(a.auditor_signed_at) %></p>
          </div>
        <% } %>
        <% if (a.supervisor_signature_text) { %>
          <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-xs text-gray-500 uppercase font-semibold">Supervisor / STMS</p>
            <p class="text-2xl text-gray-900 mt-1" style="font-family:'Brush Script MT','Segoe Script',cursive;"><%= a.supervisor_signature_text %></p>
            <p class="text-[11px] text-emerald-700 mt-1">✓ Signed <%= fmtDate(a.supervisor_signed_at) %></p>
          </div>
        <% } %>
      </div>
      <% if ((ctxMap['annotated_tgs'] || []).length) { %>
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs font-semibold text-gray-700 uppercase tracking-wide mb-2">Annotated TGS / Close-out Sketch</p>
          <%- thumbGrid(ctxMap['annotated_tgs']) %>
        </div>
      <% } %>
    </section>
  <% } %>

  <!-- Sign-off info -->
  <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6 text-sm text-gray-700">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div><span class="text-xs text-gray-500 font-semibold uppercase">Status</span><p class="mt-0.5 capitalize"><%= (a.status || 'draft').replace('_',' ') %></p></div>
      <div><span class="text-xs text-gray-500 font-semibold uppercase">Created by</span><p class="mt-0.5"><%= a.created_by_name || '—' %> · <%= fmtDate(a.created_at) %></p></div>
      <% if (a.signed_off_by_name) { %>
        <div><span class="text-xs text-gray-500 font-semibold uppercase">Signed off by</span><p class="mt-0.5"><%= a.signed_off_by_name %> · <%= fmtDate(a.signed_off_at) %></p></div>
      <% } %>
      <% if (a.follow_up_required) { %>
        <div><span class="text-xs text-gray-500 font-semibold uppercase">Follow-up</span><p class="mt-0.5 text-amber-700 font-semibold">Required by <%= a.follow_up_date || 'TBC' %></p></div>
      <% } %>
    </div>
  </div>

  <% if (['admin','management'].includes((user.role || '').toLowerCase())) { %>
    <form method="POST" action="/audits/<%= a.id %>/delete" onsubmit="return confirm('Delete this audit permanently?')" class="text-right">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button class="text-sm text-red-600 hover:text-red-800 font-medium">Delete audit</button>
    </form>
  <% } %>
</div>
