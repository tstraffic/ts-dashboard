<% const a = audit || {}; %>
<% function val(k, fallback) { return (a && a[k] != null) ? a[k] : (fallback || ''); } %>
<% function stateOf(r) { if (!r) return ''; if (r.state) return r.state; if (r.na) return 'na'; if (r.checked) return 'yes'; return ''; } %>

<div class="px-4 lg:px-8 py-6">
  <!-- Sticky header with live score -->
  <div class="sticky top-[56px] lg:top-0 bg-white/90 backdrop-blur border-b border-gray-200 z-20 -mx-4 lg:-mx-8 px-4 lg:px-8 py-3 mb-4">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h1 class="text-lg lg:text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Audit #' + a.id : 'New Site Audit' %></h1>
        <p class="text-xs text-gray-500 hidden lg:block">Traffic Control Site Safety Audit</p>
      </div>
      <div class="flex items-center gap-2">
        <div class="text-right">
          <div class="text-[10px] uppercase tracking-wide text-gray-500 font-semibold">Live Score</div>
          <div class="flex items-baseline gap-1.5">
            <span id="live-percent" class="text-2xl font-bold text-gray-900"><%= score.percent %>%</span>
            <span class="text-xs text-gray-500">(<span id="live-score"><%= score.total %></span>/<span id="live-max"><%= score.max %></span>)</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <form method="POST" action="<%= isEdit ? '/audits/' + a.id : '/audits' %>" id="auditForm" class="space-y-6">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

    <!-- Header fields: Linked Project FIRST (auto-fills other fields) -->
    <section class="bg-white border border-gray-200 rounded-xl p-5">
      <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-4">Audit Details</h2>

      <div class="mb-4">
        <label class="block text-xs font-semibold text-gray-700 mb-1">Linked Project (Job) <span class="text-gray-400 font-normal">— auto-fills client, site & location below</span></label>
        <select name="job_id" id="job-select" class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-white">
          <option value="">— Not linked —</option>
          <% jobs.forEach(function(j) { %>
            <option value="<%= j.id %>"
              data-job-number="<%= j.job_number || '' %>"
              data-job-name="<%= j.job_name || '' %>"
              data-client="<%= j.client || '' %>"
              data-site="<%= j.site_address || '' %>"
              data-suburb="<%= j.suburb || '' %>"
              <%= String(val('job_id')) === String(j.id) ? 'selected' : '' %>>
              <%= j.job_number %><%= j.job_name ? ' — ' + j.job_name : '' %> — <%= j.client %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Project / Site</label>
          <input id="f-project_site" name="project_site" value="<%= val('project_site') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="e.g. 38 York St">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Client</label>
          <input id="f-client" name="client" value="<%= val('client') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Location</label>
          <input id="f-location" name="location" value="<%= val('location') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Date / Time</label>
          <input type="datetime-local" name="audit_datetime" value="<%= val('audit_datetime') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">TGS / TCP / TTM Ref</label>
          <input name="tgs_ref" value="<%= val('tgs_ref') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Shift</label>
          <select name="shift" class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-white">
            <% ['day','night'].forEach(function(s){ %>
              <option value="<%= s %>" <%= val('shift') === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Auditor</label>
          <input name="auditor_name" value="<%= val('auditor_name') || (user && user.full_name) || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Supervisor / STMS / Implementer</label>
          <input name="supervisor_name" value="<%= val('supervisor_name') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-semibold text-gray-700 mb-1">Weather / Visibility</label>
          <input name="weather" value="<%= val('weather') %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg">
        </div>
      </div>
    </section>

    <!-- Checklist sections -->
    <% sections.forEach(function(section) { %>
      <section class="bg-white border border-gray-200 rounded-xl overflow-hidden" data-section="<%= section.key %>">
        <header class="bg-brand-600 text-white px-5 py-3 flex items-center justify-between">
          <h2 class="text-sm lg:text-base font-bold"><%= section.key %>. <%= section.title %></h2>
          <span class="text-xs font-semibold bg-white/20 px-2 py-0.5 rounded-full" data-section-score="<%= section.key %>">0/0</span>
        </header>
        <div class="divide-y divide-gray-100">
          <% section.items.forEach(function(item, idx) {
            const key = section.key + '.' + (idx + 1);
            const r = responses[key] || {};
            const currentState = stateOf(r);
          %>
            <div class="px-4 py-3 lg:px-5 flex flex-col sm:flex-row sm:items-center gap-3" data-item="<%= key %>">
              <p class="text-sm text-gray-800 flex-1 min-w-0">
                <span class="font-semibold text-gray-500 mr-1"><%= key %></span><%= item %>
              </p>
              <div class="flex items-center gap-2 sm:flex-shrink-0">
                <!-- Yes / No / N/A pills -->
                <div class="inline-flex rounded-lg overflow-hidden border border-gray-200 bg-gray-50" role="radiogroup" data-pillgroup="<%= key %>">
                  <% [['yes','Yes','emerald'],['no','No','red'],['na','N/A','gray']].forEach(function(opt) { %>
                    <label class="relative cursor-pointer">
                      <input type="radio" name="q_<%= key %>_state" value="<%= opt[0] %>" <%= currentState === opt[0] ? 'checked' : '' %> class="sr-only peer q-state">
                      <span class="block px-3 py-1.5 text-xs font-semibold transition
                        <%= currentState === opt[0] ? (opt[0]==='yes' ? 'bg-emerald-600 text-white' : opt[0]==='no' ? 'bg-red-600 text-white' : 'bg-gray-500 text-white') : 'text-gray-600 hover:bg-gray-100' %>">
                        <%= opt[1] %>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <input name="q_<%= key %>_notes" value="<%= r.notes || '' %>" placeholder="Notes…" class="text-xs px-2 py-1.5 border border-gray-200 rounded-md w-full sm:w-44">
              </div>
            </div>
          <% }) %>
        </div>
        <div class="px-5 py-3 border-t border-gray-100 bg-gray-50">
          <label class="block text-[11px] font-semibold text-gray-500 uppercase tracking-wide mb-1">Section Comments</label>
          <textarea name="section_<%= section.key %>_comments" rows="2" class="w-full px-3 py-2 text-sm border border-gray-200 rounded-md bg-white"><%= sectionComments[section.key] || '' %></textarea>
        </div>
      </section>
    <% }) %>

    <!-- Non-Conformance Register -->
    <section class="bg-white border border-gray-200 rounded-xl overflow-hidden">
      <header class="bg-red-600 text-white px-5 py-3">
        <h2 class="text-sm lg:text-base font-bold">12. Non-Conformance Register</h2>
      </header>
      <div class="p-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-semibold text-gray-500 uppercase">
              <th class="py-2 pr-2 w-10">#</th>
              <th class="py-2 pr-2">Issue Found</th>
              <th class="py-2 pr-2">Risk</th>
              <th class="py-2 pr-2">Action Required</th>
              <th class="py-2 pr-2">Responsible</th>
              <th class="py-2 pr-2">Due</th>
              <th class="py-2 pr-2">Closed</th>
            </tr>
          </thead>
          <tbody>
            <% for (let i = 1; i <= 10; i++) { const nc = (nonconformances || [])[i-1] || {}; %>
              <tr class="border-t border-gray-100">
                <td class="py-1.5 pr-2 text-xs text-gray-500"><%= i %></td>
                <td class="py-1.5 pr-2"><input name="nc_<%= i %>_issue" value="<%= nc.issue || '' %>" class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded"></td>
                <td class="py-1.5 pr-2">
                  <select name="nc_<%= i %>_risk" class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded bg-white">
                    <option value="">—</option>
                    <% ['Low','Medium','High','Critical'].forEach(function(r){ %>
                      <option value="<%= r %>" <%= nc.risk === r ? 'selected' : '' %>><%= r %></option>
                    <% }) %>
                  </select>
                </td>
                <td class="py-1.5 pr-2"><input name="nc_<%= i %>_action" value="<%= nc.action || '' %>" class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded"></td>
                <td class="py-1.5 pr-2"><input name="nc_<%= i %>_responsible" value="<%= nc.responsible || '' %>" class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded"></td>
                <td class="py-1.5 pr-2"><input type="date" name="nc_<%= i %>_due" value="<%= nc.due_date || '' %>" class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded"></td>
                <td class="py-1.5 pr-2 text-center"><input type="checkbox" name="nc_<%= i %>_closed" value="1" <%= nc.closed ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300"></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Score summary + overall finding -->
    <section class="bg-white border border-gray-200 rounded-xl p-5">
      <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-4">Audit Scoring Summary</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4" id="score-summary">
        <% scoreGroups.forEach(function(g, i) { const gr = score.groups[i] || {}; %>
          <div class="flex items-center justify-between px-4 py-3 bg-gray-50 rounded-lg" data-group="<%= i %>">
            <span class="text-sm font-medium text-gray-700"><%= g.label %></span>
            <span class="text-sm font-bold text-gray-900">
              <span data-g-score><%= gr.score || 0 %></span>/<span data-g-max><%= gr.max || 0 %></span>
              <span class="text-xs font-semibold text-gray-500 ml-2" data-g-percent><%= gr.percent || 0 %>%</span>
            </span>
          </div>
        <% }) %>
      </div>
      <div class="pt-3 border-t border-gray-200">
        <div class="flex items-center justify-between">
          <span class="text-sm font-bold text-gray-900 uppercase tracking-wide">Overall Score</span>
          <span class="text-xl font-bold text-brand-700">
            <span id="live-score-2"><%= score.total %></span>/<span id="live-max-2"><%= score.max %></span>
            <span class="text-sm font-semibold text-gray-500 ml-2">(<span id="live-percent-2"><%= score.percent %></span>%)</span>
          </span>
        </div>
      </div>

      <!-- Overall finding -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-5">
        <% ['pass','pass_with_actions','fail'].forEach(function(opt) {
          const labels = { pass: 'Pass', pass_with_actions: 'Pass with actions', fail: 'Fail — immediate rectification' };
          const colors = { pass: 'emerald', pass_with_actions: 'amber', fail: 'red' };
          const c = colors[opt];
        %>
          <label class="flex items-center gap-2 px-4 py-3 border-2 rounded-lg cursor-pointer transition
            <%= val('overall_finding') === opt ? `border-${c}-500 bg-${c}-50` : 'border-gray-200 hover:border-gray-300' %>">
            <input type="radio" name="overall_finding" value="<%= opt %>" <%= val('overall_finding') === opt ? 'checked' : '' %> class="w-4 h-4 text-<%= c %>-600">
            <span class="text-sm font-semibold text-gray-800"><%= labels[opt] %></span>
          </label>
        <% }) %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-5">
        <label class="flex items-center gap-2">
          <input type="checkbox" name="follow_up_required" value="1" <%= val('follow_up_required') ? 'checked' : '' %> class="w-4 h-4 rounded border-gray-300">
          <span class="text-sm font-medium text-gray-700">Follow-up required</span>
        </label>
        <div>
          <label class="block text-xs font-semibold text-gray-700 mb-1">Follow-up date</label>
          <input type="date" name="follow_up_date" value="<%= val('follow_up_date') %>" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg">
        </div>
      </div>
    </section>

    <!-- Actions (main form ends here) -->
    <div class="flex flex-col sm:flex-row gap-3 pb-2">
      <button type="submit" name="submit" value="0" class="flex-1 px-4 py-3 bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold rounded-xl transition">
        Save as Draft
      </button>
      <button type="submit" name="submit" value="1" class="flex-1 px-4 py-3 bg-brand-600 hover:bg-brand-700 text-white font-bold rounded-xl transition">
        <%= isEdit ? 'Update & Submit' : 'Submit Audit' %>
      </button>
      <a href="/audits<%= isEdit ? '/' + a.id : '' %>" class="sm:w-auto px-4 py-3 text-center text-gray-600 hover:text-gray-900 font-medium">Cancel</a>
    </div>
  </form>

  <!-- Attachments (only available after audit is saved) -->
  <% if (isEdit) { %>
    <section class="bg-white border border-gray-200 rounded-xl p-5 mt-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wide">Photos & Documents</h2>
        <span class="text-xs text-gray-500"><%= (typeof attachments !== 'undefined' ? attachments.length : 0) %> file(s)</span>
      </div>

      <!-- Upload form (separate from main form to avoid nested forms) -->
      <form method="POST" action="/audits/<%= a.id %>/attachments" enctype="multipart/form-data" class="mb-5 p-4 bg-gray-50 border border-dashed border-gray-300 rounded-lg">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="return_to" value="/audits/<%= a.id %>/edit">
        <div class="flex flex-col sm:flex-row gap-3">
          <input type="file" name="files" multiple accept="image/*,application/pdf,.doc,.docx,.xls,.xlsx" class="flex-1 text-sm">
          <input name="caption" placeholder="Caption / which item (optional)" class="flex-1 px-3 py-2 text-sm border border-gray-300 rounded-lg">
          <button class="px-4 py-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-lg">Upload</button>
        </div>
        <p class="text-[11px] text-gray-500 mt-2">Max 25MB per file · Images, PDF, Word, Excel</p>
      </form>

      <!-- Existing attachments -->
      <% if (typeof attachments !== 'undefined' && attachments.length) { %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <% attachments.forEach(function(att) { const isImg = (att.mime_type || '').startsWith('image/'); %>
            <div class="group relative bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
              <% if (isImg) { %>
                <a href="<%= att.file_path %>" target="_blank">
                  <img src="<%= att.file_path %>" alt="<%= att.original_name %>" class="w-full h-32 object-cover">
                </a>
              <% } else { %>
                <a href="<%= att.file_path %>" target="_blank" class="flex items-center justify-center h-32 bg-gray-100">
                  <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </a>
              <% } %>
              <div class="p-2">
                <p class="text-xs font-medium text-gray-800 truncate" title="<%= att.original_name %>"><%= att.original_name %></p>
                <% if (att.caption) { %><p class="text-[11px] text-gray-500 truncate"><%= att.caption %></p><% } %>
              </div>
              <form method="POST" action="/audits/<%= a.id %>/attachments/<%= att.id %>/delete" onsubmit="return confirm('Delete this file?')" class="absolute top-1 right-1">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="return_to" value="/audits/<%= a.id %>/edit">
                <button class="w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full text-xs opacity-0 group-hover:opacity-100 transition" title="Delete">×</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-sm text-gray-500 text-center py-4">No photos or documents uploaded yet.</p>
      <% } %>
    </section>
  <% } else { %>
    <p class="text-xs text-gray-500 italic mt-4">Tip: save as draft first to enable photo / document uploads.</p>
  <% } %>
</div>

<!-- Pass section structure to client-side scoring -->
<script>
  window.AUDIT_SECTIONS = <%- JSON.stringify(sections.map(s => ({ key: s.key, itemCount: s.items.length }))) %>;
  window.SCORE_GROUPS = <%- JSON.stringify(scoreGroups) %>;
</script>
<script>
(function() {
  function getState(key) {
    const el = document.querySelector('input[name="q_' + key + '_state"]:checked');
    return el ? el.value : '';
  }

  function recalc() {
    const groups = window.SCORE_GROUPS.map(function(g) {
      let score = 0, max = 0;
      g.sectionKeys.forEach(function(secKey) {
        const section = window.AUDIT_SECTIONS.find(function(s) { return s.key === secKey; });
        if (!section) return;
        for (let i = 1; i <= section.itemCount; i++) {
          const key = secKey + '.' + i;
          const state = getState(key);
          if (state === '' || state === 'na') continue;
          max++;
          if (state === 'yes') score++;
        }
      });
      return { score: score, max: max, percent: max ? Math.round(score / max * 100) : 0 };
    });
    document.querySelectorAll('#score-summary [data-group]').forEach(function(el) {
      const idx = parseInt(el.getAttribute('data-group'), 10);
      const g = groups[idx] || { score: 0, max: 0, percent: 0 };
      el.querySelector('[data-g-score]').textContent = g.score;
      el.querySelector('[data-g-max]').textContent = g.max;
      el.querySelector('[data-g-percent]').textContent = g.percent + '%';
    });
    const total = groups.reduce(function(a, g) { return a + g.score; }, 0);
    const max = groups.reduce(function(a, g) { return a + g.max; }, 0);
    const pct = max ? Math.round(total / max * 100) : 0;
    ['live-score', 'live-score-2'].forEach(function(id){ const e = document.getElementById(id); if (e) e.textContent = total; });
    ['live-max', 'live-max-2'].forEach(function(id){ const e = document.getElementById(id); if (e) e.textContent = max; });
    const p1 = document.getElementById('live-percent'); if (p1) p1.textContent = pct + '%';
    const p2 = document.getElementById('live-percent-2'); if (p2) p2.textContent = pct;
    // Per-section pill
    window.AUDIT_SECTIONS.forEach(function(s) {
      let sScore = 0, sMax = 0;
      for (let i = 1; i <= s.itemCount; i++) {
        const key = s.key + '.' + i;
        const st = getState(key);
        if (st === '' || st === 'na') continue;
        sMax++;
        if (st === 'yes') sScore++;
      }
      const pill = document.querySelector('[data-section-score="' + s.key + '"]');
      if (pill) pill.textContent = sScore + '/' + sMax;
    });
  }

  // Pill visual state on change
  function paintPill(groupKey) {
    const group = document.querySelector('[data-pillgroup="' + groupKey + '"]');
    if (!group) return;
    group.querySelectorAll('input[type="radio"]').forEach(function(input) {
      const span = input.nextElementSibling;
      if (!span) return;
      span.className = 'block px-3 py-1.5 text-xs font-semibold transition';
      if (input.checked) {
        if (input.value === 'yes') span.classList.add('bg-emerald-600', 'text-white');
        else if (input.value === 'no') span.classList.add('bg-red-600', 'text-white');
        else span.classList.add('bg-gray-500', 'text-white');
      } else {
        span.classList.add('text-gray-600', 'hover:bg-gray-100');
      }
    });
  }

  document.addEventListener('change', function(e) {
    if (e.target.matches('.q-state')) {
      const name = e.target.name;
      const match = name.match(/^q_(.+)_state$/);
      if (match) paintPill(match[1]);
      recalc();
    }
  });

  // Auto-fill project fields when a job is selected
  const jobSelect = document.getElementById('job-select');
  if (jobSelect) {
    jobSelect.addEventListener('change', function() {
      const opt = this.options[this.selectedIndex];
      if (!opt || !opt.value) return;
      const n = opt.getAttribute('data-job-name') || '';
      const num = opt.getAttribute('data-job-number') || '';
      const client = opt.getAttribute('data-client') || '';
      const site = opt.getAttribute('data-site') || '';
      const suburb = opt.getAttribute('data-suburb') || '';
      const fields = {
        'f-project_site': n || (num + (client ? ' — ' + client : '')),
        'f-client': client,
        'f-location': [site, suburb].filter(Boolean).join(', '),
      };
      Object.keys(fields).forEach(function(id) {
        const el = document.getElementById(id);
        // Only overwrite if field is empty
        if (el && !el.value && fields[id]) el.value = fields[id];
      });
    });
  }

  recalc();
})();
</script>
