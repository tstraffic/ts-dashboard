<% function fmtDate(d) { if (!d) return '—'; try { return new Date(d).toLocaleDateString('en-AU'); } catch(e) { return d; } } %>
<% function statusBadge(s) {
  const map = { draft: 'bg-gray-100 text-gray-700', submitted: 'bg-blue-100 text-blue-700', signed_off: 'bg-emerald-100 text-emerald-700' };
  return `<span class="px-2 py-0.5 rounded-full text-xs font-semibold ${map[s] || 'bg-gray-100 text-gray-700'}">${(s||'draft').replace('_',' ')}</span>`;
} %>
<% function findingBadge(f) {
  if (!f) return '—';
  const map = { pass: 'bg-emerald-100 text-emerald-700', pass_with_actions: 'bg-amber-100 text-amber-800', fail: 'bg-red-100 text-red-700' };
  const label = f === 'pass_with_actions' ? 'Pass with actions' : f.charAt(0).toUpperCase() + f.slice(1);
  return `<span class="px-2 py-0.5 rounded-full text-xs font-semibold ${map[f] || 'bg-gray-100 text-gray-700'}">${label}</span>`;
} %>

<div class="px-4 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Site Audits</h1>
      <p class="text-sm text-gray-500 mt-1">Traffic Control Site Safety Audits (FORM-663)</p>
    </div>
    <a href="/audits/new" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-brand-600 hover:bg-brand-700 text-white font-medium rounded-xl shadow-sm transition active:scale-[0.98]">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Audit
    </a>
  </div>

  <!-- Stat tiles -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= counts.total || 0 %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Drafts</p>
      <p class="text-2xl font-bold text-gray-700 mt-1"><%= counts.draft || 0 %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Signed Off</p>
      <p class="text-2xl font-bold text-emerald-600 mt-1"><%= counts.signed_off || 0 %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Fails</p>
      <p class="text-2xl font-bold text-red-600 mt-1"><%= counts.fail_count || 0 %></p>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" class="flex flex-wrap gap-2 mb-4">
    <select name="status" onchange="this.form.submit()" class="px-3 py-2 text-sm border border-gray-300 rounded-lg bg-white">
      <option value="all">All statuses</option>
      <% ['draft','submitted','signed_off'].forEach(function(s){ %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s.replace('_',' ') %></option>
      <% }) %>
    </select>
    <% if (filters.status || filters.job_id) { %>
      <a href="/audits" class="px-3 py-2 text-sm text-gray-600 hover:text-gray-900">Clear</a>
    <% } %>
  </form>

  <!-- Table -->
  <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
    <% if (!audits.length) { %>
      <div class="p-12 text-center">
        <p class="text-gray-500">No audits yet.</p>
        <a href="/audits/new" class="inline-block mt-3 text-brand-600 font-semibold hover:underline">Create your first audit →</a>
      </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
            <th class="px-4 py-3">#</th>
            <th class="px-4 py-3">Site / Project</th>
            <th class="px-4 py-3 hidden md:table-cell">Job</th>
            <th class="px-4 py-3 hidden lg:table-cell">Auditor</th>
            <th class="px-4 py-3 hidden md:table-cell">Date</th>
            <th class="px-4 py-3">Score</th>
            <th class="px-4 py-3 hidden sm:table-cell">Finding</th>
            <th class="px-4 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% audits.forEach(function(a) { %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location.href='/audits/<%= a.id %>'">
              <td class="px-4 py-3 font-mono text-xs text-gray-500">#<%= a.id %></td>
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900"><%= a.project_site || '(no site)' %></div>
                <% if (a.location) { %><div class="text-xs text-gray-500"><%= a.location %></div><% } %>
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-gray-700">
                <% if (a.job_number) { %><span class="font-medium"><%= a.job_number %></span><br><span class="text-xs text-gray-500"><%= a.job_client || '' %></span><% } else { %>—<% } %>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell text-gray-700"><%= a.auditor_name || a.created_by_name || '—' %></td>
              <td class="px-4 py-3 hidden md:table-cell text-gray-700"><%= fmtDate(a.audit_datetime || a.created_at) %></td>
              <td class="px-4 py-3">
                <% const pct = a.score_percent || 0; const cls = pct >= 90 ? 'text-emerald-700' : pct >= 70 ? 'text-amber-700' : 'text-red-700'; %>
                <span class="font-bold <%= cls %>"><%= pct %>%</span>
                <span class="text-xs text-gray-500 ml-1">(<%= a.score_total %>/<%= a.score_max %>)</span>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell"><%- findingBadge(a.overall_finding) %></td>
              <td class="px-4 py-3"><%- statusBadge(a.status) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>
