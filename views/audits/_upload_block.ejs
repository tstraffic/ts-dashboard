<%
// Reusable upload block for per-context audit evidence (mobile-first).
// Uses JS fetch (not <form>) to avoid nested-form issues inside the main audit form.
// Params: auditId, contextKey, label, hint, accept, returnTo, items (array), csrfToken
const _items = items || [];
const _blockId = 'upl_' + contextKey.replace(/[^a-z0-9_]/gi, '_');
// Only use camera capture when accept is image-only
const useCapture = accept && accept.indexOf('pdf') === -1 && accept.indexOf('doc') === -1 && accept.indexOf('xls') === -1;
%>
<div class="space-y-2 upload-block" data-upload-block data-audit-id="<%= auditId %>" data-context-key="<%= contextKey %>" data-return-to="<%= returnTo %>" id="<%= _blockId %>">
  <div class="flex flex-col sm:flex-row gap-2">
    <div class="flex flex-1 gap-2">
      <!-- Take photo (camera) -->
      <label class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-3 py-3 bg-emerald-50 border-2 border-dashed border-emerald-400 rounded-lg text-sm font-semibold text-emerald-700 cursor-pointer hover:bg-emerald-100 active:bg-emerald-200 transition" title="Take photo">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h1.586a1 1 0 00.707-.293l1.414-1.414A1 1 0 019.414 5h5.172a1 1 0 01.707.293l1.414 1.414a1 1 0 00.707.293H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="hidden sm:inline">Take photo</span><span class="sm:hidden">Camera</span>
        <input type="file" accept="image/*" capture="environment" class="sr-only upl-camera">
      </label>
      <!-- Pick from files -->
      <label class="flex-1 flex items-center justify-center gap-2 px-3 py-3 bg-white border-2 border-dashed border-brand-300 rounded-lg text-sm font-semibold text-brand-700 cursor-pointer hover:bg-brand-50 active:bg-brand-100 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.9A5 5 0 0115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
        <span class="upl-label"><%= label %></span>
        <input type="file" multiple accept="<%= accept %>" class="sr-only upl-file">
      </label>
    </div>
    <input type="text" placeholder="Caption (optional)" class="sm:w-48 px-3 py-2.5 text-sm border border-gray-200 rounded-lg upl-caption">
  </div>
  <p class="text-[11px] text-gray-500"><%= hint %> · Max 25MB</p>
  <div class="upl-progress hidden text-[11px] text-brand-700 font-semibold">Uploading…</div>
  <div class="upl-error hidden text-[11px] text-red-600 font-semibold"></div>

  <div class="upl-grid grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2 <%= _items.length ? '' : 'hidden' %>">
    <% _items.forEach(function(att) { const isImg = (att.mime_type || '').startsWith('image/'); %>
      <div class="group relative bg-gray-50 border border-gray-200 rounded-lg overflow-hidden" data-att-id="<%= att.id %>">
        <% if (isImg) { %>
          <a href="<%= att.file_path %>" target="_blank">
            <img src="<%= att.file_path %>" alt="<%= att.original_name %>" class="w-full h-20 sm:h-24 object-cover">
          </a>
        <% } else { %>
          <a href="<%= att.file_path %>" target="_blank" class="flex items-center justify-center h-20 sm:h-24 bg-gray-100 text-xs text-gray-500 px-2 text-center break-words"><%= att.original_name %></a>
        <% } %>
        <% if (att.caption) { %><p class="text-[10px] text-gray-600 truncate px-1.5 py-1 bg-white border-t border-gray-100"><%= att.caption %></p><% } %>
        <button type="button" class="upl-delete absolute top-1 right-1 w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full text-xs font-bold opacity-80 sm:opacity-0 group-hover:opacity-100 focus:opacity-100 transition" title="Delete" data-att-id="<%= att.id %>">×</button>
      </div>
    <% }) %>
  </div>
</div>
