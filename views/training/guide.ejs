<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= moduleTitle %> — T&S Traffic Control</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg-base: #0B1629;
      --bg-surface: rgba(255,255,255,0.04);
      --border: rgba(255,255,255,0.07);
      --text-primary: #ffffff;
      --text-body: rgba(255,255,255,0.65);
      --text-muted: rgba(255,255,255,0.45);
      --text-dim: rgba(255,255,255,0.35);
      --cyan: #00D2BE;
      --blue: #2563EB;
      --green: #16A34A;
      --orange: #F97316;
      --red: #DC2626;
      --purple: #7C3AED;
    }

    html { height: 100%; }
    body {
      min-height: 100%;
      font-family: 'Inter', sans-serif;
      background: radial-gradient(ellipse 70% 50% at 50% -5%, rgba(20,80,180,0.35) 0%, transparent 65%),
                  radial-gradient(ellipse 40% 30% at 90% 90%, rgba(0,180,160,0.08) 0%, transparent 60%),
                  var(--bg-base);
      background-attachment: fixed;
      color: var(--text-primary);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Grain Texture ── */
    @media (prefers-reduced-motion: no-preference) {
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        opacity: 0.025;
        pointer-events: none;
        z-index: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 128px 128px;
        animation: grain 0.8s steps(1) infinite;
      }
      @keyframes grain {
        0%, 100% { transform: translate(0, 0); }
        25% { transform: translate(-1%, 1%); }
        50% { transform: translate(1%, -1%); }
        75% { transform: translate(-1%, -1%); }
      }
    }

    /* ── Road Lines (from login page) ── */
    .road-lines {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
    }
    .road-line {
      position: absolute;
      width: 1px;
      background: linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.04) 30%, rgba(255,255,255,0.07) 50%, rgba(255,255,255,0.04) 70%, transparent 100%);
      transform-origin: top;
      will-change: transform;
    }
    @media (prefers-reduced-motion: no-preference) {
      .road-line:nth-child(1)  { left: 8%;  height: 120%; top: -10%; transform: rotate(25deg); animation: line-drift 18s ease-in-out infinite; }
      .road-line:nth-child(2)  { left: 18%; height: 130%; top: -15%; transform: rotate(22deg); animation: line-drift 22s ease-in-out infinite 2s; }
      .road-line:nth-child(3)  { left: 30%; height: 110%; top: -5%;  transform: rotate(28deg); animation: line-drift 20s ease-in-out infinite 4s; }
      .road-line:nth-child(4)  { left: 42%; height: 125%; top: -12%; transform: rotate(24deg); animation: line-drift 24s ease-in-out infinite 1s; }
      .road-line:nth-child(5)  { left: 55%; height: 115%; top: -8%;  transform: rotate(26deg); animation: line-drift 19s ease-in-out infinite 3s; }
      .road-line:nth-child(6)  { left: 65%; height: 135%; top: -18%; transform: rotate(21deg); animation: line-drift 23s ease-in-out infinite 5s; }
      .road-line:nth-child(7)  { left: 76%; height: 120%; top: -10%; transform: rotate(27deg); animation: line-drift 21s ease-in-out infinite 2.5s; }
      .road-line:nth-child(8)  { left: 85%; height: 110%; top: -5%;  transform: rotate(23deg); animation: line-drift 25s ease-in-out infinite 1.5s; }
      .road-line:nth-child(9)  { left: 93%; height: 125%; top: -12%; transform: rotate(20deg); animation: line-drift 17s ease-in-out infinite 4.5s; }
      .road-line:nth-child(10) { left: 50%; height: 140%; top: -20%; transform: rotate(30deg); animation: line-drift 26s ease-in-out infinite 0.5s; }
      @keyframes line-drift {
        0%, 100% { transform: rotate(var(--r, 25deg)) translateX(0); opacity: 0.5; }
        50% { transform: rotate(var(--r, 25deg)) translateX(12px); opacity: 1; }
      }
    }

    /* ── Particle Canvas ── */
    #particles-canvas {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Radial Pulse ── */
    .radial-pulse {
      position: fixed;
      top: 20%;
      left: 50%;
      width: 900px;
      height: 900px;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(43,127,255,0.10) 0%, rgba(29,106,229,0.05) 35%, transparent 70%);
      pointer-events: none;
      z-index: 0;
      will-change: opacity, transform;
    }
    @media (prefers-reduced-motion: no-preference) {
      .radial-pulse { animation: radial-pulse 8s ease-in-out infinite; }
      @keyframes radial-pulse {
        0%, 100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
        50% { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
      }
    }

    /* ── Header ── */
    .header {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(11, 22, 41, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.07);
      padding: 0 1.5rem;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-left { display: flex; align-items: center; gap: 0.6rem; }
    .logo-box {
      width: 26px; height: 26px;
      background: var(--cyan);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 0.5rem;
      color: var(--bg-base);
    }
    .header-title { font-weight: 600; font-size: 14px; color: rgba(255,255,255,0.9); }
    .header-pill {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 6px;
      padding: 3px 10px;
      font-size: 11px;
      font-weight: 500;
      color: rgba(255,255,255,0.6);
    }
    .header-counter { font-size: 12px; color: rgba(255,255,255,0.35); font-variant-numeric: tabular-nums; }
    .header-counter .num { color: var(--cyan); font-weight: 600; }

    /* ── Progress Bar ── */
    .progress-track { height: 3px; background: rgba(255,255,255,0.08); position: relative; z-index: 10; }
    .progress-fill {
      height: 100%;
      border-radius: 0 2px 2px 0;
      transition: width 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (prefers-reduced-motion: no-preference) {
      .progress-fill {
        background: linear-gradient(90deg, var(--cyan) 0%, #00E8D2 50%, var(--cyan) 100%);
        background-size: 200% auto;
        animation: shimmer 2s linear infinite;
      }
      @keyframes shimmer {
        from { background-position: -200% center; }
        to { background-position: 200% center; }
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .progress-fill { background: var(--cyan); }
    }

    /* ── Main Content ── */
    .main {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 0 48px 4rem;
      min-height: calc(100vh - 55px);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* ── Slide Panels ── */
    .slide-panel { display: none; }
    .slide-panel.active {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: calc(100vh - 120px);
    }
    @media (prefers-reduced-motion: no-preference) {
      .slide-panel.active { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
      .slide-panel.active > *:nth-child(1) { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both 0ms; }
      .slide-panel.active > *:nth-child(2) { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both 60ms; }
      .slide-panel.active > *:nth-child(3) { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both 120ms; }
      .slide-panel.active > *:nth-child(4) { animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both 180ms; }
      @keyframes slideIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .slide-panel.active { animation: none; }
      .slide-panel.active > * { animation: none !important; }
    }

    /* ── Typography ── */
    .slide-panel h2 {
      font-size: clamp(26px, 4vw, 36px);
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 12px;
      letter-spacing: -0.025em;
      line-height: 1.15;
    }
    .slide-panel .subtitle {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(0, 210, 190, 0.7);
      margin-bottom: 8px;
    }
    .slide-panel .body {
      font-size: 15px;
      line-height: 1.75;
      color: rgba(255,255,255,0.65);
      font-weight: 400;
    }
    .slide-panel .body strong { color: var(--cyan); font-weight: 600; }
    .slide-panel .body img {
      border-radius: 12px;
      max-width: 100%;
      height: auto;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.05) inset;
      border: 1px solid rgba(255,255,255,0.06);
    }

    /* ── Form List (Accessible Forms slide) ── */
    .form-list { display: grid; gap: 0.55rem; }
    .form-row {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      transition: all 150ms ease;
    }
    .form-row:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.12);
    }
    .form-ico {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px; height: 32px;
      border-radius: 8px;
      background: rgba(255,255,255,0.05);
      flex-shrink: 0;
    }
    .form-label { font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.85); }

    /* ── Leave Days (3-point card list) ── */
    .leave-points { display: grid; gap: 0.75rem; }
    .leave-point {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 12px;
      align-items: start;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 14px 16px;
      transition: all 150ms ease;
    }
    .leave-point:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
    .leave-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px; height: 28px;
      border-radius: 50%;
      background: rgba(0,210,190,0.12);
      border: 1px solid rgba(0,210,190,0.3);
      color: var(--cyan);
      font-weight: 700;
      font-size: 13px;
    }
    .leave-body p { margin: 0; }
    .leave-head { font-weight: 600; font-size: 15px; color: #fff; margin-bottom: 2px; }
    .leave-desc { font-size: 14px; color: rgba(255,255,255,0.65); line-height: 1.5; }

    /* ── Mobile Phone Policy slide ── */
    .mp-hero {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 18px 24px;
      background: rgba(220,38,38,0.10);
      border: 1px solid rgba(220,38,38,0.3);
      border-radius: 12px;
      margin-bottom: 1.5rem;
    }
    .mp-hero-icon {
      width: 48px; height: 48px;
      border-radius: 50%;
      background: rgba(220,38,38,0.2);
      display: flex; align-items: center; justify-content: center;
      color: var(--red);
      flex-shrink: 0;
    }
    .mp-hero-text { text-align: left; }
    .mp-hero-title { font-size: 18px; font-weight: 700; color: #fff; }
    .mp-hero-sub { font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 2px; }
    .mp-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    @media (max-width: 640px) { .mp-grid { grid-template-columns: 1fr; } }
    .mp-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 14px 16px;
      transition: all 150ms ease;
    }
    .mp-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
    .mp-card-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 6px;
    }
    .mp-card-ico {
      width: 26px; height: 26px;
      border-radius: 6px;
      background: rgba(220,38,38,0.12);
      color: var(--red);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .mp-card-title { font-weight: 600; font-size: 14px; color: #fff; }
    .mp-card-desc { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.55; }

    /* ── PPE Grid ── */
    .ppe-grid {
      display: flex;
      gap: 2rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2.5rem;
    }
    .ppe-item {
      width: 130px;
      text-align: center;
    }
    .ppe-slot {
      height: 140px;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      margin-bottom: 1rem;
    }
    .ppe-img {
      max-height: 130px !important;
      max-width: 110px !important;
      width: auto !important;
      height: auto !important;
      object-fit: contain;
      filter: drop-shadow(0 6px 16px rgba(0,0,0,0.45));
      box-shadow: none !important;
      border: none !important;
      border-radius: 0 !important;
      background: transparent !important;
    }
    .ppe-label {
      font-weight: 600;
      font-size: 15px;
      color: #fff;
    }
    .ppe-sub {
      font-size: 13px;
      color: rgba(255,255,255,0.45);
      margin-top: 2px;
    }

    /* ── Founders: circular images ── */
    .founder-circle {
      width: 130px; height: 130px;
      border-radius: 50%;
      overflow: hidden;
      margin: 0 auto 0.5rem;
      flex-shrink: 0;
      box-shadow: none;
    }
    .founder-circle.cyan { border: 3px solid var(--cyan); }
    .founder-circle.orange { border: 3px solid var(--orange); }
    .founder-circle img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover;
      object-position: center center;
      display: block;
      border-radius: 0 !important;
      border: none !important;
      box-shadow: none !important;
    }

    /* ── Traffio Steps Grid ── */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      align-items: start;
    }
    .step-card { text-align: center; }
    .step-label {
      color: var(--cyan);
      font-size: 11px;
      letter-spacing: 0.1em;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }
    .step-img {
      width: 100%;
      max-height: 360px;
      object-fit: contain;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 8px 32px rgba(0,0,0,0.6);
      margin-bottom: 0.75rem;
    }
    .step-title { font-weight: 600; font-size: 15px; color: white; }
    .step-desc { font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 0.25rem; }
    .step-desc-red { color: var(--red) !important; font-weight: 700; }
    @media (max-width: 780px) {
      .steps-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .step-img { max-height: 500px; }
    }

    /* ── Founders Layout (slide 4) ── */
    .founders-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2rem;
      align-items: center;
      max-width: 50rem;
      margin: 0 auto;
    }
    .founders-photos {
      display: flex;
      gap: 1.5rem;
      flex-shrink: 0;
    }
    @media (max-width: 680px) {
      .founders-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .founders-photos {
        justify-content: center;
      }
    }

    /* ── Project List (slide 5) ── */
    .project-list { display: flex; flex-direction: column; gap: 4px; }
    .proj-item {
      border-left: 2px solid rgba(0, 210, 190, 0.4);
      padding: 10px 0 10px 16px;
      transition: all 150ms ease;
      cursor: default;
    }
    .proj-item:hover { border-left-color: var(--cyan); }
    .proj-item:hover .proj-client { color: var(--cyan); }
    .proj-client { font-weight: 600; font-size: 15px; color: white; transition: color 150ms ease; }
    .proj-desc { font-size: 13px; color: rgba(255,255,255,0.45); }

    /* ── Cards (generic) ── */
    .info-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 8px;
      transition: all 150ms ease;
    }
    .info-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }

    /* ── Discussion Card ── */
    .discussion-slide { text-align: center; flex: 1; display: flex; align-items: center; justify-content: center; }
    .discussion-card {
      max-width: 600px;
      padding: 2.5rem 2rem;
      background: rgba(124, 58, 237, 0.08);
      border: 1px solid rgba(124, 58, 237, 0.25);
      border-radius: 16px;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 1rem;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 1.25rem;
    }
    .badge-purple { background: var(--purple); }
    .badge-blue { background: var(--blue); }
    .badge-cyan { background: var(--cyan); color: var(--bg-base); }

    /* ── Quiz Options ── */
    .quiz-options { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-top: 1.5rem; }
    .quiz-opt {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 14px 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      cursor: pointer;
      transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
      font-size: 15px;
      color: var(--text-body);
    }
    .quiz-opt:hover {
      border-color: var(--cyan);
      background: rgba(0, 210, 190, 0.06);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(0,210,190,0.1);
    }
    .quiz-opt.selected {
      border-color: var(--cyan);
      background: rgba(0, 210, 190, 0.1);
      box-shadow: 0 0 0 2px rgba(0,210,190,0.2);
      color: var(--text-primary);
    }
    .opt-letter {
      width: 32px; height: 32px; border-radius: 50%;
      background: rgba(255,255,255,0.06);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 13px; color: var(--text-dim);
      flex-shrink: 0; transition: all 200ms ease;
    }
    .quiz-opt.selected .opt-letter { background: var(--cyan); color: var(--bg-base); }

    /* ── Results ── */
    .results-card {
      text-align: center;
      padding: 2.5rem 2rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 16px;
      max-width: 600px;
      margin: 2rem auto;
    }
    .score-big { font-size: 3rem; font-weight: 800; }
    .score-big.pass { color: var(--green); }
    .score-big.fail { color: var(--red); }
    .result-badge {
      display: inline-block; padding: 0.4rem 1.25rem; border-radius: 100px;
      font-size: 13px; font-weight: 700; letter-spacing: 0.05em;
      text-transform: uppercase; color: #fff; margin: 0.75rem 0 1rem;
    }
    .result-badge.pass { background: var(--green); }
    .result-badge.fail { background: var(--red); }
    .breakdown { text-align: left; border-top: 1px solid var(--border); padding-top: 1rem; margin-top: 1.5rem; }
    .bd-row { display: flex; gap: 0.6rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.03); font-size: 14px; }
    .bd-ok { color: var(--green); font-weight: 700; flex-shrink: 0; }
    .bd-no { color: var(--red); font-weight: 700; flex-shrink: 0; }
    .bd-correct { color: var(--green); font-weight: 600; font-size: 13px; margin-top: 2px; }

    /* ── Navigation Buttons ── */
    .nav-bar {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: auto; padding-top: 20px;
      border-top: 1px solid rgba(255,255,255,0.07);
      flex-shrink: 0;
      position: relative;
      z-index: 10;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      height: 44px; padding: 0 1.5rem;
      border: none; border-radius: 10px;
      font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: all 200ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .btn:active { transform: scale(0.98); }
    .btn-prev {
      background: transparent;
      color: rgba(255,255,255,0.6);
      border: 1px solid rgba(255,255,255,0.15);
    }
    .btn-prev:hover { border-color: rgba(255,255,255,0.35); color: rgba(255,255,255,0.9); }
    .btn-next {
      background: var(--cyan); color: var(--bg-base);
      box-shadow: 0 4px 14px rgba(0,210,200,0.25);
    }
    .btn-next:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,210,190,0.35); }
    .btn-next:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }
    .btn-green { background: var(--green); color: #fff; box-shadow: 0 4px 14px rgba(22,163,74,0.3); }
    .btn-green:hover { background: #15803d; transform: translateY(-2px); }
    .btn-red { background: var(--red); color: #fff; }
    .btn-red:hover { background: #b91c1c; transform: translateY(-2px); }

    /* ── Title Slide ── */
    .title-slide {
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center; flex: 1;
    }
    .title-slide h1 {
      font-size: clamp(36px, 5vw, 48px);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
      color: #ffffff;
      line-height: 1.1;
    }
    .title-slide .tagline {
      font-size: 17px; font-style: italic;
      color: rgba(255,255,255,0.55);
    }
    .title-slide .module-label {
      display: inline-flex; align-items: center;
      background: rgba(0,210,190,0.12);
      border: 1px solid rgba(0,210,190,0.3);
      color: var(--cyan);
      border-radius: 99px;
      padding: 4px 14px;
      font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
      margin-top: 1.5rem;
    }

    /* ── Highlight Card ── */
    .highlight-slide { text-align: center; flex: 1; display: flex; align-items: center; justify-content: center; }
    .highlight-card {
      max-width: 700px; margin: 0 auto;
      padding: 2.5rem 2rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--cyan);
      border-radius: 16px;
      box-shadow: 0 0 30px rgba(0, 210, 190, 0.06);
    }

    /* ── Confetti ── */
    @keyframes confetti-fall {
      0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
      100% { transform: translateY(105vh) rotate(720deg); opacity: 0; }
    }
    .confetti-piece { position: fixed; top: 0; z-index: 200; pointer-events: none; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .main { padding: 0 24px 4rem; }
      .quiz-options { grid-template-columns: 1fr; }
      .results-card { padding: 1.5rem 1rem; }
      .btn { padding: 0 1rem; font-size: 13px; height: 40px; }
      .slide-panel h2 { font-size: 24px; }
    }
  </style>
</head>
<body>
  <!-- Background Animations -->
  <div class="road-lines">
    <div class="road-line"></div><div class="road-line"></div><div class="road-line"></div>
    <div class="road-line"></div><div class="road-line"></div><div class="road-line"></div>
    <div class="road-line"></div><div class="road-line"></div><div class="road-line"></div>
    <div class="road-line"></div>
  </div>
  <div class="radial-pulse"></div>
  <canvas id="particles-canvas"></canvas>

  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <div class="logo-box">T&S</div>
      <span class="header-title"><%= moduleTitle %></span>
      <span class="header-pill">Module 1</span>
    </div>
    <div class="header-counter">
      <span class="num" id="slideNum">1</span> / <span id="slideTotal"><%= totalSlides %></span>
    </div>
  </div>
  <div class="progress-track">
    <div class="progress-fill" id="progressFill" style="width:0%"></div>
  </div>

  <!-- Main Content -->
  <div class="main" id="slideContainer">
    <% slides.forEach(function(slide, idx) { %>
      <% if (slide.layout === 'title') { %>
        <section class="slide-panel<%= idx === 0 ? ' active' : '' %>" data-idx="<%= idx %>">
          <div class="title-slide">
            <img src="/images/slides/ts-logo.png" alt="T&S" style="width:100px;height:auto;filter:drop-shadow(0 4px 20px rgba(0,0,0,0.5));margin-bottom:1.5rem;">
            <div style="font-size:12px;letter-spacing:0.08em;color:rgba(255,255,255,0.45);text-transform:uppercase;margin-bottom:0.75rem;">Module 1 — Company Overview</div>
            <h1><%= slide.title %></h1>
            <div class="tagline"><%= slide.subtitle %></div>
            <div class="module-label">T&S OPERATIONS</div>
          </div>
          <div class="nav-bar" style="justify-content:center;">
            <button class="btn btn-next" onclick="nextSlide()">Get Started &#8594;</button>
          </div>
        </section>

      <% } else if (slide.layout === 'discussion') { %>
        <section class="slide-panel" data-idx="<%= idx %>">
          <div class="discussion-slide">
            <div class="discussion-card">
              <div class="badge badge-purple">&#128172; Think About It</div>
              <h2><%= slide.title %></h2>
              <div class="body" style="text-align:center;margin-top:0.75rem;"><%- slide.content %></div>
            </div>
          </div>
          <div class="nav-bar">
            <button class="btn btn-prev" onclick="prevSlide()">&#8592; Back</button>
            <button class="btn btn-next" onclick="nextSlide()">Continue &#8594;</button>
          </div>
        </section>

      <% } else if (slide.layout === 'interactive-quiz' && slide.quizData) { %>
        <section class="slide-panel" data-idx="<%= idx %>" data-quiz="<%= slide.quizData.questionNumber %>">
          <div style="text-align:center;flex:1;display:flex;flex-direction:column;justify-content:center;">
            <div class="badge badge-blue">Question <%= slide.quizData.questionNumber %> of 10</div>
            <h2 style="max-width:600px;margin:0 auto;"><%= slide.quizData.question %></h2>
            <div class="quiz-options" id="qopts-<%= slide.quizData.questionNumber %>">
              <% slide.quizData.options.forEach(function(opt) { %>
                <div class="quiz-opt" data-q="<%= slide.quizData.questionNumber %>" data-v="<%= opt.id %>" onclick="pickAnswer(this, <%= slide.quizData.questionNumber %>, '<%= opt.id %>')">
                  <span class="opt-letter"><%= opt.id.toUpperCase() %></span>
                  <span><%= opt.text %></span>
                </div>
              <% }); %>
            </div>
          </div>
          <div class="nav-bar">
            <button class="btn btn-prev" onclick="prevSlide()">&#8592; Back</button>
            <button class="btn btn-next" id="qnext-<%= slide.quizData.questionNumber %>" onclick="nextSlide()" disabled>Select an answer &#8594;</button>
          </div>
        </section>

      <% } else if (slide.layout === 'quiz-results') { %>
        <section class="slide-panel" data-idx="<%= idx %>" id="resultsSlide">
          <div class="results-card" id="resultsCard"></div>
        </section>

      <% } else if (slide.layout === 'highlight') { %>
        <section class="slide-panel" data-idx="<%= idx %>">
          <div class="highlight-slide">
            <div class="highlight-card">
              <h2><%= slide.title %></h2>
              <div class="body" style="margin-top:1rem;"><%- slide.content %></div>
            </div>
          </div>
          <div class="nav-bar">
            <button class="btn btn-prev" onclick="prevSlide()">&#8592; Back</button>
            <button class="btn btn-next" onclick="nextSlide()">Continue &#8594;</button>
          </div>
        </section>

      <% } else { %>
        <section class="slide-panel" data-idx="<%= idx %>">
          <h2><%= slide.title %></h2>
          <% if (slide.subtitle) { %><div class="subtitle"><%= slide.subtitle %></div><% } %>
          <div class="body"><%- slide.content %></div>
          <div class="nav-bar">
            <% if (idx > 0) { %>
              <button class="btn btn-prev" onclick="prevSlide()">&#8592; Back</button>
            <% } else { %><div></div><% } %>
            <button class="btn btn-next" onclick="nextSlide()">Continue &#8594;</button>
          </div>
        </section>
      <% } %>
    <% }); %>
  </div>

  <script>
    // ── Particle System (from login page) ──
    (function() {
      var canvas = document.getElementById('particles-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var w, h, particles = [];
      var COUNT = 14, DIST = 180;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
      window.addEventListener('resize', resize);
      resize();

      for (var i = 0; i < COUNT; i++) {
        particles.push({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 2 + 1, opacity: Math.random() * 0.3 + 0.15
        });
      }

      function animate() {
        ctx.clearRect(0, 0, w, h);
        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0) p.x = w; if (p.x > w) p.x = 0;
          if (p.y < 0) p.y = h; if (p.y > h) p.y = 0;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(147,197,253,' + p.opacity + ')';
          ctx.fill();
        }
        for (var i = 0; i < particles.length; i++) {
          for (var j = i + 1; j < particles.length; j++) {
            var dx = particles[i].x - particles[j].x;
            var dy = particles[i].y - particles[j].y;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < DIST) {
              var alpha = (1 - dist / DIST) * 0.12;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = 'rgba(147,197,253,' + alpha + ')';
              ctx.lineWidth = 0.5;
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(animate);
      }
      animate();
    })();

    // ── State ──
    var current = 0;
    var total = <%= totalSlides %>;
    var panels = document.querySelectorAll('.slide-panel');
    var answers = {};
    var quizData = <%- JSON.stringify(slides.filter(function(s){ return s.layout === 'interactive-quiz' && s.quizData; }).map(function(s){ return s.quizData; })) %>;

    // ── Navigation ──
    function showSlide(idx) {
      panels.forEach(function(p) { p.classList.remove('active'); });
      panels[idx].classList.add('active');
      current = idx;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      document.getElementById('slideNum').textContent = idx + 1;
      var pct = total > 1 ? (idx / (total - 1)) * 100 : 100;
      document.getElementById('progressFill').style.width = pct + '%';
      if (panels[idx].id === 'resultsSlide') renderResults();
    }
    function nextSlide() { if (current < total - 1) showSlide(current + 1); }
    function prevSlide() { if (current > 0) showSlide(current - 1); }

    // ── Quiz ──
    function pickAnswer(el, qNum, val) {
      answers[qNum] = val;
      var opts = el.parentElement.querySelectorAll('.quiz-opt');
      opts.forEach(function(o) { o.classList.remove('selected'); });
      el.classList.add('selected');
      var btn = document.getElementById('qnext-' + qNum);
      if (btn) { btn.disabled = false; btn.textContent = 'Next \u2192'; }
    }

    function renderResults() {
      var correct = 0;
      var rows = '';
      quizData.forEach(function(q) {
        var picked = answers[q.questionNumber] || null;
        var ok = picked === q.correctAnswer;
        if (ok) correct++;
        var correctText = '';
        q.options.forEach(function(o) { if (o.id === q.correctAnswer) correctText = o.text; });
        rows += '<div class="bd-row"><span class="' + (ok ? 'bd-ok' : 'bd-no') + '">' + (ok ? '\u2713' : '\u2717') + '</span><div><div style="color:rgba(255,255,255,0.55)">Q' + q.questionNumber + ': ' + q.question + '</div>';
        if (!ok) rows += '<div class="bd-correct">Correct: ' + correctText + '</div>';
        rows += '</div></div>';
      });
      var pct = Math.round((correct / quizData.length) * 100);
      var passed = pct >= 90;
      document.getElementById('resultsCard').innerHTML =
        '<div class="score-big ' + (passed ? 'pass' : 'fail') + '">' + correct + ' / ' + quizData.length + '</div>' +
        '<div style="font-size:1.1rem;font-weight:600;color:rgba(255,255,255,0.55);">' + pct + '%</div>' +
        '<div class="result-badge ' + (passed ? 'pass' : 'fail') + '">' + (passed ? '\u2713 PASSED' : '\u2717 NOT YET PASSED') + '</div>' +
        '<div style="color:rgba(255,255,255,0.55);margin-bottom:1rem;font-size:15px;">' +
          (passed ? 'Congratulations! You have successfully completed the T&S Employee Guide \u2014 Module 1.' : 'You need 90% or higher to pass. Please review the material and try again.') +
        '</div>' +
        '<div class="breakdown"><div style="font-weight:600;margin-bottom:0.5rem;font-size:14px;">Question Breakdown</div>' + rows + '</div>' +
        '<div style="margin-top:1.5rem;">' +
          (passed ? '<button class="btn btn-green" onclick="window.location.href=\'/training/employee-guide\'">&#10003; Done</button>' : '<button class="btn btn-red" onclick="retryQuiz()">&#8634; Retry Quiz</button>') +
        '</div>';
      if (passed) spawnConfetti();
    }

    function retryQuiz() {
      answers = {};
      document.querySelectorAll('.quiz-opt.selected').forEach(function(o) { o.classList.remove('selected'); });
      quizData.forEach(function(q) {
        var btn = document.getElementById('qnext-' + q.questionNumber);
        if (btn) { btn.disabled = true; btn.innerHTML = 'Select an answer &#8594;'; }
      });
      for (var i = 0; i < panels.length; i++) {
        if (panels[i].dataset.quiz) { showSlide(i); return; }
      }
    }

    function spawnConfetti() {
      var colors = ['#00D2BE', '#22c55e', '#facc15', '#f97316', '#a855f7', '#ec4899', '#2563EB', '#14b8a6'];
      for (var i = 0; i < 50; i++) {
        var el = document.createElement('div');
        el.className = 'confetti-piece';
        el.style.left = Math.random() * 100 + 'vw';
        el.style.width = (5 + Math.random() * 8) + 'px';
        el.style.height = (5 + Math.random() * 8) + 'px';
        el.style.background = colors[Math.floor(Math.random() * colors.length)];
        el.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
        el.style.animation = 'confetti-fall ' + (2 + Math.random() * 2.5) + 's linear forwards';
        el.style.animationDelay = Math.random() * 0.8 + 's';
        document.body.appendChild(el);
      }
      setTimeout(function() {
        document.querySelectorAll('.confetti-piece').forEach(function(c) { c.remove(); });
      }, 5500);
    }

    // ── Keyboard ──
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowRight' || e.key === ' ') {
        e.preventDefault();
        var panel = panels[current];
        var nextBtn = panel.querySelector('.btn-next');
        if (nextBtn && !nextBtn.disabled) nextSlide();
      }
      if (e.key === 'ArrowLeft') { e.preventDefault(); prevSlide(); }
    });
  </script>
</body>
</html>
