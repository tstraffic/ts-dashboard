<% locals.currentPage = 'crm-dashboard' %>
<%
  function formatCurrency(v) {
    return '$' + (v || 0).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }
  function formatDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    return dt.toLocaleDateString('en-AU', { day: '2-digit', month: 'short', year: 'numeric' });
  }
  function formatTime(d) {
    if (!d) return '';
    const dt = new Date(d);
    return dt.toLocaleTimeString('en-AU', { hour: '2-digit', minute: '2-digit' });
  }
  function timeAgo(d) {
    if (!d) return '';
    const now = new Date();
    const dt = new Date(d);
    const diffMs = now - dt;
    const diffMins = Math.floor(diffMs / 60000);
    if (diffMins < 1) return 'just now';
    if (diffMins < 60) return diffMins + 'm ago';
    const diffHrs = Math.floor(diffMins / 60);
    if (diffHrs < 24) return diffHrs + 'h ago';
    const diffDays = Math.floor(diffHrs / 24);
    if (diffDays < 7) return diffDays + 'd ago';
    return formatDate(d);
  }
  const activityTypeIcons = {
    call: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
    email: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
    meeting: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    site_visit: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
    note: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
    task: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4'
  };
  const activityTypeColors = {
    call: 'bg-green-50 text-green-600',
    email: 'bg-blue-50 text-blue-600',
    meeting: 'bg-purple-50 text-purple-600',
    site_visit: 'bg-amber-50 text-amber-600',
    note: 'bg-gray-50 text-gray-500',
    task: 'bg-brand-50 text-brand-600'
  };
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">BDM Dashboard</h1>
    <p class="text-gray-500 text-sm mt-0.5">Pipeline overview and activity tracking</p>
  </div>
  <div class="flex items-center gap-2">
    <a href="/crm/activities/new" class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      Log Activity
    </a>
    <a href="/opportunities/new" class="inline-flex items-center px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
      New Opportunity
    </a>
  </div>
</div>

<!-- Dashboard Filters -->
<% const f = typeof filters !== 'undefined' ? filters : { view: 'my', period: 'month' }; %>
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 mb-5">
  <form method="GET" action="/crm" class="flex flex-wrap items-center gap-3">
    <%- include('../partials/csrf') %>
    <!-- My / Team Toggle -->
    <div class="inline-flex rounded-lg border border-gray-200 overflow-hidden">
      <a href="/crm?view=my&period=<%= f.period %>" class="px-3 py-1.5 text-xs font-semibold transition-colors <%= f.view === 'my' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">My View</a>
      <a href="/crm?view=team&period=<%= f.period %>" class="px-3 py-1.5 text-xs font-semibold transition-colors <%= f.view === 'team' ? 'bg-brand-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">Team View</a>
    </div>

    <!-- Owner filter (only in team view) -->
    <% if (f.view === 'team' && typeof dashboardUsers !== 'undefined') { %>
    <select name="owner_id" onchange="this.form.submit()" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-xs text-gray-700 focus:ring-2 focus:ring-brand-500">
      <option value="">All Owners</option>
      <% dashboardUsers.forEach(u => { %>
        <option value="<%= u.id %>" <%= f.owner_id == u.id ? 'selected' : '' %>><%= u.full_name %></option>
      <% }) %>
    </select>
    <% } %>

    <!-- Period Toggle -->
    <div class="inline-flex rounded-lg border border-gray-200 overflow-hidden">
      <a href="/crm?view=<%= f.view %>&period=week<%= f.owner_id && f.view === 'team' ? '&owner_id=' + f.owner_id : '' %>" class="px-3 py-1.5 text-xs font-semibold transition-colors <%= f.period === 'week' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">This Week</a>
      <a href="/crm?view=<%= f.view %>&period=month<%= f.owner_id && f.view === 'team' ? '&owner_id=' + f.owner_id : '' %>" class="px-3 py-1.5 text-xs font-semibold transition-colors <%= f.period === 'month' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">This Month</a>
      <a href="/crm?view=<%= f.view %>&period=quarter<%= f.owner_id && f.view === 'team' ? '&owner_id=' + f.owner_id : '' %>" class="px-3 py-1.5 text-xs font-semibold transition-colors <%= f.period === 'quarter' ? 'bg-gray-800 text-white' : 'bg-white text-gray-600 hover:bg-gray-50' %>">This Quarter</a>
    </div>

    <input type="hidden" name="view" value="<%= f.view %>">
    <input type="hidden" name="period" value="<%= f.period %>">
  </form>
</div>

<!-- Row 1: Pipeline Summary Cards -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-5">
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Open Opps</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= pipeline.open_count || 0 %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Pipeline Value</p>
    <p class="text-xl font-bold text-brand-600 mt-0.5"><%= formatCurrency(pipeline.total_value) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Weighted Value</p>
    <p class="text-xl font-bold text-gray-900 mt-0.5"><%= formatCurrency(pipeline.weighted_value) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Closing This Month</p>
    <p class="text-xl font-bold <%= (pipeline.closing_this_month || 0) > 0 ? 'text-amber-600' : 'text-gray-900' %> mt-0.5"><%= pipeline.closing_this_month || 0 %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Won This Month</p>
    <p class="text-xl font-bold text-emerald-600 mt-0.5"><%= formatCurrency(pipeline.won_value) %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3">
    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Lost This Month</p>
    <p class="text-xl font-bold <%= (pipeline.lost_this_month || 0) > 0 ? 'text-red-600' : 'text-gray-900' %> mt-0.5"><%= pipeline.lost_this_month || 0 %></p>
  </div>
</div>

<!-- Row 2: My Actions + Recent Activity -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
  <!-- Left: My Actions -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 sm:p-4">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">My Actions</h2>

    <!-- Overdue Follow-ups -->
    <% if (myActions.overdue_followups && myActions.overdue_followups.length > 0) { %>
    <div class="mb-4">
      <h3 class="text-[10px] font-bold text-red-500 uppercase tracking-widest mb-2 flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
        Overdue Follow-ups (<%= myActions.overdue_followups.length %>)
      </h3>
      <div class="space-y-2">
        <% myActions.overdue_followups.forEach(function(item) { %>
        <a href="<%= item.opportunity_id ? '/opportunities/' + item.opportunity_id : '#' %>" class="flex items-center gap-3 p-2 rounded-lg hover:bg-red-50 transition group">
          <div class="w-8 h-8 rounded-lg bg-red-50 text-red-500 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate"><%= item.subject || item.title || 'Follow-up' %></p>
            <p class="text-xs text-gray-400 truncate"><%= item.client_name || '' %> <% if (item.next_step_due) { %>&middot; Due <%= formatDate(item.next_step_due) %><% } %></p>
          </div>
          <span class="text-xs font-medium text-red-600"><%= item.days_overdue || '' %>d overdue</span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Today's Activities -->
    <div class="mb-4">
      <h3 class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Today's Activities</h3>
      <% if (myActions.today_activities && myActions.today_activities.length > 0) { %>
      <div class="space-y-2">
        <% myActions.today_activities.forEach(function(item) { %>
        <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50 transition">
          <div class="w-8 h-8 rounded-lg <%= activityTypeColors[item.activity_type] || 'bg-gray-50 text-gray-500' %> flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons[item.activity_type] || activityTypeIcons.note %>"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate"><%= item.subject || 'Activity' %></p>
            <p class="text-xs text-gray-400 truncate"><%= item.client_name || '' %> <% if (item.contact_name) { %>&middot; <%= item.contact_name %><% } %></p>
          </div>
          <span class="text-xs text-gray-400"><%= formatTime(item.activity_date) %></span>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="text-sm text-gray-400 italic">No activities scheduled today</p>
      <% } %>
    </div>

    <!-- Opportunities Needing Attention -->
    <% if (myActions.no_next_step && myActions.no_next_step.length > 0) { %>
    <div>
      <h3 class="text-[10px] font-bold text-amber-500 uppercase tracking-widest mb-2">No Next Step Set (<%= myActions.no_next_step.length %>)</h3>
      <div class="space-y-2">
        <% myActions.no_next_step.forEach(function(item) { %>
        <a href="/opportunities/<%= item.id %>" class="flex items-center gap-3 p-2 rounded-lg hover:bg-amber-50 transition">
          <div class="w-8 h-8 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate"><%= item.title %></p>
            <p class="text-xs text-gray-400 truncate"><%= item.client_name || '' %> &middot; <%= formatCurrency(item.estimated_value) %></p>
          </div>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if ((!myActions.overdue_followups || myActions.overdue_followups.length === 0) && (!myActions.today_activities || myActions.today_activities.length === 0) && (!myActions.no_next_step || myActions.no_next_step.length === 0)) { %>
    <div class="text-center py-4">
      <div class="w-12 h-12 bg-emerald-50 rounded-full flex items-center justify-center mx-auto mb-3">
        <svg class="w-6 h-6 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-sm text-gray-500">All caught up! No pending actions.</p>
    </div>
    <% } %>
  </div>

  <!-- Right: Recent Activity Feed -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 sm:p-4">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest">Recent Activity</h2>
      <a href="/crm/activities" class="text-xs text-brand-600 hover:text-brand-700 font-medium">View all</a>
    </div>
    <% if (recentActivities && recentActivities.length > 0) { %>
    <div class="space-y-3">
      <% recentActivities.forEach(function(act) { %>
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 rounded-lg <%= activityTypeColors[act.activity_type] || 'bg-gray-50 text-gray-500' %> flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons[act.activity_type] || activityTypeIcons.note %>"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm text-gray-900">
            <span class="font-medium"><%= act.owner_name || 'Unknown' %></span>
            logged a <span class="font-medium"><%= (act.activity_type || 'note').replace(/_/g, ' ') %></span>
          </p>
          <p class="text-sm text-gray-600 truncate"><%= act.subject || '' %></p>
          <p class="text-xs text-gray-400 mt-0.5">
            <% if (act.client_name) { %><%= act.client_name %><% } %>
            <% if (act.contact_name) { %> &middot; <%= act.contact_name %><% } %>
            &middot; <%= timeAgo(act.activity_date || act.created_at) %>
          </p>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="text-center py-5">
      <p class="text-sm text-gray-400">No recent activities</p>
    </div>
    <% } %>
  </div>
</div>

<!-- Row 3: Activity Summary -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 sm:p-4 mb-5">
  <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Activity Summary</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
    <div class="text-center p-3 rounded-lg bg-green-50">
      <div class="w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.call %>"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= activitySummary.this_week_calls || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Calls This Week</p>
    </div>
    <div class="text-center p-3 rounded-lg bg-blue-50">
      <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.email %>"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= activitySummary.this_week_emails || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Emails This Week</p>
    </div>
    <div class="text-center p-3 rounded-lg bg-purple-50">
      <div class="w-8 h-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= activityTypeIcons.meeting %>"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= activitySummary.this_week_meetings || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Meetings This Week</p>
    </div>
    <div class="text-center p-3 rounded-lg bg-amber-50">
      <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= activitySummary.followups_due_today || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Follow-ups Today</p>
    </div>
    <div class="text-center p-3 rounded-lg bg-red-50">
      <div class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= activitySummary.overdue_followups || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Overdue</p>
    </div>
    <div class="text-center p-3 rounded-lg bg-gray-50">
      <div class="w-8 h-8 rounded-full bg-gray-100 text-gray-500 flex items-center justify-center mx-auto mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= accountHealth.dormant_count || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Dormant Accounts</p>
    </div>
  </div>
</div>

<!-- Row 4: Conversion Tracking -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-3 sm:p-4">
  <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Conversion Tracking (This Month)</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="text-center">
      <p class="text-2xl font-bold text-gray-900"><%= conversion.leads_this_month || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Leads</p>
      <div class="mt-2 h-1 bg-gray-200 rounded-full">
        <div class="h-1 bg-sky-500 rounded-full" style="width: 100%"></div>
      </div>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-gray-900"><%= conversion.opps_this_month || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Opps Created</p>
      <div class="mt-2 h-1 bg-gray-200 rounded-full">
        <% const oppRate = conversion.leads_this_month ? Math.round((conversion.opps_this_month || 0) / conversion.leads_this_month * 100) : 0; %>
        <div class="h-1 bg-brand-500 rounded-full" style="width: <%= Math.min(oppRate, 100) %>%"></div>
      </div>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-emerald-600"><%= conversion.won_this_month || 0 %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Won Deals</p>
      <div class="mt-2 h-1 bg-gray-200 rounded-full">
        <% const wonRate = conversion.opps_this_month ? Math.round((conversion.won_this_month || 0) / conversion.opps_this_month * 100) : 0; %>
        <div class="h-1 bg-emerald-500 rounded-full" style="width: <%= Math.min(wonRate, 100) %>%"></div>
      </div>
    </div>
    <div class="text-center">
      <p class="text-2xl font-bold text-brand-600"><%= formatCurrency(conversion.won_value) %></p>
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1">Won Value</p>
      <div class="mt-2">
        <% const winRate = conversion.opps_this_month ? Math.round((conversion.won_this_month || 0) / conversion.opps_this_month * 100) : 0; %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold <%= winRate >= 50 ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' : winRate >= 25 ? 'bg-amber-50 text-amber-700 ring-1 ring-amber-600/20' : 'bg-gray-50 text-gray-600 ring-1 ring-gray-600/20' %>">
          Win Rate: <%= winRate %>%
        </span>
      </div>
    </div>
  </div>
</div>