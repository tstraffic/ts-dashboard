<% locals.currentPage = 'crm-meetings' %>
<% const isEdit = meeting !== null && typeof meeting !== 'undefined' && meeting %>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-400 mb-4">
  <a href="/crm/meetings" class="hover:text-gray-900 transition">Meetings</a>
  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <span class="text-gray-900"><%= isEdit ? 'Edit Meeting' : 'Schedule Meeting' %></span>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= isEdit ? 'Edit Meeting' : 'Schedule Meeting' %></h1>
    <p class="text-gray-500 text-sm mt-0.5"><%= isEdit ? 'Update meeting details and record outcome' : 'Schedule a new client meeting' %></p>
  </div>
</div>

<!-- Form -->
<form method="POST" action="<%= isEdit ? '/crm/meetings/' + meeting.id : '/crm/meetings' %>" class="space-y-5">

  <!-- 1. Meeting Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Meeting Details</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="sm:col-span-2 lg:col-span-3">
        <label for="title" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Title <span class="text-red-500">*</span></label>
        <input type="text" id="title" name="title" required value="<%= isEdit ? (meeting.title || '') : '' %>" placeholder="Meeting title"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="meeting_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Date & Time <span class="text-red-500">*</span></label>
        <input type="datetime-local" id="meeting_date" name="meeting_date" required
          value="<%= isEdit && meeting.meeting_date ? meeting.meeting_date.replace(' ', 'T').substring(0, 16) : new Date().toISOString().substring(0, 16) %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
      <div>
        <label for="duration" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Duration</label>
        <select id="duration" name="duration"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select duration...</option>
          <option value="15" <%= isEdit && meeting.duration == 15 ? 'selected' : '' %>>15 minutes</option>
          <option value="30" <%= isEdit && meeting.duration == 30 ? 'selected' : '' %>>30 minutes</option>
          <option value="45" <%= isEdit && meeting.duration == 45 ? 'selected' : '' %>>45 minutes</option>
          <option value="60" <%= isEdit && meeting.duration == 60 ? 'selected' : (!isEdit ? 'selected' : '') %>>1 hour</option>
          <option value="90" <%= isEdit && meeting.duration == 90 ? 'selected' : '' %>>1.5 hours</option>
          <option value="120" <%= isEdit && meeting.duration == 120 ? 'selected' : '' %>>2 hours</option>
          <option value="custom" <%= isEdit && meeting.duration && ![15,30,45,60,90,120].includes(Number(meeting.duration)) ? 'selected' : '' %>>Custom</option>
        </select>
      </div>
      <div>
        <label for="location_type" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Location Type</label>
        <select id="location_type" name="location_type"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select type...</option>
          <option value="office" <%= isEdit && meeting.location_type === 'office' ? 'selected' : '' %>>Office</option>
          <option value="site" <%= isEdit && meeting.location_type === 'site' ? 'selected' : '' %>>Site</option>
          <option value="phone" <%= isEdit && meeting.location_type === 'phone' ? 'selected' : '' %>>Phone</option>
          <option value="teams" <%= isEdit && meeting.location_type === 'teams' ? 'selected' : '' %>>Teams</option>
          <option value="zoom" <%= isEdit && meeting.location_type === 'zoom' ? 'selected' : '' %>>Zoom</option>
          <option value="other" <%= isEdit && meeting.location_type === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
      <div class="sm:col-span-2 lg:col-span-3">
        <label for="location_text" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Location / Address</label>
        <input type="text" id="location_text" name="location_text" value="<%= isEdit ? (meeting.location_text || '') : '' %>" placeholder="Meeting room, site address, or link"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>

  <!-- 2. Linked Records -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Linked Records</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div>
        <label for="client_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Account</label>
        <select id="client_id" name="client_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">No account linked</option>
          <% (clients || []).forEach(function(c) { %>
            <option value="<%= c.id %>" <%= (isEdit && meeting.client_id == c.id) || (!isEdit && typeof query !== 'undefined' && query.client_id == c.id) ? 'selected' : '' %>>
              <%= c.company_name || c.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="opportunity_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Opportunity</label>
        <select id="opportunity_id" name="opportunity_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">No opportunity linked</option>
          <% (opportunities || []).forEach(function(opp) { %>
            <option value="<%= opp.id %>" data-client-id="<%= opp.client_id || '' %>"
              <%= (isEdit && meeting.opportunity_id == opp.id) || (!isEdit && typeof query !== 'undefined' && query.opportunity_id == opp.id) ? 'selected' : '' %>>
              OPP-<%= String(opp.id).padStart(3, '0') %> &mdash; <%= opp.title %>
            </option>
          <% }) %>
        </select>
      </div>
      <div>
        <label for="owner_id" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Owner</label>
        <select id="owner_id" name="owner_id"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
          <option value="">Select owner...</option>
          <% (users || []).forEach(function(u) { %>
            <option value="<%= u.id %>" <%= (isEdit && meeting.owner_id == u.id) || (!isEdit && typeof user !== 'undefined' && user.id == u.id) ? 'selected' : '' %>>
              <%= u.full_name %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>

  <!-- 3. Details -->
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Details</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label for="purpose" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Purpose</label>
        <textarea id="purpose" name="purpose" rows="3" placeholder="What is this meeting about?"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= isEdit ? (meeting.purpose || '') : '' %></textarea>
      </div>
      <div>
        <label for="attendees" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Attendees</label>
        <textarea id="attendees" name="attendees" rows="3" placeholder="List attendees, one per line"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= isEdit ? (meeting.attendees || '') : '' %></textarea>
      </div>
      <div class="lg:col-span-2">
        <label for="notes" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Notes</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Preparation notes, agenda items..."
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= isEdit ? (meeting.notes || '') : '' %></textarea>
      </div>
    </div>
  </div>

  <!-- 4. Outcome (edit only) -->
  <% if (isEdit) { %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 sm:p-5">
    <h2 class="text-xs font-bold text-gray-800 uppercase tracking-widest mb-4">Outcome</h2>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div>
        <label for="outcome" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Outcome</label>
        <textarea id="outcome" name="outcome" rows="4" placeholder="What was discussed, what was decided?"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= meeting.outcome || '' %></textarea>
      </div>
      <div>
        <label for="follow_up_actions" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Follow-up Actions</label>
        <textarea id="follow_up_actions" name="follow_up_actions" rows="4" placeholder="What needs to happen next?"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"><%= meeting.follow_up_actions || '' %></textarea>
      </div>
      <div>
        <label for="next_meeting_date" class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Next Meeting Date</label>
        <input type="date" id="next_meeting_date" name="next_meeting_date"
          value="<%= meeting.next_meeting_date ? meeting.next_meeting_date.split('T')[0] : '' %>"
          class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
      </div>
    </div>
  </div>
  <% } %>

  <!-- Submit -->
  <div class="flex items-center justify-end gap-3">
    <a href="/crm/meetings" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 text-sm font-medium rounded-lg transition-colors">Cancel</a>
    <button type="submit" class="px-6 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      <%= isEdit ? 'Update Meeting' : 'Schedule Meeting' %>
    </button>
  </div>
</form>