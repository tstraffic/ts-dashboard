<div class="mb-6">
  <a href="/settings" class="text-sm text-brand-600 hover:text-brand-700">&larr; Back to Settings</a>
  <div class="mt-2">
    <h1 class="text-2xl font-bold text-gray-900">System Configuration</h1>
    <p class="text-gray-500 mt-1">Company details, shift rules, and compliance thresholds</p>
  </div>
</div>

<form method="POST" action="/settings/system">
  <%- include('../partials/csrf') %>
  <%
    // Group configs by prefix
    const configGroups = {
      'Company': configs.filter(c => ['company_name', 'company_tagline'].includes(c.config_key)),
      'Regional': configs.filter(c => ['default_timezone', 'currency'].includes(c.config_key)),
      'Shift Rules': configs.filter(c => ['default_shift_hours', 'max_shift_length_hours', 'min_rest_between_shifts_hours'].includes(c.config_key)),
      'Compliance & Fatigue': configs.filter(c => ['fatigue_max_days', 'fatigue_window_days', 'ticket_expiry_warning_days'].includes(c.config_key)),
      'Email (SMTP)': configs.filter(c => ['smtp_host', 'smtp_port', 'smtp_user', 'smtp_pass', 'smtp_from'].includes(c.config_key)),
    };

    const fieldLabels = {
      company_name: 'Company Name',
      company_tagline: 'Dashboard Subtitle',
      default_timezone: 'Default Timezone',
      currency: 'Currency',
      default_shift_hours: 'Default Shift Length (hours)',
      max_shift_length_hours: 'Maximum Shift Length (hours)',
      min_rest_between_shifts_hours: 'Minimum Rest Between Shifts (hours)',
      fatigue_max_days: 'Fatigue: Max Work Days in Window',
      fatigue_window_days: 'Fatigue: Rolling Window (days)',
      ticket_expiry_warning_days: 'Ticket Expiry Warning (days before)',
      smtp_host: 'SMTP Host',
      smtp_port: 'SMTP Port',
      smtp_user: 'SMTP Username',
      smtp_pass: 'SMTP Password',
      smtp_from: 'From Address',
    };
  %>

  <div class="space-y-6">
    <% for (const [groupName, groupConfigs] of Object.entries(configGroups)) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= groupName %></h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% groupConfigs.forEach(config => { %>
            <div>
              <label for="<%= config.config_key %>" class="block text-sm font-medium text-gray-600 mb-1">
                <%= fieldLabels[config.config_key] || config.config_key %>
              </label>
              <% if (config.config_type === 'number') { %>
                <input type="number" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>" step="any"
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } else if (config.config_key === 'smtp_pass') { %>
                <input type="password" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>" placeholder="App password or SMTP password" autocomplete="new-password"
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } else { %>
                <input type="text" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>"
                  <% if (config.config_key === 'smtp_host') { %>placeholder="e.g. smtp.resend.com"<% } %>
                  <% if (config.config_key === 'smtp_user') { %>placeholder="e.g. ops@tstraffic.com.au"<% } %>
                  <% if (config.config_key === 'smtp_from') { %>placeholder="e.g. noreply@tstraffic.com.au"<% } %>
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } %>
              <% if (config.description) { %>
                <p class="text-xs text-gray-400 mt-1"><%= config.description %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="flex justify-end space-x-3 mt-6">
    <a href="/settings" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg transition-colors">Cancel</a>
    <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Save Configuration</button>
  </div>
</form>

<!-- Test Email Section -->
<div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm p-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Test Email</h2>
  <p class="text-sm text-gray-500 mb-4">Send a test email to verify your SMTP configuration is working. Save your SMTP settings above first.</p>
  <form method="POST" action="/settings/system/test-email" class="flex items-end gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1">
      <label for="test_email" class="block text-sm font-medium text-gray-600 mb-1">Send test to</label>
      <input type="email" id="test_email" name="test_email" value="<%= user.email || '' %>" placeholder="your@email.com" required
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <button type="submit" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors whitespace-nowrap">
      Send Test Email
    </button>
  </form>
  <p class="text-xs text-gray-400 mt-3">
    <strong>Tip:</strong> Using Resend? Set host to <code class="bg-gray-100 px-1 rounded">smtp.resend.com</code>, port <code class="bg-gray-100 px-1 rounded">465</code>, username <code class="bg-gray-100 px-1 rounded">resend</code>, password = your API key (starts with <code class="bg-gray-100 px-1 rounded">re_</code>).
    Or set SMTP_* environment variables in Railway instead.
  </p>
</div>

<!-- Push Notifications Section -->
<div class="mt-6 bg-white border border-gray-200 rounded-xl shadow-sm p-6">
  <h2 class="text-lg font-semibold text-gray-900 mb-2">Push Notifications</h2>
  <p class="text-sm text-gray-500 mb-4">Browser push notifications for overdue tasks, compliance deadlines, incidents, and more. Each user must enable notifications on their device.</p>

  <!-- Status -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
    <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">This Browser</p>
      <p id="pushStatus" class="text-sm font-semibold text-gray-500 mt-1">Checking...</p>
    </div>
    <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Your Subscriptions</p>
      <p id="pushSubCount" class="text-sm font-semibold text-gray-500 mt-1">Loading...</p>
    </div>
    <div class="bg-gray-50 rounded-lg p-3 border border-gray-200">
      <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">VAPID Keys</p>
      <p id="vapidStatus" class="text-sm font-semibold text-gray-500 mt-1">Checking...</p>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex flex-wrap gap-3">
    <button type="button" id="enablePushBtn" onclick="enablePush()" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      Enable Notifications
    </button>
    <button type="button" id="testPushBtn" onclick="testPush()" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium rounded-lg transition-colors">
      Send Test Notification
    </button>
    <button type="button" id="disablePushBtn" onclick="disablePush()" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-medium rounded-lg transition-colors hidden">
      Disable Notifications
    </button>
  </div>
  <p id="pushMessage" class="text-sm mt-3 hidden"></p>

  <!-- Info -->
  <div class="mt-4 p-3 bg-blue-50 rounded-lg border border-blue-100">
    <p class="text-xs text-blue-700"><strong>How it works:</strong> Notifications are generated every 15 minutes for overdue tasks, expiring compliance, missing updates, open incidents, and more. Each user needs to click "Enable Notifications" on their own device/browser.</p>
    <p class="text-xs text-blue-600 mt-1"><strong>iOS:</strong> On iPhone/iPad, first add the site to your Home Screen (Share &rarr; Add to Home Screen), then open from there and enable notifications.</p>
  </div>
</div>

<script>
(function() {
  var csrfToken = document.querySelector('input[name="_csrf"]') ? document.querySelector('input[name="_csrf"]').value : '';
  var statusEl = document.getElementById('pushStatus');
  var subCountEl = document.getElementById('pushSubCount');
  var vapidEl = document.getElementById('vapidStatus');
  var enableBtn = document.getElementById('enablePushBtn');
  var disableBtn = document.getElementById('disablePushBtn');
  var testBtn = document.getElementById('testPushBtn');
  var msgEl = document.getElementById('pushMessage');

  function showMsg(text, isError) {
    msgEl.textContent = text;
    msgEl.className = 'text-sm mt-3 ' + (isError ? 'text-red-600' : 'text-emerald-600');
    msgEl.classList.remove('hidden');
  }

  // Check current state
  function checkStatus() {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      statusEl.textContent = 'Not Supported';
      statusEl.className = 'text-sm font-semibold text-red-600 mt-1';
      enableBtn.disabled = true;
      enableBtn.classList.add('opacity-50');
      return;
    }

    Notification.permission === 'granted'
      ? (statusEl.textContent = 'Enabled', statusEl.className = 'text-sm font-semibold text-emerald-600 mt-1', enableBtn.classList.add('hidden'), disableBtn.classList.remove('hidden'))
      : Notification.permission === 'denied'
        ? (statusEl.textContent = 'Blocked by Browser', statusEl.className = 'text-sm font-semibold text-red-600 mt-1', enableBtn.textContent = 'Blocked — Check Browser Settings')
        : (statusEl.textContent = 'Not Enabled', statusEl.className = 'text-sm font-semibold text-amber-600 mt-1');

    // Check subscription count
    navigator.serviceWorker.ready.then(function(reg) {
      return reg.pushManager.getSubscription();
    }).then(function(sub) {
      subCountEl.textContent = sub ? 'Subscribed on this device' : 'Not subscribed';
      subCountEl.className = 'text-sm font-semibold ' + (sub ? 'text-emerald-600' : 'text-amber-600') + ' mt-1';
    });

    // Check VAPID
    fetch('/notifications/push/vapid-key')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        vapidEl.textContent = d.publicKey ? 'Configured' : 'Not Set';
        vapidEl.className = 'text-sm font-semibold ' + (d.publicKey ? 'text-emerald-600' : 'text-red-600') + ' mt-1';
      })
      .catch(function() {
        vapidEl.textContent = 'Error';
        vapidEl.className = 'text-sm font-semibold text-red-600 mt-1';
      });
  }

  // Enable push
  window.enablePush = function() {
    enableBtn.textContent = 'Enabling...';
    enableBtn.disabled = true;

    Notification.requestPermission().then(function(permission) {
      if (permission !== 'granted') {
        showMsg('Notification permission denied. Check your browser settings.', true);
        enableBtn.textContent = 'Enable Notifications';
        enableBtn.disabled = false;
        checkStatus();
        return;
      }

      fetch('/notifications/push/vapid-key')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          return navigator.serviceWorker.ready.then(function(reg) {
            var key = urlBase64ToUint8Array(data.publicKey);
            return reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: key });
          });
        })
        .then(function(subscription) {
          return fetch('/notifications/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
            body: JSON.stringify(subscription),
          });
        })
        .then(function() {
          showMsg('Push notifications enabled! You will now receive alerts.', false);
          checkStatus();
        })
        .catch(function(err) {
          showMsg('Failed to enable: ' + err.message, true);
          enableBtn.textContent = 'Enable Notifications';
          enableBtn.disabled = false;
        });
    });
  };

  // Disable push
  window.disablePush = function() {
    navigator.serviceWorker.ready.then(function(reg) {
      return reg.pushManager.getSubscription();
    }).then(function(sub) {
      if (sub) {
        return fetch('/notifications/push/unsubscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
          body: JSON.stringify({ endpoint: sub.endpoint }),
        }).then(function() { return sub.unsubscribe(); });
      }
    }).then(function() {
      showMsg('Push notifications disabled on this device.', false);
      checkStatus();
    });
  };

  // Test push
  window.testPush = function() {
    testBtn.textContent = 'Sending...';
    testBtn.disabled = true;
    fetch('/notifications/push/test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) {
          showMsg(d.error, true);
        } else {
          showMsg('Test notification sent! Check your device.', false);
        }
        testBtn.textContent = 'Send Test Notification';
        testBtn.disabled = false;
      })
      .catch(function() {
        showMsg('Failed to send test notification.', true);
        testBtn.textContent = 'Send Test Notification';
        testBtn.disabled = false;
      });
  };

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/\-/g, '+').replace(/_/g, '/');
    var rawData = window.atob(base64);
    var outputArray = new Uint8Array(rawData.length);
    for (var i = 0; i < rawData.length; ++i) outputArray[i] = rawData.charCodeAt(i);
    return outputArray;
  }

  checkStatus();
})();
</script>
