<div class="mb-6">
  <a href="/settings" class="text-sm text-brand-600 hover:text-brand-700">&larr; Back to Settings</a>
  <div class="mt-2">
    <h1 class="text-2xl font-bold text-gray-900">System Configuration</h1>
    <p class="text-gray-500 mt-1">Company details, shift rules, and compliance thresholds</p>
  </div>
</div>

<form method="POST" action="/settings/system">
  <%
    // Group configs by prefix
    const configGroups = {
      'Company': configs.filter(c => ['company_name', 'company_tagline'].includes(c.config_key)),
      'Regional': configs.filter(c => ['default_timezone', 'currency'].includes(c.config_key)),
      'Shift Rules': configs.filter(c => ['default_shift_hours', 'max_shift_length_hours', 'min_rest_between_shifts_hours'].includes(c.config_key)),
      'Compliance & Fatigue': configs.filter(c => ['fatigue_max_days', 'fatigue_window_days', 'ticket_expiry_warning_days'].includes(c.config_key)),
      'Email (SMTP)': configs.filter(c => ['smtp_host', 'smtp_port', 'smtp_user', 'smtp_pass', 'smtp_from'].includes(c.config_key)),
    };

    const fieldLabels = {
      company_name: 'Company Name',
      company_tagline: 'Dashboard Subtitle',
      default_timezone: 'Default Timezone',
      currency: 'Currency',
      default_shift_hours: 'Default Shift Length (hours)',
      max_shift_length_hours: 'Maximum Shift Length (hours)',
      min_rest_between_shifts_hours: 'Minimum Rest Between Shifts (hours)',
      fatigue_max_days: 'Fatigue: Max Work Days in Window',
      fatigue_window_days: 'Fatigue: Rolling Window (days)',
      ticket_expiry_warning_days: 'Ticket Expiry Warning (days before)',
      smtp_host: 'SMTP Host',
      smtp_port: 'SMTP Port',
      smtp_user: 'SMTP Username',
      smtp_pass: 'SMTP Password',
      smtp_from: 'From Address',
    };
  %>

  <div class="space-y-6">
    <% for (const [groupName, groupConfigs] of Object.entries(configGroups)) { %>
      <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4"><%= groupName %></h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% groupConfigs.forEach(config => { %>
            <div>
              <label for="<%= config.config_key %>" class="block text-sm font-medium text-gray-600 mb-1">
                <%= fieldLabels[config.config_key] || config.config_key %>
              </label>
              <% if (config.config_type === 'number') { %>
                <input type="number" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>" step="any"
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } else if (config.config_key === 'smtp_pass') { %>
                <input type="password" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>" placeholder="App password or SMTP password" autocomplete="new-password"
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } else { %>
                <input type="text" id="<%= config.config_key %>" name="<%= config.config_key %>" value="<%= config.config_value %>"
                  <% if (config.config_key === 'smtp_host') { %>placeholder="e.g. smtp.gmail.com"<% } %>
                  <% if (config.config_key === 'smtp_user') { %>placeholder="e.g. ops@tstraffic.com.au"<% } %>
                  <% if (config.config_key === 'smtp_from') { %>placeholder="e.g. noreply@tstraffic.com.au"<% } %>
                  class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
              <% } %>
              <% if (config.description) { %>
                <p class="text-xs text-gray-400 mt-1"><%= config.description %></p>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="flex justify-end space-x-3 mt-6">
    <a href="/settings" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg transition-colors">Cancel</a>
    <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Save Configuration</button>
  </div>
</form>
