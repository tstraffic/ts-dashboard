<div class="mb-6">
  <a href="/settings" class="text-sm text-brand-600 hover:text-brand-700">&larr; Back to Settings</a>
  <div class="flex items-center justify-between mt-2">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= meta.label %></h1>
      <p class="text-gray-500 mt-1">Manage options for the <span class="text-gray-900 font-medium"><%= meta.group.toLowerCase() %></span> module</p>
    </div>
  </div>
</div>

<!-- Add New Item Form -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm p-4 mb-6">
  <h3 class="text-sm font-semibold text-gray-600 mb-3">Add New Item</h3>
  <form method="POST" action="/settings/category/<%= category %>/add" class="flex flex-wrap items-end gap-3">
    <%- include('../partials/csrf') %>
    <div class="flex-1 min-w-[150px]">
      <label class="block text-xs text-gray-500 mb-1">Key (system ID)</label>
      <input type="text" name="key" required placeholder="e.g. new_status" pattern="[a-zA-Z0-9_]+" title="Letters, numbers, underscores only"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="flex-1 min-w-[150px]">
      <label class="block text-xs text-gray-500 mb-1">Display Label</label>
      <input type="text" name="label" required placeholder="e.g. New Status"
        class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent">
    </div>
    <div class="w-32">
      <label class="block text-xs text-gray-500 mb-1">Color</label>
      <select name="color" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        <option value="">None</option>
        <option value="slate">Slate</option>
        <option value="gray">Gray</option>
        <option value="red">Red</option>
        <option value="orange">Orange</option>
        <option value="amber">Amber</option>
        <option value="green">Green</option>
        <option value="emerald">Emerald</option>
        <option value="teal">Teal</option>
        <option value="blue">Blue</option>
        <option value="indigo">Indigo</option>
        <option value="purple">Purple</option>
        <option value="pink">Pink</option>
        <option value="sky">Sky</option>
      </select>
    </div>
    <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">
      + Add
    </button>
  </form>
</div>

<!-- Items Table -->
<div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 text-left">
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase w-12">#</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Key</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase">Label</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase w-28">Color</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase w-20 text-center">Active</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase w-40 text-right">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach((item, idx) => { %>
        <tr class="border-b border-gray-200/50 <%= item.is_active ? '' : 'opacity-50' %> hover:bg-gray-50">
          <td class="px-4 py-3 text-gray-400"><%= idx + 1 %></td>
          <td class="px-4 py-3">
            <code class="text-xs bg-white px-2 py-0.5 rounded text-gray-600"><%= item.key %></code>
          </td>
          <td class="px-4 py-3 text-gray-900 font-medium"><%= item.label %></td>
          <td class="px-4 py-3">
            <% if (item.color) { %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                <% if (item.color === 'red') { %>bg-red-50 text-red-700 ring-1 ring-red-600/20
                <% } else if (item.color === 'orange') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else if (item.color === 'amber') { %>bg-amber-50 text-amber-700 ring-1 ring-amber-600/20
                <% } else if (item.color === 'green') { %>bg-green-50 text-green-700 ring-1 ring-green-600/20
                <% } else if (item.color === 'emerald') { %>bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20
                <% } else if (item.color === 'teal') { %>bg-teal-50 text-teal-700 ring-1 ring-teal-600/20
                <% } else if (item.color === 'blue') { %>bg-blue-50 text-blue-700 ring-1 ring-blue-600/20
                <% } else if (item.color === 'indigo') { %>bg-indigo-50 text-indigo-700 ring-1 ring-indigo-600/20
                <% } else if (item.color === 'purple') { %>bg-purple-50 text-purple-700 ring-1 ring-purple-600/20
                <% } else if (item.color === 'pink') { %>bg-pink-50 text-pink-700 ring-1 ring-pink-600/20
                <% } else if (item.color === 'sky') { %>bg-sky-50 text-sky-700 ring-1 ring-sky-600/20
                <% } else if (item.color === 'slate') { %>bg-white text-gray-600
                <% } else { %>bg-gray-100 text-gray-600
                <% } %>"><%= item.color %></span>
            <% } else { %>
              <span class="text-gray-400">&mdash;</span>
            <% } %>
          </td>
          <td class="px-4 py-3 text-center">
            <% if (item.is_active) { %>
              <span class="inline-block w-2.5 h-2.5 rounded-full bg-green-500" title="Active"></span>
            <% } else { %>
              <span class="inline-block w-2.5 h-2.5 rounded-full bg-gray-100" title="Inactive"></span>
            <% } %>
          </td>
          <td class="px-4 py-3 text-right space-x-2">
            <button onclick="openEditModal(<%= item.id %>, '<%= item.key %>', `<%= item.label.replace(/`/g, '\\`') %>`, '<%= item.color %>', <%= item.is_active %>)" class="text-brand-600 hover:text-brand-700 text-xs font-medium">Edit</button>
            <% if (item.is_active) { %>
              <form method="POST" action="/settings/category/<%= category %>/<%= item.id %>/delete" class="inline" onsubmit="return confirm('Deactivate &quot;<%= item.label %>&quot;? It will no longer appear in dropdowns.')">
                <%- include('../partials/csrf') %>
                <button type="submit" class="text-red-600 hover:text-red-600 text-xs font-medium">Deactivate</button>
              </form>
            <% } else { %>
              <form method="POST" action="/settings/category/<%= category %>/<%= item.id %>" class="inline">
                <%- include('../partials/csrf') %>
                <input type="hidden" name="label" value="<%= item.label %>">
                <input type="hidden" name="color" value="<%= item.color %>">
                <input type="hidden" name="is_active" value="1">
                <button type="submit" class="text-emerald-600 hover:text-emerald-600 text-xs font-medium">Restore</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% if (items.length === 0) { %>
    <div class="text-center py-12 text-gray-400">
      <p>No items in this category yet.</p>
    </div>
  <% } %>
</div>

<p class="mt-3 text-xs text-gray-400"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %> total &middot; <%= items.filter(i => i.is_active).length %> active</p>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60">
  <div class="bg-white border border-gray-300 rounded-xl p-6 w-full max-w-md mx-4">
    <h3 class="text-lg font-semibold text-gray-900 mb-4">Edit Setting</h3>
    <form id="editForm" method="POST">
      <%- include('../partials/csrf') %>
      <div class="space-y-3">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Key</label>
          <input type="text" id="editKey" disabled class="w-full px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-500 text-sm">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Display Label</label>
          <input type="text" name="label" id="editLabel" required class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Color</label>
          <select name="color" id="editColor" class="w-full px-3 py-2 bg-white border border-gray-300 rounded-lg text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500">
            <option value="">None</option>
            <option value="slate">Slate</option>
            <option value="gray">Gray</option>
            <option value="red">Red</option>
            <option value="orange">Orange</option>
            <option value="amber">Amber</option>
            <option value="green">Green</option>
            <option value="emerald">Emerald</option>
            <option value="teal">Teal</option>
            <option value="blue">Blue</option>
            <option value="indigo">Indigo</option>
            <option value="purple">Purple</option>
            <option value="pink">Pink</option>
            <option value="sky">Sky</option>
          </select>
        </div>
        <div class="flex items-center space-x-2">
          <input type="checkbox" name="is_active" id="editActive" value="1" class="rounded bg-white border-gray-300 text-brand-500 focus:ring-brand-500">
          <label for="editActive" class="text-sm text-gray-600">Active (visible in dropdowns)</label>
        </div>
      </div>
      <div class="flex justify-end space-x-3 mt-5 pt-4 border-t border-gray-200">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm rounded-lg transition-colors">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium rounded-lg transition-colors">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openEditModal(id, key, label, color, isActive) {
    document.getElementById('editForm').action = '/settings/category/<%= category %>/' + id;
    document.getElementById('editKey').value = key;
    document.getElementById('editLabel').value = label;
    document.getElementById('editColor').value = color || '';
    document.getElementById('editActive').checked = isActive === 1;
    const modal = document.getElementById('editModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.getElementById('editLabel').focus();
  }

  function closeEditModal() {
    const modal = document.getElementById('editModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeEditModal();
  });

  // Close on backdrop click
  document.getElementById('editModal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeEditModal();
  });
</script>
